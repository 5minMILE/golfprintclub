  <!-- RC Affiliate Attribution (30-day cookie) -->
  <script>
  (function() {
    var API = 'https://easygoing-youthfulness-production-999b.up.railway.app/api/tracking';
    var COOKIE_DAYS = 30;

    function setCookie(name, val, days) {
      var d = new Date();
      d.setTime(d.getTime() + days * 86400000);
      document.cookie = name + '=' + encodeURIComponent(val) + ';expires=' + d.toUTCString() + ';path=/;SameSite=Lax';
    }

    function getCookie(name) {
      var m = document.cookie.match('(^|; )' + name + '=([^;]*)');
      return m ? decodeURIComponent(m[2]) : null;
    }

    function genId() {
      return 'rc_' + Date.now().toString(36) + '_' + Math.random().toString(36).substr(2, 9);
    }

    function sendEvent(type, extra) {
      var ref = getCookie('_rc_ref');
      if (!ref) return;
      var payload = {
        type: type,
        ref: ref,
        visitorId: getCookie('_rc_vid') || '',
        page: window.location.pathname,
        referrer: document.referrer || ''
      };
      if (extra) { for (var k in extra) payload[k] = extra[k]; }
      navigator.sendBeacon ? navigator.sendBeacon(API, JSON.stringify(payload)) :
        fetch(API, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload), keepalive: true });
    }

    function updateCartAttributes() {
      var ref = getCookie('_rc_ref');
      var vid = getCookie('_rc_vid');
      if (!ref) return;
      fetch('/cart/update.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ attributes: { rc_ref: ref, rc_vid: vid || '' } })
      });
    }

    // 1. Capture ref from URL params
    var params = new URLSearchParams(window.location.search);
    var refParam = params.get('ref') || params.get('utm_source');
    if (refParam) {
      setCookie('_rc_ref', refParam, COOKIE_DAYS);
      if (!getCookie('_rc_vid')) {
        setCookie('_rc_vid', genId(), COOKIE_DAYS);
      }
      // Clean URL without reload
      if (window.history.replaceState) {
        params.delete('ref');
        var clean = window.location.pathname + (params.toString() ? '?' + params.toString() : '') + window.location.hash;
        window.history.replaceState(null, '', clean);
      }
    }

    // First visit — generate visitor ID if ref exists but no vid yet
    if (getCookie('_rc_ref') && !getCookie('_rc_vid')) {
      setCookie('_rc_vid', genId(), COOKIE_DAYS);
    }

    // 2. If attributed visitor, track session + set cart attributes
    if (getCookie('_rc_ref')) {
      sendEvent('SESSION');
      updateCartAttributes();
    }

    // 3. Intercept cart/add.js to track ATC
    var origFetch = window.fetch;
    window.fetch = function() {
      var url = arguments[0];
      if (typeof url === 'string' && url.indexOf('/cart/add') !== -1 && getCookie('_rc_ref')) {
        sendEvent('ADD_TO_CART');
        // Re-stamp cart attributes after item is added
        var result = origFetch.apply(this, arguments);
        result.then(function() { updateCartAttributes(); });
        return result;
      }
      return origFetch.apply(this, arguments);
    };

    // 4. Detect checkout initiation
    document.addEventListener('click', function(e) {
      var el = e.target.closest ? e.target.closest('a[href*="/checkout"], button[name="checkout"], input[name="checkout"]') : null;
      if (el && getCookie('_rc_ref')) {
        sendEvent('CHECKOUT_INITIATED');
      }
    });

    // Also catch form-based checkout submissions
    document.addEventListener('submit', function(e) {
      if (e.target && e.target.action && e.target.action.indexOf('/checkout') !== -1 && getCookie('_rc_ref')) {
        sendEvent('CHECKOUT_INITIATED');
      }
    });
  })();
  </script>
  </head>
  <body
    id="{{ page_title | handle }}"
    class="template-{{ template.name | handle }} grid-{{ settings.grid_style }}{% if customer %} customer-logged-in{% endif %}{% if settings.animations_enable %} aos-initialized{% endif %}{% if settings.product_grid_outline %} has-line-design{% endif %}"
    data-animations="{{ settings.animations_enable }}"
  >
    {%- render 'loading' -%}

    <a class="in-page-link visually-hidden skip-link" data-skip-content href="#MainContent">
      {{- 'general.accessibility.skip_to_content' | t -}}
    </a>

    <div class="container" data-site-container>
      <div class="header-sections">
        {% sections 'group-header' %}
      </div>

      {% sections 'group-overlay' %}

      <!-- CONTENT -->
      <main role="main" id="MainContent" class="main-content">
        {{ content_for_layout }}
      </main>
    </div>

    {% sections 'group-pre-footer' %}

    <footer class="footer-sections">
      {% sections 'group-footer' %}
    </footer>

    {% render 'template-swatch' %}

    {% render 'zoom-pswp' %}

    {%- if template.name != 'product' and settings.show_scroll_top_button -%}
      <button
        type="button"
        class="btn btn--scroll-top btn--black btn--solid"
        aria-label="{{ 'general.accessibility.scroll_to_top' | t }}"
        data-scroll-top-button
      >
        {%- render 'icon-arrow-up' -%}
      </button>
    {%- endif -%}

    {%- comment -%}
      In order to use your custom javascript file at assets/custom.js
      just cut this next line and paste it outside this comment:
      <script src="{{ 'custom.js' | asset_url }}" defer="defer"></script>
    {%- endcomment -%}
    <!-- Paste marketing code or third party scripts below this comment line ============== -->

    <!-- And above this comment line ================================================== -->

    <!-- Global: auto-add spike bag when RC-3Y2X79-BAG discount is applied (any page) -->
    <script>
    (function() {
      var SPIKE_BAG_VARIANT = 51374584037672;
      var TRIGGER_CODE = 'RC-3Y2X79-BAG';
      var norm = function(s) { return (s || '').trim().toUpperCase(); };

      function getCart() {
        return fetch('/cart.js', { credentials: 'same-origin', cache: 'no-store' })
          .then(function(r) { if (!r.ok) throw new Error('cart fetch failed'); return r.json(); });
      }

      function addBag() {
        return fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify({ id: SPIKE_BAG_VARIANT, quantity: 1 })
        });
      }

      function hasTriggerDiscount(cart) {
        /* Check Shopify discount_codes */
        var codes = cart.discount_codes || [];
        for (var i = 0; i < codes.length; i++) {
          if (norm(codes[i].code) === TRIGGER_CODE) return true;
        }
        var apps = cart.cart_level_discount_applications || [];
        for (var j = 0; j < apps.length; j++) {
          if (norm(apps[j].title) === TRIGGER_CODE) return true;
        }
        /* Check localStorage flag (set by cart page Apply button) */
        if (localStorage.getItem('rc_spike_bag_code') === 'true') return true;
        return false;
      }

      function bagInCart(cart) {
        return cart.items.some(function(item) {
          return Number(item.variant_id) === SPIKE_BAG_VARIANT;
        });
      }

      /* Check on page load and add bag if needed */
      function checkAndAdd() {
        getCart().then(function(cart) {
          if (bagInCart(cart)) return;
          if (hasTriggerDiscount(cart)) {
            addBag().then(function() {
              document.dispatchEvent(new Event('cart:refresh'));
              document.dispatchEvent(new Event('cart:change'));
              if (/\/cart\b/.test(window.location.pathname)) {
                window.location.reload();
              }
            });
          }
        }).catch(function() {});
      }

      /* Run on page load */
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', checkAndAdd);
      } else {
        checkAndAdd();
      }

      /* Poll every 1.5s to catch async discount application */
      var added = false;
      setInterval(function() {
        if (added) return;
        getCart().then(function(cart) {
          if (bagInCart(cart)) { added = true; return; }
          if (hasTriggerDiscount(cart)) {
            added = true;
            addBag().then(function() {
              document.dispatchEvent(new Event('cart:refresh'));
              document.dispatchEvent(new Event('cart:change'));
              if (/\/cart\b/.test(window.location.pathname)) {
                window.location.reload();
              }
            });
          }
        }).catch(function() {});
      }, 1500);
    })();
    </script>

    {%- render 'rc-popup-cart' -%}

    {{ content_for_footer }}

  </body>
</html>
