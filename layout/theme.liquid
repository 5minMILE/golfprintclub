<!doctype html>
<html class="no-js no-touch supports-no-cookies" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="{{ settings.accent_bright }}">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com">
    <link rel="preconnect" href="https://cdn.judge.me">

    {%- comment -%} Hreflang tags for multi-language support {%- endcomment -%}
    {%- if request.locale and shop.published_locales.size > 1 -%}
      {%- for locale in shop.published_locales -%}
        <link rel="alternate" hreflang="{{ locale.iso_code }}" href="{{ canonical_url | replace: request.locale.root_url, locale.root_url }}">
      {%- endfor -%}
      <link rel="alternate" hreflang="x-default" href="{{ canonical_url }}">
    {%- endif -%}

    <!-- ======================= Broadcast Theme V5.8.0 ========================= -->

    {{ 'theme.css' | asset_url | preload_tag: as: 'style' }}
    {{ 'vendor.js' | asset_url | preload_tag: as: 'script' }}
    {{ 'theme.js' | asset_url | preload_tag: as: 'script' }}

    {%- assign heading_font_url = settings.type_heading_font | font_url -%}
    {%- assign base_font_url = settings.type_base_font | font_url -%}
    {%- if heading_font_url != blank -%}
      <link rel="preload" href="{{ heading_font_url }}" as="font" type="font/woff2" crossorigin>
    {%- endif -%}
    {%- if base_font_url != blank -%}
      <link rel="preload" href="{{ base_font_url }}" as="font" type="font/woff2" crossorigin>
    {%- endif -%}

    {%- if settings.loading_image_1 != blank or settings.loading_image_2 != blank -%}
      {%- style -%}
        .loading { position: fixed; top: 0; left: 0; z-index: 99999; width: 100%; height: 100%; background: var(--bg); transition: opacity 0.2s ease-out, visibility 0.2s ease-out; }
        body.is-loaded .loading { opacity: 0; visibility: hidden; pointer-events: none; }
        .loading__image__holder { position: absolute; top: 0; left: 0; width: 100%; height: 100%; font-size: 0; display: flex; align-items: center; justify-content: center; }
        .loading__image__holder:nth-child(2) { opacity: 0; }
        .loading__image { max-width: {{ settings.loading_image_width }}px; max-height: {{ settings.loading_image_width }}px; object-fit: contain; }
        .loading--animate .loading__image__holder:nth-child(1) { animation: pulse1 2s infinite ease-in-out; }
        .loading--animate .loading__image__holder:nth-child(2) { animation: pulse2 2s infinite ease-in-out; }
        @keyframes pulse1 {
          0% { opacity: 1; }
          50% { opacity: 0; }
          100% { opacity: 1; }
        }
        @keyframes pulse2 {
          0% { opacity: 0; }
          50% { opacity: 1; }
          100% { opacity: 0; }
        }
      {%- endstyle -%}
    {%- endif -%}

    {% if settings.favicon %}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {% endif %}

    <!-- Title and description ================================================ -->
    {% capture seo_title %}
    {% assign title_content = page_title %}
    {% if template == 'password' %}
      {% assign title_content = shop.name %}
    {%- endif -%}
    {%- comment -%}
      Homepage SEO title: use a keyword-rich default unless the merchant
      has set a custom title in Shopify admin (Online Store > Preferences).
      page_title falls back to shop.name when no custom title is set, so
      we detect "no custom title" by checking exact equality with shop.name.
    {%- endcomment -%}
    {%- if template.name == 'index' and title_content == shop.name -%}
      {%- assign title_content = 'Golf Print Club — Golf Wall Art for Competitors | Golf Posters' -%}
    {%- endif -%}
    {{ title_content }}
    {% if current_tags %}
      {%- assign meta_tags = current_tags | join: ', ' %} &ndash; {{ 'general.meta.tags' | t: tags: meta_tags -}}
    {% endif %}
    {% if current_page != 1 %}
      &ndash; {{ 'general.meta.page' | t: page: current_page }}
    {% endif %}
    {% unless page_title contains shop.name or title_content contains shop.name %}
      &ndash; {{ shop.name }}
    {% endunless %}
  {% endcapture %}
    <title>{{ seo_title | strip_newlines | replace: '    ', ' ' | replace: '   ', ' ' | replace: '  ', ' ' | strip }}</title>

    {% if template.name == 'index' %}
      <meta name="description" content="Golf apparel and golf posters for competitors — golf posters, golf posters, golf posters, and premium golf wall art. Designed by golfers, priced for golfers.">
    {% elsif page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% else %}
      <meta name="description" content="{{ shop.description | escape }}">
    {% endif %}

    {% render 'seo-head' %}
    {% render 'json-ld-supplements' %}

    {%- comment -%} Force header dropdown panels to render solid white with dark, readable links {%- endcomment -%}
    <style>
      .header__dropdown,
      .header__dropdown .header__dropdown__wrapper,
      .header__dropdown .header__dropdown__inner {
        background-color: #ffffff !important;
      }
      .header__dropdown {
        --bg: #ffffff;
        --text: #111111;
        --text-dark: #111111;
        --text-light: #111111;
        --link-hover: #3D6E2E;
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.12);
        border: 1px solid #ececec;
      }
      .header__dropdown a,
      .header__dropdown .header__link,
      .header__dropdown .header__dropdown__inner a {
        color: #111111 !important;
      }
      .header__dropdown a:hover,
      .header__dropdown .header__link:hover,
      .header__dropdown .header__dropdown__inner a:hover {
        color: #3D6E2E !important;
      }

      /* Full-width mega menu (menu items that have image blocks) */
      @media only screen and (min-width: 990px) {
        /* backdrop-filter on the nav pill traps position:fixed; drop it while a mega menu is open */
        .header__wrapper.meganav--visible .together {
          backdrop-filter: none !important;
          -webkit-backdrop-filter: none !important;
        }
        /* keep the nav links sitting ON TOP of the white panel, and dark so they're readable on white */
        .header__wrapper .navlink--toplevel,
        .header__wrapper .menu__item > .navlink {
          position: relative;
          z-index: 30;
        }
        .header__wrapper.meganav--visible .navlink--toplevel,
        .header__wrapper.meganav--visible .navlink--toplevel .navtext {
          color: #111111 !important;
        }
        /* keep account + cart icons above the white panel and dark/visible when mega is open */
        .header__wrapper .navlink--cart,
        .header__wrapper .header__icons,
        .header__wrapper .header__icons a,
        .header__wrapper .header__desktop__buttons,
        .header__wrapper .header__desktop__button,
        .header__wrapper .header__desktop__button a,
        .header__wrapper a[href$="/cart"],
        .header__wrapper a[href*="/account"],
        .header__wrapper a[href*="account."],
        .header__wrapper a[href*="customer."],
        .header__wrapper a[href*="/login"] {
          position: relative;
          z-index: 30;
        }
        /* force EVERY header action icon (search, account/login, cart) dark on the white panel */
        .header__wrapper.meganav--visible .navlink--cart,
        .header__wrapper.meganav--visible .navlink--cart svg,
        .header__wrapper.meganav--visible .header__icons a,
        .header__wrapper.meganav--visible .header__icons svg,
        .header__wrapper.meganav--visible .header__desktop__button a,
        .header__wrapper.meganav--visible .header__desktop__button svg,
        .header__wrapper.meganav--visible .header__desktop__buttons a,
        .header__wrapper.meganav--visible .header__desktop__buttons svg,
        .header__wrapper.meganav--visible a[href$="/cart"] svg,
        .header__wrapper.meganav--visible a[href*="/account"] svg,
        .header__wrapper.meganav--visible a[href*="account."] svg,
        .header__wrapper.meganav--visible a[href*="customer."] svg,
        .header__wrapper.meganav--visible a[href*="/login"] svg {
          color: #111111 !important;
          stroke: #111111 !important;
        }
        .header__wrapper.meganav--visible .navlink--cart svg [fill]:not([fill="none"]),
        .header__wrapper.meganav--visible .header__icons svg [fill]:not([fill="none"]),
        .header__wrapper.meganav--visible .header__desktop__button svg [fill]:not([fill="none"]),
        .header__wrapper.meganav--visible .header__desktop__buttons svg [fill]:not([fill="none"]) {
          fill: #111111 !important;
        }
        /* the white panel: full width, up to the announcement bar, behind the nav */
        .menu__item.grandparent .header__dropdown {
          position: fixed !important;
          top: 24px !important;
          left: 0 !important;
          right: 0 !important;
          width: 100vw !important;
          max-width: 100vw !important;
          transform: none !important;
          background-color: #ffffff !important;
          box-shadow: 0 18px 32px rgba(0, 0, 0, 0.10);
          z-index: 5 !important;
        }
        /* content fills the full width: images = left 50%, nav links = right 50% */
        .menu__item.grandparent .header__dropdown__wrapper {
          max-width: 100vw !important;
          width: 100vw !important;
          margin: 0 !important;
          padding: 0 !important;
        }
        .menu__item.grandparent .header__dropdown__inner {
          display: flex !important;
          flex-direction: row !important;
          align-items: stretch !important;
          gap: 0 !important;
          background-color: #ffffff !important;
          padding: 0 !important;
        }
        /* IMAGES: left 50%, two side-by-side (25% each), flush, zero padding */
        .menu__item.grandparent .menu__blocks {
          order: 0 !important;
          display: flex !important;
          flex-direction: row !important;
          gap: 0 !important;
          flex: 0 0 50% !important;
          width: 50% !important;
          max-width: 50% !important;
          margin: 0 !important;
          padding: 0 !important;
          align-items: stretch !important;
        }
        .menu__item.grandparent .menu__block,
        .menu__item.grandparent .menu__block--narrow,
        .menu__item.grandparent .menu__block--wide {
          flex: 1 1 100% !important;
          width: 100% !important;
          max-width: 100% !important;
          margin: 0 !important;
          padding: 0 !important;
        }
        .menu__item.grandparent .header__dropdown__image {
          height: 50vh !important;
          min-height: 50vh;
          border-radius: 0 !important;
          margin: 0 !important;
          position: relative !important;
          overflow: hidden !important;
        }
        /* make the image (and its lazy-load wrapper) fill the whole panel — kills the white bar at the bottom.
           The wrapper is a FIGURE.lazy-image--backfill that sets height via aspect-ratio padding, so we
           force it absolute/full-height and zero its padding. */
        .menu__item.grandparent .header__dropdown__image .image-wrapper,
        .menu__item.grandparent .header__dropdown__image figure,
        .menu__item.grandparent .header__dropdown__image .lazy-image,
        .menu__item.grandparent .header__dropdown__image .lazy-image--backfill,
        .menu__item.grandparent .header__dropdown__image a.link-over-image,
        .menu__item.grandparent .header__dropdown__image img,
        .menu__item.grandparent .header__dropdown__image picture,
        .menu__item.grandparent .header__dropdown__image picture img {
          position: absolute !important;
          inset: 0 !important;
          top: 0 !important;
          left: 0 !important;
          width: 100% !important;
          height: 100% !important;
          min-height: 100% !important;
          max-height: none !important;
          padding: 0 !important;
          margin: 0 !important;
          object-fit: cover !important;
          transform: none !important;
        }
        /* MENU LINKS: right 50%, beside the images */
        .menu__item.grandparent .header__grandparent__links {
          order: 1 !important;
          flex: 1 1 50% !important;
          width: 50% !important;
          display: flex !important;
          flex-direction: column !important;
          justify-content: center !important;
          gap: 16px !important;
          padding: 64px 40px 24px 48px !important;
        }
        .menu__item.grandparent .header__grandparent__links .navlink--child h5,
        .menu__item.grandparent .header__grandparent__links .navtext {
          font-size: 15px !important;
          letter-spacing: 0.04em !important;
        }
      }
    </style>


    <!-- CSS ================================================================== -->
