<div class="lp-page-wrap">
  <div class="lp-sales-trust">
    {% for block in section.blocks %}
      <div class="lp-sales-trust__item" {{ block.shopify_attributes }}>
        <div class="lp-sales-trust__icon">
          {% case block.settings.icon %}
            {% when 'golfer' %}
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M13.49 5.48c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm-3.6 13.9l1-4.4 2.1 2v6h2v-7.5l-2.1-2 .6-3c1.3 1.5 3.3 2.5 5.5 2.5v-2c-1.9 0-3.5-1-4.3-2.4l-1-1.6c-.4-.6-1-1-1.7-1-.3 0-.5.1-.8.1L6.49 8.58v5h2v-3.5l1.8-.7-1.6 8.1-4.7-1-.4 2 6.3 1z"/></svg>
            {% when 'star' %}
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01L12 2z"/></svg>
            {% when 'shipping' %}
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            {% when 'returns' %}
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
          {% endcase %}
        </div>
        <div class="lp-sales-trust__label">{{ block.settings.label }}</div>
      </div>
    {% endfor %}
  </div>
</div>

<style>
  .lp-sales-trust {
    display: flex;
    justify-content: space-around;
    padding: 10px 8px;
    background: var(--lp-gray);
    border-top: 1px solid var(--lp-border);
    border-bottom: 1px solid var(--lp-border);
    margin: 0 auto;
  }
  .lp-sales-trust__item { text-align: center; }
  .lp-sales-trust__icon { font-size: 16px; color: var(--lp-blue); display: flex; justify-content: center; }
  .lp-sales-trust__label {
    font-size: 9px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #555;
    margin-top: 2px;
    font-family: var(--lp-font-body);
  }
</style>

{% schema %}
{
  "name": "LP Sales — Trust Strip",
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "golfer", "label": "Golfer" },
            { "value": "star", "label": "Star" },
            { "value": "shipping", "label": "Shipping" },
            { "value": "returns", "label": "Returns" }
          ],
          "default": "star"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "4.81 Rating"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP Sales — Trust Strip",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "golfer", "label": "4,000+ Golfers" } },
        { "type": "trust_item", "settings": { "icon": "star", "label": "4.81 Rating" } },
        { "type": "trust_item", "settings": { "icon": "shipping", "label": "Fast Shipping" } },
        { "type": "trust_item", "settings": { "icon": "returns", "label": "Easy Returns" } }
      ]
    }
  ]
}
{% endschema %}
