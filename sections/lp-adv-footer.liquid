<div class="lp-page-wrap">
  <div class="lp-adv-footer">
    <div class="lp-adv-footer__head">{{ section.settings.heading }}</div>
    <div class="lp-adv-footer__sub">{{ section.settings.subheading }}</div>
    {% if section.blocks.size > 0 %}
      <div class="lp-adv-footer__links">
        {% for block in section.blocks %}
          <a href="{{ block.settings.url }}" class="lp-adv-footer__link" {{ block.shopify_attributes }}>{{ block.settings.text }}</a>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

<style>
  .lp-adv-footer {
    background: var(--lp-blue);
    padding: 20px 16px;
    color: #fff;
    max-width: 390px;
    margin: 0 auto;
  }
  .lp-adv-footer__head {
    font-family: var(--lp-font-head);
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .lp-adv-footer__sub { font-size: 12px; opacity: 0.8; line-height: 1.5; }
  .lp-adv-footer__links {
    margin-top: 14px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .lp-adv-footer__link {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    opacity: 0.8;
    color: #fff;
    text-decoration: none;
  }
</style>

{% schema %}
{
  "name": "LP Adv — Footer",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Golf Print Club"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Built for golfers who run hard."
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Footer Link",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Link text",
          "default": "FAQs"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP Adv — Footer",
      "blocks": [
        { "type": "link", "settings": { "text": "FAQs" } },
        { "type": "link", "settings": { "text": "Returns" } },
        { "type": "link", "settings": { "text": "Size Chart" } },
        { "type": "link", "settings": { "text": "Contact" } }
      ]
    }
  ]
}
{% endschema %}
