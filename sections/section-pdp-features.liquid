<div class="v1-features">
  <h2 class="v1-sh">{{ section.settings.heading }}</h2>
  {% for block in section.blocks %}
    {% if block.type == 'feature' %}
      <div class="v1-fc" {{ block.shopify_attributes }}>
        <div class="v1-fc__img {% unless block.settings.image %}v1-fc__ph{% endunless %}">
          {% if block.settings.image %}
            <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title }}" loading="lazy">
          {% else %}
            <span>{{ block.settings.placeholder_text }}</span>
          {% endif %}
        </div>
        <div class="v1-fc__body">
          <h3 class="v1-fc__t">{{ block.settings.title }}</h3>
          <p class="v1-fc__d">{{ block.settings.description }}</p>
        </div>
      </div>
    {% endif %}
  {% endfor %}
</div>

<style>
.v1-features{padding:10px 0;background:#fff;border-top:8px solid #F3F3F3}
.v1-sh{font-family:var(--FONT-STACK-HEADING);font-size:17px;font-weight:900;text-transform:uppercase;letter-spacing:0.02em;margin:0 0 10px;color:#0A0A0A}
.v1-fc{border:1px solid #E4E4E4;border-radius:10px;overflow:hidden;margin-bottom:14px}
.v1-fc__img{width:100%;aspect-ratio:2/1;overflow:hidden}
.v1-fc__img img{width:100%;height:100%;object-fit:cover;display:block}
.v1-fc__ph{background:#D0D0D0;display:flex;align-items:center;justify-content:center}
.v1-fc__ph span{background:rgba(255,255,255,0.9);padding:4px 9px;border-radius:4px;font-size:8px;font-weight:700;letter-spacing:0.05em;text-transform:uppercase;color:#555}
.v1-fc__body{padding:14px}
.v1-fc__t{font-family:var(--FONT-STACK-HEADING);font-size:14px;font-weight:900;text-transform:uppercase;letter-spacing:0.02em;margin:0 0 3px;color:#0A0A0A}
.v1-fc__d{font-size:10px;color:#555;line-height:1.5;margin:0}
@media(min-width:992px){.v1-features{padding:10px 0}.v1-sh{font-size:21px}.v1-fc{display:flex;align-items:stretch}.v1-fc__img{width:50%;flex-shrink:0;aspect-ratio:auto;min-height:200px}.v1-fc__body{display:flex;flex-direction:column;justify-content:center;padding:15px 18px}.v1-fc__t{font-size:17px}.v1-fc__d{font-size:11px}}
</style>

{% schema %}
{
  "name": "PDP Features",
  "class": "section-pdp-features",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built for golfers who run hard"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "placeholder_text",
          "label": "Placeholder text (if no image)",
          "default": "Feature Shot"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Feature description text."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PDP Features",
      "blocks": [
        { "type": "feature", "settings": { "title": "No Ride Up", "description": "Stays locked at the thigh through full stride. No adjusting mid-rep.", "placeholder_text": "No Ride Up Shot" } },
        { "type": "feature", "settings": { "title": "No Bounce Pocket", "description": "Rear pocket holds your phone tight. It doesn't move. Period.", "placeholder_text": "Pocket Detail Shot" } },
        { "type": "feature", "settings": { "title": "Real Compression", "description": "Support where it matters -- without feeling restrictive or cheap.", "placeholder_text": "Compression Stretch" } }
      ]
    }
  ]
}
{% endschema %}
