        "code": "<!-- =========================================================\n     HEADER / TOOLBAR / SEARCH (CSS)\n========================================================= -->\n<style>\n/* --- Base / Global --- */\n.grid-classic{ padding-right:0 !important; }\n\n#country-heading-toolbar{ display:none; }\n\nhtml, body { overflow-x: hidden; }\n\n/* --- Ultra-wide wrapper --- */\n@media only screen and (min-width: 3000px) {\n  .wrapper--full-padded{\n    padding-left: 0;\n    padding-right: 0;\n    max-width:3000px;\n  }\n}\n\n/* =========================================================\n   DESKTOP HEADER / MEGANAV (>= 763px)\n========================================================= */\n@media only screen and (min-width: 763px){\n\n  .header__grandparent__links{\n    grid-template-columns: repeat(3, 1fr);\n  }\n\n  .header__logo {display:none;}\n\n  .header__wrapper .section-padding{\n    padding: 0;\n  }\n\n  .header__dropdown {\n    --bg: none;\n    --text: #2E7D32;\n    --text-dark: #2E7D32;\n    --text-light: #2E7D32;\n    --link-hover: #2E7D32;\n\n    position: absolute;\n    top: 150%;         /* adjust as needed */\n    left: 0;           /* snap to the left edge */\n    width: 100%;       /* full width if you want it to stretch */\n\n    opacity: 0;        /* 100 isn’t valid — use 1 */\n    border-bottom: 1px solid transparent;\n    border-top: 1px solid transparent;\n\n    visibility: hidden;\n    pointer-events: none;\n    z-index: 1 !important;\n\n    transition: opacity .2s cubic-bezier(.215,.61,.355,1), visibility 0s .2s;\n    border-radius: 10px;\n    background: white; /* translucent blue tint */\n    -webkit-backdrop-filter: blur(16px);\n    border-radius: 10px;\n    box-shadow: 0 5px 30px rgba(0, 0, 0, 0.3)\n\n    font-style: var(--BTN-FONT-STYLE);\n    font-weight: var(--BTN-FONT-WEIGHT);\n    font-family: var(--BTN-FONT-STACK);\n  }\n\n  .grandparent .navlink--child {\n    padding:auto;\n  }\n\n  .dropdown__family .navtext {\n    color: #0c0c0c !important;\n  }\n\n  .menu__item:not(.grandparent):hover>.header__dropdown,\n  .header__dropdown.is-visible {\n    opacity: 1;\n    visibility: visible;\n    pointer-events: auto;\n    transition-delay: 0s;\n    backdrop-filter: blur(20px);                /* blur the background behind */\n    -webkit-backdrop-filter: blur(20px);\n  }\n\n  .header__dropdown__wrapper, .header__dropdown__inner {\n    border-radius: 10px;\n    backdrop-filter: blur(10px);                /* blur the background behind */\n    -webkit-backdrop-filter: blur(10px);\n  }\n\n  .header__menu {\n    z-index: 10 !important;\n  }\n\n  .navtext { \n    color:white !important;\n  }\n\n  .navlink--child .navtext {\n    flex-wrap: nowrap;\n    letter-spacing: -.0em !important;\n    font-size: 20px !important; \n    font-weight: 1000 !important;\n    white-space: nowrap;\n    flex-shrink: 0;\n    color: #2E7D32 !important;\n  }\n\n  .navlink--grandchild .navtext { \n    font-style: italic;\n    letter-spacing: -.01em !important;\n    font-size: 16px !important; \n    font-weight: 600 !important;\n    margin-left: 40px;\n    text-allign: right !important;\n    color: #0c0c0c !important;\n  }\n\n  .header__desktop__bar__r{\n    padding-right:30px;\n    border-radius:0 10px 10px 0;\n  }\n\n  .header__menu {\n    padding-left:30px;\n    border-radius: 10px 0 0 10px;\n  }\n\n  .js__header__stuck .header__desktop .header__desktop__bar__l {\n    display:none;\n  }\n\n  .header__desktop .header__wrapper {\n    --bg: transparent;\n  }\n\n  .theme__header:after {\n    background:transparent;\n    color: white;\n  }\n\n  .js__header__stuck .theme__header {\n    --border-opacity: 0.6;\n    color: white;\n    border: 1px;\n  }\n\n  .navtext, .navlink--search, .icon {\n    color:white;\n  }\n\n  .header__desktop__bar__r {\n    flex:0 0 0;\n  }\n\n  .together {\n    display: flex;\n    justify-content: space-between; /* optional: controls spacing between the items */\n    align-items: center; /* optional aligns items vertically */\n    position: absolute;\n    top: calc(3vh + 20px);\n    right: 3vw;\n    backdrop-filter: blur(20px);\n    box-shadow: 0 5px 30px rgba(0, 0, 0, 0.3);\n    background: rgba(0, 123, 255, 0.5); /* translucent blue tint */\n    -webkit-backdrop-filter: blur(16px);\n    border-radius: 10px;\n    z-index:10 !important;\n  }\n\n  .together > div {\n    flex: 0 1 auto;\n  }\n\n  .toolbar {\n    background: rgba(0, 123, 255, 0.5); /* translucent blue tint */\n    -webkit-backdrop-filter: blur(16px);\n    backdrop-filter: blur(20px);\n  }\n\n  .toolbar__text__frame {\n    width: 400px;\n  }\n\n  .toolbar__inner {\n    align-items: right;\n  }\n\n  .toolbar__menu, .popout__toggle__text{\n    white-space: nowrap;\n    flex-shrink: 0;\n    text-transform: uppercase !important;\n    font-style: var(--BTN-FONT-STYLE);\n    font-family: var(--BTN-FONT-STACK);\n    letter-spacing: -.01em;\n    line-height: 1;\n    margin: .0em 0;\n    text-transform: var(--FONT-UPPERCASE-HEADING, none);\n    align-items: right;\n    font-size: 12px; \n    font-weight: 300;\n  }\n\n  .toolbar__menu .navlink {\n    padding-left: 20px;\n    padding-right: 20px;\n    margin:0;\n    height: calc(30px* var(--FONT-ADJUST-NAV));\n    border-left: 1px solid rgba(255, 255, 255, 0.5); /* or whatever color and width you want */\n    letter-spacing: -.01em;\n    font-size: 12px; \n    font-weight: 300;\n    width:auto;\n    align-items: right;\n    flex-wrap: nowrap;\n  }\n\n  .dropdown__family {\n    padding: 10px 0;\n    text-allign:left;\n  }\n\n  .grandparent .dropdown__family {\n    padding-left: 50px;\n    padding-right: 50px;\n    overflow-y: hidden;\n  }\n\n  .toolbar__utility{\n    padding-left: 0px;\n    border-left: 1px solid rgba(255, 255, 255, 0.5);\n    height: calc(31px* var(--FONT-ADJUST-NAV));\n  }\n\n  .theme__header .toolbar {\n    padding-top: 0;\n    padding-bottom: 0;\n  }\n\n  .popout__flag {\n    display: block;\n    width: 30px;\n    height: 20px;\n    margin-right: 8px;\n    aspect-ratio: 3 / 2;\n    object-fit: fit;\n    align-self: flex-start;\n  }\n\n  .popout__toggle__text{\n    display:none;\n    font-size: 16px; \n    font-weight: 600;\n  }\n\n  .toolbar__inner {\n    min-height: calc(30px * var(--FONT-ADJUST-NAV));\n  }\n\n  .dropdown__family { width:100%; }\n\n  .grandparent.kids-3 .header__grandparent__links {\n    display: flex;             /* switch from grid to flex */\n    flex-direction: column;    /* stack vertically */\n    gap: 10px;                 /* optional spacing between items */\n    grid-template-columns: none;\n  }\n\n  .header__grandparent__links {\n    padding: 30px 0;\n  }\n\n  .grandparent .menu__blocks:last-child .menu__block:last-child {\n    padding-right: 5px;\n  }\n\n  .grandparent .menu__blocks .menu__block {\n    padding: 0px !important;\n  }\n\n  .image-wrapper, .image-overlay, .link-over-image {\n    z-index: 100;\n  }\n\n  .image-wrapper, .image-overlay{\n    z-index: 1;\n  }\n\n  .navtext::before {\n    content: \"\";\n    position: absolute;\n    top: -10px;    /* Expand hover area above */\n    left: -10px;   /* Expand hover area to the left */\n    right: -10px;  /* Expand hover area to the right */\n    bottom: -50px; /* Expand hover area below */\n    background: transparent; /* Invisible */\n    pointer-events: auto;    /* Ensures it can capture hover */\n  }\n\n  .header__dropdown__image {\n    height: 100%;\n  }\n}\n\n/* --- Toolbar utilities pseudo element --- */\n@media only screen and (min-width: 750px) {\n  .toolbar__utilities:before {\n    background: transparent;\n  }\n}\n\n/* --- Together alignment on large screens --- */\n@media only screen and (min-width: 2000px) {\n  .together {\n    right: calc((100vw - 1920px) / 2);\n  }\n}\n\nbody:has(.main-content>.shopify-section.section-overlay-header:first-of-type)\n  [data-header-transparent]:not(.meganav--visible)\n  .navlink--cart--icon .header__cart__status {\n  --bg: white;\n}\n\n/* =========================================================\n   MOBILE HEADER / SEARCH / DRAWERS (<= 763px)\n========================================================= */\n@media only screen and (max-width: 763px){\n\n  .search-popdown\n  .wrapper{ \n    gap:20px;\n    margin-top: calc(50vh - 43px);\n    height:86px;\n  }\n\n  .search-popdown__submit{ display:none; }\n\n  .search-popdown__close{ margin-left: 10px; }\n\n  .input-holder{\n    border: 1px white solid;\n    border-radius: 10px;\n    background: white;\n  }\n\n  .search-popdown__main{\n    background-color:transparent;\n    color: #2E7D32;\n  }\n\n  .search-popdown .wrapper {\n    padding-left: 30px;\n    padding-right: 30px;\n  }\n\n  .search-popdown input[type=search] { color: #2E7D32; }\n\n  .search-popdown__close__button .icon{\n    fill: white !important;\n    color: white !important;\n  }\n\n  .filter-group__heading{ border-bottom: 0px transparent solid; }\n\n  .is-open .search-popdown{\n    height:100vh;\n    background: rgba(0, 123, 255, 0.5); /* translucent blue tint */\n    -webkit-backdrop-filter: blur(16px);\n    backdrop-filter: blur(20px);\n  }\n\n  .drawer--header .drawer__bottom__row--menu {\n    border-top: 1px solid transparent;\n    border-bottom: 1px solid transparent;\n  }\n\n  .sliderow__title {\n    padding-left: 30px;\n    border-bottom: 1px solid rgba(255, 255, 255, 0.2);\n    font-size: 20px;\n    font-weight: 700;\n    font-style: var(--BTN-FONT-STYLE);\n    font-family: var(--BTN-FONT-STACK);\n  }\n\n  .drawer__main-menu {\n    margin-top: 5vh;\n    border-top: 1px solid rgba(255, 255, 255, 0.2);\n  }\n\n  .header__wrapper{\n    position: fixed;\n    width: 100%;\n    top: 0;\n    z-index: 5600;\n  }\n\n  .toolbar__menu{display:none;}\n\n  .drawer__close .icon { color: white !important; }\n\n  .drawer__inner, .collection__sidebar__slider {\n    background: rgba(0, 123, 255, 0.5); /* translucent blue tint */\n    -webkit-backdrop-filter: blur(16px);\n    backdrop-filter: blur(20px);\n  }\n\n  .collection__sidebar__head{\n    color:white;\n    border-bottom: 1px white solid;\n  }\n\n  .collection__sidebar__slider{ border: 0px transparent solid; }\n\n  .sliderow{ background-color:transparent; }\n\n  .logo__img--transparent { opacity: 0 !important; }\n  .logo__img{ opacity: 1!important; }\n\n  .theme__header { background-color: #fbfbfb !important; }\n\n  .icon { color:black; }\n\n  .toolbar__text p { font-weight:500; }\n}\n\n/* --- Cart badge --- */\n.navlink--cart--icon .header__cart__status{\n  background: #D20000;\n}\n\n/* --- Collection sidebar close icon --- */\n.collection__sidebar__close .icon{\n  color:white !important;\n}\n\n/* --- Filter heading red --- */\n.filter-group__heading .icon, .filter-group__heading{\n  color:red;\n}\n</style>\n\n<!-- =========================================================\n     HEADER ELEMENT REMOVAL (JS)\n========================================================= -->\n<script>\n  document.addEventListener(\"DOMContentLoaded\", function() {\n    // IDs to remove\n    var idsToRemove = [\n      \"country-heading-toolbar\",\n      \"country-heading-sections--25036437520680__header-header-mobile\"\n    ];\n    \n    idsToRemove.forEach(function(id) {\n      var el = document.getElementById(id);\n      if (el) {\n        el.remove();\n      }\n    });\n  });\n</script>\n\n\n<!-- =========================================================\n     MOBILE PROMO SLIDER (HTML)\n========================================================= -->\n<div id=\"rc-mobile-promo\" class=\"free-shipping-mobile\" role=\"region\" aria-label=\"Promotions\">\n  <div class=\"fsm-viewport\">\n    <div class=\"fsm-slide is-active\" aria-live=\"polite\">Free shipping on US orders over $50</div>\n    <div class=\"fsm-slide\" aria-live=\"polite\">Buy any 2 posters, get 1 free</div>\n  </div>\n\n  <button type=\"button\" class=\"fsm-arrow fsm-prev\" aria-label=\"Previous\">\n    <svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" aria-hidden=\"true\">\n      <path d=\"M15 6l-6 6 6 6\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"/>\n    </svg>\n  </button>\n\n  <button type=\"button\" class=\"fsm-arrow fsm-next\" aria-label=\"Next\">\n    <svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" aria-hidden=\"true\">\n      <path d=\"M9 6l6 6-6 6\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"/>\n    </svg>\n  </button>\n</div>\n\n<!-- =========================================================\n     MOBILE PROMO SLIDER (CSS)\n========================================================= -->\n<style>\n  .free-shipping-mobile {\n    display: none; /* hidden by default */\n    position: relative;\n    padding: 8px;\n    text-align: center;\n    font-size: 13px;\n    background-color: #2E7D32;\n    color: #fff;\n  }\n\n  .free-shipping-mobile .fsm-viewport {\n    position: relative;\n    min-height: 1.6em; /* keeps height steady during fades */\n    overflow: hidden;\n    z-index: 1; /* below arrows */\n  }\n\n  .free-shipping-mobile { margin-top: 88px; }\n\n  .free-shipping-mobile .fsm-slide {\n    position: absolute;\n    inset: 0;\n    display: grid;\n    place-items: center;\n    opacity: 0;\n    transition: opacity 300ms ease-in-out;\n    padding: 0 40px; /* room for arrows */\n    line-height: 1.3;\n    font-weight: 400; /* normal weight */\n    will-change: opacity;\n  }\n  .free-shipping-mobile .fsm-slide.is-active { opacity: 1; }\n\n  .free-shipping-mobile .fsm-arrow {\n    position: absolute;\n    top: 50%;\n    transform: translateY(-50%);\n    border: 0;\n    background: transparent;\n    color: #fff;\n    width: 40px; height: 40px;\n    display: grid; place-items: center;\n    cursor: pointer;\n    opacity: 0.95;\n    z-index: 2; /* ensure arrows sit ABOVE the slides/viewport */\n  }\n  .free-shipping-mobile .fsm-prev { left: 6px; }\n  .free-shipping-mobile .fsm-next { right: 6px; }\n\n  /* Only on mobile */\n  @media (max-width: 763px) {\n    .toolbar { display: none; }\n    .header__mobile { height: 50px; }\n\n    .free-shipping-mobile {\n      display: block;\n      margin-top: 0; /* default */\n    }\n\n    /* Home + collection pages get 88px top margin */\n    {% if template == 'index' or template contains 'collection' %}\n    .free-shipping-mobile { margin-top: 0; }\n    {% endif %}\n  }\n\n  @media (prefers-reduced-motion: reduce) {\n    .free-shipping-mobile .fsm-slide { transition: none; }\n  }\n</style>\n\n<!-- =========================================================\n     MOBILE PROMO SLIDER (JS)\n========================================================= -->\n<script>\n  (function() {\n    const root = document.getElementById('rc-mobile-promo');\n    if (!root || !matchMedia('(max-width: 763px)').matches) return;\n\n    const slides = Array.from(root.querySelectorAll('.fsm-slide'));\n    const prevBtn = root.querySelector('.fsm-prev');\n    const nextBtn = root.querySelector('.fsm-next');\n\n    const intervalMs = 5000;\n    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;\n\n    let i = 0, timer;\n\n    function show(n) {\n      slides[i].classList.remove('is-active');\n      i = (n + slides.length) % slides.length; // handles prev/next wrap\n      slides[i].classList.add('is-active');\n    }\n\n    function next() { show(i + 1); }\n    function prev() { show(i - 1); }\n\n    function start() {\n      if (reduceMotion) return;\n      stop();\n      timer = setInterval(next, intervalMs);\n    }\n    function stop() { if (timer) clearInterval(timer); }\n\n    nextBtn.addEventListener('click', () => { next(); start(); });\n    prevBtn.addEventListener('click', () => { prev(); start(); });\n\n    // Pause on interaction; resume after\n    ['touchstart','mouseenter','focusin'].forEach(e => root.addEventListener(e, stop, {passive:true}));\n    ['touchend','mouseleave','focusout'].forEach(e => root.addEventListener(e, start, {passive:true}));\n\n    start();\n  })();\n</script>\n\n<style>\nheader-search-popdown {\ndisplay:none;}\n<style>",
