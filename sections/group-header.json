      "name": "Mobile Header Slider | Code + CSS",
      "settings": {
        "code": "<!-- Mobile Promo Slider (no schema) -->\n<div id=\"rc-mobile-promo\" class=\"free-shipping-mobile\" role=\"region\" aria-label=\"Promotions\">\n  <div class=\"fsm-viewport\">\n    <div class=\"fsm-slide is-active\" aria-live=\"polite\">Free shipping on US orders over $125</div>\n    <div class=\"fsm-slide\" aria-live=\"polite\">Buy any 2 shorts, get 1 free</div>\n  </div>\n\n  <button type=\"button\" class=\"fsm-arrow fsm-prev\" aria-label=\"Previous\">\n    <svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" aria-hidden=\"true\"><path d=\"M15 6l-6 6 6 6\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"/></svg>\n  </button>\n  <button type=\"button\" class=\"fsm-arrow fsm-next\" aria-label=\"Next\">\n    <svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" aria-hidden=\"true\"><path d=\"M9 6l6 6-6 6\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"/></svg>\n  </button>\n</div>\n\n<style>\n  .free-shipping-mobile {\n    display: none; /* hidden by default */\n    position: relative;\n    padding: 8px;\n    text-align: center;\n    font-size: 13px;\n    background-color: #2E7D32;\n    color: #fff;\n  }\n\n  .free-shipping-mobile .fsm-viewport {\n    position: relative;\n    min-height: 1.6em; /* keeps height steady during fades */\n    overflow: hidden;\n    z-index: 1; /* below arrows */\n  }\n\n.free-shipping-mobile { margin-top: 88px; }\n\n  .free-shipping-mobile .fsm-slide {\n    position: absolute;\n    inset: 0;\n    display: grid;\n    place-items: center;\n    opacity: 0;\n    transition: opacity 300ms ease-in-out;\n    padding: 0 40px; /* room for arrows */\n    line-height: 1.3;\n    font-weight: 400; /* normal weight */\n    will-change: opacity;\n  }\n  .free-shipping-mobile .fsm-slide.is-active { opacity: 1; }\n\n  .free-shipping-mobile .fsm-arrow {\n    position: absolute;\n    top: 50%;\n    transform: translateY(-50%);\n    border: 0;\n    background: transparent;\n    color: #fff;\n    width: 40px; height: 40px;\n    display: grid; place-items: center;\n    cursor: pointer;\n    opacity: 0.95;\n    z-index: 2; /* ensure arrows sit ABOVE the slides/viewport */\n  }\n  .free-shipping-mobile .fsm-prev { left: 6px; }\n  .free-shipping-mobile .fsm-next { right: 6px; }\n\n  /* Only on mobile */\n  @media (max-width: 763px) {\n    .toolbar { display: none; }\n    .header__mobile { height: 80px; }\n\n    .free-shipping-mobile {\n      display: block;\n      margin-top: 0; /* default */\n    }\n\n    /* Home + collection pages get 88px top margin */\n    {% if template == 'index' or template contains 'collection' %}\n    .free-shipping-mobile { margin-top: 88px; }\n    {% endif %}\n  }\n\n  @media (prefers-reduced-motion: reduce) {\n    .free-shipping-mobile .fsm-slide { transition: none; }\n  }\n</style>\n\n<script>\n  (function() {\n    const root = document.getElementById('rc-mobile-promo');\n    if (!root || !matchMedia('(max-width: 763px)').matches) return;\n\n    const slides = Array.from(root.querySelectorAll('.fsm-slide'));\n    const prevBtn = root.querySelector('.fsm-prev');\n    const nextBtn = root.querySelector('.fsm-next');\n\n    const intervalMs = 5000;\n    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;\n\n    let i = 0, timer;\n\n    function show(n) {\n      slides[i].classList.remove('is-active');\n      i = (n + slides.length) % slides.length; // handles prev/next wrap\n      slides[i].classList.add('is-active');\n    }\n\n    function next() { show(i + 1); }\n    function prev() { show(i - 1); }\n\n    function start() {\n      if (reduceMotion) return;\n      stop();\n      timer = setInterval(next, intervalMs);\n    }\n    function stop() { if (timer) clearInterval(timer); }\n\n    nextBtn.addEventListener('click', () => { next(); start(); });\n    prevBtn.addEventListener('click', () => { prev(); start(); });\n\n    // Pause on interaction; resume after\n    ['touchstart','mouseenter','focusin'].forEach(e => root.addEventListener(e, stop, {passive:true}));\n    ['touchend','mouseleave','focusout'].forEach(e => root.addEventListener(e, start, {passive:true}));\n\n    start();\n  })();\n</script>",
