<!-- /sections/section-wf-highlights.liquid -->
<style>
  .hl-{{ section.id }} {
    padding: 48px 0 56px;
    background: {{ section.settings.bg_color | default: '#FBFBFB' }};
  }
  .hl-{{ section.id }} .hl-head {
    max-width: 3000px;
    margin: 0 auto 20px;
    padding: 0 20px;
    text-align: center;
  }
  .hl-{{ section.id }} .hl-eyebrow {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 700;
    color: #2E7D32;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin: 0 0 6px;
    display: block;
  }
  .hl-{{ section.id }} .hl-heading {
    font-family: 'Montserrat', sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: #0A0A0A;
    letter-spacing: 0.01em;
    line-height: 1.3;
    margin: 0 0 4px;
  }
  .hl-{{ section.id }} .hl-sub {
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: #555;
    line-height: 1.5;
    margin: 0;
    max-width: 52ch;
    margin-left: auto;
    margin-right: auto;
  }
  .hl-{{ section.id }} .hl-row {
    display: flex;
    gap: 28px;
    overflow-x: auto;
    padding: 8px 50px 4px;
    justify-content: center;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .hl-{{ section.id }} .hl-row::-webkit-scrollbar {
    display: none;
  }
  .hl-{{ section.id }} .hl-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    text-decoration: none;
    color: inherit;
    width: 100px;
  }
  .hl-{{ section.id }} .hl-ring {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    padding: 3px;
    background: linear-gradient(135deg, #2E7D32 0%, #00d4ff 50%, #2E7D32 100%);
    transition: transform 0.25s ease;
  }
  .hl-{{ section.id }} .hl-item:hover .hl-ring {
    transform: scale(1.06);
  }
  .hl-{{ section.id }} .hl-circle {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: #fff;
    padding: 3px;
    overflow: hidden;
    box-sizing: border-box;
  }
  .hl-{{ section.id }} .hl-circle__img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    background: #0A0A0A;
  }
  .hl-{{ section.id }} .hl-circle__placeholder {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: #0A0A0A;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Montserrat', sans-serif;
    font-size: 22px;
    font-weight: 1000;
    letter-spacing: 0.02em;
  }
  .hl-{{ section.id }} .hl-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 10px;
    text-align: center;
    line-height: 1.2;
    max-width: 100px;
    color: #0A0A0A;
  }
  @media (max-width: 749px) {
    .hl-{{ section.id }} {
      padding: 32px 0 40px;
    }
    .hl-{{ section.id }} .hl-head {
      margin: 0 16px 22px;
    }
    .hl-{{ section.id }} .hl-heading {
      font-size: 14px;
    }
    .hl-{{ section.id }} .hl-row {
      gap: 18px;
      padding: 8px 18px 4px;
      justify-content: flex-start;
    }
    .hl-{{ section.id }} .hl-item {
      width: 84px;
    }
    .hl-{{ section.id }} .hl-ring {
      width: 84px;
      height: 84px;
    }
    .hl-{{ section.id }} .hl-label {
      font-size: 10px;
      max-width: 84px;
    }
  }
</style>

<section class="hl-{{ section.id }}" data-section-id="{{ section.id }}" data-section-type="highlights">
  {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank -%}
    <div class="hl-head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="hl-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="hl-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="hl-sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="hl-row">
      {%- for block in section.blocks -%}
        {%- assign first_letter = block.settings.label | upcase | slice: 0 -%}
        <a href="{{ block.settings.link | default: '#' }}" class="hl-item" {{ block.shopify_attributes }}>
          <div class="hl-ring">
            <div class="hl-circle">
              {%- if block.settings.image != blank -%}
                <img class="hl-circle__img" src="{{ block.settings.image | image_url: width: 240 }}" alt="{{ block.settings.label | escape }}" loading="lazy">
              {%- else -%}
                <div class="hl-circle__placeholder">{{ first_letter }}</div>
              {%- endif -%}
            </div>
          </div>
          <div class="hl-label">{{ block.settings.label }}</div>
        </a>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Story Highlights",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recent drops, lookbooks, and moments"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FBFBFB"
    }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "label", "label": "Label", "default": "Highlight" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Story Highlights",
      "category": "Collection",
      "blocks": [
        { "type": "highlight", "settings": { "label": "Drop 01" } },
        { "type": "highlight", "settings": { "label": "Drop 02" } },
        { "type": "highlight", "settings": { "label": "Track Series" } },
        { "type": "highlight", "settings": { "label": "Lookbook '26" } },
        { "type": "highlight", "settings": { "label": "Tournament Day" } },
        { "type": "highlight", "settings": { "label": "Behind the Build" } }
      ]
    }
  ]
}
{% endschema %}
