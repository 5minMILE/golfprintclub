<div class="rc-compare">
  <div class="rc-compare__inner">
    <h2 class="rc-compare__heading">{{ section.settings.heading }}</h2>
    {% for block in section.blocks %}
      <div class="rc-compare-card {% if block.settings.highlight %}rc-compare-card--hl{% endif %}" {{ block.shopify_attributes }}>
        <div class="rc-compare-card__head">
          <div class="rc-compare-card__name {% if block.settings.highlight %}rc-compare-card__name--hl{% endif %}">{{ block.settings.name }}</div>
          <div class="rc-compare-card__price {% if block.settings.highlight %}rc-compare-card__price--hl{% endif %}">{{ block.settings.price }}</div>
        </div>
        <div class="rc-compare-card__body">
          <div class="rc-compare-card__desc">{{ block.settings.description }}</div>
          <div class="rc-compare-card__bar">
            <div class="rc-compare-card__bar-fill {% unless block.settings.highlight %}rc-compare-card__bar-fill--muted{% endunless %}" style="width:{{ block.settings.score }}%;"></div>
          </div>
          <div class="rc-compare-card__chips">
            {% assign chips = block.settings.chips | split: '|' %}
            {% for chip in chips %}
              {% assign trimmed = chip | strip %}
              {% if trimmed != blank %}
                <span class="rc-chip {% if block.settings.highlight %}rc-chip--good{% else %}rc-chip--bad{% endif %}">{{ trimmed }}</span>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</div>

<style>
  .rc-compare {
    padding: 4px 16px 16px;
    background: #fff;
  }
  .rc-compare__inner {
    max-width: 600px;
  }
  .rc-compare__heading {
    font-family: var(--FONT-STACK-HEADING);
    font-size: 22px;
    font-weight: 900;
    text-transform: uppercase;
    margin: 0 0 14px;
    color: #0A0A0A;
  }
  .rc-compare-card {
    border: 1px solid #E4E4E4;
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 10px;
  }
  .rc-compare-card--hl {
    border: 2px solid #3D6E2E;
  }
  .rc-compare-card__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 11px 14px 8px;
  }
  .rc-compare-card__name {
    font-family: var(--FONT-STACK-HEADING);
    font-size: 15px;
    font-weight: 900;
    text-transform: uppercase;
  }
  .rc-compare-card__name--hl {
    color: #3D6E2E;
  }
  .rc-compare-card__price {
    background: #f0f0f0;
    border-radius: 20px;
    padding: 3px 10px;
    font-size: 12px;
    font-weight: 700;
  }
  .rc-compare-card__price--hl {
    background: rgba(0,123,255,0.08);
    color: #3D6E2E;
  }
  .rc-compare-card__body {
    padding: 0 14px 12px;
  }
  .rc-compare-card__desc {
    font-size: 12px;
    color: #555;
    margin-bottom: 6px;
    line-height: 1.4;
  }
  .rc-compare-card__bar {
    height: 5px;
    background: #eee;
    border-radius: 3px;
    overflow: hidden;
    margin: 4px 0 8px;
  }
  .rc-compare-card__bar-fill {
    height: 100%;
    background: #3D6E2E;
    border-radius: 3px;
  }
  .rc-compare-card__bar-fill--muted {
    background: #bbb;
  }
  .rc-compare-card__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .rc-chip {
    display: inline-flex;
    align-items: center;
    border-radius: 20px;
    padding: 3px 10px;
    font-size: 11px;
    font-weight: 600;
  }
  .rc-chip--good {
    border: 1.5px solid rgba(0,87,255,0.2);
    color: #3D6E2E;
    background: rgba(0,87,255,0.03);
  }
  .rc-chip--bad {
    border: 1.5px solid rgba(255,45,45,0.2);
    color: #cc0000;
    background: rgba(255,45,45,0.03);
  }

  /* Desktop */
  @media (min-width: 992px) {
    .rc-compare {
      padding: 8px 40px 24px;
      padding-left: calc(calc(50vh * 0.8) + 40px);
    }
    .rc-compare__heading {
      font-size: 28px;
    }
  }
</style>

{% schema %}
{
  "name": "PDP Compare",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "How it compares"
    }
  ],
  "blocks": [
    {
      "type": "competitor",
      "name": "Competitor",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Brand name",
          "default": "Budget Shorts"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price label",
          "default": "$35"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Fine for easy runs -- breaks down when pace goes up."
        },
        {
          "type": "range",
          "id": "score",
          "label": "Score bar (%)",
          "min": 0,
          "max": 100,
          "step": 5,
          "default": 25
        },
        {
          "type": "checkbox",
          "id": "highlight",
          "label": "Highlight (this is your brand)",
          "default": false
        },
        {
          "type": "text",
          "id": "chips",
          "label": "Tags (pipe separated)",
          "default": "Rides up | Flimsy"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PDP Compare",
      "blocks": [
        { "type": "competitor", "settings": { "name": "Budget Shorts", "price": "$35", "description": "Fine for easy runs -- breaks down when pace goes up.", "score": 25, "highlight": false, "chips": "Rides up | Flimsy" } },
        { "type": "competitor", "settings": { "name": "Golf Print Club", "price": "$40 (B2G1)", "description": "Race-ready fit, locked-in feel, designs you won't see everywhere.", "score": 88, "highlight": true, "chips": "No ride up | Real compression | Fair price" } },
        { "type": "competitor", "settings": { "name": "Big Brands", "price": "$90", "description": "Good performance -- but you pay for the logo, not the fit.", "score": 60, "highlight": false, "chips": "Brand markup | Safe designs" } }
      ]
    }
  ]
}
{% endschema %}
