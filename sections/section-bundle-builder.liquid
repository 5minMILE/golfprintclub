    font-weight: 700;
    background: #c00;
    color: #fff;
    padding: 1px 5px;
    border-radius: 3px;
    margin-left: 4px;
    vertical-align: middle;
  }
  .lp-offer__summary-total {
    display: flex;
    justify-content: space-between;
    font-family: var(--lp-font-head);
    font-size: 18px;
    font-weight: 900;
    padding: 10px 0 4px;
  }
  .lp-offer__summary-total-value { color: #000; }
  .lp-offer__summary-hint {
    text-align: center;
    font-size: 11px;
    color: #666;
    margin-top: 6px;
  }

  /* CTA */
  .lp-offer__cta { padding: 20px 16px 24px; text-align: center; }
  .lp-offer__cta-nudge {
    font-family: var(--lp-font-head);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 12px;
    color: #555;
  }
  .lp-offer__atc-btn { margin-bottom: 10px; }
  .lp-offer__atc-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .lp-offer__single-text {
    font-size: 13px;
    color: #888;
    margin-bottom: 14px;
  }
  .lp-offer__trust-row {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
  }
  .lp-offer__trust-item {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 10px;
    font-weight: 600;
    color: #888;
  }
  .lp-offer__trust-item svg { color: #888; }

  /* Fit Quiz Modal */
  .lp-fit-modal {
    position: fixed;
    inset: 0;
    z-index: 2147483000;
    background: rgba(0,0,0,.55);
    display: none;
    opacity: 0;
    pointer-events: none;
    transition: opacity .18s ease;
  }
  .lp-fit-modal.isOpen {
    display: block;
    opacity: 1;
    pointer-events: auto;
  }
  .lp-fit-modal__sheet-wrap {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    display: flex;
    justify-content: center;
  }
  .lp-fit-modal__sheet {
    width: 100%;
    max-width: 560px;
    height: min(86vh, 760px);
    background: #fff;
    border-top-left-radius: 22px;
    border-top-right-radius: 22px;
    box-shadow: 0 -20px 60px rgba(0,0,0,.28);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .lp-fit-modal__handle {
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fbfbfb;
  }
  .lp-fit-modal__handle span {
    width: 36px;
    height: 4px;
    border-radius: 2px;
    background: #ccc;
  }
  .lp-fit-modal__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 16px 10px;
    border-bottom: 1px solid #eee;
  }
  .lp-fit-modal__title {
    font-family: var(--lp-font-head);
    font-size: 16px;
    font-weight: 800;
    text-transform: uppercase;
  }
  .lp-fit-modal__close {
    width: 32px;
    height: 32px;
    border: none;
    background: #f0f0f0;
    border-radius: 50%;
    font-size: 18px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #333;
  }
  .lp-fit-modal__iframe {
    flex: 1;
    width: 100%;
    border: none;
  }
</style>

<style>
  #sticky-add-to-cart.rc-hide-for-bundle {
    opacity: 0 !important;
    pointer-events: none !important;
    transform: translateY(100%) !important;
    visibility: hidden !important;
  }
</style>

<script>
(function(){
  function init() {
    var stickyBar = document.getElementById('sticky-add-to-cart');
    var bundleSection = document.querySelector('.lp-offer');
    if (!stickyBar || !bundleSection) return;

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          stickyBar.classList.add('rc-hide-for-bundle');
        } else {
          stickyBar.classList.remove('rc-hide-for-bundle');
        }
      });
    }, { threshold: 0.05 });

    observer.observe(bundleSection);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

