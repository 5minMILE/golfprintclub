<div class="lp-page-wrap">
  <div class="lp-section-gap"></div>
  <div class="lp-bundle-reviews">
    <div class="lp-sec-head" style="margin-bottom:12px;">{{ section.settings.heading }}</div>
    {% for block in section.blocks %}
      <div class="lp-bundle-review {% unless forloop.last %}lp-bundle-review--bordered{% endunless %}" {{ block.shopify_attributes }}>
        <div class="lp-stars" style="font-size:12px;margin-bottom:4px;">{{ block.settings.stars }}</div>
        <div class="lp-bundle-review__title">{{ block.settings.title }}</div>
        <div class="lp-bundle-review__body">{{ block.settings.body }}</div>
        <div class="lp-bundle-review__meta">{{ block.settings.meta }}</div>
      </div>
    {% endfor %}
  </div>
</div>

<style>
  .lp-bundle-reviews {
    padding: 20px 16px;
    max-width: 390px;
    margin: 0 auto;
    background: var(--lp-white);
  }
  .lp-bundle-review { padding: 14px 0; }
  .lp-bundle-review--bordered { border-bottom: 1px solid var(--lp-border); }
  .lp-bundle-review__title { font-weight: 700; font-size: 13px; margin: 4px 0; }
  .lp-bundle-review__body { font-size: 12px; color: #555; line-height: 1.5; }
  .lp-bundle-review__meta { margin-top: 6px; font-size: 11px; color: var(--lp-blue); }
</style>

{% schema %}
{
  "name": "LP Bundle — Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Golfers love the bundle"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "stars",
          "label": "Stars",
          "default": "★★★★★"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Best golf posters!"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "\"Never found any this good at this affordable of a price.\""
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Meta",
          "default": "Logan R. · 6'0\" · Size L · ✓ Verified"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP Bundle — Reviews",
      "blocks": [
        { "type": "review", "settings": { "stars": "★★★★★", "title": "Best golf posters!", "body": "\"Never found any this good at this affordable of a price.\"", "meta": "Logan R. · 6'0\" · Size L · ✓ Verified" } },
        { "type": "review", "settings": { "stars": "★★★★★", "title": "Love these!", "body": "\"Ordered 2 designs and both fit perfectly for track workouts.\"", "meta": "Joan R. · ✓ Verified Purchase" } }
      ]
    }
  ]
}
{% endschema %}
