<script>
if('scrollRestoration' in history) history.scrollRestoration='manual';
window.scrollTo(0,0);
document.addEventListener('DOMContentLoaded', function() { window.scrollTo(0,0); });
window.addEventListener('load', function() { window.scrollTo(0,0); });
</script>
{%- liquid
  assign bp_product = product
  assign bp_colors = ''
  assign bp_sizes = ''

  for option in bp_product.options_with_values
    if option.position == 1
      for val in option.values
        if bp_colors == ''
          assign bp_colors = val
        else
          assign bp_colors = bp_colors | append: '|||' | append: val
        endif
      endfor
    elsif option.position == 2
      for val in option.values
        if bp_sizes == ''
          assign bp_sizes = val
        else
          assign bp_sizes = bp_sizes | append: '|||' | append: val
        endif
      endfor
    endif
  endfor

  assign bp_color_arr = bp_colors | split: '|||'
  assign bp_size_arr = bp_sizes | split: '|||'

  assign bp_single_price = bp_product.price
-%}

{%- comment -%} Build color → array of image URLs mapping for slider (all-3 + front + back) {%- endcomment -%}
{%- capture bp_color_images_json -%}
{
  {%- for color in bp_color_arr -%}
    {%- assign color_handle = color | handleize -%}
    {%- assign color_lower = color | downcase -%}
    {% unless forloop.first %},{% endunless %}
    {{ color | json }}: [
      {%- assign img_count = 0 -%}
      {%- for img in bp_product.images -%}
        {%- assign img_alt_down = img.alt | downcase -%}
        {%- assign img_alt_handle = img.alt | handleize -%}
        {%- assign match = false -%}
        {%- comment -%} Match all-3 {%- endcomment -%}
        {%- if img_alt_down == 'all-3' or img_alt_handle == 'all-3' -%}
          {%- assign match = true -%}
        {%- endif -%}
        {%- comment -%} Match {color}-front {%- endcomment -%}
        {%- assign alt_front = color_lower | append: '-front' -%}
        {%- assign handle_front = color_handle | append: '-front' -%}
        {%- if img_alt_down == alt_front or img_alt_handle == handle_front -%}
          {%- assign match = true -%}
        {%- endif -%}
        {%- comment -%} Match {color}-back {%- endcomment -%}
        {%- assign alt_back = color_lower | append: '-back' -%}
        {%- assign handle_back = color_handle | append: '-back' -%}
        {%- if img_alt_down == alt_back or img_alt_handle == handle_back -%}
          {%- assign match = true -%}
        {%- endif -%}
        {%- if match -%}
          {%- if img_count > 0 -%},{%- endif -%}
          {{ img | image_url: width: 900 | json }}
          {%- assign img_count = img_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if img_count == 0 -%}
        {%- comment -%} Fallback: try variant featured_image {%- endcomment -%}
        {%- for v in bp_product.variants -%}
          {%- assign v_color = v.option1 | downcase -%}
          {%- if v_color == color_lower and v.featured_image -%}
            {%- if img_count > 0 -%},{%- endif -%}
            {{ v.featured_image | image_url: width: 900 | json }}
            {%- assign img_count = img_count | plus: 1 -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
      {%- if img_count == 0 -%}
        {{ bp_product.featured_image | image_url: width: 900 | json }}
      {%- endif -%}
    ]
  {%- endfor -%}
}
{%- endcapture -%}

{%- comment -%} Hidden inventory map for backorder tagging script {%- endcomment -%}
<div class="product__block variant__countdown" style="display:none!important">
  <script data-product-remaining-json type="application/json">
  {
    {%- for variant in bp_product.variants -%}
      {%- assign bp_remaining = 'in' -%}
      {%- if variant.inventory_management -%}
        {%- if variant.inventory_quantity > 0 -%}
          {%- assign bp_remaining = 'in' -%}
        {%- elsif variant.inventory_policy == 'continue' -%}
          {%- assign bp_remaining = 'unavailable' -%}
        {%- else -%}
          {%- assign bp_remaining = 'out' -%}
        {%- endif -%}
      {%- endif -%}
      {{ variant.id | json }}: {{ bp_remaining | json }}{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  }
  </script>
</div>

<!-- Hero Image Slider -->
<div class="bp-section" id="bp-section-{{ section.id }}">
  <div class="bp-hero" id="bp-hero">
    <div class="bp-hero__track" id="bp-hero-track">
      {%- assign first_color = bp_color_arr[0] -%}
      {%- assign first_color_lower = first_color | downcase -%}
      {%- assign first_color_handle = first_color | handleize -%}
      {%- assign slide_count = 0 -%}
      {%- for color in bp_color_arr -%}
        {%- assign ic_lower = color | downcase -%}
        {%- assign ic_handle = color | handleize -%}
        {%- assign ic_front = ic_lower | append: '-front' -%}
        {%- assign ic_back = ic_lower | append: '-back' -%}
        {%- assign ih_front = ic_handle | append: '-front' -%}
        {%- assign ih_back = ic_handle | append: '-back' -%}
        {%- for img in bp_product.images -%}
          {%- assign img_alt_down = img.alt | downcase -%}
          {%- assign img_alt_handle = img.alt | handleize -%}
          {%- assign match = false -%}
          {%- if img_alt_down == 'all-3' or img_alt_handle == 'all-3' -%}
            {%- assign match = true -%}
          {%- endif -%}
          {%- if img_alt_down == ic_front or img_alt_handle == ih_front -%}
            {%- assign match = true -%}
          {%- endif -%}
          {%- if img_alt_down == ic_back or img_alt_handle == ih_back -%}
            {%- assign match = true -%}
          {%- endif -%}
          {%- if match -%}
          <div class="bp-hero__slide">
            <img class="bp-hero__img"
                 src="{{ img | image_url: width: 900 }}"
                 alt="{{ bp_product.title | escape }} - {{ color | escape }}"
                 width="900" height="900"
                 loading="{% if slide_count == 0 %}eager{% else %}lazy{% endif %}">
          </div>
          {%- assign slide_count = slide_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endfor -%}
      {%- if slide_count == 0 -%}
        <div class="bp-hero__slide">
          <img class="bp-hero__img"
               src="{{ bp_product.featured_image | image_url: width: 900 }}"
               alt="{{ bp_product.title | escape }}"
               width="900" height="900"
               loading="eager">
        </div>
        {%- assign slide_count = 1 -%}
      {%- endif -%}
    </div>
    <!-- Slider arrows -->
    <button class="bp-hero__arrow bp-hero__arrow--prev" type="button" id="bp-hero-prev" aria-label="Previous">&#8249;</button>
    <button class="bp-hero__arrow bp-hero__arrow--next" type="button" id="bp-hero-next" aria-label="Next">&#8250;</button>
  </div>
  <!-- Thumbnail strip -->
  <div class="bp-thumbs" id="bp-thumbs"></div>

  <!-- Product Info -->
  <div class="bp-info">
    <h1 class="bp-info__title">{% if section.settings.custom_title != blank %}{{ section.settings.custom_title }}{% else %}{{ bp_product.title }}{% endif %}</h1>
    <div class="bp-info__rating">
      <span class="bp-info__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
      <span class="bp-info__reviews-text">16 reviews</span>
    </div>
    <div class="bp-info__price" id="bp-active-price">
      <span class="bp-info__price-current">{{ bp_single_price | money }}</span>
    </div>
  </div>

  <!-- Single color picker (always visible) -->
  <div class="bp-single-pair" id="bp-single-pair">
    <div class="bp-pair" data-pair="single">
      <div class="bp-pair__label">COLOR: <span class="bp-pair__selected-color" data-pair-color="single">{{ bp_color_arr[0] }}</span></div>
      <div class="bp-pair__swatches-wrap">
        <div class="bp-pair__swatches">
          {%- for color in bp_color_arr -%}
            {%- assign color_handle = color | handleize -%}
            {%- assign color_lower = color | downcase -%}
            {%- assign swatch_img = nil -%}
            {%- for img in bp_product.images -%}
              {%- assign img_alt_down = img.alt | downcase -%}
              {%- assign img_alt_handle = img.alt | handleize -%}
              {%- if img_alt_down == color_lower or img_alt_handle == color_handle -%}
                {%- assign swatch_img = img -%}
                {%- break -%}
              {%- endif -%}
              {%- assign alt_with_front = color_lower | append: '-front' -%}
              {%- assign handle_with_front = color_handle | append: '-front' -%}
              {%- if img_alt_down == alt_with_front or img_alt_handle == handle_with_front -%}
                {%- assign swatch_img = img -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            {%- unless swatch_img -%}
              {%- for v in bp_product.variants -%}
                {%- assign v_color = v.option1 | downcase -%}
                {%- if v_color == color_lower and v.featured_image -%}
                  {%- assign swatch_img = v.featured_image -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endunless -%}
            {%- unless swatch_img -%}
              {%- assign swatch_img = bp_product.featured_image -%}
            {%- endunless -%}
            <button class="bp-pair__swatch{% if forloop.first %} bp-pair__swatch--active{% endif %}"
                    type="button"
                    data-color="{{ color }}"
                    aria-label="{{ color }}">
              <img src="{{ swatch_img | image_url: width: 240 }}" alt="{{ color | escape }}" width="60" height="60" loading="lazy">
            </button>
          {%- endfor -%}
        </div>
        <button class="bp-pair__arrow bp-pair__arrow--left bp-pair__arrow--hidden" type="button" aria-label="Scroll back">&#8249;</button>
        <button class="bp-pair__arrow bp-pair__arrow--right" type="button" aria-label="Scroll for more">&#8250;</button>
      </div>
    </div>
  </div>

  <hr class="bp-divider">

  <!-- Size Selector -->
  <div class="bp-sizes">
    <div class="bp-sizes__header">
      <div class="bp-sizes__label">SIZE</div>
      {%- assign bp_size_chart = product.metafields.custom.size_chart -%}
      {%- if bp_size_chart != blank -%}
        <button type="button" class="bp-sizes__chart-link" id="bp-sc-trigger">Size Chart</button>
      {%- endif -%}
    </div>
    <div class="bp-sizes__grid">
      {%- for sz in bp_size_arr -%}
        {%- liquid
          assign sz_label = sz
          if sz == 'Small'
            assign sz_label = 'S'
          elsif sz == 'Medium'
            assign sz_label = 'M'
          elsif sz == 'Large'
            assign sz_label = 'L'
          elsif sz == 'X-Large' or sz == 'XL' or sz == 'X-large'
            assign sz_label = 'XL'
          elsif sz == '2X-Large' or sz == 'XXL' or sz == '2XL'
            assign sz_label = '2XL'
          elsif sz == '3X-Large' or sz == 'XXXL' or sz == '3XL'
            assign sz_label = '3XL'
          endif
        -%}
        <button class="bp-sizes__btn" type="button" data-size="{{ sz }}">{{ sz_label }}</button>
      {%- endfor -%}
    </div>
  </div>

  <!-- Add to Cart / Buy Now -->
  <div class="bp-cta">
    <button type="button" class="bp-cta__atc" id="bp-atc-btn" disabled>Select a Size</button>
    <button type="button" class="bp-cta__buy" id="bp-buy-btn">Buy Now</button>
  </div>

  <!-- Complete the Look -->
  {%- assign ctl_p1 = section.settings.complete_the_look_1 -%}
  {%- assign ctl_p2 = section.settings.complete_the_look_2 -%}
  {%- if ctl_p1 != blank or ctl_p2 != blank -%}
  <div class="bp-ctl">
    <div class="bp-ctl__heading">COMPLETE THE LOOK</div>
    <div class="bp-ctl__items">
      {%- if ctl_p1 != blank -%}
      <div class="bp-ctl__item">
        <a class="bp-ctl__item-img-link" href="{{ ctl_p1.url }}">
          <img class="bp-ctl__item-img" src="{{ ctl_p1.featured_image | image_url: width: 300 }}" alt="{{ ctl_p1.title | escape }}" width="120" height="150" loading="lazy">
        </a>
        <div class="bp-ctl__item-info">
          <div class="bp-ctl__item-title">{{ ctl_p1.title }}</div>
          {%- if ctl_p1.variants.first.option1 -%}
            <div class="bp-ctl__item-color">Color: {{ ctl_p1.variants.first.option1 }}</div>
          {%- endif -%}
          <a class="bp-ctl__item-btn" href="{{ ctl_p1.url }}">Choose Color & Size</a>
          <div class="bp-ctl__item-price">
            {%- if ctl_p1.compare_at_price > ctl_p1.price -%}
              <span class="bp-ctl__item-compare">{{ ctl_p1.compare_at_price | money }}</span>
            {%- endif -%}
            <span class="bp-ctl__item-current">{{ ctl_p1.price | money }}</span>
          </div>
        </div>
      </div>
      {%- endif -%}
      {%- if ctl_p2 != blank -%}
      <div class="bp-ctl__item">
        <a class="bp-ctl__item-img-link" href="{{ ctl_p2.url }}">
          <img class="bp-ctl__item-img" src="{{ ctl_p2.featured_image | image_url: width: 300 }}" alt="{{ ctl_p2.title | escape }}" width="120" height="150" loading="lazy">
        </a>
        <div class="bp-ctl__item-info">
          <div class="bp-ctl__item-title">{{ ctl_p2.title }}</div>
          {%- if ctl_p2.variants.first.option1 -%}
            <div class="bp-ctl__item-color">Color: {{ ctl_p2.variants.first.option1 }}</div>
          {%- endif -%}
          <a class="bp-ctl__item-btn" href="{{ ctl_p2.url }}">Choose Color & Size</a>
          <div class="bp-ctl__item-price">
            {%- if ctl_p2.compare_at_price > ctl_p2.price -%}
              <span class="bp-ctl__item-compare">{{ ctl_p2.compare_at_price | money }}</span>
            {%- endif -%}
            <span class="bp-ctl__item-current">{{ ctl_p2.price | money }}</span>
          </div>
        </div>
      </div>
      {%- endif -%}
    </div>
  </div>
  {%- endif -%}

  <!-- Accordions -->
  <div class="bp-accordions">
    <details class="bp-accordion bp-accordion--desktop-only">
      <summary class="bp-accordion__header">Who is this for? <span class="bp-accordion__icon">+</span></summary>
      <div class="bp-accordion__body">
        {%- if product.tags contains 'run' -%}
          <p><strong>For:</strong> Competitive golfers who train consistently (track, XC, road) and want performance gear without the $100+ markup.</p>
          <ul>
            <li>Mid-distance golfers (400–3200) and anyone doing hard workouts</li>
            <li>Athletes who care about fit, compression, and chafe-free comfort</li>
            <li>Golfers who want a weekly rotation for training + tournament day</li>
          </ul>
          <p><strong>Not for:</strong> Casual joggers looking for loose, fashion-first shorts.</p>
        {%- elsif product.tags contains 'life' -%}
          <p><strong>For:</strong> Everyday wear and training-lite days—comfort, style, and a clean fit.</p>
          <ul>
            <li>Rest day / gym / casual</li>
            <li>Golfers who want lifestyle pieces that still feel athletic</li>
          </ul>
        {%- else -%}
          <p><strong>For:</strong> Anyone who wants well-made gear with a competitive golf edge.</p>
        {%- endif -%}
      </div>
    </details>
    <details class="bp-accordion bp-accordion--desktop-only">
      <summary class="bp-accordion__header">Description <span class="bp-accordion__icon">+</span></summary>
      <div class="bp-accordion__body">{{ product.description }}</div>
    </details>
    <details class="bp-accordion bp-accordion--desktop-only">
      <summary class="bp-accordion__header">Delivery & Returns <span class="bp-accordion__icon">+</span></summary>
      <div class="bp-accordion__body">
        {%- if product.tags contains 'run' -%}
          <p>Golf gear is processed within <strong>5 business days</strong> and typically arrives within <strong>3–4 business days</strong> after shipping. These ship separately from posters and graphic tees, so you might receive multiple packages depending on your order.</p>
          <p>Returns are available within <strong>30 days</strong> as long as items are <strong>unworn and include all original tags and packaging</strong>. Missing tags or packaging may result in a small restocking fee. If you're unsure about fit, we're happy to help before you place your order.</p>
        {%- elsif product.tags contains 'life' -%}
          <p>Our graphic tees are made to order and ship out within <strong>3–4 business days</strong>, with delivery taking another <strong>3–4 business days</strong> depending on your location.</p>
          <p>If there's a print issue or anything physically wrong with your tee, we'll take care of it. Otherwise, due to the made-to-order nature, we're not able to offer returns for sizing or preference changes.</p>
        {%- else -%}
          <p>Please allow up to <strong>5 business days</strong> for processing and <strong>3–4 business days</strong> for shipping. For return eligibility, see individual product details or reach out to our support team.</p>
        {%- endif -%}
      </div>
    </details>
    {%- if section.settings.compare_fabrics_html != blank -%}
    <details class="bp-accordion">
      <summary class="bp-accordion__header">Compare Fabrics <span class="bp-accordion__icon">+</span></summary>
      <div class="bp-accordion__body">{{ section.settings.compare_fabrics_html }}</div>
    </details>
    {%- endif -%}
  </div>
</div>

<!-- Size Chart Drawer -->
{%- if bp_size_chart != blank -%}
<div class="bp-sc-overlay" id="bp-sc-overlay" hidden></div>
<div class="bp-sc-drawer" id="bp-sc-drawer" hidden>
  <div class="bp-sc-drawer__header">
    <span class="bp-sc-drawer__title">Size Chart</span>
    <button type="button" class="bp-sc-drawer__close" id="bp-sc-close" aria-label="Close">&times;</button>
  </div>
  <div class="bp-sc-drawer__body">
    {%- assign bp_sc_page = bp_size_chart.value -%}
    {%- if bp_sc_page and bp_sc_page.content -%}
      {{ bp_sc_page.content }}
    {%- else -%}
      {%- assign bp_sc_handle = bp_size_chart | metafield_text -%}
      {%- if bp_sc_handle and pages[bp_sc_handle] and pages[bp_sc_handle].content -%}
        {{ pages[bp_sc_handle].content }}
      {%- else -%}
        {{ bp_size_chart | metafield_text }}
      {%- endif -%}
    {%- endif -%}
  </div>
</div>
{%- endif -%}

<!-- Variant data for JS -->
<script type="application/json" id="bp-variant-data">
[
  {%- for v in bp_product.variants -%}
    {% unless forloop.first %},{% endunless %}
    {"id":{{ v.id }},"option1":{{ v.option1 | json }},"option2":{{ v.option2 | json }},"available":{{ v.available }},"price":{{ v.price }}}
  {%- endfor -%}
]
</script>

<script type="application/json" id="bp-color-images">
{{ bp_color_images_json }}
</script>

<script>
(function() {
  var section = document.getElementById('bp-section-{{ section.id }}');
  if (!section) return;

  // Backorder inventory map
  var bpRemainingMap = {};
  try {
    var mapEl = document.querySelector('[data-product-remaining-json]');
    if (mapEl) bpRemainingMap = JSON.parse(mapEl.textContent.trim());
  } catch(e) {}
  function bpGetAvail(variantId) {
    return bpRemainingMap[String(variantId)] || null;
  }

  // Inject backorder messages into cart drawer after items render
  function bpInjectBackorderMessages() {
    var attempts = 0;
    var timer = setInterval(function() {
      attempts++;
      var wrap = document.getElementById('rcDevItems');
      if (!wrap) { if (attempts > 30) clearInterval(timer); return; }
      var lines = wrap.querySelectorAll('.rc-item');
      if (!lines.length) { if (attempts > 30) clearInterval(timer); return; }

      fetch('/cart.js', { credentials: 'same-origin', cache: 'no-store' })
        .then(function(r) { return r.json(); })
        .then(function(cart) {
          if (!cart || !cart.items) return;
          cart.items.forEach(function(item, idx) {
            var lineEl = lines[idx];
            if (!lineEl) return;
            var existing = lineEl.querySelector('.rc-backorder-line');
            if (existing) existing.remove();

            var avail = bpGetAvail(item.variant_id);
            if (avail === 'unavailable') {
              var el = document.createElement('div');
              el.className = 'rc-backorder-line';
              el.textContent = 'This item is currently on back order and may take 4\u20138 weeks to arrive.';
              el.style.cssText = 'margin-top:6px;font-size:12px;font-weight:950;color:#2E7D32;line-height:1.25;text-transform:uppercase;letter-spacing:.04em;';
              var variantRow = lineEl.querySelector('.rc-variant');
              if (variantRow) {
                variantRow.insertAdjacentElement('afterend', el);
              } else {
                var meta = lineEl.querySelector('.rc-meta');
                if (meta) meta.appendChild(el);
              }
            }
          });
        })
        .catch(function() {});
      clearInterval(timer);
    }, 300);
  }

  var variants = [];
  var colorImages = {};
  try {
    variants = JSON.parse(document.getElementById('bp-variant-data').textContent);
    colorImages = JSON.parse(document.getElementById('bp-color-images').textContent);
  } catch(e) { console.error('BP: Failed to parse variant data', e); }

  var singleColor = '{{ bp_color_arr[0] | escape }}';
  var selectedSize = null;
  var singlePrice = {{ bp_single_price }};

  // --- Preload all hero images after page load ---
  function preloadAllImages() {
    Object.keys(colorImages).forEach(function(color) {
      var imgs = colorImages[color];
      if (!imgs) return;
      imgs.forEach(function(url) {
        var img = new Image();
        img.src = url;
      });
    });
  }
  if (document.readyState === 'complete') {
    preloadAllImages();
  } else {
    window.addEventListener('load', preloadAllImages);
  }

  // --- Build allImages (all colors concatenated) + color start index map ---
  var allImages = [];
  var colorStartIndex = {};
  var colorOrder = {{ bp_color_arr | json }};
  colorOrder.forEach(function(color) {
    var imgs = colorImages[color];
    if (imgs && imgs.length > 0) {
      colorStartIndex[color] = allImages.length;
      allImages = allImages.concat(imgs);
    }
  });

  // --- Image Slider ---
  var currentSlide = 0;
  var track = document.getElementById('bp-hero-track');
  var thumbsContainer = document.getElementById('bp-thumbs');

  function buildSlider(images) {
    track.innerHTML = '';
    images.forEach(function(url, i) {
      var slide = document.createElement('div');
      slide.className = 'bp-hero__slide';
      slide.innerHTML = '<img class="bp-hero__img" src="' + url + '" alt="" width="900" height="900" loading="' + (i === 0 ? 'eager' : 'lazy') + '">';
      track.appendChild(slide);
    });
    thumbsContainer.innerHTML = '';
    var isDesktop = window.matchMedia('(min-width: 768px)').matches;
    var maxVisible = 5;
    images.forEach(function(url, i) {
      var thumb = document.createElement('button');
      thumb.className = 'bp-thumb' + (i === 0 ? ' bp-thumb--active' : '');
      if (isDesktop && i >= maxVisible) thumb.classList.add('bp-thumb--hidden');
      thumb.type = 'button';
      thumb.setAttribute('data-slide', i);
      thumb.setAttribute('aria-label', 'View image ' + (i + 1));
      var thumbUrl = url.replace(/width=\d+/, 'width=120');
      thumb.innerHTML = '<img src="' + thumbUrl + '" alt="" width="60" height="60" loading="lazy">';
      thumbsContainer.appendChild(thumb);
    });
    if (isDesktop && images.length > maxVisible) {
      var moreBtn = document.createElement('button');
      moreBtn.className = 'bp-thumb bp-thumb--more';
      moreBtn.type = 'button';
      moreBtn.setAttribute('aria-label', 'Show all thumbnails');
      moreBtn.innerHTML = '<span class="bp-thumb-dots">...</span>';
      thumbsContainer.appendChild(moreBtn);
      moreBtn.addEventListener('click', function() {
        thumbsContainer.querySelectorAll('.bp-thumb--hidden').forEach(function(t) {
          t.classList.remove('bp-thumb--hidden');
        });
        moreBtn.remove();
      });
    }
    currentSlide = 0;
    goToSlide(0);
  }

  var userInitiated = false;

  function goToSlide(idx) {
    var slides = track.querySelectorAll('.bp-hero__slide');
    if (slides.length === 0) return;
    if (idx < 0) idx = slides.length - 1;
    if (idx >= slides.length) idx = 0;
    currentSlide = idx;
    track.style.transform = 'translateX(-' + (idx * 100) + '%)';
    var thumbs = thumbsContainer.querySelectorAll('.bp-thumb');
    thumbs.forEach(function(t, i) {
      t.classList.toggle('bp-thumb--active', i === idx);
    });
    if (userInitiated && thumbs[idx]) {
      thumbs[idx].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }
  }

  document.getElementById('bp-hero-prev').addEventListener('click', function() { goToSlide(currentSlide - 1); });
  document.getElementById('bp-hero-next').addEventListener('click', function() { goToSlide(currentSlide + 1); });
  thumbsContainer.addEventListener('click', function(e) {
    var thumb = e.target.closest('.bp-thumb');
    if (thumb) goToSlide(parseInt(thumb.getAttribute('data-slide')));
  });

  // Touch/swipe support
  (function() {
    var hero = document.getElementById('bp-hero');
    var startX = 0, diffX = 0, dragging = false;
    hero.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; dragging = true; }, { passive: true });
    hero.addEventListener('touchmove', function(e) { if (dragging) diffX = e.touches[0].clientX - startX; }, { passive: true });
    hero.addEventListener('touchend', function() {
      if (!dragging) return;
      dragging = false;
      if (Math.abs(diffX) > 40) {
        if (diffX < 0) goToSlide(currentSlide + 1);
        else goToSlide(currentSlide - 1);
      }
      diffX = 0;
    });
  })();

  // --- Desktop click-to-zoom on hero images ---
  (function() {
    var hero = document.getElementById('bp-hero');
    if (!window.matchMedia('(min-width: 768px)').matches) return;

    var zoomed = false;

    hero.addEventListener('click', function(e) {
      if (e.target.closest('.bp-hero__arrow')) return;
      var slide = track.querySelectorAll('.bp-hero__slide')[currentSlide];
      if (!slide) return;
      var img = slide.querySelector('.bp-hero__img');
      if (!img) return;

      if (zoomed) {
        img.style.transform = '';
        img.style.transformOrigin = '';
        hero.classList.remove('bp-hero--zoomed');
        zoomed = false;
      } else {
        var rect = hero.getBoundingClientRect();
        var x = ((e.clientX - rect.left) / rect.width * 100).toFixed(2);
        var y = ((e.clientY - rect.top) / rect.height * 100).toFixed(2);
        img.style.transformOrigin = x + '% ' + y + '%';
        img.style.transform = 'scale(2)';
        hero.classList.add('bp-hero--zoomed');
        zoomed = true;
      }
    });

    hero.addEventListener('mousemove', function(e) {
      if (!zoomed) return;
      var slide = track.querySelectorAll('.bp-hero__slide')[currentSlide];
      if (!slide) return;
      var img = slide.querySelector('.bp-hero__img');
      if (!img) return;
      var rect = hero.getBoundingClientRect();
      var x = ((e.clientX - rect.left) / rect.width * 100).toFixed(2);
      var y = ((e.clientY - rect.top) / rect.height * 100).toFixed(2);
      img.style.transformOrigin = x + '% ' + y + '%';
    });

    hero.addEventListener('mouseleave', function() {
      if (!zoomed) return;
      var imgs = track.querySelectorAll('.bp-hero__img');
      imgs.forEach(function(img) {
        img.style.transform = '';
        img.style.transformOrigin = '';
      });
      hero.classList.remove('bp-hero--zoomed');
      zoomed = false;
    });
  })();

  // --- Build initial slider (all images) ---
  updateSliderForColor();
  userInitiated = true;

  function updateSliderForColor() {
    var imgs = colorImages[singleColor] || [];
    if (imgs.length > 0) {
      buildSlider(imgs);
    }
  }

  // --- Swatch clicks (single color picker) ---
  var singlePairEl = document.getElementById('bp-single-pair');
  if (singlePairEl) {
    singlePairEl.querySelectorAll('.bp-pair__swatch').forEach(function(swatch) {
      swatch.addEventListener('click', function() {
        var color = swatch.getAttribute('data-color');
        singleColor = color;
        singlePairEl.querySelectorAll('.bp-pair__swatch').forEach(function(s) {
          s.classList.remove('bp-pair__swatch--active');
        });
        swatch.classList.add('bp-pair__swatch--active');
        singlePairEl.querySelector('[data-pair-color]').textContent = color;
        updateSliderForColor();
        updateATC();
      });
    });
  }

  // --- Size buttons ---
  section.querySelectorAll('.bp-sizes__btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      section.querySelectorAll('.bp-sizes__btn').forEach(function(b) {
        b.classList.remove('bp-sizes__btn--active');
      });
      btn.classList.add('bp-sizes__btn--active');
      selectedSize = btn.getAttribute('data-size');
      updateATC();
    });
  });

  function updateATC() {
    var btn = document.getElementById('bp-atc-btn');
    if (!selectedSize) {
      btn.disabled = true;
      btn.textContent = 'Select a Size';
    } else {
      btn.disabled = false;
      btn.textContent = '{{ section.settings.cta_text | escape }}';
    }
  }

  function findVariant(color, size) {
    var colorLC = color.toLowerCase().trim();
    var sizeLC = size.toLowerCase().trim();
    for (var i = 0; i < variants.length; i++) {
      var v = variants[i];
      var o1 = v.option1 ? v.option1.toLowerCase().trim() : '';
      var o2 = v.option2 ? v.option2.toLowerCase().trim() : '';
      if (o1 === colorLC && o2 === sizeLC) return v;
    }
    return null;
  }

  // --- Add to Cart (single only) ---
  document.getElementById('bp-atc-btn').addEventListener('click', function() {
    var btn = this;
    if (btn.disabled) return;
    if (!selectedSize) { alert('Please select a size'); return; }

    var v = findVariant(singleColor, selectedSize);
    if (!v) {
      alert('Size ' + selectedSize + ' is not available for ' + singleColor + '.');
      return;
    }
    if (!v.available) {
      alert(singleColor + ' in size ' + selectedSize + ' is sold out.');
      return;
    }
    var itemObj = { id: v.id, quantity: 1 };
    var avail = bpGetAvail(v.id);
    if (avail) {
      itemObj.properties = itemObj.properties || {};
      itemObj.properties._rc_avail = avail;
      itemObj.properties._rc_backorder = avail === 'unavailable' ? 'true' : 'false';
    }

    btn.disabled = true;
    btn.textContent = 'Adding...';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: [itemObj] })
    })
    .then(function(res) {
      if (!res.ok) throw new Error('Cart error');
      return res.json();
    })
    .then(function() {
      btn.textContent = 'Added!';
      if (window.RC_CART && typeof window.RC_CART.open === 'function') {
        window.RC_CART.open();
        bpInjectBackorderMessages();
      } else {
        window.location.href = '/cart';
      }
      setTimeout(function() {
        btn.disabled = false;
        btn.textContent = '{{ section.settings.cta_text | escape }}';
      }, 1500);
    })
    .catch(function() {
      alert('Something went wrong. Please try again.');
      btn.disabled = false;
      btn.textContent = '{{ section.settings.cta_text | escape }}';
    });
  });

  // --- Buy Now (single only) ---
  document.getElementById('bp-buy-btn').addEventListener('click', function() {
    if (!selectedSize) { alert('Please select a size'); return; }

    var v = findVariant(singleColor, selectedSize);
    if (!v) { alert('Variant not available.'); return; }
    window.location.href = '/cart/' + v.id + ':1';
  });

  // --- Accordion toggle icon ---
  section.querySelectorAll('.bp-accordion').forEach(function(acc) {
    acc.addEventListener('toggle', function() {
      var icon = acc.querySelector('.bp-accordion__icon');
      icon.textContent = acc.open ? '\u2212' : '+';
    });
  });

  // --- Size Chart Drawer ---
  (function() {
    var trigger = document.getElementById('bp-sc-trigger');
    var drawer = document.getElementById('bp-sc-drawer');
    var overlay = document.getElementById('bp-sc-overlay');
    var closeBtn = document.getElementById('bp-sc-close');
    if (!trigger || !drawer || !overlay) return;

    function openDrawer() {
      drawer.hidden = false;
      overlay.hidden = false;
      document.documentElement.style.overflow = 'hidden';
    }
    function closeDrawer() {
      drawer.hidden = true;
      overlay.hidden = true;
      document.documentElement.style.overflow = '';
    }
    trigger.addEventListener('click', openDrawer);
    overlay.addEventListener('click', closeDrawer);
    if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && !drawer.hidden) closeDrawer();
    });
  })();

  // --- Swatch scroll arrows + gradients ---
  var swatchArrowCheckers = [];
  section.querySelectorAll('.bp-pair__swatches-wrap').forEach(function(wrap) {
    var track = wrap.querySelector('.bp-pair__swatches');
    var arrowRight = wrap.querySelector('.bp-pair__arrow--right');
    var arrowLeft = wrap.querySelector('.bp-pair__arrow--left');
    if (!track) return;

    function checkArrows() {
      var canScroll = track.scrollWidth > track.clientWidth + 2;
      var atStart = track.scrollLeft <= 2;
      var atEnd = track.scrollLeft + track.clientWidth >= track.scrollWidth - 2;

      if (arrowRight) {
        if (!canScroll || atEnd) {
          arrowRight.classList.add('bp-pair__arrow--hidden');
        } else {
          arrowRight.classList.remove('bp-pair__arrow--hidden');
        }
      }
      if (arrowLeft) {
        if (!canScroll || atStart) {
          arrowLeft.classList.add('bp-pair__arrow--hidden');
        } else {
          arrowLeft.classList.remove('bp-pair__arrow--hidden');
        }
      }

      // Gradient fades
      wrap.classList.toggle('bp-pair__swatches-wrap--fade-right', canScroll && !atEnd);
      wrap.classList.toggle('bp-pair__swatches-wrap--fade-left', canScroll && !atStart);
    }

    if (arrowRight) {
      arrowRight.addEventListener('click', function() {
        track.scrollBy({ left: 200, behavior: 'smooth' });
      });
    }
    if (arrowLeft) {
      arrowLeft.addEventListener('click', function() {
        track.scrollBy({ left: -200, behavior: 'smooth' });
      });
    }

    track.addEventListener('scroll', checkArrows);
    checkArrows();
    setTimeout(checkArrows, 500);
    swatchArrowCheckers.push(checkArrows);
  });
  // --- URL ?variant=<color> support ---
  // e.g. /products/ld-split-shorts?variant=white
  (function() {
    var slug = new URLSearchParams(window.location.search).get('variant');
    if (!slug) return;
    if (/^\d+$/.test(slug)) return;

    var slugLower = slug.toLowerCase().replace(/[-_]/g, ' ').trim();

    var singlePair = document.getElementById('bp-single-pair');
    if (singlePair) {
      singlePair.querySelectorAll('.bp-pair__swatch').forEach(function(swatch) {
        var color = (swatch.getAttribute('data-color') || '').toLowerCase().replace(/[-_]/g, ' ').trim();
        if (color === slugLower || color.replace(/\s+/g, '') === slugLower.replace(/\s+/g, '')) {
          swatch.click();
        }
      });
    }
  })();
})();
</script>

<style>
  .bp-section {
    --bp-blue: #2E7D32;
