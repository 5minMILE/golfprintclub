    opacity: 0.6;
    transition: opacity 0.2s, border-color 0.2s;
  }
  .bp-thumb img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .bp-thumb--active {
    border-color: #000;
    opacity: 1;
  }
  .bp-thumb:hover {
    opacity: 1;
  }

  /* Info */
  .bp-info { padding: 8px 16px 4px; }
  .bp-info__title {
    font-family: var(--bp-font);
    font-size: 22px;
    font-weight: 900;
    text-transform: uppercase;
    margin: 0 0 6px;
    line-height: 1.1;
  }
  .bp-info__rating { margin-bottom: 6px; display: flex; align-items: center; gap: 6px; }
  .bp-info__stars { color: #000; font-size: 16px; letter-spacing: 1px; }
  .bp-info__reviews-text { font-size: 13px; color: #555; font-weight: 600; }
  .bp-info__price {
    font-family: var(--bp-font);
    font-size: 18px;
    font-weight: 800;
    color: #000;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .bp-info__price-compare {
    text-decoration: line-through;
    color: #999;
    font-weight: 600;
  }
  .bp-info__price-sale {
    color: #c00;
    font-weight: 900;
  }
  .bp-info__price-current {
    color: #000;
    font-weight: 900;
  }

  /* Pair selectors / single color picker */
  .bp-single-pair { padding: 0 16px 8px; }
  .bp-pair { margin-bottom: 12px; }
  .bp-pair__label {
    font-family: var(--bp-font);
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 8px;
    color: #000;
  }
  .bp-pair__selected-color { color: #000; }
  .bp-divider {
    border: none;
    border-top: 1px solid #eee;
    margin: 4px 16px 8px;
  }
  .bp-pair__swatches-wrap {
    position: relative;
  }
  .bp-pair__swatches-wrap::before,
  .bp-pair__swatches-wrap::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 4px;
    width: 36px;
    z-index: 1;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .bp-pair__swatches-wrap::after {
    right: 0;
    background: linear-gradient(to left, #fff 0%, transparent 100%);
  }
  .bp-pair__swatches-wrap::before {
    left: 0;
    background: linear-gradient(to right, #fff 0%, transparent 100%);
  }
  .bp-pair__swatches-wrap--fade-right::after { opacity: 1; }
  .bp-pair__swatches-wrap--fade-left::before { opacity: 1; }
  .bp-pair__swatches {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 4px;
    scroll-behavior: smooth;
  }
  .bp-pair__swatches::-webkit-scrollbar { display: none; }
  .bp-pair__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: none;
    background: rgba(0,0,0,0.7);
    color: #fff;
    font-size: 18px;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    box-shadow: 0 2px 6px rgba(0,0,0,0.2);
    transition: opacity 0.2s;
  }
  .bp-pair__arrow--right { right: -4px; }
  .bp-pair__arrow--left { left: -4px; }
  .bp-pair__arrow--hidden {
    opacity: 0;
    pointer-events: none;
  }
  .bp-pair__swatch {
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    border-radius: 6px;
    border: 2px solid transparent;
    padding: 0;
    background: #f5f5f5;
    cursor: pointer;
    overflow: hidden;
    transition: border-color .15s;
    scroll-snap-align: start;
  }
  .bp-pair__swatch img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 4px;
    transform: scale(1.5);
    transform-origin: center center;
  }
  .bp-pair__swatch--active { border-color: #2E7D32; }
  .bp-pair__swatch {
    position: relative;
  }
  .bp-pair__swatch--active::after {
    content: '\2713';
    position: absolute;
    top: -2px;
    right: -2px;
    width: 20px;
    height: 20px;
    background: #2E7D32;
    color: #fff;
    border-radius: 0 4px 0 8px;
    font-size: 12px;
    font-weight: 700;
    line-height: 20px;
    text-align: center;
    pointer-events: none;
    z-index: 2;
  }

  /* Sizes */
  .bp-sizes { padding: 8px 16px 12px; }
  .bp-sizes__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }
  .bp-sizes__chart-link {
    font-family: var(--bp-font);
    font-size: 11px;
    font-weight: 600;
    color: #000;
    text-decoration: underline;
    text-underline-offset: 2px;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  /* Size Chart Drawer */
  .bp-sc-overlay[hidden],
  .bp-sc-drawer[hidden] { display: none !important; }
  .bp-sc-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 10000;
    animation: bp-sc-fade 0.15s ease-out;
  }
  .bp-sc-drawer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 10001;
    background: #fff;
    border-top-left-radius: 16px;
    border-top-right-radius: 16px;
    box-shadow: 0 -8px 30px rgba(0,0,0,0.15);
    max-height: 85vh;
    display: flex;
    flex-direction: column;
    animation: bp-sc-slide 0.25s ease-out;
  }
  .bp-sc-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 18px;
    border-bottom: 1px solid #eee;
    flex-shrink: 0;
  }
  .bp-sc-drawer__title {
    font-family: var(--bp-font);
    font-size: 16px;
    font-weight: 800;
    text-transform: uppercase;
  }
  .bp-sc-drawer__close {
    background: none;
    border: none;
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
    padding: 4px 8px;
    color: #333;
  }
  .bp-sc-drawer__body {
    padding: 16px 18px 32px;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    font-size: 14px;
