  }
  .bp-sc-drawer__body table { width: 100%; border-collapse: collapse; }
  .bp-sc-drawer__body th,
  .bp-sc-drawer__body td { border: 1px solid #eee; padding: 8px; text-align: center; }
  .bp-sc-drawer__body img { max-width: 100%; height: auto; }
  @keyframes bp-sc-slide {
    from { transform: translateY(100%); }
    to { transform: translateY(0); }
  }
  @keyframes bp-sc-fade {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @media (min-width: 768px) {
    .bp-sc-drawer {
      left: auto;
