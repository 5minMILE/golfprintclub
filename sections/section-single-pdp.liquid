      top: 0;
      right: 0;
      border-radius: 0;
      max-height: none;
      animation: bp-sc-slide-right 0.25s ease-out;
    }
    @keyframes bp-sc-slide-right {
      from { transform: translateX(100%); }
      to { transform: translateX(0); }
    }
  }
  .bp-sizes__label {
    font-family: var(--bp-font);
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .bp-sizes__grid {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 4px;
  }
  .bp-sizes__grid::-webkit-scrollbar { display: none; }
  .bp-sizes__btn {
    flex-shrink: 0;
    min-width: 48px;
    padding: 12px 10px;
    border: 2px solid #ddd;
    border-radius: 6px;
    font-family: var(--bp-font);
    font-size: 14px;
    font-weight: 700;
    text-align: center;
    cursor: pointer;
    background: transparent;
    color: #000;
    transition: border-color .15s, background .15s;
  }
  .bp-sizes__btn--active {
    border-color: var(--bp-blue);
    background: var(--bp-blue);
    color: #fff;
  }

  /* CTA */
  .bp-cta { padding: 8px 16px 16px; }
  .bp-cta__atc {
    display: block;
    width: 100%;
    padding: 16px;
    background: var(--bp-blue);
    color: #fff;
    border: none;
    border-radius: 6px;
    font-family: var(--bp-font);
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    margin-bottom: 8px;
  }
  .bp-cta__atc:disabled { opacity: 0.5; cursor: not-allowed; }
  .bp-cta__buy {
    display: block;
    width: 100%;
    padding: 16px;
    background: #000;
    color: #fff;
    border: none;
    border-radius: 6px;
    font-family: var(--bp-font);
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
  }

  /* Complete the Look */
  .bp-ctl { padding: 16px; border-top: 1px solid #eee; }
  .bp-ctl__heading {
    font-family: var(--bp-font);
    font-size: 14px;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .bp-ctl__items { display: flex; flex-direction: column; gap: 12px; }
  .bp-ctl__item {
    display: flex;
    align-items: center;
    gap: 14px;
    color: #000;
    padding: 0;
    background: #f9f9f9;
    border-radius: 10px;
    border: 1px #eee solid;
  }
  .bp-ctl__item-img-link {
    flex-shrink: 0;
    display: block;
  }
  .bp-ctl__item-img {
    width: 100px;
    height: 120px;
    border-radius: 12px 0 0 12px;
    object-fit: cover;
    display: block;
  }
  .bp-ctl__item-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .bp-ctl__item-title {
    font-family: var(--bp-font);
    font-size: 15px;
    font-weight: 800;
    line-height: 1.2;
  }
  .bp-ctl__item-color {
    font-size: 13px;
    color: #555;
  }
  .bp-ctl__item-btn {
    display: inline-block;
    width: fit-content;
    padding: 10px 20px;
    background: #000;
    color: #fff;
    border-radius: 30px;
    font-family: var(--bp-font);
    font-size: 12px;
    font-weight: 700;
    text-decoration: none;
    text-transform: none;
    margin: 4px 0;
    transition: background 0.15s;
  }
  .bp-ctl__item-btn:hover { background: #2E7D32; color: #fff; }
  .bp-ctl__item-price {
    display: flex;
    align-items: baseline;
    gap: 6px;
    font-size: 14px;
    margin-top: 2px;
  }
  .bp-ctl__item-compare {
    text-decoration: line-through;
    color: #999;
    font-weight: 600;
  }
  .bp-ctl__item-current {
    color: #000;
    font-weight: 800;
  }

  /* Accordions */
  .bp-accordions { border-top: 1px solid #eee; }
  .bp-accordion { border-bottom: 1px solid #eee; }
  .bp-accordion__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px;
    font-family: var(--bp-font);
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    list-style: none;
  }
  .bp-accordion__header::-webkit-details-marker { display: none; }
  .bp-accordion__header::marker { content: ''; }
  .bp-accordion__icon {
    font-size: 18px;
    font-weight: 400;
    line-height: 1;
  }
  .bp-accordion__body {
    padding: 0 16px 16px;
    font-size: 14px;
    line-height: 1.6;
    color: #444;
  }
  .bp-accordion__body ul { margin: 8px 0; padding-left: 20px; }
  .bp-accordion__body li { margin-bottom: 4px; }

  /* Hide desktop-only accordions on mobile */
  .bp-accordion--desktop-only { display: none; }

  /* ===== Desktop layout ===== */
  @media (min-width: 768px) {
    .bp-section {
      width: 100%;
      max-width: 3000px;
      box-sizing: border-box;
      display: grid;
      grid-template-columns: 70px 1fr 1fr;
      grid-auto-rows: min-content;
      margin: 0 auto;
      padding: 20px 50px;
      gap: 0 24px;
    }

    /* Thumbnails — vertical strip on far left */
    .bp-thumbs {
      grid-column: 1;
      grid-row: 1 / 100;
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding: 0;
      overflow-y: auto;
      overflow-x: hidden;
      scrollbar-width: none;
      position: sticky;
      top: 20px;
      max-height: calc(100vh - 40px);
    }

    /* Hero — middle column */
    .bp-hero {
      grid-column: 2;
      grid-row: 1 / 100;
    }
    .bp-thumbs::-webkit-scrollbar { display: none; }
    .bp-thumb {
      width: 60px;
      height: 60px;
    }
    .bp-thumb--hidden {
      display: none;
    }
    .bp-thumb--more {
      display: flex;
      align-items: center;
      justify-content: center;
      background: #f0f0f0;
      border: 2px solid #ddd;
      opacity: 1;
    }
    .bp-thumb--more:hover {
      border-color: #000;
    }
    .bp-thumb-dots {
      font-size: 20px;
      font-weight: 900;
      color: #333;
      line-height: 1;
      letter-spacing: 2px;
    }

    /* Hero image — sticky */
    .bp-hero {
      position: sticky;
      top: 20px;
      width: 100%;
      margin-left: 0;
      border-radius: 10px;
      overflow: hidden;
      max-height: 95vh;
      border: 1px solid #eee;
    }
    .bp-hero__slide {
      aspect-ratio: 4 / 5;
      max-height: 95vh;
      max-width: calc(95vh * 4 / 5);
    }
    .bp-hero__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 10px;
      cursor: zoom-in;
      transition: transform 0.15s ease;
    }
    .bp-thumb {
      border-radius: 10px;
    }
    .bp-thumb img {
      border-radius: 8px;
    }
    .bp-thumb--more {
      border-radius: 10px;
    }
    .bp-hero__arrow {
      bottom: auto;
      top: 50%;
      transform: translateY(-50%);
      width: 36px;
      height: 36px;
      font-size: 28px;
      background: rgba(0,0,0,0.35);
      color: #fff;
      border-radius: 50%;
    }
    .bp-hero__arrow--prev { left: 12px; }
    .bp-hero__arrow--next { right: 12px; }

    /* Hide arrows when zoomed */
    .bp-hero--zoomed .bp-hero__arrow {
      display: none !important;
    }

    /* Right column — all product info elements */
    .bp-info,
    .bp-single-pair,
    .bp-sizes,
    .bp-cta {
      grid-column: 3;
      max-width: 608px;
    }
    .bp-section > hr.bp-divider {
      grid-column: 3;
      max-width: 608px !important;
    }

    /* Info spacing tweaks for desktop */
    .bp-info { padding: 100px 0 4px; grid-row-start: 1; }
    .bp-info__title { font-size: 28px; }
    .bp-info__price { font-size: 20px; }

    /* Single pair spacing */
    .bp-single-pair { padding: 0 0 8px; }
    .bp-divider { margin: 4px 0 8px; }

    /* Swatch images slightly larger on desktop */
    .bp-pair__swatch { width: 70px; height: 70px; }

    /* Sizes */
    .bp-sizes { padding: 8px 0 12px; }

    /* CTA */
    .bp-cta { padding: 8px 0 16px; }
    .bp-cta__atc, .bp-cta__buy { max-width: 608px; }

    /* Full-width bottom sections */
    .bp-ctl { grid-column: 3; max-width: 608px; }
    .bp-accordions { grid-column: 3; max-width: 608px; }
    .bp-accordion--desktop-only { display: block; }
  }

  /* Hide non-essential sections on desktop */
  @media (min-width: 768px) {
    #shopify-section-section_custom_code_8iXcJk,
    #shopify-section-section_custom_code_rdCKhc,
    #shopify-section-section_custom_code_dTApjA,
    #shopify-section-related,
    #shopify-section-section_recent_products_AzTTN9 {
      display: none !important;
    }
  }

  @media only screen and (min-width: 992px) {
    #judgeme_product_reviews {
      width: calc(100vw - 100px) !important;
      max-width: 3000px !important;
      padding-left: 50px;
    }
    .wrapper--full-padded {
      padding-left: 50px !important;
    }
    .rc-hero-mini {
      display: none !important;
    }
  }
</style>

