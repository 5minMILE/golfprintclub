<!-- /sections/section-comparison.liquid -->
{%- style -%}
  #Comparison--{{ section.id }} {
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;900&display=swap" rel="stylesheet">

<style>
  #Comparison--{{ section.id }} {
    padding-top: var(--PT);
    padding-bottom: var(--PB);
  }
  #Comparison--{{ section.id }} .comparison__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  #Comparison--{{ section.id }} .comparison__heading {
    font-family: 'Montserrat', sans-serif;
    font-size: 18px;
    font-weight: 1000;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1.2;
    text-align: center;
    margin-bottom: 16px;
  }
  #Comparison--{{ section.id }} .comparison__table {
    border: 1px solid #E0E0E0;
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
  }
  #Comparison--{{ section.id }} .comparison__header {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    padding: 10px 16px;
    background: #FAFAFA;
    border-bottom: 1px solid #E0E0E0;
  }
  #Comparison--{{ section.id }} .comparison__header-rc {
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    font-weight: 1000;
    text-transform: uppercase;
    line-height: 1.2;
    color: #1B5E20;
    text-align: center;
  }
  #Comparison--{{ section.id }} .comparison__header-them {
    font-family: 'Montserrat', sans-serif;
    font-size: 9px;
    font-weight: 600;
    color: #999;
    text-align: center;
    line-height: 1.4;
  }
  #Comparison--{{ section.id }} .comparison__row {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    padding: 9px 16px;
    border-bottom: 1px solid #f0f0f0;
    align-items: center;
  }
  #Comparison--{{ section.id }} .comparison__row:last-child {
    border-bottom: none;
  }
  #Comparison--{{ section.id }} .comparison__feature {
    font-family: 'Montserrat', sans-serif;
    font-size: 9px;
    font-weight: 600;
    color: #333;
    line-height: 1.4;
  }
  #Comparison--{{ section.id }} .comparison__us {
    font-family: 'Montserrat', sans-serif;
    font-size: 9px;
    font-weight: 600;
    color: #1B5E20;
    text-align: center;
    line-height: 1.4;
  }
  #Comparison--{{ section.id }} .comparison__them {
    font-family: 'Montserrat', sans-serif;
    font-size: 9px;
    font-weight: 600;
    color: #999;
    text-align: center;
    line-height: 1.4;
  }
  @media (max-width: 749px) {
    #Comparison--{{ section.id }} .comparison__inner {
      padding: 0 16px;
    }
    #Comparison--{{ section.id }} .comparison__heading {
      font-size: 15px;
      margin-bottom: 10px;
    }
    #Comparison--{{ section.id }} .comparison__header {
      grid-template-columns: 1.4fr 1fr 1fr;
      padding: 8px 10px;
    }
    #Comparison--{{ section.id }} .comparison__header-rc {
      font-size: 8px;
    }
    #Comparison--{{ section.id }} .comparison__header-them {
      font-size: 7px;
    }
    #Comparison--{{ section.id }} .comparison__row {
      grid-template-columns: 1.4fr 1fr 1fr;
      padding: 7px 10px;
    }
    #Comparison--{{ section.id }} .comparison__feature,
    #Comparison--{{ section.id }} .comparison__us,
    #Comparison--{{ section.id }} .comparison__them {
      font-size: 8px;
    }
  }
</style>

<section id="Comparison--{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="comparison">
  <div class="comparison__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="comparison__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="comparison__table">
      <div class="comparison__header">
        <span></span>
        <span class="comparison__header-rc">Golf Print Club</span>
        <span class="comparison__header-them">Big Brands</span>
      </div>
      {%- for block in section.blocks -%}
        <div class="comparison__row" {{ block.shopify_attributes }}>
          <span class="comparison__feature">{{ block.settings.feature }}</span>
          <span class="comparison__us">{{ block.settings.us }}</span>
          <span class="comparison__them">{{ block.settings.them }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Comparison Table",
  "max_blocks": 10,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Golfers Switch to Us"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Row",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Feature",
          "default": "Feature"
        },
        {
          "type": "text",
          "id": "us",
          "label": "Golf Print Club value",
          "default": "✓"
        },
        {
          "type": "text",
          "id": "them",
          "label": "Big Brands value",
          "default": "✗"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comparison Table",
      "category": "Text",
      "blocks": [
        {
          "type": "row",
          "settings": {
            "feature": "Price",
            "us": "$60",
            "them": "$90-120"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "Real Compression",
            "us": "✓",
            "them": "Marketing only"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "No Ride Up Guarantee",
            "us": "✓",
            "them": "✗"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "No Bounce Phone Pocket",
            "us": "✓",
            "them": "✗"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "Designed by a Golfer",
            "us": "✓",
            "them": "Corporate team"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "Free US Shipping",
            "us": "$125+",
            "them": "$200+"
          }
        }
      ]
    }
  ]
}
{% endschema %}
