    color: #000;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .bp-info__price-compare {
    text-decoration: line-through;
    color: #999;
    font-weight: 600;
  }
  .bp-info__price-sale {
    color: #c00;
    font-weight: 900;
  }
  .bp-info__price-current {
    color: #000;
    font-weight: 900;
  }

  /* Toggle */
  .bp-toggle { display: flex; gap: 8px; padding: 12px 16px; }
  .bp-toggle__tab {
    flex: 1;
    padding: 12px 8px;
    border: 2px solid #ddd;
    border-radius: 6px;
    background: #fff;
    cursor: pointer;
    text-align: center;
    transition: border-color .15s, background .15s;
  }
  .bp-toggle__tab--active {
    border-color: #000;
    background: #000;
    color: #fff;
  }
  .bp-toggle__tab-label {
    display: block;
    font-family: var(--bp-font);
    font-size: 14px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .bp-toggle__tab-sub {
    display: block;
    font-size: 11px;
    margin-top: 2px;
    opacity: 0.7;
  }
  .bp-toggle__tab--active .bp-toggle__tab-sub { opacity: 1; color: #fff; }

  /* Pair selectors */
  .bp-pairs, .bp-single-pair { padding: 0 16px 8px; }
  .bp-pair { margin-bottom: 12px; }
  .bp-pair__label {
    font-family: var(--bp-font);
