    padding: 10px 16px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .bp-thumbs::-webkit-scrollbar { display: none; }
  .bp-thumb {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    border-radius: 0;
    border: 2px solid transparent;
    padding: 0;
    cursor: pointer;
    background: #f5f5f5;
