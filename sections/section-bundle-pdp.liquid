<script>
if('scrollRestoration' in history) history.scrollRestoration='manual';
window.scrollTo(0,0);
document.addEventListener('DOMContentLoaded', function() { window.scrollTo(0,0); });
window.addEventListener('load', function() { window.scrollTo(0,0); });
</script>
{%- liquid
  assign bp_product = product
  assign bp_colors = ''
  assign bp_sizes = ''

  for option in bp_product.options_with_values
    if option.position == 1
      for val in option.values
        if bp_colors == ''
          assign bp_colors = val
        else
          assign bp_colors = bp_colors | append: '|||' | append: val
        endif
      endfor
    elsif option.position == 2
      for val in option.values
        if bp_sizes == ''
          assign bp_sizes = val
        else
          assign bp_sizes = bp_sizes | append: '|||' | append: val
        endif
      endfor
    endif
  endfor

  assign bp_color_arr = bp_colors | split: '|||'
  assign bp_size_arr = bp_sizes | split: '|||'

  assign bp_single_price = bp_product.price
  assign bp_bundle_price = bp_single_price | times: 3
-%}

{%- comment -%} Build color → array of image URLs mapping for slider {%- endcomment -%}
{%- comment -%} All-3 images (used in single mode) {%- endcomment -%}
{%- capture bp_all3_images_json -%}
[
  {%- assign all3_count = 0 -%}
  {%- for img in bp_product.images -%}
    {%- assign img_alt_tok = img.alt | strip | split: ' ' | first -%}
    {%- assign img_alt_first_down = img_alt_tok | downcase -%}
    {%- assign img_alt_first_handle = img_alt_tok | handleize -%}
    {%- if img_alt_first_down == 'all-3' or img_alt_first_handle == 'all-3' -%}
      {%- if all3_count > 0 -%},{%- endif -%}
      {{ img | image_url: width: 900 | json }}
      {%- assign all3_count = all3_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
]
{%- endcapture -%}
{%- comment -%} Single-mode color images: broad color- prefix matching {%- endcomment -%}
{%- capture bp_single_color_images_json -%}
{
  {%- for color in bp_color_arr -%}
    {%- assign color_handle = color | handleize -%}
    {%- assign color_lower = color | downcase -%}
    {% unless forloop.first %},{% endunless %}
    {{ color | json }}: [
      {%- assign img_count = 0 -%}
      {%- for img in bp_product.images -%}
        {%- assign img_alt_down = img.alt | downcase -%}
        {%- assign img_alt_handle = img.alt | handleize -%}
        {%- assign color_prefix_lower = color_lower | append: '-' -%}
        {%- assign color_prefix_handle = color_handle | append: '-' -%}
        {%- if img_alt_down contains color_prefix_lower or img_alt_handle contains color_prefix_handle -%}
          {%- if img_count > 0 -%},{%- endif -%}
          {{ img | image_url: width: 900 | json }}
          {%- assign img_count = img_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if img_count == 0 -%}
        {%- for v in bp_product.variants -%}
          {%- assign v_color = v.option1 | downcase -%}
          {%- if v_color == color_lower and v.featured_image -%}
            {{ v.featured_image | image_url: width: 900 | json }}
            {%- assign img_count = img_count | plus: 1 -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
      {%- if img_count == 0 -%}
        {{ bp_product.featured_image | image_url: width: 900 | json }}
      {%- endif -%}
    ]
  {%- endfor -%}
}
{%- endcapture -%}
{%- comment -%} Poster hero: per-color images WITH alt, so the JS can order them and drop up-close shots {%- endcomment -%}
{%- capture bp_single_color_meta_json -%}
{
  {%- for color in bp_color_arr -%}
    {%- assign color_handle = color | handleize -%}
    {%- assign color_lower = color | downcase -%}
    {% unless forloop.first %},{% endunless %}
    {{ color | json }}: [
      {%- assign m_count = 0 -%}
      {%- for img in bp_product.images -%}
        {%- assign a_down = img.alt | downcase -%}
        {%- assign a_handle = img.alt | handleize -%}
        {%- assign cp_lower = color_lower | append: '-' -%}
        {%- assign cp_handle = color_handle | append: '-' -%}
        {%- if a_down contains cp_lower or a_handle contains cp_handle -%}
          {%- if m_count > 0 -%},{%- endif -%}
          {"a":{{ a_down | json }},"u":{{ img | image_url: width: 900 | json }}}
          {%- assign m_count = m_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    ]
  {%- endfor -%}
}
{%- endcapture -%}
{%- comment -%} Universal lifestyle images (alt: life-N) — shown for every color in the hero {%- endcomment -%}
{%- capture bp_life_images_json -%}
[
  {%- assign life_count = 0 -%}
  {%- for img in bp_product.images -%}
    {%- assign a_down = img.alt | downcase -%}
    {%- if a_down contains 'life-' -%}
      {%- if life_count > 0 -%},{%- endif -%}
      {"a":{{ a_down | json }},"u":{{ img | image_url: width: 900 | json }}}
      {%- assign life_count = life_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
]
{%- endcapture -%}
{%- capture bp_color_images_json -%}
{
  {%- for color in bp_color_arr -%}
    {%- assign color_handle = color | handleize -%}
    {%- assign color_lower = color | downcase -%}
    {% unless forloop.first %},{% endunless %}
    {{ color | json }}: [
      {%- assign img_count = 0 -%}
      {%- for img in bp_product.images -%}
        {%- assign img_alt_down = img.alt | downcase -%}
        {%- assign img_alt_handle = img.alt | handleize -%}
        {%- assign match = false -%}
        {%- if section.settings.single_only -%}
          {%- assign color_prefix_lower = color_lower | append: '-' -%}
          {%- assign color_prefix_handle = color_handle | append: '-' -%}
          {%- if img_alt_down contains color_prefix_lower or img_alt_handle contains color_prefix_handle -%}
            {%- assign match = true -%}
          {%- endif -%}
        {%- else -%}
          {%- assign alt_1 = color_lower | append: '-1' -%}
          {%- assign alt_2 = color_lower | append: '-2' -%}
          {%- assign alt_3 = color_lower | append: '-3' -%}
          {%- assign handle_1 = color_handle | append: '-1' -%}
          {%- assign handle_2 = color_handle | append: '-2' -%}
          {%- assign handle_3 = color_handle | append: '-3' -%}
          {%- assign img_alt_tok = img.alt | strip | split: ' ' | first -%}
          {%- assign img_alt_first_down = img_alt_tok | downcase -%}
          {%- assign img_alt_first_handle = img_alt_tok | handleize -%}
          {%- if img_alt_first_down == alt_3 or img_alt_first_handle == handle_3
              or img_alt_first_down == alt_1 or img_alt_first_handle == handle_1
              or img_alt_first_down == alt_2 or img_alt_first_handle == handle_2 -%}
            {%- assign match = true -%}
          {%- endif -%}
        {%- endif -%}
        {%- if match -%}
          {%- if img_count > 0 -%},{%- endif -%}
          {{ img | image_url: width: 900 | json }}
          {%- assign img_count = img_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if img_count == 0 -%}
        {%- comment -%} Fallback: try variant featured_image {%- endcomment -%}
        {%- for v in bp_product.variants -%}
          {%- assign v_color = v.option1 | downcase -%}
          {%- if v_color == color_lower and v.featured_image -%}
            {%- if img_count > 0 -%},{%- endif -%}
            {{ v.featured_image | image_url: width: 900 | json }}
            {%- assign img_count = img_count | plus: 1 -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
      {%- if img_count == 0 -%}
        {{ bp_product.featured_image | image_url: width: 900 | json }}
      {%- endif -%}
    ]
  {%- endfor -%}
}
{%- endcapture -%}

{%- comment -%} Hidden inventory map for backorder tagging script {%- endcomment -%}
<div class="product__block variant__countdown" style="display:none!important">
  <script data-product-remaining-json type="application/json">
  {
    {%- for variant in bp_product.variants -%}
      {%- assign bp_remaining = 'in' -%}
      {%- if variant.inventory_management -%}
        {%- if variant.inventory_quantity > 0 -%}
          {%- assign bp_remaining = 'in' -%}
        {%- elsif variant.inventory_policy == 'continue' -%}
          {%- assign bp_remaining = 'unavailable' -%}
        {%- else -%}
          {%- assign bp_remaining = 'out' -%}
        {%- endif -%}
      {%- endif -%}
      {{ variant.id | json }}: {{ bp_remaining | json }}{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  }
  </script>
</div>

<!-- Hero Image Slider -->
<div class="bp-section" id="bp-section-{{ section.id }}">
  <div class="bp-hero" id="bp-hero">
    {%- comment -%} Best Seller badge — hidden on poster templates per request, kept intact for other templates and easy re-enable (just remove the unless). {%- endcomment -%}
    {%- unless template.suffix contains 'poster' or template.suffix == 'graphic-tee-2' -%}<span class="bp-hero__badge">Best Seller</span>{%- endunless -%}
    {%- comment -%} Urgency pill moved below the thumbnails into .bp-info (see .bp-urgency). {%- endcomment -%}
    <div class="bp-hero__track" id="bp-hero-track">
      {%- assign first_color = bp_color_arr[0] -%}
      {%- assign first_color_lower = first_color | downcase -%}
      {%- assign first_color_handle = first_color | handleize -%}
      {%- assign slide_count = 0 -%}
      {%- comment -%} For single_only: render all-3 images once at the front {%- endcomment -%}
      {%- if section.settings.single_only -%}
        {%- for img in bp_product.images -%}
          {%- assign img_alt_down = img.alt | downcase -%}
          {%- assign img_alt_handle = img.alt | handleize -%}
          {%- assign img_alt_tok = img.alt | strip | split: ' ' | first -%}
          {%- assign img_alt_first_down = img_alt_tok | downcase -%}
          {%- assign img_alt_first_handle = img_alt_tok | handleize -%}
          {%- if img_alt_first_down == 'all-3' or img_alt_first_handle == 'all-3' -%}
          <div class="bp-hero__slide">
            <img class="bp-hero__img"
                 src="{{ img | image_url: width: 900 }}"
                 alt="{{ img.alt | default: bp_product.title | escape }}"
                 width="900" height="900"
                 loading="{% if slide_count == 0 %}eager{% else %}lazy{% endif %}">
          </div>
          {%- assign slide_count = slide_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
      {%- for color in bp_color_arr -%}
        {%- assign ic_lower = color | downcase -%}
        {%- assign ic_handle = color | handleize -%}
        {%- for img in bp_product.images -%}
          {%- assign img_alt_down = img.alt | downcase -%}
          {%- assign img_alt_handle = img.alt | handleize -%}
          {%- assign match = false -%}
          {%- if section.settings.single_only -%}
            {%- assign ic_prefix_lower = ic_lower | append: '-' -%}
            {%- assign ic_prefix_handle = ic_handle | append: '-' -%}
            {%- if img_alt_down contains ic_prefix_lower or img_alt_handle contains ic_prefix_handle -%}
              {%- assign match = true -%}
            {%- endif -%}
            {%- comment -%} up-close shots are below-the-fold only — keep them out of the hero {%- endcomment -%}
            {%- if img_alt_down contains 'upclose' -%}
              {%- assign match = false -%}
            {%- endif -%}
          {%- else -%}
            {%- assign ic_1 = ic_lower | append: '-1' -%}
            {%- assign ic_2 = ic_lower | append: '-2' -%}
            {%- assign ic_3 = ic_lower | append: '-3' -%}
            {%- assign ih_1 = ic_handle | append: '-1' -%}
            {%- assign ih_2 = ic_handle | append: '-2' -%}
            {%- assign ih_3 = ic_handle | append: '-3' -%}
            {%- assign img_alt_tok = img.alt | strip | split: ' ' | first -%}
            {%- assign img_alt_first_down = img_alt_tok | downcase -%}
            {%- assign img_alt_first_handle = img_alt_tok | handleize -%}
            {%- if img_alt_first_down == ic_3 or img_alt_first_handle == ih_3
                or img_alt_first_down == ic_1 or img_alt_first_handle == ih_1
                or img_alt_first_down == ic_2 or img_alt_first_handle == ih_2 -%}
              {%- assign match = true -%}
            {%- endif -%}
          {%- endif -%}
          {%- if match -%}
          <div class="bp-hero__slide">
            <img class="bp-hero__img"
                 src="{{ img | image_url: width: 900 }}"
                 alt="{{ img.alt | default: bp_product.title | escape }}"
                 width="900" height="900"
                 loading="{% if slide_count == 0 %}eager{% else %}lazy{% endif %}">
          </div>
          {%- assign slide_count = slide_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endfor -%}
      {%- if slide_count == 0 -%}
        <div class="bp-hero__slide">
          <img class="bp-hero__img"
               src="{{ bp_product.featured_image | image_url: width: 900 }}"
               alt="{{ bp_product.title | escape }}"
               width="900" height="900"
               loading="eager">
        </div>
        {%- assign slide_count = 1 -%}
      {%- endif -%}
    </div>
    <!-- Slider arrows -->
    <button class="bp-hero__arrow bp-hero__arrow--prev" type="button" id="bp-hero-prev" aria-label="Previous">&#8249;</button>
    <button class="bp-hero__arrow bp-hero__arrow--next" type="button" id="bp-hero-next" aria-label="Next">&#8250;</button>
    <!-- Zoom button -->
    <button class="bp-hero__zoom" type="button" id="bp-hero-zoom" aria-label="Zoom in">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
    </button>
  </div>
  <!-- Thumbnail strip -->
  <div class="bp-thumbs" id="bp-thumbs"></div>

  <!-- Lightbox popup -->
  <div class="bp-lightbox" id="bp-lightbox" hidden>
    <div class="bp-lightbox__header">
      <span class="bp-lightbox__counter" id="bp-lb-counter"></span>
      <button class="bp-lightbox__close" type="button" id="bp-lb-close" aria-label="Close">&times;</button>
    </div>
    <div class="bp-lightbox__track" id="bp-lb-track"></div>
    <div class="bp-lightbox__nav">
      <button class="bp-lightbox__arrow" type="button" id="bp-lb-prev" aria-label="Previous">&#8249;</button>
      <button class="bp-lightbox__arrow" type="button" id="bp-lb-next" aria-label="Next">&#8250;</button>
    </div>
  </div>

  <!-- Product Info -->
  <div class="bp-info">
    {%- if template.suffix contains 'poster' or template.suffix == 'graphic-tee-2' -%}
    {%- comment -%} Urgency pill — below the thumbnails, above the title, centered. View count is a PLACEHOLDER (see JS near the delivery line). {%- endcomment -%}
    <div class="bp-urgency" aria-hidden="true">
      <span class="bp-urgency__pill">
        <span class="bp-hero__pill-dot"></span>
        <span class="bp-hero__pill-text"><span id="bp-view-count">27</span> viewed in the last 24 hours</span>
      </span>
    </div>
    {%- endif -%}
    <h1 class="bp-info__title">{% if section.settings.custom_title != blank %}{{ section.settings.custom_title }}{% else %}{{ bp_product.title }}{% endif %}</h1>
    <div class="bp-info__rating">
      {%- assign jm_badge = bp_product.metafields.judgeme.badge.value | default: '' -%}
      {%- assign jm_count = jm_badge | split: "data-number-of-reviews='" | last | split: "'" | first -%}
      {%- assign jm_rating = jm_badge | split: "data-average-rating='" | last | split: "'" | first -%}
      {%- if jm_count != blank and jm_count != '0' -%}
        <a href="#judgeme_product_reviews" class="bp-info__reviews-link" id="bp-reviews-link">
          <span class="bp-info__stars" id="bp-review-stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <span class="bp-info__rating-num">{{ jm_rating }}</span>
          <span class="bp-info__reviews-text" id="bp-review-count">({{ jm_count }} reviews)</span>
        </a>
      {%- endif -%}
    </div>
    <div class="bp-info__price" id="bp-active-price">
      {%- if section.settings.single_only -%}
        <span class="bp-info__price-current">{{ bp_single_price | money }}</span>
      {%- else -%}
        <span class="bp-info__price-compare">{{ bp_bundle_price | money }}</span>
        <span class="bp-info__price-sale">{{ section.settings.bundle_sale_price }}</span>
      {%- endif -%}
    </div>
  </div>

  {%- unless section.settings.single_only -%}
  <!-- 3-PACK / SINGLE Toggle -->
  <div class="bp-toggle">
    <button class="bp-toggle__tab bp-toggle__tab--active" type="button" data-mode="bundle">
      <span class="bp-toggle__tab-label">{{ section.settings.bundle_tab_label }}</span>
      <span class="bp-toggle__tab-sub">{{ section.settings.bundle_tab_sub }}</span>
    </button>
    <button class="bp-toggle__tab" type="button" data-mode="single">
      <span class="bp-toggle__tab-label">{{ section.settings.single_tab_label }}</span>
      <span class="bp-toggle__tab-sub">{{ section.settings.single_tab_sub }}</span>
    </button>
  </div>
  {%- endunless -%}

  {%- unless section.settings.single_only -%}
  <!-- Pair Selectors (bundle mode) -->
  <div class="bp-pairs" id="bp-pairs">
    {%- for i in (1..3) -%}
      {%- unless forloop.first -%}<hr class="bp-divider">{%- endunless -%}
      <div class="bp-pair" data-pair="{{ i }}">
        <div class="bp-pair__label">PAIR {{ i }}: <span class="bp-pair__selected-color" data-pair-color="{{ i }}">{% if forloop.first %}{{ bp_color_arr[0] }}{% else %}Select{% endif %}</span></div>
        <div class="bp-pair__swatches-wrap">
          <div class="bp-pair__swatches">
            {%- for color in bp_color_arr -%}
              {%- assign color_handle = color | handleize -%}
              {%- assign color_lower = color | downcase -%}
              {%- assign swatch_img = nil -%}
              {%- for img in bp_product.images -%}
                {%- assign img_alt_down = img.alt | downcase -%}
                {%- assign img_alt_handle = img.alt | handleize -%}
                {%- if img_alt_down == color_lower or img_alt_handle == color_handle -%}
                  {%- assign swatch_img = img -%}
                  {%- break -%}
                {%- endif -%}
                {%- assign alt_with_1 = color_lower | append: '-1' -%}
                {%- assign handle_with_1 = color_handle | append: '-1' -%}
                {%- if img_alt_down == alt_with_1 or img_alt_handle == handle_with_1 -%}
                  {%- assign swatch_img = img -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
              {%- unless swatch_img -%}
                {%- for v in bp_product.variants -%}
                  {%- assign v_color = v.option1 | downcase -%}
                  {%- if v_color == color_lower and v.featured_image -%}
                    {%- assign swatch_img = v.featured_image -%}
                    {%- break -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endunless -%}
              {%- unless swatch_img -%}
                {%- assign swatch_img = bp_product.featured_image -%}
              {%- endunless -%}
              <button class="bp-pair__swatch{% if i == 1 and forloop.first %} bp-pair__swatch--active{% endif %}"
                      type="button"
                      data-color="{{ color }}"
                      aria-label="{{ color }}">
                <img src="{{ swatch_img | image_url: width: 240 }}" alt="{{ color | escape }}" width="60" height="60" loading="lazy">
              </button>
            {%- endfor -%}
          </div>
          <button class="bp-pair__arrow bp-pair__arrow--left bp-pair__arrow--hidden" type="button" aria-label="Scroll back">&#8249;</button>
          <button class="bp-pair__arrow bp-pair__arrow--right" type="button" aria-label="Scroll for more">&#8250;</button>
        </div>
      </div>
    {%- endfor -%}
  </div>
  {%- endunless -%}

  <!-- Single color picker (single mode{% unless section.settings.single_only %}, hidden by default{% endunless %}) -->
  <div class="bp-single-pair" id="bp-single-pair" {% unless section.settings.single_only %}style="display:none;"{% endunless %}>
    <div class="bp-pair" data-pair="single">
      <div class="bp-pair__label">COLOR: <span class="bp-pair__selected-color" data-pair-color="single">{{ bp_color_arr[0] }}</span></div>
      <div class="bp-pair__swatches-wrap">
        <div class="bp-pair__swatches">
          {%- for color in bp_color_arr -%}
            {%- assign color_handle = color | handleize -%}
            {%- assign color_lower = color | downcase -%}
            {%- assign swatch_img = nil -%}
            {%- comment -%} Posters: use the -2 image (close-up of the poster design) for the color swatch {%- endcomment -%}
            {%- if section.settings.single_only -%}
              {%- comment -%} Apparel (tees): prefer the {color}-front image for the swatch; posters have no -front and fall through to {color}-2 {%- endcomment -%}
              {%- assign alt_with_front = color_lower | append: '-front' -%}
              {%- assign handle_with_front = color_handle | append: '-front' -%}
              {%- for img in bp_product.images -%}
                {%- assign img_alt_down = img.alt | downcase -%}
                {%- assign img_alt_handle = img.alt | handleize -%}
                {%- if img_alt_down == alt_with_front or img_alt_handle == handle_with_front -%}
                  {%- assign swatch_img = img -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
              {%- unless swatch_img -%}
              {%- assign alt_with_2 = color_lower | append: '-2' -%}
              {%- assign handle_with_2 = color_handle | append: '-2' -%}
              {%- for img in bp_product.images -%}
                {%- assign img_alt_down = img.alt | downcase -%}
                {%- assign img_alt_handle = img.alt | handleize -%}
                {%- if img_alt_down == alt_with_2 or img_alt_handle == handle_with_2 -%}
                  {%- assign swatch_img = img -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
              {%- endunless -%}
            {%- endif -%}
            {%- unless swatch_img -%}
            {%- for img in bp_product.images -%}
              {%- assign img_alt_down = img.alt | downcase -%}
              {%- assign img_alt_handle = img.alt | handleize -%}
              {%- if img_alt_down == color_lower or img_alt_handle == color_handle -%}
                {%- assign swatch_img = img -%}
                {%- break -%}
              {%- endif -%}
              {%- assign alt_with_1 = color_lower | append: '-1' -%}
              {%- assign handle_with_1 = color_handle | append: '-1' -%}
              {%- if img_alt_down == alt_with_1 or img_alt_handle == handle_with_1 -%}
                {%- assign swatch_img = img -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            {%- endunless -%}
            {%- unless swatch_img -%}
              {%- for v in bp_product.variants -%}
                {%- assign v_color = v.option1 | downcase -%}
