    justify-content: center;
  }
  .bp-hero__arrow--prev { left: 12px; }
  .bp-hero__arrow--next { right: 12px; }
  .bp-hero__badge {
    position: absolute;
    top: 10px;
    left: 0;
    z-index: 3;
    background: #2E7D32;
    color: #fff;
    font-family: var(--bp-font);
