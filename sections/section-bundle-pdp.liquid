  }
  .bp-thumb:hover {
    opacity: 1;
  }

  /* Info */
  .bp-info { padding: 8px 16px 4px; }
  .bp-info__title {
    font-family: var(--bp-font);
    font-size: 22px;
    font-weight: 900;
    text-transform: uppercase;
    margin: 0 0 6px;
    line-height: 1.1;
  }
  .bp-info__rating { margin-bottom: 6px; display: flex; align-items: center; gap: 6px; }
  .bp-info__stars { color: #2E7D32; font-size: 16px; letter-spacing: 1px; }
  .bp-info__rating-num { font-size: 13px; color: #111; font-weight: 700; }
  .bp-info__reviews-text { font-size: 13px; color: #555; font-weight: 600; }
  .bp-info__reviews-link { text-decoration: none; color: inherit; display: flex; align-items: center; gap: 6px; }
  .bp-info__reviews-link:hover .bp-info__reviews-text { text-decoration: underline; }
  .bp-info__price {
