    <svg class="bp-guarantee__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
    <span class="bp-guarantee__text">{{ section.settings.guarantee_text | default: 'Free shipping on orders $100+ &bull; 30-day returns' }}</span>
  </div>
  {%- endunless -%}

  {%- if template.suffix contains 'poster' or template.suffix == 'graphic-tee-2' -%}
  <!-- Estimated delivery range — computed client-side as 5–8 business days from today -->
  <div class="bp-delivery" id="bp-delivery">
    <span>Estimated delivery <strong id="bp-eta-low">&mdash;</strong> to <strong id="bp-eta-high">&mdash;</strong></span>
  </div>
  <script>
  (function () {
    function addBiz(start, n) {
      var d = new Date(start), added = 0;
      while (added < n) { d.setDate(d.getDate() + 1); var w = d.getDay(); if (w !== 0 && w !== 6) added++; }
      return d;
    }
    function fmt(d) { return d.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' }); }
    var lo = document.getElementById('bp-eta-low'), hi = document.getElementById('bp-eta-high');
    if (lo && hi) { var now = new Date(); lo.textContent = fmt(addBiz(now, 5)); hi.textContent = fmt(addBiz(now, 8)); }

    // PLACEHOLDER social proof until real view analytics is wired (e.g. a 2–3 day-delayed real count).
    // Deterministic per-day value (stable within a day, rotates daily) so it isn't a static figure.
    var vc = document.getElementById('bp-view-count');
    if (vc) { var t = new Date(); var doy = Math.floor((t - new Date(t.getFullYear(), 0, 0)) / 86400000); vc.textContent = 22 + ((doy * 7 + t.getFullYear()) % 13); }
  })();
  </script>
  {%- endif -%}

  {%- if template.suffix contains 'poster' or template.suffix == 'graphic-tee-2' -%}
  <!-- Sticky add-to-cart bar — appears once the main Add-to-Cart scrolls out of view -->
  <div class="bp-sticky" id="bp-sticky" aria-hidden="true">
    <div class="bp-sticky__inner">
      <button class="bp-sticky__toggle" id="bp-sticky-toggle" type="button" aria-label="Collapse">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
      <div class="bp-sticky__top">
        <div class="bp-sticky__price" id="bp-sticky-price"></div>
        <div class="bp-sticky__sizes" id="bp-sticky-sizes"></div>
      </div>
      <div class="bp-pair__swatches-wrap bp-sticky__colors-wrap" id="bp-sticky-colors-wrap">
        <button class="bp-pair__arrow bp-pair__arrow--left bp-pair__arrow--hidden" id="bp-sticky-col-left" type="button" aria-label="Scroll colors left">&#8249;</button>
        <div class="bp-pair__swatches" id="bp-sticky-colors"></div>
        <button class="bp-pair__arrow bp-pair__arrow--right" id="bp-sticky-col-right" type="button" aria-label="Scroll colors right">&#8250;</button>
      </div>
      <button class="bp-cta__atc bp-sticky__atc" id="bp-sticky-atc" type="button">Add to Cart</button>
    </div>
  </div>
  <script>
  (function () {
    function setupSticky() {
    var sticky = document.getElementById('bp-sticky');
    var mainAtc = document.getElementById('bp-atc-btn');
    if (!sticky || !mainAtc) return;
    var sizesEl = document.getElementById('bp-sticky-sizes');
    var colorsEl = document.getElementById('bp-sticky-colors');
    var colorsWrap = document.getElementById('bp-sticky-colors-wrap');
    var priceEl = document.getElementById('bp-sticky-price');
    var mainPrice = document.getElementById('bp-active-price');
    var stickyAtc = document.getElementById('bp-sticky-atc');
    var toggle = document.getElementById('bp-sticky-toggle');
    var singlePair = document.getElementById('bp-single-pair');
    var mainSwatches = singlePair ? singlePair.querySelectorAll('.bp-pair__swatch') : [];
    var sizeBtns = document.querySelectorAll('.bp-sizes__grid .bp-sizes__btn');

    sizeBtns.forEach(function (b) {
      var clone = b.cloneNode(true);
      clone.addEventListener('click', function () {
        b.click();
        syncSticky();
      });
      sizesEl.appendChild(clone);
    });

    if (mainSwatches.length > 1 && colorsEl) {
      mainSwatches.forEach(function (sw) {
        var c = sw.getAttribute('data-color');
        var clone = sw.cloneNode(true);
        clone.removeAttribute('id');
        clone.addEventListener('click', function () {
          var orig = singlePair.querySelector('.bp-pair__swatch[data-color="' + c + '"]');
          if (orig) orig.click();
          syncSticky();
        });
        colorsEl.appendChild(clone);
      });
    } else if (colorsWrap) {
      colorsWrap.style.display = 'none';
    }

    function syncSticky() {
      if (priceEl) {
        var anySize = document.querySelector('.bp-sizes__grid .bp-sizes__btn--active');
        if (anySize && mainPrice) { priceEl.innerHTML = mainPrice.innerHTML; }
        else { {% if template.suffix == 'graphic-tee-2' %}if (mainPrice) { priceEl.innerHTML = mainPrice.innerHTML; } else { priceEl.textContent = 'Select size'; }{% else %}priceEl.textContent = 'Select size';{% endif %} }
      }
      if (singlePair && colorsEl) {
        var origSw = singlePair.querySelectorAll('.bp-pair__swatch');
        for (var i = 0; i < origSw.length; i++) {
          if (colorsEl.children[i]) colorsEl.children[i].classList.toggle('bp-pair__swatch--active', origSw[i].classList.contains('bp-pair__swatch--active'));
        }
      }
      var origSz = document.querySelectorAll('.bp-sizes__grid .bp-sizes__btn');
      for (var j = 0; j < origSz.length; j++) {
        if (sizesEl.children[j]) sizesEl.children[j].classList.toggle('bp-sizes__btn--active', origSz[j].classList.contains('bp-sizes__btn--active'));
      }
    }

    // Color scroll arrows + edge fades (mirrors the hero swatch behavior)
    var checkColArrows = function () {};
    if (colorsWrap && colorsEl) {
      var aL = colorsWrap.querySelector('.bp-pair__arrow--left');
      var aR = colorsWrap.querySelector('.bp-pair__arrow--right');
      checkColArrows = function () {
        var canScroll = colorsEl.scrollWidth > colorsEl.clientWidth + 2;
        var atStart = colorsEl.scrollLeft <= 2;
        var atEnd = colorsEl.scrollLeft + colorsEl.clientWidth >= colorsEl.scrollWidth - 2;
        if (aR) aR.classList.toggle('bp-pair__arrow--hidden', !canScroll || atEnd);
        if (aL) aL.classList.toggle('bp-pair__arrow--hidden', !canScroll || atStart);
        colorsWrap.classList.toggle('bp-pair__swatches-wrap--fade-right', canScroll && !atEnd);
        colorsWrap.classList.toggle('bp-pair__swatches-wrap--fade-left', canScroll && !atStart);
      };
      if (aR) aR.addEventListener('click', function () { colorsEl.scrollBy({ left: 160, behavior: 'smooth' }); });
      if (aL) aL.addEventListener('click', function () { colorsEl.scrollBy({ left: -160, behavior: 'smooth' }); });
      colorsEl.addEventListener('scroll', checkColArrows);
    }

    // Collapse / expand — hides sizes + colors, keeps Add to Cart.
    if (toggle) {
      toggle.addEventListener('click', function () {
        sticky.classList.toggle('bp-sticky--collapsed');
        if (!sticky.classList.contains('bp-sticky--collapsed')) setTimeout(checkColArrows, 60);
      });
    }

    stickyAtc.addEventListener('click', function () { mainAtc.click(); });

    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) {
        var e = entries[0];
        var show = !e.isIntersecting && e.boundingClientRect.top < 0;
        sticky.classList.toggle('is-visible', show);
        if (show) { syncSticky(); checkColArrows(); }
      }, { threshold: 0 });
      io.observe(mainAtc);
    }
    syncSticky();
    checkColArrows();
    setTimeout(checkColArrows, 400);
    }
    if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', setupSticky); }
    else { setupSticky(); }
  })();
  </script>
  {%- endif -%}

