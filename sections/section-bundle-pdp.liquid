<script>
  (function () {
    function initTestimonial(el) {
      var slides = el.querySelectorAll('.bp-testimonial__slide');
      var dotsWrap = el.querySelector('[data-bp-dots]');
      if (slides.length < 2 || !dotsWrap) return;
      var idx = 0, dots = [], timer;
      function go(n) {
        idx = n;
        for (var i = 0; i < slides.length; i++) {
          slides[i].classList.toggle('is-active', i === n);
          dots[i].classList.toggle('is-active', i === n);
        }
      }
      function restart() { clearInterval(timer); timer = setInterval(function () { go((idx + 1) % slides.length); }, 5000); }
      for (var i = 0; i < slides.length; i++) {
        var d = document.createElement('button');
        d.type = 'button';
        d.className = 'bp-testimonial__dot' + (i === 0 ? ' is-active' : '');
        d.setAttribute('aria-label', 'Review ' + (i + 1));
        (function (n) { d.addEventListener('click', function () { go(n); restart(); }); })(i);
        dotsWrap.appendChild(d);
        dots.push(d);
      }
      restart();
    }
    var nodes = document.querySelectorAll('[data-bp-testimonial]');
    for (var i = 0; i < nodes.length; i++) initTestimonial(nodes[i]);
  })();
</script>

{%- comment -%} Auto-hide the sticky header on scroll-down, return it on scroll-up. Posters + graphic tee only (gated). {%- endcomment -%}
{%- if template.suffix contains 'poster' or template.suffix == 'graphic-tee-2' -%}
<style>
  [data-header-wrapper].bp-header-autohide .theme__header { transition: transform .35s ease !important; will-change: transform; }
</style>
<script>
(function () {
  var wraps = document.querySelectorAll('[data-header-wrapper]');
  if (!wraps.length) return;
  var bars = [];
  for (var i = 0; i < wraps.length; i++) { wraps[i].classList.add('bp-header-autohide'); var b = wraps[i].querySelector('.theme__header'); if (b) bars.push(b); }
  if (!bars.length) return;
  /* Slide the header element itself (inline transform overrides the theme's own handling). */
  function setHidden(on) {
    for (var i = 0; i < bars.length; i++) {
      if (on) { bars[i].style.setProperty('transform', 'translateY(-200px)', 'important'); bars[i].style.pointerEvents = 'none'; }
      else { bars[i].style.removeProperty('transform'); bars[i].style.pointerEvents = ''; }
    }
  }
  var lastY = window.pageYOffset || document.documentElement.scrollTop || 0;
  var THRESH = 140, ticking = false;
  function update() {
    var y = window.pageYOffset || document.documentElement.scrollTop || 0;
    if (y <= THRESH) { setHidden(false); }            /* near the top: always show */
    else if (y > lastY + 4) { setHidden(true); }      /* scrolling down: hide */
    else if (y < lastY - 4) { setHidden(false); }     /* scrolling up: show */
    lastY = y; ticking = false;
  }
  window.addEventListener('scroll', function () { if (!ticking) { ticking = true; window.requestAnimationFrame(update); } }, { passive: true });
})();
</script>
{%- endif -%}

