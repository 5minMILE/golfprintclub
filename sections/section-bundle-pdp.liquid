{%- endif -%}

<!-- Variant data for JS -->
<script type="application/json" id="bp-variant-data">
[
  {%- for v in bp_product.variants -%}
    {% unless forloop.first %},{% endunless %}
    {"id":{{ v.id }},"option1":{{ v.option1 | json }},"option2":{{ v.option2 | json }},"available":{{ v.available }},"price":{{ v.price }}}
  {%- endfor -%}
]
</script>

<script type="application/json" id="bp-color-images">
{{ bp_color_images_json }}
</script>

<script type="application/json" id="bp-all3-images">
{{ bp_all3_images_json }}
</script>

<script type="application/json" id="bp-single-color-images">
{{ bp_single_color_images_json }}
</script>

<script type="application/json" id="bp-single-color-meta">
{{ bp_single_color_meta_json }}
</script>

<script type="application/json" id="bp-life-images">
{{ bp_life_images_json }}
</script>

<script>
(function() {
  var section = document.getElementById('bp-section-{{ section.id }}');
  if (!section) return;

  // Backorder inventory map
  var bpRemainingMap = {};
  try {
    var mapEl = document.querySelector('[data-product-remaining-json]');
    if (mapEl) bpRemainingMap = JSON.parse(mapEl.textContent.trim());
  } catch(e) {}
  function bpGetAvail(variantId) {
    return bpRemainingMap[String(variantId)] || null;
  }

  // Inject backorder messages into cart drawer after items render
  function bpInjectBackorderMessages() {
    var attempts = 0;
    var timer = setInterval(function() {
      attempts++;
      var wrap = document.getElementById('rcDevItems');
      if (!wrap) { if (attempts > 30) clearInterval(timer); return; }
      var lines = wrap.querySelectorAll('.rc-item');
      if (!lines.length) { if (attempts > 30) clearInterval(timer); return; }

      fetch('/cart.js', { credentials: 'same-origin', cache: 'no-store' })
        .then(function(r) { return r.json(); })
        .then(function(cart) {
          if (!cart || !cart.items) return;
          cart.items.forEach(function(item, idx) {
            var lineEl = lines[idx];
            if (!lineEl) return;
            // Remove existing backorder line
            var existing = lineEl.querySelector('.rc-backorder-line');
            if (existing) existing.remove();

            var avail = bpGetAvail(item.variant_id);
            if (avail === 'unavailable') {
              var el = document.createElement('div');
              el.className = 'rc-backorder-line';
              el.textContent = 'This item is currently on back order and may take 4\u20138 weeks to arrive.';
              el.style.cssText = 'margin-top:6px;font-size:12px;font-weight:950;color:#2E7D32;line-height:1.25;text-transform:uppercase;letter-spacing:.04em;';
              var variantRow = lineEl.querySelector('.rc-variant');
              if (variantRow) {
                variantRow.insertAdjacentElement('afterend', el);
              } else {
                var meta = lineEl.querySelector('.rc-meta');
                if (meta) meta.appendChild(el);
              }
            }
          });
        })
        .catch(function() {});
      clearInterval(timer);
    }, 300);
  }

  var variants = [];
  var colorImages = {};
  try {
    variants = JSON.parse(document.getElementById('bp-variant-data').textContent);
    colorImages = JSON.parse(document.getElementById('bp-color-images').textContent);
  } catch(e) { console.error('BP: Failed to parse variant data', e); }

  var singleOnly = {{ section.settings.single_only | json }};
  var mode = singleOnly ? 'single' : 'bundle';
  var pairColors = ['{{ bp_color_arr[0] | escape }}', null, null];
  var singleColor = '{{ bp_color_arr[0] | escape }}';
  var selectedSize = null;
  var bundlePrice = {{ bp_bundle_price }};
  var singlePrice = {{ bp_single_price }};
  var bundleTitle = {{ section.settings.custom_title | default: bp_product.title | json }};
  var singleTitle = bundleTitle.replace(/\s*\(3\s*pairs?\)\s*/i, '').replace(/\s*3[\s-]*pairs?\s*/i, '').replace(/\s*\(3\s*pack\)\s*/i, '').replace(/\s*3[\s-]*pack\s*/i, '');

  // --- Preload all hero images after page load ---
  function preloadAllImages() {
    Object.keys(colorImages).forEach(function(color) {
      var imgs = colorImages[color];
      if (!imgs) return;
      imgs.forEach(function(url) {
        var img = new Image();
        img.src = url;
      });
    });
  }
  if (document.readyState === 'complete') {
    preloadAllImages();
  } else {
    window.addEventListener('load', preloadAllImages);
  }

  // --- Build allBundleImages (all colors concatenated) + color start index map ---
  var allBundleImages = [];
  var colorStartIndex = {};
  var colorOrder = {{ bp_color_arr | json }};

  // All-3 images (used in single mode)
  var all3Images = [];
  try {
    var all3El = document.getElementById('bp-all3-images');
    if (all3El) all3Images = JSON.parse(all3El.textContent);
  } catch(e) {}

  // Single-mode color images (broad matching: color-front, color-back, color-1, etc.)
  var singleColorImages = {};
  try {
    singleColorImages = JSON.parse(document.getElementById('bp-single-color-images').textContent);
  } catch(e) {}

  // Poster hero composition: per-color images (with alt) + universal lifestyle images.
  // Order = color-1, color-2, life-1..N, color-3..; up-close shots excluded (those live below the fold).
  var singleColorMeta = {};
  try { singleColorMeta = JSON.parse(document.getElementById('bp-single-color-meta').textContent); } catch(e) {}
  var lifeImages = [];
  try { lifeImages = JSON.parse(document.getElementById('bp-life-images').textContent); } catch(e) {}
  // Standard poster sizing chart — appended to the end of the hero gallery for posters only (not per-product).
  var bpSizingImg = {% if template.suffix contains 'poster' %}'https://cdn.shopify.com/s/files/1/0772/2041/3736/files/sizing.png?v=1781806794&width=1000'{% else %}''{% endif %};
  function bpTrailNum(a) { var m = (a || '').match(/(\d+)\s*$/); return m ? parseInt(m[1], 10) : 9999; }
  // Order: numbered images first (1, 2, 3...), then front, then back, then the rest (4, 5...). Posters have no front/back, so they keep numeric order.
  function bpRank(a) { a = (a || '').toLowerCase(); if (a.indexOf('front') !== -1) return 3.5; if (a.indexOf('back') !== -1) return 3.6; return bpTrailNum(a); }
  function posterImagesForColor(color) {
    var raw = (singleColorMeta[color] || []).filter(function(o) { return (o.a || '').indexOf('upclose') === -1; });
    raw.sort(function(x, y) { return bpRank(x.a) - bpRank(y.a); });
    var life = (lifeImages || []).slice().sort(function(x, y) { return bpTrailNum(x.a) - bpTrailNum(y.a); });
    var out = [];
    if (raw[0]) out.push(raw[0].u);
    if (raw[1]) out.push(raw[1].u);
    life.forEach(function(o) { out.push(o.u); });
    for (var i = 2; i < raw.length; i++) out.push(raw[i].u);
    if (bpSizingImg) out.push(bpSizingImg);
    return out;
  }

  // Prepend all-3 images
  allBundleImages = allBundleImages.concat(all3Images);

  colorOrder.forEach(function(color) {
    var imgs = singleColorImages[color] || colorImages[color];
    if (imgs && imgs.length > 0) {
      colorStartIndex[color] = allBundleImages.length;
      allBundleImages = allBundleImages.concat(imgs);
    }
  });

  // --- Image Slider ---
  var currentSlide = 0;
  var track = document.getElementById('bp-hero-track');
  var thumbsContainer = document.getElementById('bp-thumbs');

  function buildSlider(images) {
    track.innerHTML = '';
    images.forEach(function(url, i) {
      var slide = document.createElement('div');
      slide.className = 'bp-hero__slide';
      var fitCls = (bpSizingImg && url === bpSizingImg) ? ' bp-hero__img--contain' : '';
      slide.innerHTML = '<img class="bp-hero__img' + fitCls + '" src="' + url + '" alt="' + ((bpSizingImg && url === bpSizingImg) ? 'Poster size comparison: 12x18, 16x24, 24x36 inches' : '') + '" width="900" height="900" loading="' + (i === 0 ? 'eager' : 'lazy') + '">';
      track.appendChild(slide);
    });
    thumbsContainer.innerHTML = '';
    var isDesktop = window.matchMedia('(min-width: 768px)').matches;
    var maxVisible = 5;
    var thumbsExpanded = false;
    images.forEach(function(url, i) {
      var thumb = document.createElement('button');
      thumb.className = 'bp-thumb' + (i === 0 ? ' bp-thumb--active' : '');
      if (isDesktop && i >= maxVisible) thumb.classList.add('bp-thumb--hidden');
      thumb.type = 'button';
      thumb.setAttribute('data-slide', i);
      thumb.setAttribute('aria-label', 'View image ' + (i + 1));
      var thumbUrl = url.replace(/width=\d+/, 'width=120');
      var thumbFit = (bpSizingImg && url === bpSizingImg) ? ' class="bp-thumb__img--contain"' : '';
      thumb.innerHTML = '<img' + thumbFit + ' src="' + thumbUrl + '" alt="" width="60" height="60" loading="lazy">';
      thumbsContainer.appendChild(thumb);
    });
    if (isDesktop && images.length > maxVisible) {
      var moreBtn = document.createElement('button');
      moreBtn.className = 'bp-thumb bp-thumb--more';
      moreBtn.type = 'button';
      moreBtn.setAttribute('aria-label', 'Show all thumbnails');
      moreBtn.innerHTML = '<span class="bp-thumb-dots">...</span>';
      thumbsContainer.appendChild(moreBtn);
      moreBtn.addEventListener('click', function() {
        thumbsContainer.querySelectorAll('.bp-thumb--hidden').forEach(function(t) {
          t.classList.remove('bp-thumb--hidden');
        });
        moreBtn.remove();
      });
    }
    currentSlide = 0;
    goToSlide(0);
  }

  var userInitiated = false;

  function goToSlide(idx) {
    var slides = track.querySelectorAll('.bp-hero__slide');
    if (slides.length === 0) return;
    if (idx < 0) idx = slides.length - 1;
    if (idx >= slides.length) idx = 0;
    currentSlide = idx;
    track.style.transform = 'translateX(-' + (idx * 100) + '%)';
    var thumbs = thumbsContainer.querySelectorAll('.bp-thumb');
    thumbs.forEach(function(t, i) {
      t.classList.toggle('bp-thumb--active', i === idx);
    });
    if (userInitiated && thumbs[idx]) {
      thumbs[idx].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }
  }

  document.getElementById('bp-hero-prev').addEventListener('click', function() { goToSlide(currentSlide - 1); });
  document.getElementById('bp-hero-next').addEventListener('click', function() { goToSlide(currentSlide + 1); });
  thumbsContainer.addEventListener('click', function(e) {
    var thumb = e.target.closest('.bp-thumb');
    if (thumb) goToSlide(parseInt(thumb.getAttribute('data-slide')));
  });

  // Touch/swipe support — lock to horizontal, ignore vertical scroll
  (function() {
    var hero = document.getElementById('bp-hero');
    var startX = 0, startY = 0, diffX = 0, diffY = 0, dragging = false, directionLocked = false, isHorizontal = false;
    hero.addEventListener('touchstart', function(e) {
      startX = e.touches[0].clientX;
      startY = e.touches[0].clientY;
      diffX = 0;
      diffY = 0;
      dragging = true;
      directionLocked = false;
      isHorizontal = false;
    }, { passive: true });
    hero.addEventListener('touchmove', function(e) {
      if (!dragging) return;
      diffX = e.touches[0].clientX - startX;
      diffY = e.touches[0].clientY - startY;
      if (!directionLocked) {
        directionLocked = true;
        isHorizontal = Math.abs(diffX) > Math.abs(diffY);
      }
      if (isHorizontal) {
        e.preventDefault();
      }
    }, { passive: false });
    hero.addEventListener('touchend', function() {
      if (!dragging) return;
      dragging = false;
      if (isHorizontal && Math.abs(diffX) > 50) {
        if (diffX < 0) goToSlide(currentSlide + 1);
        else goToSlide(currentSlide - 1);
      }
      diffX = 0;
      diffY = 0;
    });
  })();

  // --- Lightbox popup for image zoom ---
  (function() {
    var zoomBtn = document.getElementById('bp-hero-zoom');
    var lightbox = document.getElementById('bp-lightbox');
    var lbTrack = document.getElementById('bp-lb-track');
    var lbCounter = document.getElementById('bp-lb-counter');
    var lbClose = document.getElementById('bp-lb-close');
    var lbPrev = document.getElementById('bp-lb-prev');
    var lbNext = document.getElementById('bp-lb-next');
    if (!zoomBtn || !lightbox) return;

    var lbSlide = 0;
    var lbTotal = 0;
    var lbImages = [];

    function openLightbox() {
      // Grab current slider images
      lbImages = [];
      track.querySelectorAll('.bp-hero__img').forEach(function(img) {
        lbImages.push(img.src.replace(/width=\d+/, 'width=1600'));
      });
      if (lbImages.length === 0) return;
      lbTotal = lbImages.length;
      lbSlide = currentSlide;

      // Build lightbox slides
      lbTrack.innerHTML = '';
      lbImages.forEach(function(url) {
        var div = document.createElement('div');
        div.className = 'bp-lightbox__slide';
        div.innerHTML = '<img class="bp-lightbox__img" src="' + url + '" alt="" draggable="false">';
        lbTrack.appendChild(div);
      });

      updateLb();
      lightbox.hidden = false;
      document.documentElement.style.overflow = 'hidden';
      document.body.style.overflow = 'hidden';
      document.body.style.position = 'fixed';
      document.body.style.width = '100%';
      document.body.style.top = '-' + window.scrollY + 'px';
    }

    function closeLightbox() {
      var scrollY = Math.abs(parseInt(document.body.style.top || '0'));
      lightbox.hidden = true;
      document.documentElement.style.overflow = '';
      document.body.style.overflow = '';
      document.body.style.position = '';
      document.body.style.width = '';
      document.body.style.top = '';
      window.scrollTo(0, scrollY);
    }

    function updateLb() {
      lbTrack.style.transform = 'translateX(-' + (lbSlide * 100) + '%)';
      lbCounter.textContent = (lbSlide + 1) + ' / ' + lbTotal;
    }

    function lbGo(dir) {
      lbSlide += dir;
      if (lbSlide < 0) lbSlide = lbTotal - 1;
      if (lbSlide >= lbTotal) lbSlide = 0;
      updateLb();
    }

    zoomBtn.addEventListener('click', function(e) { e.stopPropagation(); openLightbox(); });
    lbClose.addEventListener('click', closeLightbox);
    lbPrev.addEventListener('click', function() { lbGo(-1); });
    lbNext.addEventListener('click', function() { lbGo(1); });

    // Close on backdrop click
    lightbox.addEventListener('click', function(e) {
      if (e.target === lightbox) closeLightbox();
    });

    // Keyboard
    document.addEventListener('keydown', function(e) {
      if (lightbox.hidden) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') lbGo(-1);
      if (e.key === 'ArrowRight') lbGo(1);
    });

    // Check if user has pinch-zoomed
    function isZoomed() {
      return window.visualViewport && window.visualViewport.scale > 1.05;
    }

    // Touch swipe in lightbox — only when not zoomed in
    var lbStartX = 0, lbDiffX = 0, lbTouches = 0, lbZoomedAtStart = false;
    lbTrack.addEventListener('touchstart', function(e) {
      lbTouches = e.touches.length;
      lbZoomedAtStart = isZoomed();
      if (lbTouches === 1 && !lbZoomedAtStart) {
        lbStartX = e.touches[0].clientX;
        lbDiffX = 0;
      }
    }, { passive: true });
    lbTrack.addEventListener('touchmove', function(e) {
      if (isZoomed() || lbZoomedAtStart) return;
      if (e.touches.length > 1) { lbTouches = 2; return; }
      if (lbTouches > 1) return;
      lbDiffX = e.touches[0].clientX - lbStartX;
      e.preventDefault();
    }, { passive: false });
    lbTrack.addEventListener('touchend', function() {
      if (!lbZoomedAtStart && !isZoomed() && lbTouches === 1 && Math.abs(lbDiffX) > 50) {
        if (lbDiffX < 0) lbGo(1);
        else lbGo(-1);
      }
      lbDiffX = 0;
      lbTouches = 0;
      lbZoomedAtStart = false;
    });

    // Prevent scroll behind lightbox only when not zoomed
    lightbox.addEventListener('touchmove', function(e) {
      if (!isZoomed() && e.touches.length < 2) e.preventDefault();
    }, { passive: false });

  })();

  // --- Desktop click-to-zoom on hero images ---
  (function() {
    var hero = document.getElementById('bp-hero');
    if (!window.matchMedia('(min-width: 768px)').matches) return;

    var zoomed = false;

    hero.addEventListener('click', function(e) {
      if (e.target.closest('.bp-hero__arrow') || e.target.closest('.bp-hero__zoom')) return;
      var slide = track.querySelectorAll('.bp-hero__slide')[currentSlide];
      if (!slide) return;
      var img = slide.querySelector('.bp-hero__img');
      if (!img) return;

      if (zoomed) {
        img.style.transform = '';
        img.style.transformOrigin = '';
        hero.classList.remove('bp-hero--zoomed');
        zoomed = false;
      } else {
        var rect = hero.getBoundingClientRect();
        var x = ((e.clientX - rect.left) / rect.width * 100).toFixed(2);
        var y = ((e.clientY - rect.top) / rect.height * 100).toFixed(2);
        img.style.transformOrigin = x + '% ' + y + '%';
        img.style.transform = 'scale(2)';
        hero.classList.add('bp-hero--zoomed');
        zoomed = true;
      }
    });

    hero.addEventListener('mousemove', function(e) {
      if (!zoomed) return;
      var slide = track.querySelectorAll('.bp-hero__slide')[currentSlide];
      if (!slide) return;
      var img = slide.querySelector('.bp-hero__img');
      if (!img) return;
      var rect = hero.getBoundingClientRect();
      var x = ((e.clientX - rect.left) / rect.width * 100).toFixed(2);
      var y = ((e.clientY - rect.top) / rect.height * 100).toFixed(2);
      img.style.transformOrigin = x + '% ' + y + '%';
    });

    hero.addEventListener('mouseleave', function() {
      if (!zoomed) return;
      var imgs = track.querySelectorAll('.bp-hero__img');
      imgs.forEach(function(img) {
        img.style.transform = '';
        img.style.transformOrigin = '';
      });
      hero.classList.remove('bp-hero--zoomed');
      zoomed = false;
    });
  })();

  // --- Build initial slider (all images for bundle mode) ---
  updateSliderForColor();
  userInitiated = true;

  // --- Toggle tabs ---
  section.querySelectorAll('.bp-toggle__tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      mode = tab.getAttribute('data-mode');
      section.querySelectorAll('.bp-toggle__tab').forEach(function(t) {
        t.classList.remove('bp-toggle__tab--active');
      });
      tab.classList.add('bp-toggle__tab--active');
      updateMode();
    });
  });

  function formatMoney(cents) {
    return '$' + (cents / 100).toFixed(2).replace(/\.00$/, '');
  }

  var bpPriceMin = singlePrice, bpPriceMax = singlePrice;
  if (variants && variants.length) {
    bpPriceMin = variants[0].price; bpPriceMax = variants[0].price;
    for (var _pi = 0; _pi < variants.length; _pi++) {
      if (variants[_pi].price < bpPriceMin) bpPriceMin = variants[_pi].price;
      if (variants[_pi].price > bpPriceMax) bpPriceMax = variants[_pi].price;
    }
  }
  function updatePrice() {
    var priceEl = document.getElementById('bp-active-price');
    if (!priceEl) return;
    if (!singleOnly && mode === 'bundle') return; // bundle price handled in updateMode
    var inner;
    if (selectedSize) {
      var sv = findVariant(singleColor, selectedSize);
      inner = formatMoney(sv ? sv.price : bpPriceMin);
    } else if (bpPriceMax > bpPriceMin) {
      inner = formatMoney(bpPriceMin) + ' – ' + formatMoney(bpPriceMax);
    } else {
      inner = formatMoney(bpPriceMin);
    }
    priceEl.innerHTML = '<span class="bp-info__price-current">' + inner + '</span>';
  }

  function updateMode() {
    var pairsEl = document.getElementById('bp-pairs');
    var singleEl = document.getElementById('bp-single-pair');
    var priceEl = document.getElementById('bp-active-price');
    var titleEl = section.querySelector('.bp-info__title');

    if (singleOnly) {
      if (singleEl) singleEl.style.display = '';
      if (priceEl) updatePrice();
    } else if (mode === 'bundle') {
      if (pairsEl) pairsEl.style.display = '';
      if (singleEl) singleEl.style.display = 'none';
      if (priceEl) priceEl.innerHTML = '<span class="bp-info__price-compare">' + formatMoney(bundlePrice) + '</span> <span class="bp-info__price-sale">{{ section.settings.bundle_sale_price | escape }}</span>';
      if (titleEl) titleEl.textContent = bundleTitle;
    } else {
      if (pairsEl) pairsEl.style.display = 'none';
      if (singleEl) singleEl.style.display = '';
      if (priceEl) updatePrice();
      if (titleEl) titleEl.textContent = singleTitle;
    }
    updateSliderForColor();
    updateATC();
    setTimeout(function() {
      swatchArrowCheckers.forEach(function(fn) { fn(); });
    }, 50);
  }

  function updateSliderForColor() {
    var activeColor;
    if (singleOnly || mode === 'single') {
      activeColor = singleColor;
    } else {
      activeColor = pairColors[0];
    }
    var imgs;
    if (singleOnly) { imgs = posterImagesForColor(activeColor); }
    if (!imgs || !imgs.length) {
      var colorImgs = singleColorImages[activeColor] || colorImages[activeColor] || [];
      imgs = [].concat(all3Images).concat(colorImgs);
    }
    if (imgs.length > 0) {
      buildSlider(imgs);
    }
  }

  // --- Swatch clicks (bundle pairs) ---
  section.querySelectorAll('#bp-pairs .bp-pair').forEach(function(pairEl) {
    var pairIdx = parseInt(pairEl.getAttribute('data-pair')) - 1;
    pairEl.querySelectorAll('.bp-pair__swatch').forEach(function(swatch) {
      swatch.addEventListener('click', function() {
        var color = swatch.getAttribute('data-color');
        pairColors[pairIdx] = color;
        pairEl.querySelectorAll('.bp-pair__swatch').forEach(function(s) {
          s.classList.remove('bp-pair__swatch--active');
        });
        swatch.classList.add('bp-pair__swatch--active');
        pairEl.querySelector('[data-pair-color]').textContent = color;
        // Rebuild slider with just this color's images
        var colorImgs = singleColorImages[color] || colorImages[color] || [];
        var imgs = [].concat(all3Images).concat(colorImgs);
        if (imgs.length > 0) {
          buildSlider(imgs);
        }
        updateATC();
      });
    });
  });


  // --- Swatch clicks (single mode) ---
  var singlePairEl = document.getElementById('bp-single-pair');
  if (singlePairEl) {
    singlePairEl.querySelectorAll('.bp-pair__swatch').forEach(function(swatch) {
      swatch.addEventListener('click', function() {
        var color = swatch.getAttribute('data-color');
        singleColor = color;
        updatePrice();
        singlePairEl.querySelectorAll('.bp-pair__swatch').forEach(function(s) {
          s.classList.remove('bp-pair__swatch--active');
        });
        swatch.classList.add('bp-pair__swatch--active');
        singlePairEl.querySelector('[data-pair-color]').textContent = color;
        updateSliderForColor();
        updateATC();
      });
    });
  }

  // --- Size buttons ---
  section.querySelectorAll('.bp-sizes__btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      section.querySelectorAll('.bp-sizes__btn').forEach(function(b) {
        b.classList.remove('bp-sizes__btn--active');
      });
      btn.classList.add('bp-sizes__btn--active');
      selectedSize = btn.getAttribute('data-size');
      updatePrice();
      updateATC();
    });
  });

  // --- Initialize buy-box price on load (shows range until a size is chosen) ---
  updatePrice();

  function updateATC() {
    var btn = document.getElementById('bp-atc-btn');
    var buyBtn = document.getElementById('bp-buy-btn');
    var ctaText = '{{ section.settings.cta_text | escape }}';

    if (!selectedSize) {
      btn.disabled = true;
      btn.textContent = ctaText;
      if (buyBtn) { buyBtn.disabled = false; buyBtn.style.opacity = ''; }
      return;
    }

    if (singleOnly || mode === 'single') {
      var v = findVariant(singleColor, selectedSize);
      if (!v || !v.available) {
        btn.disabled = true;
        btn.textContent = 'Sold Out';
        if (buyBtn) { buyBtn.disabled = true; buyBtn.style.opacity = '0.5'; }
        return;
      }
    } else {
      for (var i = 0; i < 3; i++) {
        if (!pairColors[i]) {
          btn.disabled = true;
          btn.textContent = ctaText;
          if (buyBtn) { buyBtn.disabled = false; buyBtn.style.opacity = ''; }
          return;
        }
        var v = findVariant(pairColors[i], selectedSize);
        if (!v || !v.available) {
          btn.disabled = true;
          btn.textContent = 'Sold Out';
          if (buyBtn) { buyBtn.disabled = true; buyBtn.style.opacity = '0.5'; }
          return;
        }
      }
    }

    btn.disabled = false;
    btn.textContent = ctaText;
    if (buyBtn) { buyBtn.disabled = false; buyBtn.style.opacity = ''; }
  }

  function findVariant(color, size) {
    var colorLC = color.toLowerCase().trim();
    var sizeLC = size.toLowerCase().trim();
    for (var i = 0; i < variants.length; i++) {
      var v = variants[i];
      var o1 = v.option1 ? v.option1.toLowerCase().trim() : '';
      var o2 = v.option2 ? v.option2.toLowerCase().trim() : '';
      if (o1 === colorLC && o2 === sizeLC) return v;
    }
    return null;
  }

  // --- Add to Cart ---
  document.getElementById('bp-atc-btn').addEventListener('click', function() {
    var btn = this;
    if (btn.disabled) return;
    if (!selectedSize) { alert('Please select a size'); return; }

    var items = [];
    if (mode === 'bundle') {
      for (var i = 0; i < 3; i++) {
        if (!pairColors[i]) {
          alert('Please select a color for Pair ' + (i + 1));
          return;
        }
        var v = findVariant(pairColors[i], selectedSize);
        if (!v) {
          alert('Size ' + selectedSize + ' is not available for ' + pairColors[i] + '. Please choose a different size.');
          return;
        }
        if (!v.available) {
          alert(pairColors[i] + ' in size ' + selectedSize + ' is sold out.');
          return;
        }
        var itemObj = { id: v.id, quantity: 1 };
        var avail = bpGetAvail(v.id);
        if (avail) {
          itemObj.properties = itemObj.properties || {};
          itemObj.properties._rc_avail = avail;
          itemObj.properties._rc_backorder = avail === 'unavailable' ? 'true' : 'false';
        }
        items.push(itemObj);
      }
    } else {
      var v = findVariant(singleColor, selectedSize);
      if (!v) {
        alert('Size ' + selectedSize + ' is not available for ' + singleColor + '.');
        return;
      }
      if (!v.available) {
        alert(singleColor + ' in size ' + selectedSize + ' is sold out.');
        return;
      }
      var itemObj = { id: v.id, quantity: 1 };
      var avail = bpGetAvail(v.id);
      if (avail) {
        itemObj.properties = itemObj.properties || {};
        itemObj.properties._rc_avail = avail;
        itemObj.properties._rc_backorder = avail === 'unavailable' ? 'true' : 'false';
      }
      items.push(itemObj);
    }

    btn.disabled = true;
    btn.textContent = 'Adding...';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: items })
    })
    .then(function(res) {
      if (!res.ok) throw new Error('Cart error');
      return res.json();
    })
    .then(function() {
      btn.textContent = 'Added!';
      if (window.RC_CART && typeof window.RC_CART.open === 'function') {
        window.RC_CART.open();
        bpInjectBackorderMessages();
      } else {
        window.location.href = '/cart';
      }
      setTimeout(function() {
        btn.disabled = false;
        btn.textContent = '{{ section.settings.cta_text | escape }}';
      }, 1500);
    })
    .catch(function() {
      alert('Something went wrong. Please try again.');
      btn.disabled = false;
      btn.textContent = '{{ section.settings.cta_text | escape }}';
    });
  });

  // --- Buy Now ---
  document.getElementById('bp-buy-btn').addEventListener('click', function() {
    if (!selectedSize) { alert('Please select a size'); return; }

    if (mode === 'bundle') {
      var items = [];
      for (var i = 0; i < 3; i++) {
        if (!pairColors[i]) {
          alert('Please select a color for Pair ' + (i + 1));
          return;
        }
        var bv = findVariant(pairColors[i], selectedSize);
        if (!bv || !bv.available) {
          alert(pairColors[i] + ' in ' + selectedSize + ' is not available.');
          return;
        }
        items.push({ id: bv.id, quantity: 1 });
      }
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: items })
      }).then(function(res) {
        if (!res.ok) throw new Error('Cart error');
        window.location.href = '/checkout';
      }).catch(function() {
        alert('Something went wrong. Please try again.');
      });
    } else {
      var v = findVariant(singleColor, selectedSize);
      if (!v) { alert('Variant not available.'); return; }
      window.location.href = '/cart/' + v.id + ':1';
    }
  });

  // --- Accordion toggle icon ---
  section.querySelectorAll('.bp-accordion').forEach(function(acc) {
    acc.addEventListener('toggle', function() {
      var icon = acc.querySelector('.bp-accordion__icon');
      icon.textContent = acc.open ? '\u2212' : '+';
    });
  });


  // --- Size Chart Drawer ---
  (function() {
    var trigger = document.getElementById('bp-sc-trigger');
    var drawer = document.getElementById('bp-sc-drawer');
    var overlay = document.getElementById('bp-sc-overlay');
    var closeBtn = document.getElementById('bp-sc-close');
    if (!trigger || !drawer || !overlay) return;

    function openDrawer() {
      drawer.hidden = false;
      overlay.hidden = false;
      document.documentElement.style.overflow = 'hidden';
    }
    function closeDrawer() {
      drawer.hidden = true;
      overlay.hidden = true;
      document.documentElement.style.overflow = '';
    }
    trigger.addEventListener('click', openDrawer);
    overlay.addEventListener('click', closeDrawer);
    if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && !drawer.hidden) closeDrawer();
    });
  })();

  // --- Swatch scroll arrows + gradients ---
  var swatchArrowCheckers = [];
  section.querySelectorAll('.bp-pair__swatches-wrap').forEach(function(wrap) {
    var track = wrap.querySelector('.bp-pair__swatches');
    var arrowRight = wrap.querySelector('.bp-pair__arrow--right');
    var arrowLeft = wrap.querySelector('.bp-pair__arrow--left');
    if (!track) return;

    function checkArrows() {
      var canScroll = track.scrollWidth > track.clientWidth + 2;
      var atStart = track.scrollLeft <= 2;
      var atEnd = track.scrollLeft + track.clientWidth >= track.scrollWidth - 2;

      if (arrowRight) {
        if (!canScroll || atEnd) {
          arrowRight.classList.add('bp-pair__arrow--hidden');
        } else {
          arrowRight.classList.remove('bp-pair__arrow--hidden');
        }
      }
      if (arrowLeft) {
        if (!canScroll || atStart) {
          arrowLeft.classList.add('bp-pair__arrow--hidden');
        } else {
          arrowLeft.classList.remove('bp-pair__arrow--hidden');
        }
      }

      // Gradient fades
      wrap.classList.toggle('bp-pair__swatches-wrap--fade-right', canScroll && !atEnd);
      wrap.classList.toggle('bp-pair__swatches-wrap--fade-left', canScroll && !atStart);
    }

    if (arrowRight) {
      arrowRight.addEventListener('click', function() {
        track.scrollBy({ left: 200, behavior: 'smooth' });
      });
    }
    if (arrowLeft) {
      arrowLeft.addEventListener('click', function() {
        track.scrollBy({ left: -200, behavior: 'smooth' });
      });
    }

    track.addEventListener('scroll', checkArrows);
    checkArrows();
    setTimeout(checkArrows, 500);
    swatchArrowCheckers.push(checkArrows);
  });

  // --- Rating row: smooth-scroll to the reviews section on click ---
  (function() {
    var link = document.getElementById('bp-reviews-link');
    if (!link) return;
    link.addEventListener('click', function(e) {
      var target = document.querySelector('[id^="WfPosterReviews"], #judgeme_product_reviews, .jdgm-rev-widg, [id^="WfReviews"]');
      if (target) { e.preventDefault(); target.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
    });
  })();

  // --- URL ?variant=<color> support ---
  // e.g. /products/ld-split-shorts?variant=white
  (function() {
    var slug = new URLSearchParams(window.location.search).get('variant');
    if (!slug) return;
    if (/^\d+$/.test(slug)) return;

    var slugLower = slug.toLowerCase().replace(/[-_]/g, ' ').trim();

    function matchesSlug(color) {
      var c = (color || '').toLowerCase().replace(/[-_]/g, ' ').trim();
      return c === slugLower || c.replace(/\s+/g, '') === slugLower.replace(/\s+/g, '');
    }

    // Bundle mode: click the matching swatch in Pair 1
    var pair1 = section.querySelector('#bp-pairs .bp-pair[data-pair="1"]');
    if (pair1) {
      pair1.querySelectorAll('.bp-pair__swatch').forEach(function(swatch) {
        if (matchesSlug(swatch.getAttribute('data-color'))) {
          swatch.click();
        }
      });
    }

    // Single mode: click the matching swatch in the single pair
    var singlePair = document.getElementById('bp-single-pair');
    if (singlePair) {
      singlePair.querySelectorAll('.bp-pair__swatch').forEach(function(swatch) {
        if (matchesSlug(swatch.getAttribute('data-color'))) {
          swatch.click();
        }
      });
    }
  })();

  // --- Filter $0 items from Recently Viewed ---
  (function() {
    function filterFreeItems() {
      var grids = document.querySelectorAll('[id^="recently-viewed-products"]');
      grids.forEach(function(grid) {
        grid.querySelectorAll('.product-grid-item').forEach(function(item) {
          var priceEl = item.querySelector('[data-product-price]') || item.querySelector('.product__grid__price .money');
          if (priceEl) {
            var price = priceEl.textContent.trim().replace(/[^0-9.]/g, '');
            if (parseFloat(price) === 0) {
              item.closest('.grid__item, .grid-item, .flickity-slide') ?
                item.closest('.grid__item, .grid-item, .flickity-slide').style.display = 'none' :
                item.style.display = 'none';
            }
          }
        });
      });
    }
    // Run after recently viewed loads
    if (document.readyState === 'complete') {
      setTimeout(filterFreeItems, 1000);
    } else {
      window.addEventListener('load', function() { setTimeout(filterFreeItems, 1000); });
    }
    // Also observe for dynamically loaded items
    var observer = new MutationObserver(function() { setTimeout(filterFreeItems, 200); });
    var target = document.querySelector('[data-recently-viewed-wrapper], [data-recent-wrapper]');
    if (target) observer.observe(target, { childList: true, subtree: true });
  })();

  // --- Auto-open "Who is this for?" accordion on mobile ---
  (function() {
    if (window.matchMedia('(min-width: 768px)').matches) return;
    var attempts = 0;
    var timer = setInterval(function() {
      attempts++;
      var toggles = document.querySelectorAll('.accordion-toggle');
      var found = false;
      toggles.forEach(function(toggle) {
        if (toggle.textContent.trim().toLowerCase().indexOf('who is this for') === 0) {
          found = true;
          if (!toggle.classList.contains('active')) {
            toggle.click();
          }
        }
      });
      if (found || attempts > 30) clearInterval(timer);
    }, 200);
  })();
})();
</script>

<style>
  .bp-section {
    --bp-blue: #2E7D32;
    --bp-font: var(--FONT-STACK-HEADING);
    margin: 0 auto;
    background: #fbfbfb;
    color: #000;
  }

  /* Hero Slider — full width edge to edge */
  .bp-hero {
    width: 100vw;
    height: 100vw;
    margin-left: none;
    background: #000;
    position: relative;
    overflow: hidden;
  }
