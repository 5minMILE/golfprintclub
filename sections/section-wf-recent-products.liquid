<!-- /sections/section-wf-recent-products.liquid -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;900&display=swap" rel="stylesheet">

{%- style -%}
  #WfRecent--{{ section.id }} {
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<style>
  #WfRecent--{{ section.id }} {
    padding-top: var(--PT);
    padding-bottom: var(--PB);
    display: none;
  }
  #WfRecent--{{ section.id }}.is-visible {
    display: block;
  }
  #WfRecent--{{ section.id }} .wf-recent__inner {
    max-width: 3000px;
    margin: 0 50px;
    position: relative;
  }
  #WfRecent--{{ section.id }} .wf-recent__heading {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #000;
    margin: 0 0 14px;
  }
  #WfRecent--{{ section.id }} .wf-recent__strip {
    display: flex;
    gap: 0;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    align-items: start;
  }
  #WfRecent--{{ section.id }} .wf-recent__strip::-webkit-scrollbar {
    display: none;
  }
  #WfRecent--{{ section.id }} .wf-recent__strip .wf-card {
    flex: 0 0 calc(25% - 16px);
    min-width: 220px;
  }
  /* Product card — exact match of wf-collection-tabs */
  #WfRecent--{{ section.id }} .wf-card {
    border: 1px solid #E0E0E0;
    padding: 0;
    margin: 8px;
    overflow: hidden;
  }
  #WfRecent--{{ section.id }} .wf-card__info {
    padding: 8px 10px 10px;
  }
  #WfRecent--{{ section.id }} .wf-card__img {
    display: block;
    position: relative;
    width: 100%;
    aspect-ratio: 4/5;
    background: #F0F0F0;
    overflow: hidden;
  }
  #WfRecent--{{ section.id }} .wf-card__img img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  #WfRecent--{{ section.id }} .wf-card__badge {
    position: absolute;
    top: 6px;
    left: 6px;
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    font-weight: 700;
    padding: 4px 10px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    z-index: 1;
  }
  #WfRecent--{{ section.id }} .wf-card__badge--soldout {
    background: #1B5E20;
  }
  #WfRecent--{{ section.id }} .wf-card:has(.wf-card__badge--soldout) .wf-card__img img {
    opacity: 0.8;
  }
  #WfRecent--{{ section.id }} .wf-card__badge--sale {
    background: #d71616;
  }
  #WfRecent--{{ section.id }} .wf-card__badge--backorder {
    background: #FF8800;
  }
  @media (min-width: 750px) {
    #WfRecent--{{ section.id }} .wf-recent__inner {
      padding-left: 0;
    }
    #WfRecent--{{ section.id }} .wf-card__badge {
      font-size: 10px;
      font-weight: 700;
    }
    #WfRecent--{{ section.id }} .wf-recent__heading {
      font-size: 12px;
    }
  }
  #WfRecent--{{ section.id }} .wf-card__swatches {
    display: flex;
    gap: 6px;
    margin-top: 4px;
    align-items: center;
  }
  #WfRecent--{{ section.id }} .wf-card__swatch {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 2px solid #ccc;
    cursor: pointer;
    transition: transform 0.15s, border-color 0.15s;
  }
  #WfRecent--{{ section.id }} .wf-card__swatch:hover,
  #WfRecent--{{ section.id }} .wf-card__swatch.is-active {
    transform: scale(1.2);
    border-color: #333;
  }
  #WfRecent--{{ section.id }} .wf-card__title {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 1000;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-top: 4px;
    line-height: 1.2;
  }
  #WfRecent--{{ section.id }} .wf-card__title a {
    color: inherit;
    text-decoration: none;
  }
  #WfRecent--{{ section.id }} .wf-card__variants {
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    font-weight: 600;
    color: #888;
    margin-top: 2px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  #WfRecent--{{ section.id }} .wf-card__variant-item {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  #WfRecent--{{ section.id }} .wf-card__price {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 1000;
    margin-top: 3px;
  }
  #WfRecent--{{ section.id }} .wf-card__price .old-price {
    text-decoration: line-through;
    color: #999;
    margin-left: 4px;
    font-weight: 400;
    font-size: 9px;
  }
  /* Desktop slider arrows */
  #WfRecent--{{ section.id }} .wf-recent__arrow {
    display: none;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #2E7D32;
    border: none;
    box-shadow: 0 2px 6px rgba(0,0,0,0.15);
    cursor: pointer;
    font-size: 18px;
    line-height: 1;
    color: #fff;
    align-items: center;
    justify-content: center;
  }
  #WfRecent--{{ section.id }} .wf-recent__arrow:hover {
    background: #0069d9;
  }
  #WfRecent--{{ section.id }} .wf-recent__arrow {
    transition: box-shadow 0.3s ease, transform 0.2s ease, background 0.2s ease;
  }
  #WfRecent--{{ section.id }} .wf-recent__arrow:hover {
    background: #0080ff;
    box-shadow: 0 0 12px rgba(0,123,255,0.5);
    transform: translateY(-50%) scale(1.1);
  }
  #WfRecent--{{ section.id }} .wf-recent__arrow--prev { left: -16px; }
  #WfRecent--{{ section.id }} .wf-recent__arrow--next { right: -16px; }
  @media (min-width: 750px) {
    #WfRecent--{{ section.id }} .wf-recent__arrow--prev { left: calc(calc(50vh * 0.8) + 30px - 16px); }
  }
  #WfRecent--{{ section.id }} .wf-recent__arrow.is-visible {
    display: flex;
  }
  /* Mobile arrows */
  #WfRecent--{{ section.id }} .wf-recent__mob-arrows {
    display: none;
    justify-content: center;
    gap: 12px;
    margin-top: 10px;
  }
  #WfRecent--{{ section.id }} .wf-recent__mob-arrow {
    width: 30px;
    height: 30px;
    background: none;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0;
  }
  #WfRecent--{{ section.id }} .wf-recent__mob-arrow svg {
    width: 14px;
    height: 14px;
    stroke: #000;
    fill: none;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  @media (max-width: 749px) {
    #WfRecent--{{ section.id }} .wf-recent__inner {
      margin: 0 16px;
    }
    #WfRecent--{{ section.id }} .wf-recent__strip {
      scroll-snap-type: x mandatory;
      -webkit-scroll-snap-type: x mandatory;
      padding: 0 14px;
    }
    #WfRecent--{{ section.id }} .wf-recent__strip .wf-card {
      flex: 0 0 75vw;
      min-width: 75vw;
      scroll-snap-align: start;
      margin: 8px 6px;
    }
    #WfRecent--{{ section.id }} .wf-recent__arrow {
      display: none !important;
    }
    #WfRecent--{{ section.id }} .wf-recent__mob-arrows {
      display: flex;
    }
  }
</style>

<section id="WfRecent--{{ section.id }}" data-section-id="{{ section.id }}" data-section-type="wf-recent-products" data-limit="{{ section.settings.limit }}" data-minimum="{{ section.settings.minimum }}">
  <div class="wf-recent__inner">
    {%- if section.settings.heading != blank -%}
      <p class="wf-recent__heading">{{ section.settings.heading }}</p>
    {%- endif -%}
    <button class="wf-recent__arrow wf-recent__arrow--prev" aria-label="Previous">&#8249;</button>
    <button class="wf-recent__arrow wf-recent__arrow--next" aria-label="Next">&#8250;</button>
    <div class="wf-recent__strip" data-wf-recent-grid></div>
    <div class="wf-recent__mob-arrows">
      <button class="wf-recent__mob-arrow" data-recent-prev aria-label="Previous">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button class="wf-recent__mob-arrow" data-recent-next aria-label="Next">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  </div>
</section>

<script>
  (function() {
    var section = document.getElementById('WfRecent--{{ section.id }}');
    if (!section) return;

    var grid = section.querySelector('[data-wf-recent-grid]');
    var limit = parseInt(section.getAttribute('data-limit')) || 6;
    var minimum = parseInt(section.getAttribute('data-minimum')) || 2;
    var isMobile = window.matchMedia('(max-width: 749px)');

    /* Read the theme's recently viewed cookie */
    function getRecentHandles() {
      var cookieName = 'shopify_recently_viewed';
      var cookies = document.cookie.split(';');
      for (var i = 0; i < cookies.length; i++) {
        var c = cookies[i].trim();
        if (c.indexOf(cookieName + '=') === 0) {
          var val = decodeURIComponent(c.substring(cookieName.length + 1));
          return val.split(' ').filter(function(h) { return h.length > 0; });
        }
      }
      return [];
    }

    /* Exclude current product if on a product page */
    var currentHandle = '';
    if (window.location.pathname.indexOf('/products/') !== -1) {
      var parts = window.location.pathname.split('/products/');
      if (parts[1]) currentHandle = parts[1].split('/')[0].split('?')[0];
    }

    var handles = getRecentHandles().filter(function(h) { return h !== currentHandle; });
    if (handles.length < minimum) return;
    handles = handles.slice(0, limit);

    var loaded = 0;
    var total = handles.length;

    handles.forEach(function(handle) {
      fetch('/products/' + handle + '?section_id=api-wf-product-grid-item')
        .then(function(r) { return r.text(); })
        .then(function(html) {
          var parser = new DOMParser();
          var doc = parser.parseFromString(html, 'text/html');
          var content = doc.querySelector('[data-api-content]');
          if (content) {
            var card = content.querySelector('.wf-card');
            if (card) grid.appendChild(card);
          }
          loaded++;
          if (loaded >= total) finalize();
        })
        .catch(function() {
          loaded++;
          if (loaded >= total) finalize();
        });
    });

    function finalize() {
      var cards = grid.querySelectorAll('.wf-card');
      if (cards.length < minimum) return;
      section.classList.add('is-visible');
      initHover();
      updateArrows();
    }

    /* Desktop hover: left half = -1, right half = -2 */
    function initHover() {
      if (isMobile.matches) return;
      var cardImgs = section.querySelectorAll('.wf-card__img');
      cardImgs.forEach(function(cardImg) {
        var img = cardImg.querySelector('img');
        if (!img) return;
        var hoverSrc = cardImg.getAttribute('data-hover-src');
        var secondSrc = cardImg.getAttribute('data-second-src');
        if (!hoverSrc) return;
        /* Preload */
        var p1 = new Image(); p1.src = hoverSrc;
        if (secondSrc) { var p2 = new Image(); p2.src = secondSrc; }

        cardImg.addEventListener('mouseenter', function() { img.src = hoverSrc; });
        if (secondSrc) {
          cardImg.addEventListener('mousemove', function(e) {
            var rect = cardImg.getBoundingClientRect();
            img.src = (e.clientX - rect.left > rect.width / 2) ? secondSrc : hoverSrc;
          });
        }
        cardImg.addEventListener('mouseleave', function() {
          var original = img.getAttribute('data-original-src');
          if (original) img.src = original;
        });
      });

      /* Swatch hover */
      var swatches = section.querySelectorAll('.wf-card__swatch[data-swatch-image]');
      swatches.forEach(function(swatch) {
        var preload = new Image(); preload.src = swatch.getAttribute('data-swatch-image');
        var card = swatch.closest('.wf-card');
        if (!card) return;
        var img = card.querySelector('.wf-card__img img');
        if (!img) return;
        swatch.addEventListener('mouseenter', function() {
          img.src = this.getAttribute('data-swatch-image');
          card.querySelectorAll('.wf-card__swatch').forEach(function(s) { s.classList.remove('is-active'); });
          this.classList.add('is-active');
        });
        swatch.addEventListener('mouseleave', function() {
          var original = img.getAttribute('data-original-src');
          if (original) img.src = original;
          this.classList.remove('is-active');
        });
      });
    }

    /* Desktop slider arrows */
    var strip = section.querySelector('.wf-recent__strip');
    var prevBtn = section.querySelector('.wf-recent__arrow--prev');
    var nextBtn = section.querySelector('.wf-recent__arrow--next');

    function updateArrows() {
      if (isMobile.matches) {
        if (prevBtn) prevBtn.classList.remove('is-visible');
        if (nextBtn) nextBtn.classList.remove('is-visible');
        return;
      }
      var canScroll = strip.scrollWidth > strip.offsetWidth + 5;
      if (prevBtn) prevBtn.classList.toggle('is-visible', canScroll && strip.scrollLeft > 5);
      if (nextBtn) nextBtn.classList.toggle('is-visible', canScroll && strip.scrollLeft < strip.scrollWidth - strip.offsetWidth - 5);
    }

    if (prevBtn) prevBtn.addEventListener('click', function() { strip.scrollLeft -= strip.offsetWidth * 0.75; });
    if (nextBtn) nextBtn.addEventListener('click', function() { strip.scrollLeft += strip.offsetWidth * 0.75; });
    strip.addEventListener('scroll', function() { if (!isMobile.matches) updateArrows(); });
    isMobile.addEventListener('change', updateArrows);

    /* Mobile arrows — scroll by one card width */
    var mobPrev = section.querySelector('[data-recent-prev]');
    var mobNext = section.querySelector('[data-recent-next]');
    function getMobileScrollAmount() {
      var card = strip.querySelector('.wf-card');
      return card ? card.offsetWidth + 12 : 260;
    }
    if (mobPrev) {
      mobPrev.addEventListener('click', function() {
        strip.scrollBy({ left: -getMobileScrollAmount(), behavior: 'smooth' });
      });
    }
    if (mobNext) {
      mobNext.addEventListener('click', function() {
        strip.scrollBy({ left: getMobileScrollAmount(), behavior: 'smooth' });
      });
    }
  })();
</script>

{% schema %}
{
  "name": "WF Recently Viewed",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recently Viewed"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 2,
      "max": 10,
      "step": 1,
      "label": "Max products to show",
      "default": 6
    },
    {
      "type": "range",
      "id": "minimum",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "Minimum to display",
      "info": "Hide section until this many products have been viewed",
      "default": 2
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "WF Recently Viewed",
      "category": "Collection"
    }
  ]
}
{% endschema %}
