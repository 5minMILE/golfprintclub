<!-- /sections/section-guarantee.liquid -->
{%- style -%}
  #Guarantee--{{ section.id }} {
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;900&display=swap" rel="stylesheet">

<style>
  #Guarantee--{{ section.id }} {
    padding-top: var(--PT);
    padding-bottom: var(--PB);
    background-color: #0A0A0A;
    color: #fff;
  }
  #Guarantee--{{ section.id }} .guarantee__inner {
    max-width: 3000px;
    margin: 0 auto;
    padding: 56px 32px;
    text-align: center;
  }
  #Guarantee--{{ section.id }} .guarantee__heading {
    font-family: 'Montserrat', sans-serif;
    font-size: 28px;
    font-weight: 1000;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.15;
  }
  #Guarantee--{{ section.id }} .guarantee__desc {
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: rgba(255,255,255,0.78);
    line-height: 1.65;
    margin-top: 14px;
    max-width: 56ch;
    margin-left: auto;
    margin-right: auto;
  }
  #Guarantee--{{ section.id }} .guarantee__badges {
    display: flex;
    justify-content: center;
    gap: 36px;
    margin-top: 28px;
    flex-wrap: wrap;
  }
  #Guarantee--{{ section.id }} .guarantee__badge {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  #Guarantee--{{ section.id }} .guarantee__check {
    color: #2E7D32;
    font-size: 14px;
    line-height: 1;
  }
  #Guarantee--{{ section.id }} .guarantee__badge-text {
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    font-weight: 1000;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    line-height: 1.2;
  }
  @media (max-width: 749px) {
    #Guarantee--{{ section.id }} .guarantee__inner {
      padding: 40px 20px;
    }
    #Guarantee--{{ section.id }} .guarantee__heading {
      font-size: 22px;
    }
    #Guarantee--{{ section.id }} .guarantee__desc {
      font-size: 13px;
      line-height: 1.6;
      margin-top: 12px;
    }
    #Guarantee--{{ section.id }} .guarantee__badges {
      gap: 20px;
      margin-top: 20px;
    }
    #Guarantee--{{ section.id }} .guarantee__badge {
      gap: 6px;
    }
    #Guarantee--{{ section.id }} .guarantee__check {
      font-size: 12px;
    }
    #Guarantee--{{ section.id }} .guarantee__badge-text {
      font-size: 11px;
    }
  }
</style>

<section id="Guarantee--{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="guarantee">
  <div class="guarantee__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="guarantee__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.description != blank -%}
      <div class="guarantee__desc">{{ section.settings.description }}</div>
    {%- endif -%}
    <div class="guarantee__badges">
      {%- if section.settings.badge_1 != blank -%}
        <div class="guarantee__badge">
          <span class="guarantee__check">&#10003;</span>
          <span class="guarantee__badge-text">{{ section.settings.badge_1 }}</span>
        </div>
      {%- endif -%}
      {%- if section.settings.badge_2 != blank -%}
        <div class="guarantee__badge">
          <span class="guarantee__check">&#10003;</span>
          <span class="guarantee__badge-text">{{ section.settings.badge_2 }}</span>
        </div>
      {%- endif -%}
      {%- if section.settings.badge_3 != blank -%}
        <div class="guarantee__badge">
          <span class="guarantee__check">&#10003;</span>
          <span class="guarantee__badge-text">{{ section.settings.badge_3 }}</span>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Guarantee Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Promise"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "If your golf posters ride up, your pocket bounces, or you're not satisfied for any reason - we'll make it right. No questions asked. 30-day returns. Always."
    },
    {
      "type": "text",
      "id": "badge_1",
      "label": "Badge 1",
      "default": "30-Day Returns"
    },
    {
      "type": "text",
      "id": "badge_2",
      "label": "Badge 2",
      "default": "Free Exchanges"
    },
    {
      "type": "text",
      "id": "badge_3",
      "label": "Badge 3",
      "default": "Real Humans"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Guarantee Banner",
      "category": "Text"
    }
  ]
}
{% endschema %}
