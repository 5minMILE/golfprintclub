<!-- /sections/section-founder-story.liquid -->
{%- style -%}
  #FounderStory--{{ section.id }} {
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;900&display=swap" rel="stylesheet">

<style>
  #FounderStory--{{ section.id }} {
    padding-top: max(60px, var(--PT));
    padding-bottom: max(60px, var(--PB));
  }
  #FounderStory--{{ section.id }} .founder__inner {
    max-width: 3000px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 48px;
    align-items: center;
  }
  /* Text-only layout when no founder image is set */
  #FounderStory--{{ section.id }}.founder--text-only .founder__inner {
    max-width: 3000px;
    grid-template-columns: 1fr;
    text-align: center;
    gap: 0;
  }
  #FounderStory--{{ section.id }}.founder--text-only .founder__image {
    display: none;
  }
  #FounderStory--{{ section.id }}.founder--text-only .founder__body {
    margin-left: auto;
    margin-right: auto;
    max-width: 56ch;
  }
  #FounderStory--{{ section.id }} .founder__image {
    width: 100%;
    height: 420px;
    background: #E8E8E8;
    overflow: hidden;
  }
  #FounderStory--{{ section.id }} .founder__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #FounderStory--{{ section.id }} .founder__subtitle {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 700;
    color: #2E7D32;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    line-height: 1.2;
  }
  #FounderStory--{{ section.id }} .founder__heading {
    font-family: 'Montserrat', sans-serif;
    font-size: 28px;
    font-weight: 1000;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.15;
    margin-top: 10px;
  }
  #FounderStory--{{ section.id }} .founder__body {
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #444;
    line-height: 1.7;
    margin-top: 18px;
  }
  #FounderStory--{{ section.id }} .founder__signature {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 1000;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    line-height: 1.2;
    margin-top: 18px;
    color: #000;
  }
  @media (max-width: 749px) {
    #FounderStory--{{ section.id }} {
      padding-top: max(40px, var(--PT));
      padding-bottom: max(40px, var(--PB));
    }
    #FounderStory--{{ section.id }} .founder__inner {
      grid-template-columns: 1fr;
      padding: 0 16px;
      gap: 20px;
    }
    #FounderStory--{{ section.id }} .founder__image {
      height: 280px;
    }
    #FounderStory--{{ section.id }} .founder__text {
      padding: 0;
    }
    #FounderStory--{{ section.id }} .founder__subtitle {
      font-size: 10px;
    }
    #FounderStory--{{ section.id }} .founder__heading {
      font-size: 22px;
      margin-top: 8px;
    }
    #FounderStory--{{ section.id }} .founder__body {
      font-size: 13px;
      line-height: 1.65;
      margin-top: 14px;
    }
    #FounderStory--{{ section.id }} .founder__signature {
      font-size: 10px;
      margin-top: 14px;
    }
  }
</style>

<section id="FounderStory--{{ section.id }}"
  class="{% if section.settings.image == blank %}founder--text-only{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="founder-story">
  <div class="founder__inner">
    <div class="founder__image">
      {%- if section.settings.image != blank -%}
        {%- assign img = section.settings.image -%}
        <img src="{{ img | image_url: width: 800 }}"
          alt="{{ section.settings.heading | escape }}"
          width="{{ img.width }}"
          height="{{ img.height }}"
          loading="lazy">
      {%- endif -%}
    </div>
    <div class="founder__text">
      {%- if section.settings.subtitle != blank -%}
        <div class="founder__subtitle">{{ section.settings.subtitle }}</div>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="founder__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <div class="founder__body">{{ section.settings.body }}</div>
      {%- endif -%}
      {%- if section.settings.signature != blank -%}
        <div class="founder__signature">{{ section.settings.signature }}</div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Founder Story",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Founder image"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "The Story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built by a Golfer, Not a Board Room"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>Golf Print Club started because every pair of golf posters I owned sucked. They rode up. The pockets bounced. The \"compression\" was a lie. So I made my own. I'm still chasing 1:47 in the 800m and building this brand out of the same obsession that gets me to the track at 6am. Every product is tested in real training - not a lab. If it doesn't survive my workouts, it doesn't ship.</p>"
    },
    {
      "type": "text",
      "id": "signature",
      "label": "Signature",
      "default": "- Founder, Golf Print Club"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Founder Story",
      "category": "Text"
    }
  ]
}
{% endschema %}
