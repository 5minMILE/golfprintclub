<!-- /sections/section-wf-journal.liquid -->
<style>
  .jr-{{ section.id }} {
    padding: 64px 0;
    background: {{ section.settings.bg_color | default: '#FBFBFB' }};
  }
  .jr-{{ section.id }} .jr-head {
    max-width: 3000px;
    margin: 0 auto 36px;
    padding: 0 32px;
    text-align: left;
  }
  .jr-{{ section.id }} .jr-head__text {
    max-width: 60ch;
  }
  .jr-{{ section.id }} .jr-eyebrow {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 700;
    color: #3D6E2E;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin: 0 0 10px;
    display: block;
  }
  .jr-{{ section.id }} .jr-heading {
    font-family: 'Montserrat', sans-serif;
    font-size: 30px;
    font-weight: 1000;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.1;
    margin: 0 0 10px;
  }
  .jr-{{ section.id }} .jr-sub {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: #555;
    line-height: 1.6;
    margin: 0;
  }

  /* Carousel: 3 cards visible, scroll-snap, next arrow advances 3 at a time */
  .jr-{{ section.id }} .jr-carousel {
    position: relative;
    max-width: 3000px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .jr-{{ section.id }} .jr-scroller {
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .jr-{{ section.id }} .jr-scroller::-webkit-scrollbar {
    display: none;
  }
  .jr-{{ section.id }} .jr-track {
    display: flex;
    gap: 24px;
  }
  .jr-{{ section.id }} .jr-card {
    flex: 0 0 calc((100% - 48px) / 3);
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border: 1px solid #E0E0E0;
    background: #fff;
    overflow: hidden;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .jr-{{ section.id }} .jr-card:hover {
    transform: translateY(-3px);
    border-color: #0A0A0A;
    box-shadow: 0 8px 22px rgba(0,0,0,0.08);
  }
  .jr-{{ section.id }} .jr-card__img {
    aspect-ratio: 16 / 10;
    background: #f0f0f0;
    overflow: hidden;
  }
  .jr-{{ section.id }} .jr-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .jr-{{ section.id }} .jr-card:hover .jr-card__img img {
    transform: scale(1.04);
  }
  .jr-{{ section.id }} .jr-card__body {
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .jr-{{ section.id }} .jr-card__meta {
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    font-weight: 700;
    color: #888;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0 0 8px;
  }
  .jr-{{ section.id }} .jr-card__title {
    font-family: 'Montserrat', sans-serif;
    font-size: 16px;
    font-weight: 1000;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.25;
    margin: 0 0 8px;
  }
  .jr-{{ section.id }} .jr-card__excerpt {
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: #666;
    line-height: 1.55;
    margin: 0 0 14px;
    flex: 1;
  }
  .jr-{{ section.id }} .jr-card__cta {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 1000;
    color: #0A0A0A;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: auto;
  }
  .jr-{{ section.id }} .jr-card__cta .jr-arrow {
    font-weight: 900;
    line-height: 1;
    transform: translateY(-1px);
    display: inline-block;
  }
  .jr-{{ section.id }} .jr-arrow-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: none;
    background: #3D6E2E;
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 14px rgba(0,0,0,0.18);
    transition: background 0.2s ease, transform 0.2s ease, opacity 0.2s ease;
  }
  .jr-{{ section.id }} .jr-arrow-btn:hover {
    background: #0A0A0A;
    transform: translateY(-50%) scale(1.05);
  }
  .jr-{{ section.id }} .jr-arrow-btn[hidden] {
    display: none;
  }
  .jr-{{ section.id }} .jr-next { right: 8px; }
  .jr-{{ section.id }} .jr-prev { left: 8px; }
  .jr-{{ section.id }} .jr-arrow-btn svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }
  /* Mobile-only chevron arrows under the carousel (matches UGC grid pattern) */
  .jr-{{ section.id }} .jr-arrows-mobile {
    display: none;
    justify-content: center;
    gap: 12px;
    margin-top: 14px;
  }
  .jr-{{ section.id }} .jr-arrow-mobile {
    width: 30px;
    height: 30px;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #000;
  }
  .jr-{{ section.id }} .jr-arrow-mobile[hidden] { display: none; }
  .jr-{{ section.id }} .jr-arrow-mobile svg {
    width: 14px;
    height: 14px;
    stroke: #000;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    fill: none;
  }
  .jr-{{ section.id }} .jr-empty {
    text-align: center;
    padding: 40px 20px;
    color: #888;
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  @media (max-width: 960px) {
    .jr-{{ section.id }} .jr-card {
      flex: 0 0 calc((100% - 24px) / 2);
    }
  }
  @media (max-width: 749px) {
    .jr-{{ section.id }} {
      padding: 40px 0;
    }
    .jr-{{ section.id }} .jr-head {
      margin: 0 16px 26px;
      padding: 0;
    }
    .jr-{{ section.id }} .jr-heading {
      font-size: 22px;
    }
    .jr-{{ section.id }} .jr-carousel {
      padding: 0 16px;
    }
    .jr-{{ section.id }} .jr-track {
      gap: 16px;
    }
    .jr-{{ section.id }} .jr-card {
      flex: 0 0 calc(100% - 40px);
    }
    /* Mobile: bigger image, compressed text */
    .jr-{{ section.id }} .jr-card__img {
      aspect-ratio: 4 / 3;
    }
    .jr-{{ section.id }} .jr-card__body {
      padding: 12px 14px 14px;
    }
    .jr-{{ section.id }} .jr-card__meta {
      font-size: 9px;
      letter-spacing: 0.12em;
      margin: 0 0 5px;
    }
    .jr-{{ section.id }} .jr-card__title {
      font-size: 14px;
      line-height: 1.2;
      margin: 0 0 6px;
    }
    .jr-{{ section.id }} .jr-card__excerpt {
      font-size: 11px;
      line-height: 1.45;
      margin: 0 0 8px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .jr-{{ section.id }} .jr-card__cta {
      font-size: 10px;
      gap: 6px;
    }
    /* Hide floating circle arrows, show bottom chevrons */
    .jr-{{ section.id }} .jr-arrow-btn {
      display: none !important;
    }
    .jr-{{ section.id }} .jr-arrows-mobile {
      display: flex;
    }
  }
</style>

<section class="jr-{{ section.id }}" data-section-id="{{ section.id }}" data-section-type="journal">
  <div class="jr-head">
    <div class="jr-head__text">
      {%- if section.settings.eyebrow != blank -%}
        <span class="jr-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="jr-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="jr-sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
  </div>

  {%- assign blog_handle = section.settings.blog | default: 'news' -%}
  {%- assign blog = blogs[blog_handle] -%}

  {%- if blog != blank and blog.articles.size > 0 -%}
    <div class="jr-carousel">
      <div class="jr-scroller" data-jr-scroller>
        <div class="jr-track">
          {%- for article in blog.articles -%}
            <a href="{{ article.url }}" class="jr-card">
              <div class="jr-card__img">
                {%- if article.image -%}
                  <img src="{{ article.image | image_url: width: 800 }}" alt="{{ article.title | escape }}" loading="lazy">
                {%- endif -%}
              </div>
              <div class="jr-card__body">
                <div class="jr-card__meta">
                  {%- if article.tags.size > 0 -%}{{ article.tags.first }} · {%- endif -%}
                  {{ article.published_at | date: '%b %-d, %Y' }}
                </div>
                <h3 class="jr-card__title">{{ article.title }}</h3>
                {%- if article.excerpt_or_content != blank -%}
                  <p class="jr-card__excerpt">{{ article.excerpt_or_content | strip_html | truncate: 130 }}</p>
                {%- endif -%}
                <span class="jr-card__cta">Read more <span class="jr-arrow" aria-hidden="true">→</span></span>
              </div>
            </a>
          {%- endfor -%}
        </div>
      </div>
      {%- if blog.articles.size > 3 -%}
        <button type="button" class="jr-arrow-btn jr-prev" data-jr-prev aria-label="Previous articles" hidden>
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15.4 4.6 8 12l7.4 7.4 1.4-1.4L10.8 12l6-6z"/></svg>
        </button>
        <button type="button" class="jr-arrow-btn jr-next" data-jr-next aria-label="Next articles">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8.6 4.6 16 12l-7.4 7.4-1.4-1.4L13.2 12 7.2 6z"/></svg>
        </button>
      {%- endif -%}
    </div>
    {%- if blog.articles.size > 1 -%}
      <div class="jr-arrows-mobile">
        <button type="button" class="jr-arrow-mobile" data-jr-prev aria-label="Previous articles">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button type="button" class="jr-arrow-mobile" data-jr-next aria-label="Next articles">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    {%- endif -%}
  {%- else -%}
    <div class="jr-empty">Select a blog in the theme editor to display recent articles.</div>
  {%- endif -%}
</section>

<script>
(function() {
  var section = document.querySelector('.jr-{{ section.id }}');
  if (!section) return;
  var scroller = section.querySelector('[data-jr-scroller]');
  var nextBtns = section.querySelectorAll('[data-jr-next]');
  var prevBtns = section.querySelectorAll('[data-jr-prev]');
  if (!scroller || !nextBtns.length) return;

  function isMobile() {
    return window.matchMedia('(max-width: 749px)').matches;
  }
  function getStep() {
    var card = scroller.querySelector('.jr-card');
    if (!card) return 0;
    var trackStyle = getComputedStyle(scroller.querySelector('.jr-track'));
    var gap = parseFloat(trackStyle.columnGap || trackStyle.gap || '0');
    var perStep = isMobile() ? 1 : 3;
    return (card.offsetWidth + gap) * perStep;
  }
  function updatePrev() {
    var show = scroller.scrollLeft > 4;
    prevBtns.forEach(function(b) {
      // The desktop circle button uses the `hidden` attribute reveal pattern;
      // the mobile chevron is always visible by design (matches UGC pattern).
      if (b.classList.contains('jr-arrow-mobile')) return;
      b.hidden = !show;
    });
  }

  nextBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var step = getStep();
      if (!step) return;
      var maxScroll = scroller.scrollWidth - scroller.clientWidth;
      if (scroller.scrollLeft + step >= maxScroll - 4) {
        scroller.scrollTo({ left: 0, behavior: 'smooth' });
      } else {
        scroller.scrollBy({ left: step, behavior: 'smooth' });
      }
    });
  });
  prevBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var step = getStep();
      if (!step) return;
      if (scroller.scrollLeft <= 4) {
        // Wrap to the end
        scroller.scrollTo({ left: scroller.scrollWidth, behavior: 'smooth' });
      } else {
        scroller.scrollBy({ left: -step, behavior: 'smooth' });
      }
    });
  });
  scroller.addEventListener('scroll', updatePrev, { passive: true });
  updatePrev();
})();
</script>

{% schema %}
{
  "name": "Journal",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Journal"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Training, Racing, and Everything Between"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Gear breakdowns, race recaps, and the things you actually need to know about getting faster. Written by golfers, for golfers."
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog source"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FBFBFB"
    }
  ],
  "presets": [
    {
      "name": "Journal",
      "category": "Blog"
    }
  ]
}
{% endschema %}
