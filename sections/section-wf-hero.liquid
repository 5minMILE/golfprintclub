<!-- /sections/section-wf-hero.liquid -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;900&display=swap" rel="stylesheet">

{%- assign has_blocks = false -%}
{%- for b in section.blocks -%}
  {%- if b.type == 'slide' -%}{%- assign has_blocks = true -%}{%- endif -%}
{%- endfor -%}

<style>
  #WfHero--{{ section.id }} {
    position: relative;
    width: 100%;
    background: #ffffff;
    padding: 32px 24px 48px;
    box-sizing: border-box;
  }
  #WfHero--{{ section.id }} .wf-hero__inner {
    max-width: 720px;
    margin: 0 auto;
    position: relative;
  }
  #WfHero--{{ section.id }} .wf-hero__stage {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    background: #f4f4f5;
    overflow: hidden;
    border-radius: 6px;
  }
  #WfHero--{{ section.id }} .wf-hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 700ms ease;
    will-change: opacity;
  }
  #WfHero--{{ section.id }} .wf-hero__slide.is-active { opacity: 1; }
  #WfHero--{{ section.id }} .wf-hero__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    image-rendering: -webkit-optimize-contrast;
    image-rendering: high-quality;
    display: block;
  }

  #WfHero--{{ section.id }} .wf-hero__copy-stack {
    position: relative;
    margin-top: 32px;
    min-height: 200px;
  }
  #WfHero--{{ section.id }} .wf-hero__copy {
    position: absolute;
    inset: 0;
    text-align: center;
    opacity: 0;
    transition: opacity 700ms ease;
    pointer-events: none;
  }
  #WfHero--{{ section.id }} .wf-hero__copy.is-active {
    opacity: 1;
    pointer-events: auto;
  }
  #WfHero--{{ section.id }} .wf-hero__heading {
    font-family: 'Montserrat', sans-serif;
    font-size: 32px;
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: #0a0a0a;
    margin: 0 0 12px;
  }
  #WfHero--{{ section.id }} .wf-hero__subtitle {
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.55;
    color: rgba(10,10,10,0.65);
    margin: 0 auto 20px;
    max-width: 56ch;
  }
  #WfHero--{{ section.id }} .wf-hero__btn {
    display: inline-block;
    background: #2E7D32;
    color: #ffffff;
    padding: 13px 30px;
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 4px;
    transition: background 200ms ease;
  }
  #WfHero--{{ section.id }} .wf-hero__btn:hover { background: #1B5E20; }

  #WfHero--{{ section.id }} .wf-hero__dots {
    display: flex;
    gap: 8px;
    justify-content: center;
    padding: 0;
    margin: 24px 0 0;
    list-style: none;
  }
  #WfHero--{{ section.id }} .wf-hero__dot {
    width: 28px;
    height: 3px;
    border-radius: 2px;
    background: rgba(10,10,10,0.18);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 200ms ease, width 200ms ease;
  }
  #WfHero--{{ section.id }} .wf-hero__dot.is-active {
    background: #0a0a0a;
    width: 40px;
  }
  #WfHero--{{ section.id }} .wf-hero__dot:hover { background: rgba(10,10,10,0.5); }

  @media (max-width: 749px) {
    #WfHero--{{ section.id }} {
      padding: 20px 16px 40px;
    }
    #WfHero--{{ section.id }} .wf-hero__inner {
      max-width: 100%;
    }
    #WfHero--{{ section.id }} .wf-hero__heading {
      font-size: 26px;
    }
    #WfHero--{{ section.id }} .wf-hero__subtitle {
      font-size: 13.5px;
    }
    #WfHero--{{ section.id }} .wf-hero__copy-stack { min-height: 220px; }
  }
  @media (min-width: 750px) {
    #WfHero--{{ section.id }} .wf-hero__heading { font-size: 42px; }
    #WfHero--{{ section.id }} .wf-hero__subtitle { font-size: 15px; }
  }
  @media (prefers-reduced-motion: reduce) {
    #WfHero--{{ section.id }} .wf-hero__slide,
    #WfHero--{{ section.id }} .wf-hero__copy { transition: none; }
  }
</style>

<section id="WfHero--{{ section.id }}"
         data-wf-hero
         data-autoplay="{{ section.settings.autoplay | default: true }}"
         data-interval="{{ section.settings.autoplay_interval | default: 6 }}">
  <div class="wf-hero__inner">

    {%- comment -%} ----- IMAGE STAGE (square) ----- {%- endcomment -%}
    <div class="wf-hero__stage">
      {%- if has_blocks -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'slide' -%}
            {%- assign idx = forloop.index0 -%}
            {%- assign is_first = false -%}
            {%- if forloop.first -%}{%- assign is_first = true -%}{%- endif -%}
            <div class="wf-hero__slide{% if is_first %} is-active{% endif %}" data-slide-index="{{ idx }}" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                {%- assign img = block.settings.image -%}
                {%- assign max_w = img.width | at_most: 5760 -%}
                <img
                  src="{{ img | image_url: width: 1200, format: 'pjpg' }}"
                  srcset="{{ img | image_url: width: 600, format: 'pjpg' }} 600w,
                          {{ img | image_url: width: 900, format: 'pjpg' }} 900w,
                          {{ img | image_url: width: 1200, format: 'pjpg' }} 1200w,
                          {{ img | image_url: width: 1600, format: 'pjpg' }} 1600w,
                          {{ img | image_url: width: 2000, format: 'pjpg' }} 2000w,
                          {{ img | image_url: width: max_w, format: 'pjpg' }} {{ max_w }}w"
                  sizes="(min-width: 750px) 720px, 100vw"
                  alt="{{ block.settings.alt_text | default: block.settings.heading | escape }}"
                  width="{{ img.width }}"
                  height="{{ img.height }}"
                  loading="{% if is_first %}eager{% else %}lazy{% endif %}"
                  {% if is_first %}fetchpriority="high"{% endif %}
                  decoding="{% if is_first %}sync{% else %}async{% endif %}">
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- elsif section.settings.image != blank -%}
        {%- assign img = section.settings.image -%}
        {%- assign max_w = img.width | at_most: 5760 -%}
        <div class="wf-hero__slide is-active" data-slide-index="0">
          <img
            src="{{ img | image_url: width: 1200, format: 'pjpg' }}"
            srcset="{{ img | image_url: width: 600, format: 'pjpg' }} 600w,
                    {{ img | image_url: width: 900, format: 'pjpg' }} 900w,
                    {{ img | image_url: width: 1200, format: 'pjpg' }} 1200w,
                    {{ img | image_url: width: 1600, format: 'pjpg' }} 1600w,
                    {{ img | image_url: width: max_w, format: 'pjpg' }} {{ max_w }}w"
            sizes="(min-width: 750px) 720px, 100vw"
            alt="{{ section.settings.heading | escape }}"
            width="{{ img.width }}"
            height="{{ img.height }}"
            loading="eager"
            fetchpriority="high"
            decoding="sync">
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ----- COPY STACK (below image) ----- {%- endcomment -%}
    <div class="wf-hero__copy-stack">
      {%- if has_blocks -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'slide' -%}
            {%- assign idx = forloop.index0 -%}
            {%- assign is_first = false -%}
            {%- if forloop.first -%}{%- assign is_first = true -%}{%- endif -%}
            <div class="wf-hero__copy{% if is_first %} is-active{% endif %}" data-copy-index="{{ idx }}">
              {%- if block.settings.heading != blank -%}
                {%- if is_first -%}
                  <h1 class="wf-hero__heading">{{ block.settings.heading }}</h1>
                {%- else -%}
                  <h2 class="wf-hero__heading">{{ block.settings.heading }}</h2>
                {%- endif -%}
              {%- endif -%}
              {%- if block.settings.subtitle != blank -%}
                <p class="wf-hero__subtitle">{{ block.settings.subtitle }}</p>
              {%- endif -%}
              {%- if block.settings.button_text != blank -%}
                <a href="{{ block.settings.button_link }}" class="wf-hero__btn">{{ block.settings.button_text }}</a>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <div class="wf-hero__copy is-active" data-copy-index="0">
          {%- if section.settings.heading != blank -%}
            <h1 class="wf-hero__heading">{{ section.settings.heading }}</h1>
          {%- endif -%}
          {%- if section.settings.subtitle != blank -%}
            <p class="wf-hero__subtitle">{{ section.settings.subtitle }}</p>
          {%- endif -%}
          {%- if section.settings.button_text != blank -%}
            <a href="{{ section.settings.button_link }}" class="wf-hero__btn">{{ section.settings.button_text }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- if has_blocks and section.blocks.size > 1 -%}
      <ul class="wf-hero__dots" role="tablist" aria-label="Hero slides">
        {%- for block in section.blocks -%}
          {%- if block.type == 'slide' -%}
            <li>
              <button type="button"
                      class="wf-hero__dot{% if forloop.first %} is-active{% endif %}"
                      data-slide-target="{{ forloop.index0 }}"
                      role="tab"
                      aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                      aria-label="Go to slide {{ forloop.index }}"></button>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

  </div>
</section>

<script>
  (function() {
    var root = document.getElementById('WfHero--{{ section.id }}');
    if (!root) return;
    var slides = root.querySelectorAll('.wf-hero__slide');
    var copies = root.querySelectorAll('.wf-hero__copy');
    if (slides.length < 2) return;

    var dots = root.querySelectorAll('.wf-hero__dot');
    var current = 0;
    var interval = parseFloat(root.dataset.interval || '6') * 1000;
    var autoplay = root.dataset.autoplay === 'true';
    var timer = null;
    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function go(idx) {
      idx = ((idx % slides.length) + slides.length) % slides.length;
      slides[current] && slides[current].classList.remove('is-active');
      copies[current] && copies[current].classList.remove('is-active');
      slides[idx] && slides[idx].classList.add('is-active');
      copies[idx] && copies[idx].classList.add('is-active');
      if (dots.length) {
        dots[current] && dots[current].classList.remove('is-active');
        dots[current] && dots[current].setAttribute('aria-selected', 'false');
        dots[idx] && dots[idx].classList.add('is-active');
        dots[idx] && dots[idx].setAttribute('aria-selected', 'true');
      }
      current = idx;
    }

    function start() {
      if (!autoplay || reduceMotion) return;
      stop();
      timer = setInterval(function() { go(current + 1); }, interval);
    }
    function stop() {
      if (timer) { clearInterval(timer); timer = null; }
    }

    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        var target = parseInt(dot.dataset.slideTarget, 10);
        if (!isNaN(target)) {
          go(target);
          stop(); start();
        }
      });
    });

    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);
    document.addEventListener('visibilitychange', function() {
      if (document.hidden) stop(); else start();
    });

    start();
  })();
</script>

{% schema %}
{
  "name": "WF Hero",
  "settings": [
    {
      "type": "header",
      "content": "Slideshow"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "label": "Seconds per slide",
      "min": 3,
      "max": 12,
      "step": 1,
      "unit": "s",
      "default": 6
    },
    {
      "type": "header",
      "content": "Legacy single-slide fallback",
      "info": "Used only if no slide blocks are added."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Hero image (mobile)"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide image (1:1 recommended)"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text",
          "info": "Falls back to the heading if blank."
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WF Hero",
      "category": "Image",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
