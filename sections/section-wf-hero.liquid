<!-- /sections/section-wf-hero.liquid -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;900&display=swap" rel="stylesheet">

{%- assign has_blocks = false -%}
{%- for b in section.blocks -%}
  {%- if b.type == 'slide' -%}{%- assign has_blocks = true -%}{%- endif -%}
{%- endfor -%}

<style>
  #WfHero--{{ section.id }} {
    position: relative;
    width: 100%;
    background: #ffffff;
    padding: 0;
    box-sizing: border-box;
  }
  #WfHero--{{ section.id }} .wf-hero__stage {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    background: #f4f4f5;
    overflow: hidden;
  }
  #WfHero--{{ section.id }} .wf-hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 700ms ease;
    will-change: opacity;
  }
  #WfHero--{{ section.id }} .wf-hero__slide.is-active { opacity: 1; }
  #WfHero--{{ section.id }} .wf-hero__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    image-rendering: -webkit-optimize-contrast;
    image-rendering: high-quality;
    display: block;
  }

  #WfHero--{{ section.id }} .wf-hero__dots {
    position: absolute;
    bottom: 16px;
    left: 0;
    right: 0;
    display: flex;
    gap: 8px;
    justify-content: center;
    padding: 0;
    margin: 0;
    list-style: none;
    z-index: 3;
  }
  #WfHero--{{ section.id }} .wf-hero__dot {
    width: 28px;
    height: 3px;
    border-radius: 2px;
    background: rgba(255,255,255,0.5);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 200ms ease, width 200ms ease;
  }
  #WfHero--{{ section.id }} .wf-hero__dot.is-active {
    background: #ffffff;
    width: 40px;
  }
  #WfHero--{{ section.id }} .wf-hero__dot:hover { background: rgba(255,255,255,0.85); }

  #WfHero--{{ section.id }} .wf-hero__arrow {
    position: absolute;
    bottom: 12px;
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    color: #ffffff;
    border: none;
    cursor: pointer;
    z-index: 4;
    padding: 0;
    transition: transform 150ms ease, opacity 200ms ease;
    -webkit-tap-highlight-color: transparent;
  }
  #WfHero--{{ section.id }} .wf-hero__arrow:hover svg { opacity: 0.7; }
  #WfHero--{{ section.id }} .wf-hero__arrow:active { transform: scale(0.92); }
  #WfHero--{{ section.id }} .wf-hero__arrow--prev { left: 6px; }
  #WfHero--{{ section.id }} .wf-hero__arrow--next { right: 6px; }
  #WfHero--{{ section.id }} .wf-hero__arrow svg {
    width: 26px;
    height: 26px;
    display: block;
    filter: drop-shadow(0 1px 3px rgba(0,0,0,0.55));
    transition: opacity 200ms ease;
  }

  #WfHero--{{ section.id }} .wf-hero__stage {
    touch-action: pan-y;
  }

  #WfHero--{{ section.id }} .wf-hero__copy {
    padding: 28px 24px 36px;
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }
  #WfHero--{{ section.id }} .wf-hero__heading {
    font-family: 'Montserrat', sans-serif;
    font-size: 26px;
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: #0a0a0a;
    margin: 0 0 12px;
  }
  #WfHero--{{ section.id }} .wf-hero__subtitle {
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.55;
    color: rgba(10,10,10,0.65);
    margin: 0 auto 20px;
    max-width: 56ch;
  }
  #WfHero--{{ section.id }} .wf-hero__btn {
    display: inline-block;
    background: #2E7D32;
    color: #ffffff;
    padding: 13px 30px;
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 4px;
    transition: background 200ms ease;
  }
  #WfHero--{{ section.id }} .wf-hero__btn:hover { background: #1B5E20; }

  @media (min-width: 750px) {
    #WfHero--{{ section.id }} .wf-hero__stage {
      aspect-ratio: auto;
      height: calc(70vh - 100px);
      min-height: 320px;
    }
    #WfHero--{{ section.id }} .wf-hero__heading { font-size: 20px; }
    #WfHero--{{ section.id }} .wf-hero__subtitle { font-size: 14px; }
    #WfHero--{{ section.id }} .wf-hero__copy { padding: 24px 24px 40px; }
  }
  @media (prefers-reduced-motion: reduce) {
    #WfHero--{{ section.id }} .wf-hero__slide { transition: none; }
  }
</style>

<section id="WfHero--{{ section.id }}"
         data-wf-hero
         data-autoplay="{{ section.settings.autoplay | default: true }}"
         data-interval="{{ section.settings.autoplay_interval | default: 6 }}">

  {%- comment -%} ----- IMAGE STAGE (square, slideshow) ----- {%- endcomment -%}
  <div class="wf-hero__stage">
    {%- if has_blocks -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'slide' -%}
          {%- assign idx = forloop.index0 -%}
          {%- assign is_first = false -%}
          {%- if forloop.first -%}{%- assign is_first = true -%}{%- endif -%}
          <div class="wf-hero__slide{% if is_first %} is-active{% endif %}" data-slide-index="{{ idx }}" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {%- assign img = block.settings.image -%}
              {%- assign max_w = img.width | at_most: 5760 -%}
              <img
                src="{{ img | image_url: width: 1600, format: 'pjpg' }}"
                srcset="{{ img | image_url: width: 600, format: 'pjpg' }} 600w,
                        {{ img | image_url: width: 900, format: 'pjpg' }} 900w,
                        {{ img | image_url: width: 1200, format: 'pjpg' }} 1200w,
                        {{ img | image_url: width: 1600, format: 'pjpg' }} 1600w,
                        {{ img | image_url: width: 2000, format: 'pjpg' }} 2000w,
                        {{ img | image_url: width: max_w, format: 'pjpg' }} {{ max_w }}w"
                sizes="100vw"
                alt="{{ block.settings.alt_text | default: section.settings.heading | escape }}"
                width="{{ img.width }}"
                height="{{ img.height }}"
                loading="{% if is_first %}eager{% else %}lazy{% endif %}"
                {% if is_first %}fetchpriority="high"{% endif %}
                decoding="{% if is_first %}sync{% else %}async{% endif %}">
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    {%- elsif section.settings.image != blank -%}
      {%- assign img = section.settings.image -%}
      {%- assign max_w = img.width | at_most: 5760 -%}
      <div class="wf-hero__slide is-active" data-slide-index="0">
        <img
          src="{{ img | image_url: width: 1600, format: 'pjpg' }}"
          srcset="{{ img | image_url: width: 600, format: 'pjpg' }} 600w,
                  {{ img | image_url: width: 900, format: 'pjpg' }} 900w,
                  {{ img | image_url: width: 1200, format: 'pjpg' }} 1200w,
                  {{ img | image_url: width: 1600, format: 'pjpg' }} 1600w,
                  {{ img | image_url: width: max_w, format: 'pjpg' }} {{ max_w }}w"
          sizes="100vw"
          alt="{{ section.settings.heading | escape }}"
          width="{{ img.width }}"
          height="{{ img.height }}"
          loading="eager"
          fetchpriority="high"
          decoding="sync">
      </div>
    {%- endif -%}

    {%- if has_blocks and section.blocks.size > 1 -%}
      <button type="button" class="wf-hero__arrow wf-hero__arrow--prev" data-hero-prev aria-label="Previous slide">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <button type="button" class="wf-hero__arrow wf-hero__arrow--next" data-hero-next aria-label="Next slide">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
      <ul class="wf-hero__dots" role="tablist" aria-label="Hero slides">
        {%- for block in section.blocks -%}
          {%- if block.type == 'slide' -%}
            <li>
              <button type="button"
                      class="wf-hero__dot{% if forloop.first %} is-active{% endif %}"
                      data-slide-target="{{ forloop.index0 }}"
                      role="tab"
                      aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                      aria-label="Go to slide {{ forloop.index }}"></button>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>

  {%- comment -%} ----- STATIC COPY (does NOT change with slide) ----- {%- endcomment -%}
  <div class="wf-hero__copy">
    {%- if section.settings.heading != blank -%}
      <h1 class="wf-hero__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="wf-hero__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    {%- if section.settings.button_text != blank -%}
      <a href="{{ section.settings.button_link }}" class="wf-hero__btn">{{ section.settings.button_text }}</a>
    {%- endif -%}
  </div>
</section>

<script>
  (function() {
    var root = document.getElementById('WfHero--{{ section.id }}');
    if (!root) return;
    var slides = root.querySelectorAll('.wf-hero__slide');
    if (slides.length < 2) return;

    var dots = root.querySelectorAll('.wf-hero__dot');
    var current = 0;
    var interval = parseFloat(root.dataset.interval || '6') * 1000;
    var autoplay = root.dataset.autoplay === 'true';
    var timer = null;
    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function go(idx) {
      idx = ((idx % slides.length) + slides.length) % slides.length;
      slides[current] && slides[current].classList.remove('is-active');
      slides[idx] && slides[idx].classList.add('is-active');
      if (dots.length) {
        dots[current] && dots[current].classList.remove('is-active');
        dots[current] && dots[current].setAttribute('aria-selected', 'false');
        dots[idx] && dots[idx].classList.add('is-active');
        dots[idx] && dots[idx].setAttribute('aria-selected', 'true');
      }
      current = idx;
    }

    function start() {
      if (!autoplay || reduceMotion) return;
      stop();
      timer = setInterval(function() { go(current + 1); }, interval);
    }
    function stop() {
      if (timer) { clearInterval(timer); timer = null; }
    }

    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        var target = parseInt(dot.dataset.slideTarget, 10);
        if (!isNaN(target)) {
          go(target);
          stop(); start();
        }
      });
    });

    var prevBtn = root.querySelector('[data-hero-prev]');
    var nextBtn = root.querySelector('[data-hero-next]');
    if (prevBtn) prevBtn.addEventListener('click', function() { go(current - 1); stop(); start(); });
    if (nextBtn) nextBtn.addEventListener('click', function() { go(current + 1); stop(); start(); });

    // Touch / swipe support on the image stage
    var stage = root.querySelector('.wf-hero__stage');
    if (stage) {
      var touchStartX = 0, touchStartY = 0, touchActive = false;
      var SWIPE_THRESHOLD = 40; // px
      stage.addEventListener('touchstart', function(e) {
        if (!e.touches || e.touches.length !== 1) return;
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
        touchActive = true;
        stop();
      }, { passive: true });
      stage.addEventListener('touchend', function(e) {
        if (!touchActive) return;
        touchActive = false;
        var t = (e.changedTouches && e.changedTouches[0]) || null;
        if (!t) return;
        var dx = t.clientX - touchStartX;
        var dy = t.clientY - touchStartY;
        // Only count as a swipe if horizontal movement dominates and exceeds threshold
        if (Math.abs(dx) > SWIPE_THRESHOLD && Math.abs(dx) > Math.abs(dy) * 1.5) {
          go(dx < 0 ? current + 1 : current - 1);
        }
        start();
      }, { passive: true });
      stage.addEventListener('touchcancel', function() { touchActive = false; start(); }, { passive: true });
    }

    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);
    document.addEventListener('visibilitychange', function() {
      if (document.hidden) stop(); else start();
    });

    start();
  })();
</script>

{% schema %}
{
  "name": "WF Hero",
  "settings": [
    {
      "type": "header",
      "content": "Static copy (shown below image)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Posters"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Image slideshow"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "label": "Seconds per slide",
      "min": 3,
      "max": 12,
      "step": 1,
      "unit": "s",
      "default": 6
    },
    {
      "type": "header",
      "content": "Single-image fallback",
      "info": "Used only if no slide blocks are added."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide image",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (1:1 recommended)"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text",
          "info": "Falls back to the section heading if blank."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WF Hero",
      "category": "Image",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
