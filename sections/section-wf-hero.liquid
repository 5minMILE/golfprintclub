<!-- /sections/section-wf-hero.liquid -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;900&display=swap" rel="stylesheet">

{%- comment -%}
  Backwards-compatible fallback: if no slide blocks are configured, render a
  single slide from the legacy section settings. This way an existing index.json
  that still has the old settings keeps working until a block is added.
{%- endcomment -%}
{%- assign has_blocks = false -%}
{%- for b in section.blocks -%}
  {%- if b.type == 'slide' -%}{%- assign has_blocks = true -%}{%- endif -%}
{%- endfor -%}

<style>
  #WfHero--{{ section.id }} {
    position: relative;
    width: 100%;
    height: 90vh;
    background: #111;
    overflow: hidden;
  }
  #WfHero--{{ section.id }} .wf-hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 700ms ease;
    will-change: opacity;
  }
  #WfHero--{{ section.id }} .wf-hero__slide.is-active { opacity: 1; }
  #WfHero--{{ section.id }} .wf-hero__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
    image-rendering: -webkit-optimize-contrast;
    image-rendering: high-quality;
    image-rendering: crisp-edges;
  }
  #WfHero--{{ section.id }} .wf-hero__img--desktop { display: block; }
  #WfHero--{{ section.id }} .wf-hero__img--mobile { display: none; }
  #WfHero--{{ section.id }} .wf-hero__slide::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
    z-index: 1;
    pointer-events: none;
  }
  #WfHero--{{ section.id }} .wf-hero__overlay {
    position: absolute;
    bottom: 60px;
    left: 40px;
    right: 40px;
    max-width: 640px;
    z-index: 2;
  }
  #WfHero--{{ section.id }} .wf-hero__subtitle {
    font-family: 'Montserrat', sans-serif;
    font-size: 8px;
    font-weight: 600;
    color: #fff;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1.5;
    max-width: 48ch;
    margin-top: 14px;
  }
  #WfHero--{{ section.id }} .wf-hero__heading {
    font-family: 'Montserrat', sans-serif;
    font-size: 32px;
    font-weight: 1000;
    color: #fff;
    text-transform: uppercase;
    line-height: 1.05;
    letter-spacing: -0.005em;
    margin: 0;
  }
  #WfHero--{{ section.id }} .wf-hero__btn {
    display: inline-block;
    margin-top: 12px;
    background: #1B5E20;
    color: #fff;
    padding: 10px 24px;
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    font-weight: 1000;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    cursor: pointer;
  }

  #WfHero--{{ section.id }} .wf-hero__dots {
    position: absolute;
    bottom: 24px;
    left: 0;
    right: 0;
    display: flex;
    gap: 8px;
    justify-content: center;
    z-index: 3;
    padding: 0;
    margin: 0;
    list-style: none;
  }
  #WfHero--{{ section.id }} .wf-hero__dot {
    width: 28px;
    height: 3px;
    border-radius: 2px;
    background: rgba(255,255,255,0.35);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 200ms ease, width 200ms ease;
  }
  #WfHero--{{ section.id }} .wf-hero__dot.is-active {
    background: #ffffff;
    width: 40px;
  }
  #WfHero--{{ section.id }} .wf-hero__dot:hover { background: rgba(255,255,255,0.7); }

  @media (max-width: 749px) {
    #WfHero--{{ section.id }} {
      height: 70vh;
    }
    #WfHero--{{ section.id }} .wf-hero__overlay {
      bottom: 60px;
      left: 40px;
    }
    #WfHero--{{ section.id }} .wf-hero__subtitle {
      font-size: 10.5px;
    }
    #WfHero--{{ section.id }} .wf-hero__heading {
      font-size: 36px;
    }
    #WfHero--{{ section.id }} .wf-hero__btn {
      margin-top: 8px;
      padding: 13.5px 30px;
      font-size: 13.5px;
      letter-spacing: 0.1em;
      background: #2E7D32;
    }
    #WfHero--{{ section.id }} .wf-hero__img--desktop { display: none !important; }
    #WfHero--{{ section.id }} .wf-hero__img--mobile { display: block !important; }
    #WfHero--{{ section.id }} .wf-hero__dots { bottom: 18px; }
    #WfHero--{{ section.id }} .wf-hero__dot { width: 22px; }
    #WfHero--{{ section.id }} .wf-hero__dot.is-active { width: 32px; }
  }
  @media (min-width: 750px) {
    #WfHero--{{ section.id }} .wf-hero__subtitle {
      font-size: 13px;
      color: #fff;
      margin-top: 16px;
    }
    #WfHero--{{ section.id }} .wf-hero__heading {
      font-size: 48px;
    }
    #WfHero--{{ section.id }} .wf-hero__btn {
      background: #2E7D32;
      padding: 14px 32px;
      font-size: 14px;
      font-weight: 800;
      letter-spacing: 0.14em;
      margin-top: 18px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    #WfHero--{{ section.id }} .wf-hero__slide { transition: none; }
  }
</style>

<section id="WfHero--{{ section.id }}"
         data-wf-hero
         data-autoplay="{{ section.settings.autoplay | default: true }}"
         data-interval="{{ section.settings.autoplay_interval | default: 6 }}">

  {%- if has_blocks -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'slide' -%}
        {%- assign slide_index = forloop.index0 -%}
        {%- assign is_first = false -%}
        {%- if forloop.first -%}{%- assign is_first = true -%}{%- endif -%}
        <div class="wf-hero__slide{% if is_first %} is-active{% endif %}" data-slide-index="{{ slide_index }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {%- assign img = block.settings.image -%}
            {%- assign max_w = img.width | at_most: 5760 -%}
            <img class="wf-hero__img--desktop"
              src="{{ img | image_url: width: 2400, format: 'pjpg' }}"
              srcset="{{ img | image_url: width: 1200, format: 'pjpg' }} 1200w,
                      {{ img | image_url: width: 1800, format: 'pjpg' }} 1800w,
                      {{ img | image_url: width: 2400, format: 'pjpg' }} 2400w,
                      {{ img | image_url: width: 3200, format: 'pjpg' }} 3200w,
                      {{ img | image_url: width: 4000, format: 'pjpg' }} 4000w,
                      {{ img | image_url: width: max_w, format: 'pjpg' }} {{ max_w }}w"
              sizes="100vw"
              alt="{{ block.settings.alt_text | default: block.settings.heading | escape }}"
              width="{{ img.width }}"
              height="{{ img.height }}"
              loading="{% if is_first %}eager{% else %}lazy{% endif %}"
              {% if is_first %}fetchpriority="high"{% endif %}
              decoding="{% if is_first %}sync{% else %}async{% endif %}">
          {%- endif -%}
          {%- if block.settings.mobile_image != blank -%}
            {%- assign mimg = block.settings.mobile_image -%}
            {%- assign mmax_w = mimg.width | at_most: 2000 -%}
            <img class="wf-hero__img--mobile"
              src="{{ mimg | image_url: width: mmax_w, format: 'pjpg' }}"
              srcset="{{ mimg | image_url: width: 600, format: 'pjpg' }} 600w,
                      {{ mimg | image_url: width: 900, format: 'pjpg' }} 900w,
                      {{ mimg | image_url: width: 1200, format: 'pjpg' }} 1200w,
                      {{ mimg | image_url: width: 1600, format: 'pjpg' }} 1600w,
                      {{ mimg | image_url: width: mmax_w, format: 'pjpg' }} {{ mmax_w }}w"
              sizes="100vw"
              alt="{{ block.settings.alt_text | default: block.settings.heading | escape }}"
              width="{{ mimg.width }}"
              height="{{ mimg.height }}"
              loading="{% if is_first %}eager{% else %}lazy{% endif %}"
              {% if is_first %}fetchpriority="high"{% endif %}
              decoding="{% if is_first %}sync{% else %}async{% endif %}">
          {%- elsif block.settings.image != blank -%}
            {%- assign img = block.settings.image -%}
            {%- assign mmax_w = img.width | at_most: 2000 -%}
            <img class="wf-hero__img--mobile"
              src="{{ img | image_url: width: mmax_w, format: 'pjpg' }}"
              srcset="{{ img | image_url: width: 600, format: 'pjpg' }} 600w,
                      {{ img | image_url: width: 900, format: 'pjpg' }} 900w,
                      {{ img | image_url: width: 1200, format: 'pjpg' }} 1200w,
                      {{ img | image_url: width: 1600, format: 'pjpg' }} 1600w,
                      {{ img | image_url: width: mmax_w, format: 'pjpg' }} {{ mmax_w }}w"
              sizes="100vw"
              alt="{{ block.settings.alt_text | default: block.settings.heading | escape }}"
              width="{{ img.width }}"
              height="{{ img.height }}"
              loading="{% if is_first %}eager{% else %}lazy{% endif %}"
              {% if is_first %}fetchpriority="high"{% endif %}
              decoding="{% if is_first %}sync{% else %}async{% endif %}">
          {%- endif -%}
          <div class="wf-hero__overlay">
            {%- if block.settings.heading != blank -%}
              {%- if is_first -%}
                <h1 class="wf-hero__heading">{{ block.settings.heading }}</h1>
              {%- else -%}
                <h2 class="wf-hero__heading">{{ block.settings.heading }}</h2>
              {%- endif -%}
            {%- endif -%}
            {%- if block.settings.subtitle != blank -%}
              <div class="wf-hero__subtitle">{{ block.settings.subtitle }}</div>
            {%- endif -%}
            {%- if block.settings.button_text != blank -%}
              <a href="{{ block.settings.button_link }}" class="wf-hero__btn">{{ block.settings.button_text }}</a>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}

    {%- if section.blocks.size > 1 -%}
      <ul class="wf-hero__dots" role="tablist" aria-label="Hero slides">
        {%- for block in section.blocks -%}
          {%- if block.type == 'slide' -%}
            <li>
              <button type="button"
                      class="wf-hero__dot{% if forloop.first %} is-active{% endif %}"
                      data-slide-target="{{ forloop.index0 }}"
                      role="tab"
                      aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                      aria-label="Go to slide {{ forloop.index }}"></button>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

  {%- else -%}
    {%- comment -%} Legacy single-slide fallback {%- endcomment -%}
    <div class="wf-hero__slide is-active" data-slide-index="0">
      {%- if section.settings.image != blank -%}
        {%- assign img = section.settings.image -%}
        {%- assign max_w = img.width | at_most: 5760 -%}
        <img class="wf-hero__img--desktop"
          src="{{ img | image_url: width: 2400, format: 'pjpg' }}"
          srcset="{{ img | image_url: width: 1200, format: 'pjpg' }} 1200w,
                  {{ img | image_url: width: 1800, format: 'pjpg' }} 1800w,
                  {{ img | image_url: width: 2400, format: 'pjpg' }} 2400w,
                  {{ img | image_url: width: 3200, format: 'pjpg' }} 3200w,
                  {{ img | image_url: width: 4000, format: 'pjpg' }} 4000w,
                  {{ img | image_url: width: max_w, format: 'pjpg' }} {{ max_w }}w"
          sizes="100vw"
          alt="{{ section.settings.heading | escape }}"
          width="{{ img.width }}"
          height="{{ img.height }}"
          loading="eager"
          fetchpriority="high"
          decoding="sync">
      {%- endif -%}
      {%- if section.settings.mobile_image != blank -%}
        {%- assign mimg = section.settings.mobile_image -%}
        {%- assign mmax_w = mimg.width | at_most: 2000 -%}
        <img class="wf-hero__img--mobile"
          src="{{ mimg | image_url: width: mmax_w, format: 'pjpg' }}"
          srcset="{{ mimg | image_url: width: 600, format: 'pjpg' }} 600w,
                  {{ mimg | image_url: width: 900, format: 'pjpg' }} 900w,
                  {{ mimg | image_url: width: 1200, format: 'pjpg' }} 1200w,
                  {{ mimg | image_url: width: 1600, format: 'pjpg' }} 1600w,
                  {{ mimg | image_url: width: mmax_w, format: 'pjpg' }} {{ mmax_w }}w"
          sizes="100vw"
          alt="{{ section.settings.heading | escape }}"
          width="{{ mimg.width }}"
          height="{{ mimg.height }}"
          loading="eager"
          fetchpriority="high"
          decoding="sync">
      {%- elsif section.settings.image != blank -%}
        {%- assign img = section.settings.image -%}
        {%- assign mmax_w = img.width | at_most: 2000 -%}
        <img class="wf-hero__img--mobile"
          src="{{ img | image_url: width: mmax_w, format: 'pjpg' }}"
          srcset="{{ img | image_url: width: 600, format: 'pjpg' }} 600w,
                  {{ img | image_url: width: 900, format: 'pjpg' }} 900w,
                  {{ img | image_url: width: 1200, format: 'pjpg' }} 1200w,
                  {{ img | image_url: width: 1600, format: 'pjpg' }} 1600w,
                  {{ img | image_url: width: mmax_w, format: 'pjpg' }} {{ mmax_w }}w"
          sizes="100vw"
          alt="{{ section.settings.heading | escape }}"
          width="{{ img.width }}"
          height="{{ img.height }}"
          loading="eager"
          fetchpriority="high"
          decoding="sync">
      {%- endif -%}
      <div class="wf-hero__overlay">
        {%- if section.settings.heading != blank -%}
          <h1 class="wf-hero__heading">{{ section.settings.heading }}</h1>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <div class="wf-hero__subtitle">{{ section.settings.subtitle }}</div>
        {%- endif -%}
        {%- if section.settings.button_text != blank -%}
          <a href="{{ section.settings.button_link }}" class="wf-hero__btn">{{ section.settings.button_text }}</a>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}
</section>

<script>
  (function() {
    var root = document.getElementById('WfHero--{{ section.id }}');
    if (!root) return;
    var slides = root.querySelectorAll('.wf-hero__slide');
    if (slides.length < 2) return;

    var dots = root.querySelectorAll('.wf-hero__dot');
    var current = 0;
    var interval = parseFloat(root.dataset.interval || '6') * 1000;
    var autoplay = root.dataset.autoplay === 'true';
    var timer = null;
    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function go(idx) {
      idx = ((idx % slides.length) + slides.length) % slides.length;
      slides[current].classList.remove('is-active');
      slides[idx].classList.add('is-active');
      if (dots.length) {
        dots[current] && dots[current].classList.remove('is-active');
        dots[current] && dots[current].setAttribute('aria-selected', 'false');
        dots[idx] && dots[idx].classList.add('is-active');
        dots[idx] && dots[idx].setAttribute('aria-selected', 'true');
      }
      current = idx;
    }

    function start() {
      if (!autoplay || reduceMotion) return;
      stop();
      timer = setInterval(function() { go(current + 1); }, interval);
    }
    function stop() {
      if (timer) { clearInterval(timer); timer = null; }
    }

    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        var target = parseInt(dot.dataset.slideTarget, 10);
        if (!isNaN(target)) {
          go(target);
          stop();
          start();
        }
      });
    });

    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);
    document.addEventListener('visibilitychange', function() {
      if (document.hidden) stop(); else start();
    });

    start();
  })();
</script>

{% schema %}
{
  "name": "WF Hero",
  "settings": [
    {
      "type": "header",
      "content": "Slideshow"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "label": "Seconds per slide",
      "min": 3,
      "max": 12,
      "step": 1,
      "unit": "s",
      "default": 6
    },
    {
      "type": "header",
      "content": "Legacy single-slide fallback",
      "info": "Used only if no slide blocks are added. Once you add slide blocks, these are ignored."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Hero image (mobile)"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide image (desktop)"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Slide image (mobile)"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text",
          "info": "Falls back to the heading if blank."
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WF Hero",
      "category": "Image",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
