<!-- /sections/collections.liquid -->

{%- liquid
  assign enable_sort = section.settings.enable_sort
  assign enable_filters = section.settings.enable_filters
  assign filter_layout = section.settings.filter_layout
  assign border_color = section.settings.border_color

  if filter_layout == 'inline-open'
    assign filters_expanded = true
  endif
  comment
    The product limit decrement will be removed once we add more block types
  endcomment

  assign product_limit = section.settings.products_per_page
  assign blocks_featured_image = section.blocks | where: "type", "featured_image"

  assign columns_desktop = section.settings.grid | plus: 0
  assign columns_medium = 3
  assign columns_small = 2
  assign columns_mobile = section.settings.grid_mobile | plus: 0

  if columns_desktop == 2 or columns_desktop == 4
    assign columns_medium = 2
  endif

  assign animation_anchor = '.collection-' | append: collection.handle
  assign animation_duration = 800
-%}

{%- capture image_sizes -%}
  {%- if settings.grid_style == 'compact' -%}
    (min-width: 1400px) calc((100vw - 288px) / {{ columns_desktop }}), (min-width: 750px) calc((100vw - 258px) / {{ columns_medium }}), (min-width: 480px) calc(100vw / {{ columns_small }}), calc(100vw / {{ columns_mobile }})
  {%- else -%}
    (min-width: 1400px) calc((100vw - 288px - 100px) / {{ columns_desktop }} - 32px), (min-width: 750px) calc((100vw - 258px - 64px) / {{ columns_medium }} - 32px), (min-width: 480px) calc((100vw - 32px) / {{ columns_small }}), calc((100vw - 32px) / {{ columns_mobile }})
  {%- endif -%}
{%- endcapture -%}

{%- style -%}
  #Collection--{{ section.id }} {
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;

    --COLUMNS: {{ columns_desktop }};
    --COLUMNS-MEDIUM: {{ columns_medium }};
    --COLUMNS-SMALL: {{ columns_small }};
    --COLUMNS-MOBILE: {{ columns_mobile }};

    {% unless border_color == 'rgba(0,0,0,0)' or border_color == blank %}
      --hairline: {{ border_color }};
    {% endunless %}
  }

    /* =========================
     RC / Gymshark-like Collection Layout
     Scoped to this collection section
     ========================= */

  #Collection--{{ section.id }} .collection__products{
    max-width: 3000px;
    margin: 0 auto;
  }

  /* Desktop: sidebar left, grid right */
  @media (min-width: 990px){
    #Collection--{{ section.id }} .collection__products{
      display: grid;
      grid-template-columns: 320px 1fr;
      gap: 10px;
      align-items: start;
      padding: 20px;
    }

    /* sticky sidebar like Gymshark */
    #Collection--{{ section.id }} .collection__sidebar__slide-out,
    #Collection--{{ section.id }} .collection__sidebar__slider{
      position: sticky;
      top: 20px;
      height: calc(100vh - 40px);
      overflow: auto;
      padding-right: 6px;
    }
  }

  /* Tablet/Mobile spacing */
  @media (max-width: 989px){
    #Collection--{{ section.id }} .collection__products{
      padding: 10px;
    }
  }

  /* Tighten grid spacing */
  #Collection--{{ section.id }} .grid-outer .grid{
    gap: 12px;
  }

  @media (max-width: 989px){
    #Collection--{{ section.id }} .rc-mobile-btn{
      width: 100%;
      height: 44px;
      border-radius: 999px;
      border: 1px solid rgba(0,0,0,.15);
      background: #f2f2f2;
      font-weight: 800;
      letter-spacing: .02em;
    }
  }

  /* === RC: Gymshark-style PLP layout === */
#Collection--{{ section.id }} .collection__products{
  max-width: 3000px;
  margin: 0 auto;
  padding: 0 20px;
  display: grid;
  grid-template-columns: 320px 1fr;
  gap: 10px;
  align-items: start;
}

/* Sidebar stays left, scrolls with you */
#Collection--{{ section.id }} [data-collection-sidebar]{
  position: sticky;
  top: 110px; /* adjust if your header is taller/shorter */
  height: calc(100vh - 130px);
  overflow: auto;
  -webkit-overflow-scrolling: touch;
  padding-right: 8px;
}

/* Keep grid full width of its column */
#Collection--{{ section.id }} .grid-outer{
  min-width: 0;
}

/* Mobile/tablet: stack like Gymshark */
@media (max-width: 1024px){
  #Collection--{{ section.id }} .collection__products{
    grid-template-columns: 1fr;
    padding: 0 10px;
  }
  #Collection--{{ section.id }} [data-collection-sidebar]{
    position: relative;
    top: auto;
    height: auto;
    overflow: visible;
    padding-right: 0;
  }
}

#Collection--{{ section.id }} .collection__nav{
  max-width: 3000px;
  margin: 0 auto;
  padding: 12px 20px;
  display: flex;
  justify-content: space-between;
  gap: 12px;
  align-items: center;
}

@media (max-width: 1024px){
  #Collection--{{ section.id }} .collection__nav{
    padding: 12px 10px;
  }
}

/* ===== RC Mobile Controls (Gymshark-style) ===== */
#Collection--{{ section.id }} .rc-m-controls{
  display:none;
  align-items:center;
  justify-content:space-between;
  gap:10px;
  margin: 10px 0 14px;
  font-family: var(--BTN-FONT-STYLE);
}

#Collection--{{ section.id }} .rc-m-left{ display:flex; gap:8px; align-items:center; }

#Collection--{{ section.id }} .rc-m-pill{
  display:flex;
  align-items:center;
  gap:6px;
  padding:10px 12px;
  border-radius:999px;
  border:1px solid rgba(0,0,0,.08);
  background:#f3f3f3;
}

#Collection--{{ section.id }} .rc-m-btn{
  border:0;
  background:transparent;
  padding:8px 10px;
  border-radius:999px;
  cursor:pointer;
  line-height:0;
  opacity:.55;
  transition:opacity .15s ease, transform .15s ease, background .15s ease;
}

#Collection--{{ section.id }} .rc-m-btn[aria-pressed="true"]{
  opacity:1;
  background:#fff;
}

#Collection--{{ section.id }} .rc-m-filter{
  flex:1;
  display:flex;
  align-items:center;
  justify-content:center;
  gap:8px;
  padding:12px 14px;
  border-radius:999px;
  border:1px solid rgba(0,0,0,.08);
  background:#f3f3f3;
  cursor:pointer;
  font-weight: 800;
  letter-spacing:.02em;
}

@media (max-width: 763px){
  #Collection--{{ section.id }} .rc-m-controls{ display:flex; }
  body.rc-grid-1 #CollectionLoop{ grid-template-columns: 1fr !important; }
  body.rc-grid-2 #CollectionLoop{ grid-template-columns: repeat(2, minmax(0, 1fr)) !important; }
}
@media (min-width: 3000px){
  #Collection--{{ section.id }} .collection__products{
    max-width: 3000px;
    margin: 0 auto;
    padding: 0;
    display: grid;
    grid-template-columns: 600px 1fr;
    gap: 10px;
    align-items: start;
  }
}

/* =========================
   RC Mobile Bottom Sheet Filters
   ========================= */
@media (max-width: 989px){
  /* Make the filter panel a bottom sheet */
  #Collection--{{ section.id }} [data-collection-sidebar]{
    position: fixed !important;
        left: 0;
        right: 0;
        bottom: 0;
        top: auto !important;
        height: 85vh;
        max-height: 85vh;
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, .25);
        transform: translateY(110%);
        transition: transform .25s ease;
        z-index: 10000;
        overflow: auto;
        -webkit-overflow-scrolling: touch;
    padding-right: 0;
  }

  /* Dark overlay behind the sheet */
  #Collection--{{ section.id }} .underlay{
    position: fixed !important;
    inset: 0;
    background: rgba(0,0,0,.45);
    opacity: 0;
    pointer-events: none;
    transition: opacity .2s ease;
    z-index: 9999;
  }

  /* When open */
  #Collection--{{ section.id }}.rc-sheet-open [data-collection-sidebar]{
    transform: translateY(0);
  }
  #Collection--{{ section.id }}.rc-sheet-open .underlay{
    opacity: 1;
    pointer-events: auto;
  }

  /* OPTIONAL: hide the desktop inline sidebar styles on mobile */
  #Collection--{{ section.id }} .collection__sidebar__slider{
    display: block !important; /* keep it available for the sheet */
    position: fixed !important; /* sheet takes over */
  }
}

/* =========================
   RC Mobile Toolbar (Gymshark-ish)
   ========================= */
#Collection--{{ section.id }} .rc-mobile-toolbar{ display:none; }

@media (max-width: 989px){
  #Collection--{{ section.id }} .rc-mobile-toolbar{
    display:flex;
    gap: 10px;
    align-items: center;
    padding: 12px 10px 6px;
    max-width: 3000px;
    margin: 0 auto;
  }

  #Collection--{{ section.id }} .rc-viewtoggle{
    display:flex;
    gap: 6px;
    background: #f2f2f2;
    border: 1px solid rgba(0,0,0,.12);
    border-radius: 999px;
    padding: 6px;
  }
  #Collection--{{ section.id }} .rc-viewbtn{
    width: 44px;
    height: 36px;
    border-radius: 999px;
    border: 0;
    background: transparent;
    font-weight: 800;
    cursor: pointer;
  }
  #Collection--{{ section.id }} .rc-viewbtn.is-active{
    background: #fff;
    box-shadow: 0 1px 6px rgba(0,0,0,.08);
  }

  #Collection--{{ section.id }} .rc-filterbtn{
    flex: 1;
    height: 44px;
    border-radius: 999px;
    border: 1px solid rgba(0,0,0,.12);
    background: #f2f2f2;
    font-weight: 900;
    letter-spacing: .02em;
    cursor: pointer;
  }
}

/* =========================
   RC Mobile Bottom Sheet Filters
   ========================= */
@media (max-width: 989px){
  #Collection--{{ section.id }} [data-collection-sidebar]{
    position: fixed !important;
    left: 0px;
    right: 0px;
    bottom: 0px;
    top: auto !important;

    height: 85vh;
    max-height: 85vh;

    background: #fff;
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(0,0,0,.25);

    transform: translateY(110%);
    transition: transform .25s ease;
    z-index: 10000;

    overflow: auto;
    -webkit-overflow-scrolling: touch;
  }

  #Collection--{{ section.id }} .underlay{
    position: fixed !important;
    inset: 0;
    background: rgba(0,0,0,.45);
    opacity: 0;
    pointer-events: none;
    transition: opacity .2s ease;
    z-index: 9999;
  }

  #Collection--{{ section.id }}.rc-sheet-open [data-collection-sidebar]{
    transform: translateY(0);
  }
  #Collection--{{ section.id }}.rc-sheet-open .underlay{
    opacity: 1;
    pointer-events: auto;
  }
}

/* =========================
   RC Mobile grid toggle (2 per row vs 1 per row)
   ========================= */
@media (max-width: 989px){
  #Collection--{{ section.id }}.rc-grid-1{
    --COLUMNS-MOBILE: 1;
  }
  #Collection--{{ section.id }}.rc-grid-2{
    --COLUMNS-MOBILE: 2;
  }
}

.collection__products .grid-outer{
  padding:0;
}

/* =========================
   RC Better Filters UI
   ========================= */

/* Bottom-sheet header (sticky) */
@media (max-width: 989px){
  #Collection--{{ section.id }} .rc-filter-head{
    position: sticky;
    top: 0;
    z-index: 2;
    display: grid;
    grid-template-columns: 44px 1fr auto;
    align-items: center;
    gap: 10px;
    padding: 14px 14px;
    background: #fff;
    border-bottom: 1px solid rgba(0,0,0,.08);
  }

  #Collection--{{ section.id }} .rc-filter-x{
    width: 44px;
    height: 44px;
    border: 0;
    background: transparent;
    border-radius: 12px;
    cursor: pointer;
  }

  #Collection--{{ section.id }} .rc-filter-title{
    margin: 0;
    text-align: center;
    font-weight: 900;
    letter-spacing: .02em;
    font-size: 14px;
  }

  #Collection--{{ section.id }} .rc-filter-clear{
    font-size: 13px;
    font-weight: 700;
    color: rgba(0,0,0,.55);
    text-decoration: none;
    padding: 10px 10px;
    border-radius: 10px;
    white-space: nowrap;
  }
}

/* Sidebar section spacing */
#Collection--{{ section.id }} [data-collection-sidebar]{
  padding: 0; /* header handles top padding */
  width:100%;
}

/* The actual filter content wrapper (inside sidebar) */
#Collection--{{ section.id }} [data-collection-sidebar] .collection__sidebar__inner,
#Collection--{{ section.id }} [data-collection-sidebar] .collection__filters{
  padding: 0;
  width: 100%;
}

/* Each filter group row (bigger tap target / clean dividers) */
#Collection--{{ section.id }} [data-collection-sidebar] details{
  border-bottom: 1px solid #ddd;
}

#Collection--{{ section.id }} [data-collection-sidebar] details > summary{
  list-style: none;
  cursor: pointer;
  padding: 16px 0;
  font-weight: 900;
  letter-spacing: .02em;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

#Collection--{{ section.id }} [data-collection-sidebar] details > summary::-webkit-details-marker{
  display:none;
}

/* Inputs area */
#Collection--{{ section.id }} [data-collection-sidebar] .collection__sidebar__content,
#Collection--{{ section.id }} [data-collection-sidebar] .filter-group__content{
  padding: 0 0 14px;
}

/* Make checkboxes/radios easier to tap */
#Collection--{{ section.id }} [data-collection-sidebar] label{
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 0px 0;
}

#Collection--{{ section.id }} .rc-active-filters{
  display:flex;
  flex-wrap:wrap;
  gap:8px;
  padding: 0 10px 10px;
}
#Collection--{{ section.id }} .rc-chip{
  display:inline-flex;
  align-items:center;
  gap:8px;
  padding: 10px 12px;
  border-radius: 999px;
  background:#f2f2f2;
  border:1px solid rgba(0,0,0,.12);
  font-weight:800;
  font-size:13px;
  text-decoration:none;
  color:inherit;
}
#Collection--{{ section.id }} .rc-chip-x{
  opacity:.6;
  font-size:16px;
  line-height:0;
}

@media only screen and (min-width: 1400px) {
    .grid {
        --columns: 3;
    }
}
@media only screen and (min-width: 1700px) {
    .grid {
        --columns: 4;
    }
}
@media only screen and (min-width: 2000px) {
    .grid {
        --columns: 5;
    }
}

{%- endstyle -%}

{%- capture collection_sidebar_class -%}
  {%- if filter_layout == 'slide-out' -%}
    collection__sidebar__slide-out
    {%- else -%}
    collection__sidebar__slider{% if filters_expanded %} expanded drawer--animated no-mobile-animation{% endif %}
  {%- endif -%}
{%- endcapture -%}

{%- paginate collection.products by product_limit -%}{%- assign featured_images_array = '' -%}

{%- if paginate.current_page == 1 -%}
  {%- for block in section.blocks -%}
    {%- capture current_featured_image -%}
      {%- liquid
        assign featured_image = block.settings.featured_image
        assign featured_image_position = block.settings.position
        assign featured_image_order = featured_image_position | append: '-' | append: forloop.index

        if featured_image_position < 10
          assign featured_image_order = featured_image_order | prepend: '0'
        endif
      -%}{%- liquid
  assign featured_header = block.settings.featured_heading
  assign featured_text = block.settings.featured_text
  assign featured_button_text = block.settings.featured_button_text
  assign featured_button_link = block.settings.featured_button_link
  assign featured_color_text = block.settings.featured_color_text
  assign featured_color_overlay = block.settings.featured_color_overlay
  assign featured_overlay_opacity = block.settings.featured_overlay_opacity | times: 0.01

  assign button_style = block.settings.button_style
  if button_style == 'btn--text' and block.settings.show_arrow
    assign button_style = button_style | append: ' btn--text-no-underline'
  endif
-%}

{%- capture style -%}
  {%- unless featured_color_text == 'rgba(0,0,0,0)' or featured_color_text == blank -%}
    --text: {{ featured_color_text }};
  {%- endunless -%}
  --overlay-opacity: {{ featured_overlay_opacity }};
  --overlay-bg: {{ featured_color_overlay }};
{%- endcapture -%}

<div class="grid-item product-item product-item--featured-image"
  id="Product-item--{{ block.id }}"
  style="{{ style }}"
  {{ block.shopify_attributes }}
>
  {%- capture featured_image_content -%}
    <div class="product-item__image-overlay">
      <div class="product-item__image-content">
        {%- if featured_header != blank -%}
          <h3 class="heading-size-{{ block.settings.heading_size }}">{{ featured_header }}</h3>
        {%- endif -%}

        {%- if featured_text != blank -%}
          {{ featured_text }}
        {%- endif -%}

        {%- if featured_button_text != blank -%}
          <a href="{{ featured_button_link }}" class="btn {{ button_style }} {{ block.settings.button_type }} {{ block.settings.button_size }}" data-aos="fade-up" data-aos-anchor="{{ animation_anchor }}" data-aos-duration="{{ animation_duration }}" data-aos-delay="200">
            <span>{{ featured_button_text }}</span>

            {%- if block.settings.show_arrow -%}
              {%- render 'icon-arrow-right' -%}
            {%- endif -%}
          </a>
        {%- endif -%}
      </div>

      {%- if featured_button_text == blank and featured_button_link != blank -%}
        <a href="{{ featured_button_link }}" class="product-item__image-link" aria-label="{{ featured_image.alt | default: featured_header | default: featured_text | strip_html | escape }}"></a>
      {%- endif -%}
    </div>
  {%- endcapture -%}

  {%- unless featured_image == blank -%}
    <div class="product-item__image">
      <div class="product-item__bg"
        data-aos="img-in"
        data-aos-anchor="{{ animation_anchor }}"
        data-aos-delay="{{ animation_delay | times: 150 }}"
        data-aos-duration="{{ animation_duration }}"
        data-aos-easing="ease-out-quart"
      >
        {%- render 'image' image: featured_image, sizes: image_sizes, loading: 'eager', preload: 'true', fetchpriority: 'high', cover: true -%}
      </div>

      {{ featured_image_content }}
    </div>
  {%- else -%}
    <div class="product-item__image">
      <div class="svg-placeholder">
        {{ 'collection-1' | placeholder_svg_tag }}
      </div>

      {{ featured_image_content }}
    </div>
  {%- endunless -%}
</div>{%- endcapture -%}

    {%- assign featured_images_array = featured_images_array | append: featured_image_order | append: '#featured_image_position#' | append: featured_image_position | append: '#featured_image_html#' | append: current_featured_image | append: '#featured_image#' | append: featured_image | append: '@@' -%}
  {%- endfor -%}

  {%- assign featured_images_array = featured_images_array | split: '@@' | sort -%}
{%- endif -%}<section class="collection collection-products collection-{{ collection.handle }} section-padding"
    id="Collection--{{ section.id }}"
    data-section-id="{{ section.id }}"
    data-section-type="collection"
    data-sort="{{ enable_sort }}"
    data-collection="{{ collection.url | default: '/collections/all' }}">

    {%- assign align_classes = '' -%}
    {%- if enable_sort -%}
      {%- assign align_classes = align_classes | append: ' collection__nav--sort ' -%}
    {%- endif -%}

    {%- if enable_filters -%}
      {% assign align_classes = align_classes | append: ' collection__nav--filter ' %}
    {%- endif -%}

    {%- if enable_sort or enable_filters -%}
      <nav class="collection__nav visually-hidden{{ align_classes }}" data-collection-nav>
        {%- if enable_filters -%}
          {%- liquid
            assign filter_active_count = 0

            if enable_filters
              for filter in collection.filters
                assign filter_active_count = filter_active_count | plus: filter.active_values.size
              endfor
            endif
          -%}
          <div class="popout--group">
            <button
              type="button"
              class="popout__toggle{% unless filter_layout == 'slide-out' %} popout__toggle--filters{% endunless %}"
              aria-expanded="{% if filters_expanded %}true{% else %}false{% endif %}"
              aria-controls="filter-groups"
              data-aria-toggle>
              {%- render 'icon-filter' -%}

              {%- if filter_layout == 'slide-out' -%}
                {{ 'collections.general.filters' | t }}
              {%- else -%}
                <span class="popout__toggleable-text">
                  <span class="popout__expanded-show">
                    {{- 'collections.general.show_filters' | t -}}
                    <span class="filter-count{% if filter_active_count < 1 %} hidden{% endif %}" data-active-filters>
                      {{- filter_active_count -}}
                    </span>
                  </span>

                  <span class="popout__expanded-hide">
                    {{- 'collections.general.hide_filters' | t -}}
                    <span class="filter-count{% if filter_active_count < 1 %} hidden{% endif %}" data-active-filters>
                      {{- filter_active_count -}}
                    </span>
                  </span>
                </span>
              {%- endif -%}

              {%- unless filter_layout == 'slide-out' -%}
                {%- render 'icon-nav-arrow-down' -%}
              {%- endunless -%}
            </button>
          </div>
        {%- endif -%}

        {%- if enable_sort -%}
          {% render 'collection-sorting' %}
        {%- endif -%}
      </nav>
      {%- if enable_filters -%}
  <div class="rc-active-filters" data-active-filters-ui>
    {%- for filter in collection.filters -%}
      {%- if filter.type == 'price_range' -%}
        {%- if filter.min_value.value or filter.max_value.value -%}
          <a class="rc-chip" href="{{ filter.url_to_remove }}" data-filter-update-url>
            Price
            <span class="rc-chip-x">×</span>
          </a>
        {%- endif -%}
      {%- else -%}
        {%- for val in filter.active_values -%}
          <a class="rc-chip" href="{{ val.url_to_remove }}" data-filter-update-url>
            {{ val.label }}
            <span class="rc-chip-x">×</span>
          </a>
        {%- endfor -%}
      {%- endif -%}
    {%- endfor -%}
  </div>
{%- endif -%}

    {%- endif -%}

    {%- if enable_sort or enable_filters -%}
  <div class="rc-mobile-toolbar" data-rc-mobile-toolbar>
    <div class="rc-viewtoggle" role="group" aria-label="Grid view">
      <button class="rc-viewbtn is-active" id="rcGrid2" type="button" data-rc-view="2" aria-pressed="true" aria-label="2 per row">

          <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
            <rect x="2" y="2" width="6" height="6" rx="1"></rect>
            <rect x="10" y="2" width="6" height="6" rx="1"></rect>
            <rect x="2" y="10" width="6" height="6" rx="1"></rect>
            <rect x="10" y="10" width="6" height="6" rx="1"></rect>
          </svg>
        </button>
      <button class="rc-viewbtn" id="rcGrid1" type="button" data-rc-view="1" aria-pressed="false" aria-label="1 per row">

          <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
            <rect x="2" y="2" width="14" height="14" rx="2"></rect>
          </svg>
        </button>
    </div>

    <button type="button" class="rc-filterbtn" data-rc-open-filters>
      <span>FILTER &amp; SORT</span>
    </button>
  </div>
{%- endif -%}


    {%- if enable_sort or enable_filters -%}
  <!-- RC Mobile Top Controls (Gymshark-style) -->
  
{%- endif -%}

<div class="collection__products">

      {%- if enable_filters -%}
        <div class="{{ collection_sidebar_class }}" id="filter-groups" data-collection-sidebar>
          <div class="collection__sidebar__head{% unless filter_layout == 'slide-out' %} mobile{% endunless %} rc-filter-head">
  <button type="button" class="rc-filter-x" data-collection-sidebar-close aria-label="{{ 'collections.general.hide_filters' | t }}">
    {%- render 'icon-cancel' -%}
  </button>

  <h3 class="rc-filter-title">
    FILTER &amp; SORT
    <span class="filter-count{% if filter_active_count < 1 %} hidden{% endif %}" data-active-filters>
      {{- filter_active_count -}}
    </span>
  </h3>

  <a class="rc-filter-clear" href="{{ collection.url }}" data-filter-update-url>
    Clear all
  </a>
</div>


          {%- render 'collection-filters-sidebar', section: section -%}
        </div>

        <div class="underlay{% unless filter_layout == 'slide-out' %} mobile{% endunless %}" data-collection-sidebar-close></div>
      {%- elsif enable_sort -%}
        <collection-filters-form>
          <form data-collection-filters-form class="collection__filters hidden" id="{{ section.id }}-form-filter"></form>
        </collection-filters-form>
      {%- endif -%}

      <div class="grid-outer" data-products-grid>
        <div class="grid" id="CollectionLoop" style="gap: 5px;">
          {%- if collection.products_count > 0 -%}
            {%- if featured_images_array.size > 0 -%}
              {%- liquid
                assign counter_grid = 1
                assign counter_delay = 0
                assign added_images_index = ''
                assign items_on_row_remaining = columns_desktop
              -%}

              {%- for product in collection.products -%}{%- liquid
  for featured_image in featured_images_array
    if featured_image == ''
      continue
    endif

    assign featured_image_index = forloop.index
    assign featured_image_position = featured_image | split: '#featured_image_position#' | last | split: '#featured_image_html#' | first | times: 1
    assign featured_image_markup = featured_image | split: '#featured_image_html#' | last | split: '#featured_image#' | first
    assign featured_image_index_tag = '@' | append: featured_image_index | append: '@'

    if featured_image_position <= counter_grid
      unless added_images_index contains featured_image_index_tag
        assign counter_grid = counter_grid | plus: 1
        assign added_images_index = added_images_index | append: '@' | append: featured_image_index | append: '@#'

        echo featured_image_markup
      endunless
    endif
  endfor

  assign counter_delay = counter_delay | plus: 1
  assign counter_grid = counter_grid | plus: 1
  assign items_on_row_remaining = items_on_row_remaining | minus: 1

  if collection
    render 'product-grid-item', product: product, index: forloop.index, sizes: image_sizes
  endif
-%}
{%- endfor -%}

            {%- else -%}
              {%- for product in collection.products -%}
                {%- assign grid_int = section.settings.grid | times: 1 -%}
                {%- assign animation_delay = forloop.index0 | modulo: grid_int | times: 1 -%}
                {%- render 'product-grid-item', product: product, animation_delay: animation_delay, index: forloop.index, sizes: image_sizes -%}
              {%- endfor -%}
            {%- endif -%}
          {%- else -%}
            <div class="no-results">
              <p><strong>{{ 'collections.general.no_matches' | t }}</strong></p>
              {%- assign sort_by_string = '' -%}
              {%- if collection.sort_by != blank -%}
                {%- assign sort_by_string = '?sort_by=' | append: collection.sort_by -%}
              {%- endif -%}
              <a class="btn caps btn--primary btn--solid" href="{{ collection.url | append: sort_by_string }}" data-filter-update-url><span>{{ 'collections.general.reset' | t }}</span></a>
            </div>
          {%- endif -%}
        </div>

        {%- render 'pagination', paginate: paginate -%}

        <div class="grid__loader">
          <div class="loader grid__loader-line"><div class="loader-indeterminate"></div></div>
        </div>
      </div>
    </div>
  </section>

  {%- if enable_sort or enable_filters -%}
    <script src="{{ 'collection-filters-form.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  <script>
(() => {
  const root = document.getElementById('Collection--{{ section.id }}');
  if (!root) return;

  // Default mobile grid = 2
  root.classList.add('rc-grid-2');

  // Hook to theme's existing filter toggle button
  const themeFilterBtn = root.querySelector('.collection__nav [data-aria-toggle]');
  const openBtn = root.querySelector('[data-rc-open-filters]');
  const underlay = root.querySelector('.underlay');

  const openSheet = () => {
    root.classList.add('rc-sheet-open');
    // Also trigger the theme's open behavior (keeps everything in sync)
    if (themeFilterBtn && themeFilterBtn.getAttribute('aria-expanded') !== 'true') {
      themeFilterBtn.click();
    }
  };

  const closeSheet = () => {
    root.classList.remove('rc-sheet-open');
    if (themeFilterBtn && themeFilterBtn.getAttribute('aria-expanded') === 'true') {
      themeFilterBtn.click();
    }
  };

  if (openBtn) openBtn.addEventListener('click', openSheet);
  if (underlay) underlay.addEventListener('click', closeSheet);

  // If theme closes via its X button, remove our open class too
  if (themeFilterBtn) {
    const sync = () => {
      const isOpen = themeFilterBtn.getAttribute('aria-expanded') === 'true';
      root.classList.toggle('rc-sheet-open', isOpen);
    };
    sync();
    new MutationObserver(sync).observe(themeFilterBtn, { attributes: true, attributeFilter: ['aria-expanded'] });
  }

  // Grid view toggle (2 per row / 1 per row)
  const viewBtns = root.querySelectorAll('[data-rc-view]');
  viewBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const v = btn.getAttribute('data-rc-view');
      root.classList.toggle('rc-grid-1', v === '1');
      root.classList.toggle('rc-grid-2', v === '2');

      viewBtns.forEach(b => b.classList.toggle('is-active', b === btn));
    });
  });
})();
</script>




{%- endpaginate -%}

{% schema %}
  {
    "name": "Collection products",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_sort",
        "label": "Show sorting",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_filters",
        "label": "Enable filters",
        "default": true
      },
      {
        "type": "select",
        "id": "filter_layout",
        "label": "Filter layout",
        "default": "inline-open",
        "options": [
          { "label": "Slide out", "value": "slide-out" },
          { "label": "Inline (closed)", "value": "inline-closed" },
          { "label": "Inline (open)", "value": "inline-open" }
        ]
      },
      {
        "type": "link_list",
        "id": "collection_linklist",
        "label": "Sidebar navigation",
        "info": "This menu won't show dropdown items."
      },
      {
        "type": "header",
        "content": "Product grid"
      },
      {
        "type":    "range",
        "id":      "grid",
        "label":   "Products per row on desktop",
        "min":     2,
        "max":     6,
        "step":    1,
        "default": 3
      },
      {
        "type": "radio",
        "id": "grid_mobile",
        "label": "Products per row on mobile",
        "options": [
          {
            "value": "1",
            "label": "One"
          },
          {
            "value": "2",
            "label": "Two"
          }
        ],
        "default": "2"
      },
      {
        "type":    "range",
        "id":      "products_per_page",
        "min":     1,
        "max":     24,
        "step":    1,
        "label":   "Products per page",
        "default": 24
      },
      {
        "type": "header",
        "content": "Colors"
      },
      {
        "type": "color",
        "id": "border_color",
        "label": "Border color"
      },
      {
        "type": "header",
        "content": "Section padding"
      },
      {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Padding top",
        "default": 0
      },
      {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Padding bottom",
        "default": 0
      }
    ],
    "blocks": [
      {
        "type": "featured_image",
        "limit": 3,
        "name": "Featured image",
        "settings": [
          {
            "type": "image_picker",
            "id": "featured_image",
            "label": "Image"
          },
          {
            "type": "range",
            "id": "position",
            "label": "Image position",
            "min": 1,
            "max": 24,
            "step": 1,
            "default": 1
          },
          {
            "type": "text",
            "id": "featured_heading",
            "label": "Heading",
            "default": "Featured link"
          },
          {
            "type": "range",
            "id": "heading_size",
            "label": "Heading size",
            "min": 1,
            "max": 15,
            "step": 1,
            "default": 7
          },
          {
            "type": "richtext",
            "id": "featured_text",
            "label": "Text",
            "default":"<p>Promote products or collections</p>"
          },
          {
            "type": "text",
            "id": "featured_button_text",
            "label": "Button label",
            "default":"Learn more"
          },
          {
            "type": "url",
            "id": "featured_button_link",
            "label": "Button link"
          },
          {
            "type": "select",
            "id": "button_type",
            "label": "Color",
            "default": "btn--primary",
            "options": [
              {"value": "btn--primary", "label": "Primary"},
              {"value": "btn--secondary", "label": "Secondary"},
              {"value": "btn--white", "label": "White"},
              {"value": "btn--black", "label": "Black"}
            ]
          },
          {
            "type": "select",
            "id": "button_size",
            "label": "Size",
            "default": "",
            "options": [
              { "label": "Small", "value": "btn--small" },
              { "label": "Medium", "value": "" },
              { "label": "Large", "value": "btn--large" }
            ]
          },
          {
            "type": "select",
            "id": "button_style",
            "label": "Style",
            "default": "btn--outline",
            "options": [
              { "label": "Solid", "value": "btn--solid" },
              { "label": "Outline", "value": "btn--outline" },
              { "label": "Text", "value": "btn--text" }
            ]
          },
          {
            "type": "checkbox",
            "id": "show_arrow",
            "label": "Show button arrow",
            "default": false
          },
          {
            "type": "color",
            "id": "featured_color_text",
            "label": "Text",
            "default": "#ffffff"
          },
          {
            "type": "color",
            "id": "featured_color_overlay",
            "label": "Overlay",
            "default": "#222222"
          },
          {
            "type": "range",
            "id": "featured_overlay_opacity",
            "label": "Overlay opacity",
            "step": 5,
            "max": 100,
            "min": 0,
            "unit": "%",
            "default": 10
          }
        ]
      }
    ]
  }
{% endschema %}
