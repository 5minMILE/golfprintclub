egoe UI, Roboto, Arial;\n  }\n  .rc-upsellPriceRow{\n    display:flex;\n    align-items:baseline;\n    gap: 8px;\n    flex-wrap: wrap;\n  }\n  .rc-upsellPrice{\n    font-size: 13px;\n    font-weight: 1000;\n    color: #111;\n    font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial;\n  }\n  .rc-upsellOld{\n    font-size: 12px;\n    font-weight: 900;\n    color: rgba(0,0,0,.45);\n    text-decoration: line-through;\n    font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial;\n  }\n  .rc-upsellSale{\n    font-size: 12px;\n    font-weight: 1000;\n    color: var(--rc-red);\n    font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial;\n  }\n  .rc-upsellBtn{\n    height: 38px;\n    padding: 0 14px;\n    border-radius: 14px;\n    border: 0;\n    background: #000;\n    color:#fff;\n    cursor:pointer;\n    font-size: 12px;\n    font-weight: 1000;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    gap: 8px;\n    text-decoration: none;\n    -webkit-tap-highlight-color: transparent;\n  }\n  .rc-upsellPlus{ font-size: 16px; line-height: 1; transform: translateY(-.5px); }\n\n  .rc-totalRight{\n    display:flex;\n    align-items:baseline;\n    gap:10px;\n  }\n\n  .rc-retail{\n    font-size: 14px;\n    font-weight: 900;\n    color: rgba(0,0,0,.45);\n    font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial;\n    text-decoration-thickness: 2px;\n    text-decoration-color: rgba(0,0,0,.35);\n  }\n\n  \n  \n@media (min-width: 750px){\n  \n  #rcCartDevSheetWrap{\n    position: absolute;\n    inset: 0;                 \n    display: flex;\n    justify-content: flex-end;\n    align-items: stretch;     \n    padding: 0;               \n    box-sizing: border-box;\n  }\n\n  \n  #rcCartDevSheet{\n    width: var(--rc-desktopw);     \n    min-width: 700px; \n    max-width: var(--rc-maxw);     \n    height: 100vh;                \n    max-height: 100vh;\n\n    \n    border-radius: 0;             ;\n    box-shadow: -20px 0 60px rgba(0,0,0,.28);\n  }\n\n  \n  .rc-shipBar{ width: 100%; }\n  .rc-name{ max-width: 100%; }\n\n.rc-handle{ display:none;}\n\n.rc-meta {\nmin-width: 100%;}\n\n.rc-backorder-line{\nwidth:60%;}\n}\n</style>",
