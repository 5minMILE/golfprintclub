    "section_custom_code_dTApjA": {
      "type": "section-custom-code",
      "disabled": true,
      "name": "Price Ladder (Mobile)",
      "settings": {
        "code": "<style>\n  \n  .rc-priceladder-wrap { display: none; }\n  @media (max-width: 749px) {\n    .rc-priceladder-wrap { display: block; }\n  }\n\n  .rc-priceladder {\n\n    font-weight: 1000;\n    text-align: left;\n    font-size: 14px;\n    font-family: var(--BTN-FONT-STACK);\n\n    padding: 0px 0;\n  }\n\n  .rc-priceladder__title {\n    font-weight: 1000;\n    text-align: left;\n    font-size: 14px;\n    font-family: var(--BTN-FONT-STACK);\n\n    font-size: 16px;\n    font-weight: 900;\n    color: #111;\n    margin: 0 0 12px 0;\n  }\n\n  .rc-ladder {\n    display: grid;\n    grid-template-columns: 1fr;\n    gap: 14px;\n  }\n\n  \n  .rc-tier {\n    border-radius: 16px;\n    padding: 14px;\n    background: #fff;\n    border: 1px solid rgba(17,17,17,0.12);\n  }\n\n  .rc-tier__top {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    gap: 10px;\n    margin-bottom: 8px;\n  }\n\n  .rc-tier__name {\n\n    font-weight: 1000;\n    text-align: left;\n    font-size: 18px !important;\n    font-family: var(--BTN-FONT-STACK);\n\n\n    font-size: 12px;\n    font-weight: 900;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n    color: rgba(17,17,17,0.85);\n  }\n\n  .rc-tier__pricepill {\n\nfont-weight: 1000;\n    text-align: left;\n    font-size: 14px;\n    font-family: var(--BTN-FONT-STACK);\n\n\n    padding: 6px 12px;\n    border-radius: 999px;\n    font-size: 12px;\n    font-weight: 900;\n    background: rgba(17,17,17,0.05);\n    border: 1px solid rgba(17,17,17,0.15);\n    white-space: nowrap;\n  }\n\n  \n  .rc-meter {\n    height: 8px;\n    border-radius: 999px;\n    background: rgba(17,17,17,0.12);\n    overflow: hidden;\n    margin: 6px 0 10px 0;\n  }\n\n  .rc-meter__fill {\n    height: 100%;\n    border-radius: 999px;\n    background: rgba(17,17,17,0.35);\n  }\n\n  \n  .rc-tier__desc {\n\nfont-weight: 600;\n    text-align: left;\n    font-size: 12px;\n    font-family: var(--BTN-FONT-STACK);\n\n\n    font-size: 13px;\n    line-height: 1.35;\n    color: rgba(17,17,17,0.75);\n    margin-bottom: 12px;\n  }\n\n  \n  .rc-tier__tags {\n\nfont-weight: 1000;\n    text-align: left;\n    font-size: 14px;\n    font-family: var(--BTN-FONT-STACK);\n\n\n    display: grid;\n    grid-template-columns: 1fr;\n    gap: 8px;\n  }\n\n  .rc-tag {\n    display: inline-flex;\n    align-items: center;\n    gap: 8px;\n    font-size: 12px;\n    font-weight: 800;\n    padding: 7px 12px;\n    border-radius: 999px;\n    border: 1px solid rgba(17,17,17,0.15);\n    background: #fff;\n    color: rgba(17,17,17,0.8);\n\nfont-weight: 1000;\n    text-align: left;\n    font-size: 14px;\n    font-family: var(--BTN-FONT-STACK);\n  }\n\n  .rc-tag svg {\n    width: 20px;\n    height: 20px;\n  }\n\n  \n  .rc-tier--featured {\n    border: 1.5px solid #2E7D32;\n    box-shadow:\n      0 0 0 1px rgba(0,123,255,0.15),\n      0 8px 18px rgba(0,123,255,0.14);\n    background: linear-gradient(\n      180deg,\n      rgba(0,123,255,0.04),\n      #ffffff 60%\n    );\n  }\n\n  .rc-tier--featured .rc-tier__name,\n  .rc-tier--featured .rc-tier__pricepill {\n    color: #2E7D32;\n  }\n\n  .rc-tier--featured .rc-meter__fill {\n    background: rgba(0,123,255,0.8);\n  }\n\n  .rc-tier__valuehint {\n    font-size: 14px;\n    font-weight: 800;\n    color: #2E7D32;\n    text-transform: uppercase;\n    margin-bottom: 8px;\n  }\n</style>\n<style>\n  \n\n  .rc-tag {\n    padding: 4px 8px;            \n    font-size: 13px;           \n    font-weight: 700;            \n    border-radius: 9999px;         \n    border: 1px solid rgba(17,17,17,0.14);\n    background: rgba(17,17,17,0.03);\n    color: rgba(17,17,17,0.78);\n    gap: 6px;\n    width: fit-content;          \n    max-width: 100%;\n  }\n\n  \n  .rc-tag svg {\n    width: 12px;\n    height: 12px;\n  }\n\n  \n  .rc-tier--featured .rc-tag, .rc-tier--featured .rc-tier__pricepill{\n    background: rgba(0,123,255,0.05);\n    border-color: rgba(0,123,255,0.22);\n    color: rgba(0,0,0,0.85);\n  }\n\n  \n  .rc-tier__tags {\n    gap: 6px;\n  }\n\n.feature-facts-title{\nfont-size:26px;\ntext-align:center;}\n</style>\n\n\n\n\n\n<h3 class=\"feature-facts-title\">How the md golf posters compare to other brands</h3>\n<div class=\"rc-priceladder-wrap\">\n  <div class=\"rc-priceladder\">\n    \n\n    <div class=\"rc-ladder\">\n\n      <!-- Budget -->\n      <div class=\"rc-tier\">\n        <div class=\"rc-tier__top\">\n          <div class=\"rc-tier__name\">Budget Shorts</div>\n          <div class=\"rc-tier__pricepill\">$35</div>\n        </div>\n\n        <div class=\"rc-meter\">\n          <div class=\"rc-meter__fill\" style=\"width:30%\"></div>\n        </div>\n\n        <div class=\"rc-tier__desc\">\n          Fine for easy runs — but fit and fabric usually break down once you push pace or mileage.\n        </div>\n\n        <div class=\"rc-tier__tags\">\n          <span class=\"rc-tag\">\n            ⚠ Thin / flimsy feel\n          </span>\n          <span class=\"rc-tag\">\n            ⚠ Rides up at pace\n          </span>\n          <span class=\"rc-tag\">\n            ⚠ Not workout-ready\n          </span>\n        </div>\n      </div>\n\n\n     <!-- MD Golf Posters -->\n      <div class=\"rc-tier rc-tier--featured\">\n        <div class=\"rc-tier__top\">\n          <div class=\"rc-tier__name\">Golf Print Club</div>\n          <div class=\"rc-tier__pricepill\">$40 each (B2G1)</div>\n        </div>\n\n        <div class=\"rc-meter\">\n          <div class=\"rc-meter__fill\" style=\"width:90%\"></div>\n        </div>\n\n        <div class=\"rc-tier__valuehint\">\n          Comparable to premium shorts without the premium price.\n        </div>\n\n        <div class=\"rc-tier__desc\">\n          Built for real training and race effort with a locked-in fit, functional details, and designs you won’t see everywhere.\n        </div>\n\n        <div class=\"rc-tier__tags\">\n          <span class=\"rc-tag\">✓ Race-ready fit</span>\n          <span class=\"rc-tag\">✓ Comparable to premium</span>\n          <span class=\"rc-tag\">✓ Fair pricing</span>\n        </div>\n      </div>\n\n      <!-- Mainstream -->\n      <div class=\"rc-tier\">\n        <div class=\"rc-tier__top\">\n          <div class=\"rc-tier__name\">Big Brands</div>\n          <div class=\"rc-tier__pricepill\">$90</div>\n        </div>\n\n        <div class=\"rc-meter\">\n          <div class=\"rc-meter__fill\" style=\"width:55%\"></div>\n        </div>\n\n        <div class=\"rc-tier__desc\">\n          Solid training shorts — but much of the price goes toward branding rather than added performance.\n        </div>\n\n        <div class=\"rc-tier__tags\">\n          <span class=\"rc-tag\">✓ Good performance</span>\n          <span class=\"rc-tag\">⚠ Big-brand markup</span>\n          <span class=\"rc-tag\">⚠ Safe designs</span>\n        </div>\n      </div>\n\n     \n\n      <!-- Premium -->\n      <div class=\"rc-tier\">\n        <div class=\"rc-tier__top\">\n          <div class=\"rc-tier__name\">Premium</div>\n          <div class=\"rc-tier__pricepill\">$120+</div>\n        </div>\n\n        <div class=\"rc-meter\">\n          <div class=\"rc-meter__fill\" style=\"width:65%\"></div>\n        </div>\n\n        <div class=\"rc-tier__desc\">\n          Premium materials and branding — performance can be similar, but you pay heavily for positioning.\n        </div>\n\n        <div class=\"rc-tier__tags\">\n          <span class=\"rc-tag\">✓ Premium build</span>\n          <span class=\"rc-tag\">✓ Comparable performance</span>\n          <span class=\"rc-tag\">⚠ Very high price</span>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</div>",
