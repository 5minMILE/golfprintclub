        "code_TQGKeq": {
          "type": "code",
          "name": "Size Chart",
          "settings": {
            "code": "{%- comment -%}\n  Golf Print Club — Size Chart Modal\n  Uses product.metafields.custom.size_chart (Page reference) to render content in a popup.\n  Safe guards:\n   • If metafield is blank → no link renders.\n   • If it's a Page reference → prints page.content.\n   • If store uses text/handle instead of page reference → tries pages[handle].\n{%- endcomment -%}\n\n{%- assign rc_sc = product.metafields.custom.size_chart -%}\n{%- if rc_sc and rc_sc != blank -%}\n  {%- assign rc_uid = 'rc-sc-' | append: product.id -%}\n\n  <button\n    type=\"button\"\n    class=\"rc-sc-trigger\"\n    aria-haspopup=\"dialog\"\n    aria-controls=\"{{ rc_uid }}\"\n    aria-expanded=\"false\">\n    Size chart\n  </button>\n\n  <div class=\"rc-sc-overlay\" data-rc-sc-overlay hidden></div>\n\n  <div\n    id=\"{{ rc_uid }}\"\n    class=\"rc-sc-modal\"\n    role=\"dialog\"\n    aria-modal=\"true\"\n    aria-labelledby=\"{{ rc_uid }}-title\"\n    hidden>\n    <div class=\"rc-sc-window\" role=\"document\">\n      <div class=\"rc-sc-header\">\n        <h2 id=\"{{ rc_uid }}-title\" class=\"rc-sc-title\">\n          {{ rc_sc.value.title | default: 'Size Chart' }}\n        </h2>\n        <button type=\"button\" class=\"rc-sc-close\" aria-label=\"Close\">×</button>\n      </div>\n      <div class=\"rc-sc-body\">\n        {%- assign rc_page = rc_sc.value -%}\n        {%- if rc_page and rc_page.content -%}\n          <div class=\"rc-sc-content\">\n            {{ rc_page.content }}\n          </div>\n        {%- else -%}\n          {%- comment -%}\n            Fallbacks if store used a text/handle metafield by accident.\n          {%- endcomment -%}\n          {%- assign rc_handle = rc_sc | metafield_text -%}\n          {%- if rc_handle and pages[rc_handle] and pages[rc_handle].content -%}\n            <div class=\"rc-sc-content\">\n              {{ pages[rc_handle].content }}\n            </div>\n          {%- else -%}\n            <div class=\"rc-sc-content\">\n              {{ rc_sc | metafield_text }}\n            </div>\n          {%- endif -%}\n        {%- endif -%}\n      </div>\n    </div>\n  </div>\n\n  <style>\n    .rc-sc-trigger {\n  font: inherit;\n  text-decoration: underline;\n  text-decoration-thickness: 1px; \n  text-underline-offset: 4px; \n  background: none;\n  border: none;\n  padding: 0;\n  cursor: pointer;\nfont-family: var(--BTN-FONT-STACK);\n        color: #333;\n        font-size: 14px;\n        font-weight: 800;\n}\n\n\n    .rc-sc-overlay[hidden],\n    .rc-sc-modal[hidden] { display: none !important; }\n\n    .rc-sc-overlay {\n      position: fixed; inset: 0;\n      background: rgba(0,0,0,.4);\n      z-index: 10000;\n      animation: rc-sc-fade .15s ease-out;\n    }\n\n    .rc-sc-modal {\n      position: fixed; inset: 0;\n      display: grid; place-items: center;\n      z-index: 10001;\n    }\n\n    .rc-sc-window {\n      width: min(900px, 92vw);\n      max-height: min(82vh, 900px);\n      background: #fff;\n      border-radius: 14px;\n      box-shadow: 0 10px 30px rgba(0,0,0,.18);\n      overflow: hidden;\n      display: flex; flex-direction: column;\n      animation: rc-sc-pop .18s ease-out;\n    }\n\n    .rc-sc-header {\n      display: flex; align-items: center; justify-content: space-between;\n      padding: 14px 18px;\n      border-bottom: 1px solid rgba(0,0,0,.08);\n    }\n\n    .rc-sc-title { font-size: 18px; margin: 0; }\n\n    .rc-sc-close {\n      background: none; border: 0; font-size: 24px; line-height: 1;\n      cursor: pointer; padding: 6px 8px;\n    }\n\n    .rc-sc-body {\n      padding: 16px 18px;\n      overflow: auto;\n    }\n\n    \n    .rc-sc-content table { width: 100%; border-collapse: collapse; }\n    .rc-sc-content th, .rc-sc-content td { border: 1px solid #eee; padding: 8px; }\n    .rc-sc-content img { max-width: 100%; height: auto; }\n\n    @keyframes rc-sc-pop {\n      from { transform: translateY(6px) scale(.98); opacity: 0; }\n      to   { transform: translateY(0) scale(1); opacity: 1; }\n    }\n    @keyframes rc-sc-fade { from { opacity: 0; } to { opacity: 1; } }\n@media (max-width: 768px) {\n.rc-sc-trigger{display:none;}\n}\n\n  </style>\n\n  <script>\n    (function() {\n      var modal   = document.getElementById('{{ rc_uid }}');\n      var overlay = document.querySelector('[data-rc-sc-overlay]');\n      var openBtn = document.currentScript.closest('body').querySelector('[aria-controls=\"{{ rc_uid }}\"]');\n      if (!modal || !overlay || !openBtn) return;\n\n      var closeBtn = modal.querySelector('.rc-sc-close');\n      var lastFocused;\n\n      function openModal() {\n        lastFocused = document.activeElement;\n        modal.hidden = false;\n        overlay.hidden = false;\n        openBtn.setAttribute('aria-expanded', 'true');\n        // Focus heading for screen readers\n        var title = modal.querySelector('.rc-sc-title');\n        if (title) title.setAttribute('tabindex','-1'), title.focus();\n        document.addEventListener('keydown', onKey);\n      }\n\n      function closeModal() {\n        modal.hidden = true;\n        overlay.hidden = true;\n        openBtn.setAttribute('aria-expanded', 'false');\n        document.removeEventListener('keydown', onKey);\n        if (lastFocused) lastFocused.focus();\n      }\n\n      function onKey(e) {\n        if (e.key === 'Escape') closeModal();\n      }\n\n      openBtn.addEventListener('click', openModal);\n      overlay.addEventListener('click', closeModal);\n      closeBtn && closeBtn.addEventListener('click', closeModal);\n    })();\n  </script>\n{%- endif -%}",
