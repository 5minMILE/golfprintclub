          "name": "Move Heading and  price",
          "settings": {
            "code": "<script>\n(() => {\n  // Run only on product pages\n  if (!location.pathname.includes(\"/products/\")) return;\n\n  // CONFIG\n  const BASE_TITLE = \"MD Golf Posters\";\n  const BUNDLE_QTY = 3; // buy 2 get 1 free\n  const OFFER_PREFIX = \"Buy 2 Get 1 Free\";\n\n  // SELECTORS\n  const PRODUCT_PAGE_SEL = \".product__page\";\n  const TOPINFO_SEL = \".top-info\";\n\n  const TITLE_WRAP_SEL = \".product__title__wrapper\";\n  const TITLE_H1_SEL =\n    \".product__title__wrapper h1, h1.product__title, .product__title h1\";\n\n  const PRICE_WRAP_SEL = \".product__price__wrap\";\n  const PRICE_TEXT_SEL =\n    \".product__price__wrap .price-item--regular, .product__price__wrap .price-item, .product__price__wrap span\";\n\n  // Judge.me selector (reliable)\n  const JDGM_BADGE_SEL =\n    '.jdgm-widget[data-widget-name=\"preview_badge\"], .jdgm-preview-badge';\n\n  // Helpers\n  const $ = (s, r = document) => r.querySelector(s);\n\n  function ensureTopInfo() {\n    const productPage = $(PRODUCT_PAGE_SEL);\n    if (!productPage) return null;\n\n    let top = $(TOPINFO_SEL);\n    if (!top) {\n      top = document.createElement(\"div\");\n      top.className = \"top-info\";\n      productPage.insertAdjacentElement(\"afterbegin\", top);\n    } else if (top.parentElement !== productPage) {\n      productPage.insertAdjacentElement(\"afterbegin\", top);\n    }\n    return top;\n  }\n\n  function getVariant() {\n    const select = document.querySelector('select[name=\"id\"]');\n    if (select && select.options.length) {\n      return select.options[select.selectedIndex].text.trim();\n    }\n    const checked = document.querySelector('input[type=\"radio\"]:checked');\n    if (checked) {\n      const label = document.querySelector(`label[for=\"${checked.id}\"]`);\n      return label ? label.textContent.trim() : \"\";\n    }\n    return \"\";\n  }\n\n  function cleanVariant(v) {\n    if (!v) return \"\";\n    if (v.toLowerCase() === \"default title\") return \"\";\n    return v.split(\" / \")[0].trim();\n  }\n\n  function extractNumber(text) {\n    const m = (text || \"\").replace(/,/g, \"\").match(/(\\d+(\\.\\d+)?)/);\n    return m ? parseFloat(m[1]) : null;\n  }\n\n  function ensureLine(parent, cls, styles) {\n    let el = parent.querySelector(\".\" + cls);\n    if (!el) {\n      el = document.createElement(\"div\");\n      el.className = cls;\n      if (styles) Object.assign(el.style, styles);\n      parent.appendChild(el);\n    }\n    return el;\n  }\n\n  // ✅ Slot goes RIGHT UNDER TITLE (H1), always\n  function ensureReviewsSlotUnderTitle(titleH1) {\n    let slot = document.querySelector(\".rc-jdgm-slot-under-title\");\n    if (!slot) {\n      slot = document.createElement(\"div\");\n      slot.className = \"rc-jdgm-slot-under-title\";\n      titleH1.insertAdjacentElement(\"afterend\", slot);\n    } else if (slot.previousElementSibling !== titleH1) {\n      // keep it directly under h1\n      titleH1.insertAdjacentElement(\"afterend\", slot);\n    }\n    return slot;\n  }\n\n  function findJudgeMeBadge() {\n    return document.querySelector(JDGM_BADGE_SEL);\n  }\n\n  function moveJudgeMeUnderTitleOnce() {\n    const titleH1 = document.querySelector(TITLE_H1_SEL);\n    if (!titleH1) return false;\n\n    const slot = ensureReviewsSlotUnderTitle(titleH1);\n    const badge = findJudgeMeBadge();\n    if (!badge) return false;\n\n    // already moved\n    if (slot.contains(badge)) return true;\n\n    // move it\n    slot.appendChild(badge);\n    slot.dataset.rcMounted = \"1\";\n    return true;\n  }\n\n  function update() {\n    const topInfo = ensureTopInfo();\n    if (!topInfo) return;\n\n    const titleWrap = document.querySelector(TITLE_WRAP_SEL);\n    const titleH1 = document.querySelector(TITLE_H1_SEL);\n    const priceWrap = document.querySelector(PRICE_WRAP_SEL);\n    if (!titleWrap || !titleH1 || !priceWrap) return;\n\n    // Re-order once (titleWrap then priceWrap). Don't touch badge here.\n    if (!topInfo.dataset.rcMounted) {\n      topInfo.dataset.rcMounted = \"1\";\n      topInfo.appendChild(titleWrap);\n      topInfo.appendChild(priceWrap);\n    }\n\n    // Title\n    titleH1.textContent = BASE_TITLE;\n\n    // Variant subline (still exists, but badge will NOT be placed under it)\n    const variantLine = ensureLine(titleWrap, \"rc-variant-subline\", {\n      marginTop: \"4px\",\n      fontSize: \"14px\",\n      opacity: \"0.85\",\n      lineHeight: \"1.2\",\n    });\n    variantLine.textContent = cleanVariant(getVariant());\n\n    // Ensure slot exists under title\n    ensureReviewsSlotUnderTitle(titleH1);\n\n    // Offer line\n    const offerLine = ensureLine(topInfo, \"rc-offer-subline\", {\n      marginTop: \"6px\",\n      color: \"#ff3b30\",\n      fontSize: \"14px\",\n      fontWeight: \"600\",\n      lineHeight: \"1.2\",\n    });\n\n    if (priceWrap.nextElementSibling !== offerLine) {\n      priceWrap.insertAdjacentElement(\"afterend\", offerLine);\n    }\n\n    const priceTextEl = priceWrap.querySelector(PRICE_TEXT_SEL);\n    const priceNumber = extractNumber(priceTextEl ? priceTextEl.textContent : \"\");\n\n    offerLine.textContent = priceNumber ? `Buy 2 get 1 Free` : OFFER_PREFIX;\n  }\n\n  function waitForBadgeThenMove() {\n    const started = Date.now();\n    const maxMs = 12000;\n    const intervalMs = 150;\n\n    const timer = setInterval(() => {\n      update();\n      const moved = moveJudgeMeUnderTitleOnce();\n      if (moved || Date.now() - started > maxMs) clearInterval(timer);\n    }, intervalMs);\n  }\n\n  const init = () => {\n    update();\n    waitForBadgeThenMove();\n  };\n\n  if (document.readyState === \"loading\") {\n    document.addEventListener(\"DOMContentLoaded\", init, { once: true });\n  } else {\n    init();\n  }\n\n  // Variant changes\n  document.addEventListener(\n    \"change\",\n    (e) => {\n      if (\n        e.target.matches('select[name=\"id\"]') ||\n        e.target.matches('input[type=\"radio\"]') ||\n        (e.target.name && e.target.name.indexOf(\"options\") !== -1)\n      ) {\n        setTimeout(() => {\n          update();\n          waitForBadgeThenMove();\n        }, 50);\n      }\n    },\n    true\n  );\n})();\n</script>\n\n<style>\n@media only screen and (max-width: 763px) {\n  .product__title span {\n    text-align: left !important;\n  }\n  .product__title,\n  .product__price span {\n    font-size: 20px !important;\n    font-weight: 800;\n    padding-bottom: 8px;\n  }\n  .product__price__wrap {\n    justify-content: left !important;\n  }\n  .top-info {\n    padding: 10px;\n  }\n}\n\n.rc-variant-subline {\n  font-family: var(--BTN-FONT-STACK);\n  letter-spacing: var(--BTN-FONT-STYLE);\n  font-size: 10px;\n  font-weight: 700;\n  color: grey;\n  opacity: 1 !important;\n}\n\n.rc-offer-subline {\n  font-family: var(--BTN-FONT-STACK);\n  letter-spacing: var(--BTN-FONT-STYLE);\n  font-size: 10px;\n  font-weight: 700 !important;\n  color: red;\n  opacity: 1 !important;\n  margin-top: 0 !important;\n}\n\n.radio__fieldset--swatches .radio__legend {\n  padding-bottom: 0;\n}\n@media only screen and (max-width: 763px) {\n    .jdgm-prev-badge {\njustify-content:left !important;}\n@media only screen and (max-width: 763px) {\n    .jdgm-widget {\nmargin:0 !important;}}\n\n</style>",
            "padding_bottom": 0
          }
        },
        "code_BcgDaL": {
          "type": "code",
          "name": "Simplified Variant function, clear selection, atc button",
          "settings": {
            "code": "<script>\ndocument.addEventListener(\"DOMContentLoaded\", function () {\n  const slides = document.querySelectorAll('.product__slides .product__slide');\n\n  function getImageKeyFromAlt(alt) {\n    return (alt || \"\")\n      .toLowerCase()\n      .split(\"-\")[0]\n      .trim();\n  }\n\n  const imageKeys = new Set();\n  slides.forEach(slide => {\n    const img = slide.querySelector('.image-wrapper img');\n    if (img && img.alt) {\n      const key = getImageKeyFromAlt(img.alt);\n      if (key) imageKeys.add(key);\n    }\n  });\n\n  const optionSelectors = Array.from(document.querySelectorAll(\n    'input[type=\"radio\"][name^=\"options[\"], select[name^=\"options[\"]'\n  ));\n\n  const groups = {};\n  optionSelectors.forEach(el => {\n    const name = el.name;\n    groups[name] = groups[name] || { elements: [], values: new Set() };\n    groups[name].elements.push(el);\n\n    if (el.tagName === \"SELECT\") {\n      Array.from(el.options).forEach(o => groups[name].values.add(o.value.toLowerCase().trim()));\n    } else if (el.type === \"radio\") {\n      groups[name].values.add(el.value.toLowerCase().trim());\n    }\n  });\n\n  let controllingOptionName = null;\n  for (const [name, group] of Object.entries(groups)) {\n    const matches = Array.from(group.values).some(v => imageKeys.has(v));\n    if (matches) {\n      controllingOptionName = name;\n      break;\n    }\n  }\n\n  function getSelectedValue(name) {\n    const group = groups[name];\n    if (!group) return \"\";\n    const checked = group.elements.find(el => el.type === \"radio\" && el.checked);\n    if (checked) return checked.value;\n    const selectEl = group.elements.find(el => el.tagName === \"SELECT\");\n    if (selectEl) return selectEl.options[selectEl.selectedIndex]?.value || \"\";\n    return \"\";\n  }\n\n  function updateImagesByKey(keyRaw) {\n    const key = (keyRaw || \"\").toLowerCase().trim();\n    let matchFound = false;\n\n    slides.forEach(slide => {\n      const img = slide.querySelector('.image-wrapper img');\n      if (!img || !img.alt) {\n        slide.style.display = \"block\";\n        return;\n      }\n      const altKey = getImageKeyFromAlt(img.alt);\n      const show = key === \"\" || altKey === key;\n      slide.style.display = show ? \"block\" : \"none\";\n      if (show && altKey === key) matchFound = true;\n    });\n\n    if (key && !matchFound) {\n      slides.forEach(slide => slide.style.display = \"block\");\n    }\n  }\n\n  if (controllingOptionName) {\n    updateImagesByKey(getSelectedValue(controllingOptionName));\n  } else {\n    slides.forEach(slide => slide.style.display = \"block\");\n  }\n\n  optionSelectors.forEach(el => {\n    el.addEventListener(\"change\", function () {\n      if (controllingOptionName) {\n        updateImagesByKey(getSelectedValue(controllingOptionName));\n      }\n    });\n  });\n});\n</script>\n\n<script>\ndocument.addEventListener(\"DOMContentLoaded\", function () {\n  const sizeRadios = document.querySelectorAll('input[type=\"radio\"][name^=\"options[Size]\"]');\n\n  sizeRadios.forEach(input => {\n    input.checked = false;\n    input.removeAttribute(\"checked\");\n  });\n\n  const variantIdInput = document.querySelector('input[name=\"id\"]');\n  if (variantIdInput) {\n    variantIdInput.value = \"\";\n  }\n});\n</script>\n\n<!-- ✅ Sticky Add to Cart Button -->\n<div id=\"sticky-add-to-cart\">\n  <button id=\"stickyAddBtn\">Add to Cart</button>\n</div>\n\n<style>\n  .product__submit__buttons { display: none; }\n\n  @media only screen and (max-width: 768px) {\n    #sticky-add-to-cart {\n      text-transform: uppercase;\n      font-family: var(--BTN-FONT-STACK);\n      font-size: 12px;\n      position: fixed;\n      bottom: 0;\n      left: 0;\n      width: 100%;\n      background: transparent;\n      padding: 14px 0;\n      z-index: 2;\n      display: flex;\n      justify-content: center;\n    }\n\n    #stickyAddBtn {\n      background-color: #2E7D32;\n      color: #fff;\n      font-weight: 700;\n      font-size: 20px;\n      padding: 16px 24px;\n      border: none;\n      width: 90vw;\n      border-radius: 8px;\n      cursor: pointer;\n    }\n\n    #stickyAddBtn:disabled {\n      background-color: #aaa;\n      cursor: not-allowed;\n    }\n  }\n\n  @media only screen and (min-width: 769px) {\n    #sticky-add-to-cart {\n      text-transform: uppercase;\n      font-weight: 700;\n      font-family: var(--BTN-FONT-STACK);\n      font-size: 20px;\n      position: fixed;\n      bottom: 0px;\n      left: calc(calc(50vh * 0.8));\n      width: 100%;\n      background: transparent;\n      z-index: 9999;\n      display: flex;\n      justify-content: left;\n    }\n\n    #stickyAddBtn {\n      width: calc(100vw - calc(calc(50vh * 0.8)));\n      border-radius: 0px;\n      padding: 40px;\n      font-weight: 700;\n      background: rgba(0, 123, 255, 0.5) !important;\n      backdrop-filter: blur(30px);\n      color: white;\n      border-top: 1px black solid;\n    }\n\n    #stickyAddBtn:disabled {\n      background-color: #aaa;\n      cursor: not-allowed;\n    }\n  }\n</style>\n\n<!-- ✅ Replace ONLY your LAST <script>...</script> with this one.\n     FIX: Sticky now reliably shows again after the user scrolls past Buy Now.\n     Rules (mobile):\n     1) SHOW initially\n     2) HIDE once viewport bottom hits installments (.shop-movement): window.innerHeight >= installmentsRect.top\n     3) SHOW again once Buy Now is completely above the viewport: buyNowRect.bottom <= 0\n     (Uses a tiny state machine so rule #3 can’t be “overridden” by rule #2.)\n-->\n\n<script>\ndocument.addEventListener('DOMContentLoaded', () => {\n  const stickyBtn = document.getElementById('stickyAddBtn');\n  const stickyBar = document.getElementById('sticky-add-to-cart');\n  const productTitle = document.querySelector('h1');\n  const mainAddBtn = document.querySelector('button[data-add-to-cart]');\n  const mainBtnText = mainAddBtn?.querySelector('[data-add-to-cart-text]');\n\n  function scrollToTitle() {\n    if (!productTitle) return;\n    const yOffset = window.innerHeight * 0.2;\n    const y = productTitle.getBoundingClientRect().top + window.scrollY - yOffset;\n    window.scrollTo({ top: y, behavior: 'smooth' });\n  }\n\n  function getSelectedVariantId() {\n    const selected =\n      document.querySelector('input[name=\"id\"]:checked') ||\n      document.querySelector('input[name=\"id\"]');\n    return selected?.value || null;\n  }\n\n  function updateStickyButton() {\n    if (!mainAddBtn) return;\n    const isDisabled = mainAddBtn.disabled;\n    stickyBtn.disabled = isDisabled;\n    stickyBtn.classList.toggle('disabled', isDisabled);\n    stickyBtn.textContent = isDisabled ? (mainBtnText?.textContent || 'Unavailable') : 'Add to Cart';\n  }\n\n  if (mainAddBtn) {\n    const observer = new MutationObserver(updateStickyButton);\n    observer.observe(mainAddBtn, { attributes: true, childList: true, subtree: true });\n\n    document.querySelectorAll('input[name^=\"options\"], select[name^=\"options\"]').forEach(el => {\n      el.addEventListener('change', updateStickyButton);\n    });\n\n    updateStickyButton();\n  }\n\n  async function updateCartUIAfterAdd() {\n    try {\n      const cart = await fetch('/cart.js', { headers: { 'Accept': 'application/json' } }).then(r => r.json());\n      const countEls = document.querySelectorAll('[data-cart-count], .cart-count-bubble, .header__cart-count');\n      countEls.forEach(el => {\n        if ('textContent' in el) el.textContent = cart.item_count;\n        el.setAttribute?.('data-cart-count', cart.item_count);\n      });\n    } catch (e) {\n      console.warn('Cart UI update failed', e);\n    }\n  }\n\n  stickyBtn.addEventListener('click', async () => {\n    if (stickyBtn.disabled) { scrollToTitle(); return; }\n\n    const variantId = getSelectedVariantId();\n    if (!variantId) { scrollToTitle(); return; }\n\n    const prevText = stickyBtn.textContent;\n    stickyBtn.disabled = true;\n    stickyBtn.textContent = 'Adding…';\n\n    try {\n      const res = await fetch('/cart/add.js', {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },\n        body: JSON.stringify({ id: variantId, quantity: 1 })\n      });\n\n      if (!res.ok) throw new Error('Add to cart failed');\n\n      await updateCartUIAfterAdd();\n      window.location.href = '/cart';\n    } catch (err) {\n      console.error(err);\n      stickyBtn.textContent = 'Error';\n      setTimeout(() => {\n        stickyBtn.textContent = prevText || 'Add to Cart';\n        stickyBtn.disabled = false;\n        updateStickyButton();\n      }, 1500);\n    }\n  });\n\n  \n\n  if (window.innerWidth >= 769) return; // mobile only\n\n  const installments = document.querySelector('.shop-movement');\n\n  // Find the Buy Now \"block\" (best target = the container)\n  function findBuyNowContainer() {\n    // Shopify dynamic checkout wrapper\n    const container =\n      document.querySelector('.shopify-payment-button') ||\n      document.querySelector('[data-shopify=\"payment-button\"]') ||\n      document.querySelector('.shopify-payment-button__button')?.closest('.shopify-payment-button');\n\n    if (container) return container;\n\n    // Fallback: try to find a visible button that contains \"buy\" text\n    const btn = Array.from(document.querySelectorAll('button'))\n      .find(b => (b.textContent || '').toLowerCase().includes('buy'));\n    return btn ? btn.parentElement : null;\n  }\n\n  // Create marker AFTER Buy Now so we can reliably detect \"past buy now\"\n  let buyNowMarker = null;\n\n  function ensureBuyNowMarker() {\n    if (buyNowMarker) return buyNowMarker;\n\n    const buyNowContainer = findBuyNowContainer();\n    if (!buyNowContainer) return null;\n\n    buyNowMarker = document.createElement('div');\n    buyNowMarker.id = 'rc-buy-now-marker';\n    buyNowMarker.style.cssText = 'height:1px;width:1px;';\n\n    buyNowContainer.insertAdjacentElement('afterend', buyNowMarker);\n    return buyNowMarker;\n  }\n\n  function setStickyVisible(isVisible) {\n    stickyBar.style.opacity = isVisible ? '1' : '0';\n    stickyBar.style.pointerEvents = isVisible ? 'auto' : 'none';\n    stickyBar.style.transform = isVisible ? 'translateY(0)' : 'translateY(100%)';\n  }\n\n  function beforeInstallments() {\n    // Show until bottom of viewport hits installments\n    if (!installments) return true; // safe fallback\n    const r = installments.getBoundingClientRect();\n    return window.innerHeight < r.top;\n  }\n\n  function pastBuyNow() {\n    const marker = ensureBuyNowMarker();\n    if (!marker) return false; // if we can't find it yet, don't force show\n    const r = marker.getBoundingClientRect();\n    return r.top <= 0; // marker above viewport => user is past Buy Now\n  }\n\n  function computeVisibility() {\n    // Priority:\n    // If past buy now => show\n    // Else if before installments => show\n    // Else hide\n    if (pastBuyNow()) return true;\n    if (beforeInstallments()) return true;\n    return false;\n  }\n\n  function handle() {\n    setStickyVisible(computeVisibility());\n  }\n\n  // init styles + listeners\n  stickyBar.style.transition = 'all 0.3s ease';\n  stickyBar.style.willChange = 'transform, opacity';\n  setStickyVisible(true);\n\n  window.addEventListener('scroll', handle, { passive: true });\n  window.addEventListener('resize', handle);\n\n  // Shopify pay renders late sometimes — retry marker creation a few times\n  handle();\n  setTimeout(handle, 50);\n  setTimeout(handle, 250);\n  setTimeout(handle, 800);\n  setTimeout(handle, 1500);\n});\n</script>",
            "padding_bottom": 16
          }
        },
