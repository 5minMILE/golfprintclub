    "section_custom_code_qcyQ9G": {
      "type": "section-custom-code",
      "name": "Cart",
      "settings": {
        "code": "<div id=\"rcCartDevRoot\" aria-hidden=\"true\">\n  <div id=\"rcCartDevSheetWrap\">\n    <div id=\"rcCartDevSheet\" role=\"dialog\" aria-label=\"Your bag\">\n      <div class=\"rc-handle\"></div>\n\n      <div class=\"rc-header\">\n        <div class=\"rc-title rc-ucfont\">Your Bag</div>\n        <button class=\"rc-trackBtn\" type=\"button\" id=\"rcTrackBtn\" aria-label=\"Track order\">\n          <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n            <path d=\"M20 12a8 8 0 1 1-2.34-5.66\"/>\n            <path d=\"M20 4v6h-6\"/>\n          </svg>\n        </button>\n      </div>\n\n      <div class=\"rc-ship\">\n        <div class=\"rc-shipText rc-ucfont\" id=\"rcShipText\">Loading shipping…</div>\n        <div class=\"rc-shipBar\" aria-hidden=\"true\">\n          <div class=\"rc-shipBarFill\" id=\"rcShipFill\"></div>\n        </div>\n      </div>\n\n      <div class=\"rc-body\">\n        <div id=\"rcDevItems\"><div class=\"rc-empty\">Loading…</div></div>\n\n        <div class=\"rc-discount\" id=\"rcDiscountBox\">\n          <button class=\"rc-discountHead\" type=\"button\" id=\"rcDiscountToggle\" aria-expanded=\"false\">\n            <span class=\"rc-ucfont\">Have a discount code?</span>\n            <svg class=\"rc-chevron\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n              <path d=\"M6 9l6 6 6-6\"/>\n            </svg>\n          </button>\n\n          <div class=\"rc-discountBody\" id=\"rcDiscountBody\">\n            <input class=\"rc-discountInput\" id=\"rcDiscountInput\" type=\"text\" placeholder=\"Enter code\" autocomplete=\"off\" />\n            <button class=\"rc-discountApply rc-ucfont\" id=\"rcDiscountApplyBtn\" type=\"button\">Apply</button>\n            <div class=\"rc-discountHint\" id=\"rcDiscountHint\"></div>\n          </div>\n        </div>\n\n        <div id=\"rcUpsellWrap\" class=\"rc-upsellWrap\" style=\"display:none;\">\n          <div class=\"rc-upsellTitle rc-ucfont\">\n            <span>Add a little extra</span>\n            <span class=\"rc-upsellHint\">Swipe →</span>\n          </div>\n          <div id=\"rcUpsellRow\" class=\"rc-upsellRow\"></div>\n        </div>\n      </div>\n\n      <div class=\"rc-footer\">\n        <div class=\"rc-subrow\">\n          <span class=\"rc-ucfont\">Total</span>\n          <div class=\"rc-totalRight\">\n            <s id=\"rcDevRetail\" class=\"rc-retail\" style=\"display:none;\">$0.00</s>\n            <strong id=\"rcDevSubtotal\">$0.00</strong>\n          </div>\n        </div>\n\n        <a class=\"rc-checkout rc-ucfont\" href=\"/checkout\">Check out</a>\n        <div class=\"rc-small\" id=\"rcStatus\"></div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n(function(){\n  const rootEl = document.getElementById('rcCartDevRoot');\n  const sheetEl = document.getElementById('rcCartDevSheet');\n\n  const itemsEl = document.getElementById('rcDevItems');\n  const subtotalEl = document.getElementById('rcDevSubtotal');\n  const retailEl = document.getElementById('rcDevRetail');\n\n  const statusEl = document.getElementById('rcStatus');\n  const shipTextEl = document.getElementById('rcShipText');\n  const shipFillEl = document.getElementById('rcShipFill');\n  const trackBtn = document.getElementById('rcTrackBtn');\n\n  const upsellWrap = document.getElementById('rcUpsellWrap');\n  const upsellRow = document.getElementById('rcUpsellRow');\n\n  const discountBox = document.getElementById('rcDiscountBox');\n  const discountToggle = document.getElementById('rcDiscountToggle');\n  const discountInput = document.getElementById('rcDiscountInput');\n  const discountApplyBtn = document.getElementById('rcDiscountApplyBtn');\n  const discountHint = document.getElementById('rcDiscountHint');\n\n  const DEAL_THRESHOLD_CENTS = 4500;\n  const FREE_SHIP_THRESHOLD_CENTS = 12500;\n\n  const UPSELL_COLLECTION_HANDLE = 'golf-posters';\n  const UPSELL_LIMIT = 24;\n\n  const variantCache = new Map();\n  const collectionCache = new Map();\n\n  let discountOpen = false;\n\n  const SS_OPEN_KEY = 'rc_cart_should_open';\n  const SS_RETURN_KEY = 'rc_cart_return_url';\n  const SS_CODE_KEY = 'rc_cart_last_discount_code';\n\n  function money(cents){\n    const n = (cents || 0) / 100;\n    return n.toLocaleString(undefined, { style:'currency', currency:'USD' });\n  }\n  function esc(str){\n    return String(str || '')\n      .replace(/&/g,'&amp;').replace(/</g,'&lt;')\n      .replace(/>/g,'&gt;').replace(/\"/g,'&quot;')\n      .replace(/'/g,'&#039;');\n  }\n  function normalizeCents(v){\n    if(v == null) return 0;\n    if(typeof v === 'string'){\n      const s = v.trim();\n      if(!s) return 0;\n      if(s.includes('.')){\n        const n = Number(s);\n        return Number.isFinite(n) ? Math.round(n * 100) : 0;\n      }\n      const n = Number(s);\n      if(!Number.isFinite(n)) return 0;\n      v = n;\n    }\n    const n = Number(v);\n    if(!Number.isFinite(n)) return 0;\n    if(n > 0 && n < 1000) return Math.round(n * 100);\n    return Math.round(n);\n  }\n\n  function setStatus(msg){ statusEl.textContent = msg || ''; }\n  function setLoading(on){\n    if(on) sheetEl.classList.add('rc-loading');\n    else sheetEl.classList.remove('rc-loading');\n  }\n\n  function openCart(){\n    rootEl.classList.add('isOpen');\n    rootEl.setAttribute('aria-hidden','false');\n    document.documentElement.style.overflow = 'hidden';\n  }\n  function closeCart(){\n    rootEl.classList.remove('isOpen');\n    rootEl.setAttribute('aria-hidden','true');\n    document.documentElement.style.overflow = '';\n  }\n\n  // click backdrop to close (not the sheet)\n  rootEl.addEventListener('click', (e) => {\n    if(e.target === rootEl) closeCart();\n  });\n\n  async function getCart(){\n    const r = await fetch('/cart.js', { credentials:'same-origin', cache:'no-store' });\n    if(!r.ok) throw new Error('cart fetch failed');\n    return r.json();\n  }\n  async function changeLine(line, quantity){\n    const r = await fetch('/cart/change.js', {\n      method:'POST',\n      headers:{ 'Content-Type':'application/json' },\n      credentials:'same-origin',\n      body: JSON.stringify({ line, quantity: Math.max(0, quantity) })\n    });\n    if(!r.ok) throw new Error('cart change failed');\n    return r.json();\n  }\n  async function addToCartFromForm(form){\n    const fd = new FormData(form);\n    if(!fd.get('quantity')) fd.set('quantity', '1');\n    const r = await fetch('/cart/add.js', { method:'POST', credentials:'same-origin', body: fd });\n    if(!r.ok) throw new Error('add failed');\n    return r.json();\n  }\n  async function addToCartByVariantId(variantId, quantity){\n    const r = await fetch('/cart/add.js', {\n      method:'POST',\n      headers:{ 'Content-Type':'application/json' },\n      credentials:'same-origin',\n      body: JSON.stringify({ id: variantId, quantity: quantity || 1 })\n    });\n    if(!r.ok) throw new Error('add failed');\n    return r.json();\n  }\n\n  function fetchVariantPricing(variantId){\n    const key = String(variantId || '');\n    if(!key) return Promise.resolve({ compare_at_price: 0, price: 0 });\n    if(variantCache.has(key)) return variantCache.get(key);\n\n    const p = fetch(`/variants/${encodeURIComponent(key)}.js`, { credentials:'same-origin' })\n      .then(r => r.ok ? r.json() : null)\n      .then(v => ({\n        compare_at_price: normalizeCents(v?.compare_at_price || 0),\n        price: normalizeCents(v?.price || 0)\n      }))\n      .catch(() => ({ compare_at_price: 0, price: 0 }));\n\n    variantCache.set(key, p);\n    return p;\n  }\n\n  async function fetchCollectionProducts(handle){\n    const key = String(handle || '');\n    if(!key) return [];\n    if(collectionCache.has(key)) return collectionCache.get(key);\n\n    const p = fetch(`/collections/${encodeURIComponent(key)}/products.json?limit=${UPSELL_LIMIT}`, { credentials:'same-origin' })\n      .then(r => r.ok ? r.json() : null)\n      .then(data => Array.isArray(data?.products) ? data.products : [])\n      .catch(() => []);\n\n    collectionCache.set(key, p);\n    return p;\n  }\n\n  function priceHtmlWithBase(base, final){\n    if(final === 0){\n      if(base > 0){\n        return `<div class=\"rc-priceWrap\">\n                  <span class=\"rc-freeTag rc-ucfont\">FREE</span>\n                  <span class=\"rc-priceOld\">${money(base)}</span>\n                </div>`;\n      }\n      return `<div class=\"rc-priceWrap\"><span class=\"rc-freeTag rc-ucfont\">FREE</span></div>`;\n    }\n    const isDeal = (base > 0 && final < base && final < DEAL_THRESHOLD_CENTS);\n    if(isDeal){\n      return `<div class=\"rc-priceWrap\">\n                <span class=\"rc-priceOld\">${money(base)}</span>\n                <span class=\"rc-priceNew isDeal\">${money(final)}</span>\n              </div>`;\n    }\n    return `<div class=\"rc-priceWrap\"><span class=\"rc-priceNew\">${money(final)}</span></div>`;\n  }\n\n  function updateFreeShipUI(totalCents){\n    const total = Number(totalCents || 0);\n    const remaining = Math.max(0, FREE_SHIP_THRESHOLD_CENTS - total);\n    const pct = Math.max(0, Math.min(100, (total / FREE_SHIP_THRESHOLD_CENTS) * 100));\n    shipFillEl.style.width = pct + '%';\n    shipTextEl.textContent = (remaining === 0)\n      ? 'YOU QUALIFY FOR FREE SHIPPING'\n      : `YOU ARE ${money(remaining)} AWAY FROM FREE SHIPPING`;\n  }\n\n  function qtySelectHtml(line, qty){\n    const q = Number(qty || 1);\n    const max = Math.max(10, q + 6);\n    let opts = '';\n    for(let i=1;i<=max;i++){\n      opts += `<option value=\"${i}\" ${i===q ? 'selected' : ''}>${i}</option>`;\n    }\n    return `\n      <div class=\"rc-qtyWrap\">\n        <div class=\"rc-qtyLabel rc-ucfont\">Qty:</div>\n        <select class=\"rc-qtySelect\" data-qtyselect=\"${line}\">\n          ${opts}\n        </select>\n      </div>\n    `;\n  }\n\n  function trashButtonHtml(line){\n    return `\n      <button type=\"button\" class=\"rc-trashBtn\" data-trash=\"${line}\" aria-label=\"Remove item\">\n        <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n          <path d=\"M3 6h18\"/>\n          <path d=\"M8 6V4h8v2\"/>\n          <path d=\"M6 6l1 16h10l1-16\"/>\n          <path d=\"M10 11v7\"/>\n          <path d=\"M14 11v7\"/>\n        </svg>\n      </button>\n    `;\n  }\n\n  function hasHideTag(product){\n    const tags = product?.tags;\n    if(!tags) return false;\n    if(typeof tags === 'string'){\n      return tags.split(',').map(t => t.trim().toLowerCase()).includes('hide');\n    }\n    if(Array.isArray(tags)){\n      return tags.map(t => String(t).trim().toLowerCase()).includes('hide');\n    }\n    return false;\n  }\n\n  function pickUpsellVariant(product){\n    if(!product || !Array.isArray(product.variants)) return null;\n    return product.variants.find(v => v && v.available) || null;\n  }\n\n  function getProductImage(product){\n    const img = (product?.images && product.images[0] && product.images[0].src) ? product.images[0].src : '';\n    return img || '';\n  }\n\n  function upsellPriceRow(variant){\n    const price = normalizeCents(variant?.price || 0);\n    const compare = normalizeCents(variant?.compare_at_price || 0);\n\n    if(compare > price && price > 0){\n      const pct = Math.round(((compare - price) / compare) * 100);\n      return `\n        <div class=\"rc-upsellPriceRow\">\n          <span class=\"rc-upsellOld\">${money(compare)}</span>\n          <span class=\"rc-upsellPrice rc-upsellSale\">${money(price)}</span>\n          <span class=\"rc-upsellSale\">-${pct}%</span>\n        </div>\n      `;\n    }\n    return `\n      <div class=\"rc-upsellPriceRow\">\n        <span class=\"rc-upsellPrice\">${money(price)}</span>\n      </div>\n    `;\n  }\n\n  function productUrl(product){\n    const h = product?.handle ? String(product.handle) : '';\n    return h ? `/products/${encodeURIComponent(h)}` : '#';\n  }\n\n  async function renderUpsells(cart){\n    try{\n      if(!upsellWrap || !upsellRow) return;\n\n      if(!cart?.items?.length){\n        upsellWrap.style.display = 'none';\n        upsellRow.innerHTML = '';\n        return;\n      }\n\n      const productsRaw = await fetchCollectionProducts(UPSELL_COLLECTION_HANDLE);\n      const products = (productsRaw || []).filter(p => !hasHideTag(p));\n\n      const inCartProductIds = new Set((cart.items || []).map(i => String(i.product_id)));\n\n      const candidates = products\n        .filter(p => !inCartProductIds.has(String(p.id)))\n        .map(p => {\n          const v = pickUpsellVariant(p);\n          if(!v || !v.id) return null;\n          return { product: p, variant: v };\n        })\n        .filter(Boolean)\n        .slice(0, 12);\n\n      if(!candidates.length){\n        upsellWrap.style.display = 'none';\n        upsellRow.innerHTML = '';\n        return;\n      }\n\n      upsellWrap.style.display = 'block';\n      upsellRow.innerHTML = candidates.map(({product, variant}) => {\n        const img = getProductImage(product);\n        const vTitleRaw = variant?.title ? String(variant.title) : '';\n        const vColor = vTitleRaw.includes('/')\n          ? vTitleRaw.split('/')[0].trim()\n          : vTitleRaw;\n\n        const url = productUrl(product);\n\n        return `\n          <div class=\"rc-upsellCard\">\n            <div class=\"rc-upsellImg\">${img ? `<img src=\"${img}\" alt=\"\">` : ''}</div>\n            <div class=\"rc-upsellMeta\">\n              <div class=\"rc-upsellName rc-ucfont\">${esc(product.title)}</div>\n              <div class=\"rc-upsellVar\">${esc(vColor)}</div>\n\n              ${upsellPriceRow(variant)}\n            </div>\n            <a class=\"rc-upsellBtn rc-ucfont\" href=\"${url}\">\n              <span class=\"rc-upsellPlus\">+</span> add\n            </a>\n          </div>\n        `;\n      }).join('');\n    } catch(e){\n      upsellWrap.style.display = 'none';\n      upsellRow.innerHTML = '';\n    }\n  }\n\n  function setDiscountOpen(open){\n    discountOpen = !!open;\n    if(discountOpen){\n      discountBox.classList.add('isOpen');\n      discountToggle.setAttribute('aria-expanded','true');\n    } else {\n      discountBox.classList.remove('isOpen');\n      discountToggle.setAttribute('aria-expanded','false');\n    }\n  }\n\n  function applyPromoCode(code){\n    const c = String(code || '').trim();\n    if(!c){\n      discountHint.textContent = 'Enter a code first.';\n      return;\n    }\n\n    const returnUrl = window.location.pathname + window.location.search + window.location.hash;\n\n    sessionStorage.setItem(SS_OPEN_KEY, '1');\n    sessionStorage.setItem(SS_RETURN_KEY, returnUrl);\n    sessionStorage.setItem(SS_CODE_KEY, c.toUpperCase());\n\n    window.location.href = `/discount/${encodeURIComponent(c)}?redirect=${encodeURIComponent(returnUrl)}`;\n  }\n\n  function restoreAfterDiscountRedirect(){\n    const shouldOpen = sessionStorage.getItem(SS_OPEN_KEY) === '1';\n    if(shouldOpen){\n      sessionStorage.removeItem(SS_OPEN_KEY);\n      const last = (sessionStorage.getItem(SS_CODE_KEY) || '').trim();\n      if(last){\n        setStatus(`Code applied: ${last.toUpperCase()}`);\n        openCart();\n      }\n    }\n  }\n\n  async function render(){\n    itemsEl.innerHTML = '<div class=\"rc-empty\">Loading…</div>';\n    setStatus('');\n    setLoading(true);\n\n    try{\n      const cart = await getCart();\n      const total = cart.total_price || 0;\n\n      subtotalEl.textContent = money(total);\n      updateFreeShipUI(total);\n\n      // ----- Retail total (compare-at sum) -----\n      let retailTotal = 0;\n\n      // We'll compute it properly once we have variant pricing below.\n      // For now, hide until we finish calculating.\n      if(retailEl){\n        retailEl.style.display = 'none';\n        retailEl.textContent = '';\n      }\n\n      if(!cart.items || cart.items.length === 0){\n        itemsEl.innerHTML = '<div class=\"rc-empty\">Your bag is empty.</div>';\n        if(upsellWrap){ upsellWrap.style.display = 'none'; }\n        setDiscountOpen(discountOpen);\n        setLoading(false);\n        return;\n      }\n\n      const variantPricingArr = await Promise.all(cart.items.map(it => fetchVariantPricing(it.variant_id)));\n\n      // Calculate retail total using compare_at when available (per-unit), otherwise fallback base per-unit\n      retailTotal = cart.items.reduce((sum, item, idx) => {\n        const vp = variantPricingArr[idx] || { compare_at_price: 0, price: 0 };\n\n        // Choose \"retail\" per unit:\n        // - prefer compare_at_price if set\n        // - else fallback to vp.price\n        // - else fallback to item.price\n        const retailUnit =\n          (vp.compare_at_price > 0 ? vp.compare_at_price :\n           (vp.price > 0 ? vp.price : normalizeCents(item.price || 0)));\n\n        const qty = Math.max(1, Number(item.quantity || 1));\n        return sum + (retailUnit * qty);\n      }, 0);\n\n      // Show retail only if it's meaningfully higher than actual total\n      if(retailEl){\n        if(retailTotal > total){\n          retailEl.textContent = money(retailTotal);\n          retailEl.style.display = 'inline';\n        } else {\n          retailEl.style.display = 'none';\n          retailEl.textContent = '';\n        }\n      }\n\n      itemsEl.innerHTML = cart.items.map((item, idx) => {\n        const line = idx + 1;\n        const vp = variantPricingArr[idx] || { compare_at_price: 0, price: 0 };\n        const base = (vp.compare_at_price > 0 ? vp.compare_at_price : (vp.price > 0 ? vp.price : normalizeCents(item.price || 0)));\n        const final = normalizeCents(item.final_price ?? item.price ?? 0);\n\n        return `\n          <div class=\"rc-item\" data-line=\"${line}\">\n            <div class=\"rc-thumb\">${item.image ? `<img src=\"${item.image}\" alt=\"\">` : ''}</div>\n            <div class=\"rc-meta\">\n              <div class=\"rc-topline\">\n                <div class=\"rc-name rc-ucfont\">${esc(item.product_title)}</div>\n                ${trashButtonHtml(line)}\n              </div>\n              <div class=\"rc-variant\">${esc(item.variant_title)}</div>\n              <div class=\"rc-row2\">\n                ${priceHtmlWithBase(base, final)}\n                ${qtySelectHtml(line, item.quantity || 1)}\n              </div>\n            </div>\n          </div>\n        `;\n      }).join('');\n\n      setDiscountOpen(discountOpen);\n      await renderUpsells(cart);\n      setLoading(false);\n    } catch(e){\n      console.log('[RC CART DEV] render error', e);\n      itemsEl.innerHTML = '<div class=\"rc-empty\">Couldn’t load cart. Check console.</div>';\n      subtotalEl.textContent = money(0);\n      updateFreeShipUI(0);\n      setStatus('Cart failed to load.');\n      if(upsellWrap){ upsellWrap.style.display = 'none'; }\n      setDiscountOpen(discountOpen);\n      setLoading(false);\n    }\n  }\n\n  // qty change\n  itemsEl.addEventListener('change', async (e) => {\n    const sel = e.target.closest('[data-qtyselect]');\n    if(!sel) return;\n    try{\n      setLoading(true);\n      const line = parseInt(sel.getAttribute('data-qtyselect'), 10);\n      const qty = parseInt(sel.value, 10);\n      await changeLine(line, qty);\n      await render();\n    } catch(err){\n      console.log('[RC CART DEV] qty change error', err);\n      setStatus('Update failed.');\n      setLoading(false);\n    }\n  });\n\n  // trash\n  itemsEl.addEventListener('click', async (e) => {\n    const btn = e.target.closest('[data-trash]');\n    if(!btn) return;\n    try{\n      setLoading(true);\n      const line = parseInt(btn.getAttribute('data-trash'), 10);\n      await changeLine(line, 0);\n      await render();\n    } catch(err){\n      console.log('[RC CART DEV] trash error', err);\n      setStatus('Remove failed.');\n      setLoading(false);\n    }\n  });\n\n  // promo dropdown toggle\n  discountToggle.addEventListener('click', () => {\n    setDiscountOpen(!discountOpen);\n    if(!discountOpen) return;\n    setTimeout(() => discountInput && discountInput.focus(), 0);\n  });\n\n  // promo apply\n  discountApplyBtn.addEventListener('click', () => applyPromoCode(discountInput.value));\n  discountInput.addEventListener('keydown', (e) => {\n    if(e.key === 'Enter'){\n      e.preventDefault();\n      applyPromoCode(discountInput.value);\n    }\n  });\n\n  trackBtn.addEventListener('click', function(){\n    setStatus('Tracking coming next…');\n  });\n\n  // restore state after discount redirect\n  restoreAfterDiscountRedirect();\n\n  // start closed\n  setDiscountOpen(false);\n  closeCart();\n\n  // expose a tiny API\n  window.RC_CART = {\n    open: async () => { openCart(); await render(); },\n    close: () => closeCart(),\n    refresh: async () => { await render(); }\n  };\n\n  // initial render so it’s ready when opened\n  render();\n\n  \n\n  function matchesCartLink(el){\n    if(!el) return false;\n    const a = el.closest && el.closest('a');\n    if(!a) return false;\n\n    const href = (a.getAttribute('href') || '').trim();\n    const cls = (a.className || '');\n    const hasToggle = a.hasAttribute('data-cart-toggle') || a.closest('[data-cart-toggle]');\n\n    // exact targets you showed + broad safety net\n    if(cls.includes('navlink--cart') || hasToggle) return true;\n    if(href === '/cart' || href === 'cart' || href.startsWith('/cart?') || href.startsWith('cart?')) return true;\n\n    return false;\n  }\n\n  function matchesATCButton(el){\n    if(!el) return false;\n    const btn = el.closest && el.closest('button');\n    if(!btn) return false;\n\n    const id = (btn.id || '').trim();\n    if(id === 'rc-inline-atc' || id === 'stickyAddBtn') return true;\n\n    // safety net: common theme add-to-cart buttons\n    const name = (btn.getAttribute('name') || '').toLowerCase();\n    const type = (btn.getAttribute('type') || '').toLowerCase();\n    if(name === 'add' || name.includes('add')) return true;\n    if(type === 'submit' && btn.closest('form[action*=\"/cart/add\"]')) return true;\n\n    return false;\n  }\n\n  async function handleATCClick(target){\n    // Prefer the nearest product form so variant selection is respected\n    const btn = target.closest('button');\n    const form = btn && btn.closest('form');\n\n    try{\n      setStatus('Adding…');\n\n      if(form && (form.getAttribute('action') || '').toLowerCase().includes('/cart/add')){\n        await addToCartFromForm(form);\n      } else {\n        // fallback: try to find a selected variant id on the page\n        const idInput =\n          document.querySelector('form[action*=\"/cart/add\"] [name=\"id\"]') ||\n          document.querySelector('[name=\"id\"]');\n\n        const variantId = idInput ? Number(idInput.value) : 0;\n        if(!variantId) throw new Error('No variant id found for ATC fallback.');\n        await addToCartByVariantId(variantId, 1);\n      }\n\n      setStatus('Added to bag.');\n      await window.RC_CART.open();\n    } catch(e){\n      console.error('[RC CART] ATC intercept failed', e);\n      setStatus('Add to cart failed.');\n      // if something breaks, allow user to continue normal flow\n      // (you can delete this line if you never want fallback)\n      // window.location.href = '/cart';\n    }\n  }\n\n  // CAPTURE: beats theme listeners\n  document.addEventListener('click', function(e){\n    const t = e.target;\n\n    // 1) Cart icon/link -> open popup\n    if(matchesCartLink(t)){\n      e.preventDefault();\n      e.stopPropagation();\n      if(e.stopImmediatePropagation) e.stopImmediatePropagation();\n      window.RC_CART.open();\n      return;\n    }\n\n    // 2) ATC buttons -> add to cart then open popup\n    if(matchesATCButton(t)){\n      e.preventDefault();\n      e.stopPropagation();\n      if(e.stopImmediatePropagation) e.stopImmediatePropagation();\n      handleATCClick(t);\n      return;\n    }\n  }, true); // <- capture phase\n})();\n</script>\n\n<style>\n  \n  #rcDiscountBody { display: block !important; }\n  #rcDiscountBox:not(.isOpen) #rcDiscountBody { display: none !important; }\n\n  #rcDiscountInput,\n  #rcDiscountBody .rc-discountInput{\n    display: block !important;\n    width: 100% !important;\n    height: 44px !important;\n    min-height: 44px !important;\n    padding: 0 12px !important;\n    margin: 0 0 10px 0 !important;\n\n    opacity: 1 !important;\n    visibility: visible !important;\n    pointer-events: auto !important;\n\n    position: relative !important;\n    z-index: 999999 !important;\n\n    -webkit-appearance: none !important;\n    appearance: none !important;\n\n    border-radius: 12px !important;\n    border: 1px solid var(--rc-border) !important;\n    background: #fff !important;\n    color: #111 !important;\n  }\n\n  \n  #rcCartDevSheet input[type=\"text\"]{\n    display: block !important;\n    opacity: 1 !important;\n    visibility: visible !important;\n    pointer-events: auto !important;\n    height: 44px !important;\n    min-height: 44px !important;\n  }\n</style>\n\n<script>\n(function(){\n  // Rebuild the input + rebind handlers if theme removes/hides it\n  function ensureDiscountUI(){\n    const body = document.getElementById('rcDiscountBody');\n    const btn  = document.getElementById('rcDiscountApplyBtn');\n    const hint = document.getElementById('rcDiscountHint');\n\n    if(!body || !btn) return;\n\n    let input = document.getElementById('rcDiscountInput');\n\n    // If removed, recreate it (insert before apply button)\n    if(!input){\n      input = document.createElement('input');\n      input.className = 'rc-discountInput';\n      input.id = 'rcDiscountInput';\n      input.type = 'text';\n      input.placeholder = 'Enter code';\n      input.autocomplete = 'off';\n      body.insertBefore(input, btn);\n    }\n\n    // Smash any inline styles that might hide it\n    input.style.display = 'block';\n    input.style.opacity = '1';\n    input.style.visibility = 'visible';\n    input.style.pointerEvents = 'auto';\n    input.style.height = '44px';\n    input.style.minHeight = '44px';\n\n    // Prevent double-binding\n    if(input.dataset.rcBound === '1') return;\n    input.dataset.rcBound = '1';\n\n    // We reuse your existing apply logic if present\n    // (your main script defines window.RC_CART + uses /discount/ redirect)\n    function apply(){\n      const code = (input.value || '').trim();\n      if(!code){\n        if(hint) hint.textContent = 'Enter a code first.';\n        return;\n      }\n\n      // If your main script exposes apply behavior, use it.\n      // Otherwise fallback to Shopify's /discount/ redirect.\n      if(typeof window.RC_APPLY_DISCOUNT === 'function'){\n        window.RC_APPLY_DISCOUNT(code);\n        return;\n      }\n\n      const returnUrl = window.location.pathname + window.location.search + window.location.hash;\n      sessionStorage.setItem('rc_cart_should_open', '1');\n      sessionStorage.setItem('rc_cart_return_url', returnUrl);\n      sessionStorage.setItem('rc_cart_last_discount_code', code.toUpperCase());\n\n      window.location.href = '/discount/' + encodeURIComponent(code) + '?redirect=' + encodeURIComponent(returnUrl);\n    }\n\n    btn.addEventListener('click', apply, true);\n    input.addEventListener('keydown', (e) => {\n      if(e.key === 'Enter'){\n        e.preventDefault();\n        apply();\n      }\n    }, true);\n  }\n\n  // Run immediately + after a short delay (some themes run after initial render)\n  ensureDiscountUI();\n  setTimeout(ensureDiscountUI, 200);\n  setTimeout(ensureDiscountUI, 800);\n\n  // Observe for theme scripts removing/changing the discount block\n  const root = document.getElementById('rcCartDevSheet') || document.body;\n  const obs = new MutationObserver(() => ensureDiscountUI());\n  obs.observe(root, { childList: true, subtree: true });\n\n  // Also re-ensure whenever cart is opened via your API\n  const _open = window.RC_CART && window.RC_CART.open;\n  if(window.RC_CART && typeof _open === 'function'){\n    window.RC_CART.open = async function(){\n      const r = await _open.apply(this, arguments);\n      ensureDiscountUI();\n      return r;\n    };\n  }\n})();\n</script>\n\n<script>\n(function(){\n  // Keys you already use (match your existing names)\n  const SS_OPEN_KEY  = 'rc_cart_should_open';\n  const SS_CODE_KEY  = 'rc_cart_last_discount_code';\n\n  function norm(s){ return (s || '').toString().trim().toUpperCase(); }\n\n  function getStatusEl(){\n    return document.getElementById('rcStatus');\n  }\n\n  function setPromoStatus(code){\n    const el = getStatusEl();\n    if(!el) return;\n    const c = norm(code);\n    if(!c) { el.textContent = ''; return; }\n    el.textContent = `Promo code: ${c}`;\n  }\n\n  // HARD open fallback (in case window.RC_CART.open isn't available)\n  function openCartFallback(){\n    const root  = document.getElementById('rcCartDevRoot');\n    if(root){\n      root.style.display = 'block';\n      root.style.opacity = '1';\n      root.style.pointerEvents = 'auto';\n      root.setAttribute('aria-hidden','false');\n      document.documentElement.style.overflow = 'hidden';\n    }\n  }\n\n  function openCart(){\n    // Prefer your exposed API if you have it\n    if(window.RC_CART && typeof window.RC_CART.open === 'function'){\n      window.RC_CART.open();\n      return;\n    }\n    openCartFallback();\n  }\n\n  // 1) Monkey-patch your discount apply so it sets the \"reopen\" flag\n  // If your brute-force discount box patch is using window.RC_APPLY_DISCOUNT, we attach it.\n  // If not, we still intercept clicks/Enter on your discount UI.\n  function applyDiscountAndReturn(rawCode){\n    const code = (rawCode || '').toString().trim();\n    if(!code) return;\n\n    // Store intent to reopen + show code after reload\n    sessionStorage.setItem(SS_OPEN_KEY, '1');\n    sessionStorage.setItem(SS_CODE_KEY, norm(code));\n\n    const returnUrl = window.location.pathname + window.location.search + window.location.hash;\n    window.location.href =\n      '/discount/' + encodeURIComponent(code) +\n      '?redirect=' + encodeURIComponent(returnUrl);\n  }\n\n  // Expose for other scripts (optional, but makes everything consistent)\n  window.RC_APPLY_DISCOUNT = applyDiscountAndReturn;\n\n  // 2) After redirect back, reopen cart and show promo code under checkout\n  function restoreAfterDiscountRedirect(){\n    const shouldOpen = sessionStorage.getItem(SS_OPEN_KEY) === '1';\n    const code = sessionStorage.getItem(SS_CODE_KEY) || '';\n\n    if(shouldOpen){\n      sessionStorage.removeItem(SS_OPEN_KEY);\n\n      // open cart again after the new page loads + DOM exists\n      // slight delay helps if theme scripts render late\n      setTimeout(() => {\n        openCart();\n        setPromoStatus(code);\n      }, 120);\n    } else {\n      // If they refresh later and you still want it visible, keep this:\n      // setPromoStatus(code);\n      // If you ONLY want it right after apply, leave it off.\n    }\n  }\n\n  // Run on load\n  if(document.readyState === 'loading'){\n    document.addEventListener('DOMContentLoaded', restoreAfterDiscountRedirect);\n  } else {\n    restoreAfterDiscountRedirect();\n  }\n\n  // 3) Ensure your discount input/button uses this apply logic (even if theme re-renders)\n  function wireDiscountUI(){\n    const input = document.getElementById('rcDiscountInput');\n    const btn   = document.getElementById('rcDiscountApplyBtn');\n    if(!input || !btn) return;\n\n    if(btn.dataset.rcApplyBound !== '1'){\n      btn.dataset.rcApplyBound = '1';\n      btn.addEventListener('click', () => applyDiscountAndReturn(input.value), true);\n    }\n\n    if(input.dataset.rcApplyBound !== '1'){\n      input.dataset.rcApplyBound = '1';\n      input.addEventListener('keydown', (e) => {\n        if(e.key === 'Enter'){\n          e.preventDefault();\n          applyDiscountAndReturn(input.value);\n        }\n      }, true);\n    }\n  }\n\n  wireDiscountUI();\n\n  // Re-wire if the theme nukes/rebuilds the discount UI\n  const sheet = document.getElementById('rcCartDevSheet') || document.body;\n  const obs = new MutationObserver(() => wireDiscountUI());\n  obs.observe(sheet, { childList:true, subtree:true });\n\n})();\n</script>\n\n<script>\n(function () {\n  // ====== STORAGE KEYS ======\n  const SS_OPEN_KEY = \"rc_cart_should_open\";\n  const SS_CODE_KEY = \"rc_cart_last_discount_code\";\n\n  const norm = (s) => (s || \"\").toString().trim().toUpperCase();\n\n  // ====== OPEN CART (works even if you don't have a global open()) ======\n  function openCartNow() {\n    // If you already exposed an API, use it\n    if (window.RC_CART && typeof window.RC_CART.open === \"function\") {\n      window.RC_CART.open();\n      return true;\n    }\n\n    // Otherwise brute-force open the root\n    const root = document.getElementById(\"rcCartDevRoot\");\n    if (!root) return false;\n\n    root.style.display = \"block\";\n    root.style.opacity = \"1\";\n    root.style.pointerEvents = \"auto\";\n    root.setAttribute(\"aria-hidden\", \"false\");\n\n    document.documentElement.style.overflow = \"hidden\";\n    return true;\n  }\n\n  // ====== SHOW APPLIED DISCOUNTS (REAL from cart.js) ======\n  async function showAppliedDiscounts() {\n    const statusEl = document.getElementById(\"rcStatus\");\n    if (!statusEl) return;\n\n    try {\n      const r = await fetch(\"/cart.js\", { credentials: \"same-origin\", cache: \"no-store\" });\n      if (!r.ok) throw new Error(\"cart.js failed\");\n      const cart = await r.json();\n\n      const codes = [];\n      if (Array.isArray(cart.discount_codes)) {\n        cart.discount_codes.forEach(d => {\n          const c = d && d.code ? String(d.code) : \"\";\n          if (c) codes.push(norm(c));\n        });\n      }\n\n      // Some discounts show up as cart_level_discount_applications instead\n      if (!codes.length && Array.isArray(cart.cart_level_discount_applications)) {\n        cart.cart_level_discount_applications.forEach(d => {\n          const t = d && d.title ? String(d.title) : \"\";\n          if (t) codes.push(t);\n        });\n      }\n\n      if (codes.length) {\n        statusEl.textContent = `Promo code applied: ${codes.join(\", \")}`;\n      } else {\n        statusEl.textContent = \"No promo code applied.\";\n      }\n    } catch (e) {\n      console.log(\"[RC DISCOUNT] Could not read applied discounts:\", e);\n    }\n  }\n\n  // ====== APPLY DISCOUNT (Shopify standard) ======\n  function applyDiscount(codeRaw) {\n    const code = (codeRaw || \"\").toString().trim();\n    const hint = document.getElementById(\"rcDiscountHint\");\n\n    if (!code) {\n      if (hint) hint.textContent = \"Enter a code first.\";\n      return;\n    }\n\n    sessionStorage.setItem(SS_OPEN_KEY, \"1\");\n    sessionStorage.setItem(SS_CODE_KEY, norm(code));\n\n    const returnUrl = window.location.pathname + window.location.search + window.location.hash;\n    window.location.href =\n      \"/discount/\" + encodeURIComponent(code) +\n      \"?redirect=\" + encodeURIComponent(returnUrl);\n  }\n\n  // ====== INTERCEPT YOUR DISCOUNT UI (capture phase = beats existing handlers) ======\n  function wireDiscountUI() {\n    const input = document.getElementById(\"rcDiscountInput\");\n    const btn = document.getElementById(\"rcDiscountApplyBtn\");\n    if (!input || !btn) return false;\n\n    if (!btn.dataset.rcPatched) {\n      btn.dataset.rcPatched = \"1\";\n      btn.addEventListener(\"click\", function (e) {\n        e.preventDefault();\n        e.stopPropagation();\n        e.stopImmediatePropagation();\n        applyDiscount(input.value);\n      }, true);\n    }\n\n    if (!input.dataset.rcPatched) {\n      input.dataset.rcPatched = \"1\";\n      input.addEventListener(\"keydown\", function (e) {\n        if (e.key === \"Enter\") {\n          e.preventDefault();\n          e.stopPropagation();\n          e.stopImmediatePropagation();\n          applyDiscount(input.value);\n        }\n      }, true);\n    }\n\n    return true;\n  }\n\n  // keep trying in case your drawer UI renders late or gets re-rendered\n  (function retryWire() {\n    let tries = 0;\n    const t = setInterval(() => {\n      tries++;\n      wireDiscountUI();\n      if (tries > 80) clearInterval(t);\n    }, 150);\n  })();\n\n  // ====== AFTER REDIRECT: REOPEN CART + SHOW APPLIED DISCOUNTS ======\n  function restoreOpenAfterDiscount() {\n    const shouldOpen = sessionStorage.getItem(SS_OPEN_KEY) === \"1\";\n    if (!shouldOpen) return;\n\n    sessionStorage.removeItem(SS_OPEN_KEY);\n\n    // Poll until your popup cart exists, then open it\n    let tries = 0;\n    const timer = setInterval(async () => {\n      tries++;\n\n      const opened = openCartNow();\n      if (opened) {\n        clearInterval(timer);\n\n        // Give your cart render() a beat, then read discounts\n        setTimeout(() => { showAppliedDiscounts(); }, 250);\n      }\n\n      if (tries > 80) clearInterval(timer);\n    }, 150);\n  }\n\n  if (document.readyState === \"loading\") {\n    document.addEventListener(\"DOMContentLoaded\", restoreOpenAfterDiscount);\n  } else {\n    restoreOpenAfterDiscount();\n  }\n})();\n</script>\n\n<script>\n(function(){\n  // New key dedicated to \"cart was open\" persistence\n  const SS_WAS_OPEN_KEY = 'rc_cart_was_open';\n\n  function isCartOpen(){\n    const root = document.getElementById('rcCartDevRoot');\n    return !!(root && root.classList.contains('isOpen'));\n  }\n\n  function setWasOpen(on){\n    try{\n      if(on) sessionStorage.setItem(SS_WAS_OPEN_KEY, '1');\n      else sessionStorage.removeItem(SS_WAS_OPEN_KEY);\n    }catch(e){}\n  }\n\n  function reopenIfNeeded(){\n    let shouldReopen = false;\n    try{\n      shouldReopen = sessionStorage.getItem(SS_WAS_OPEN_KEY) === '1';\n    }catch(e){}\n\n    if(!shouldReopen) return;\n\n    // Wait for your main script to define RC_CART, then open.\n    let tries = 0;\n    const t = setInterval(() => {\n      tries++;\n\n      // If user already has it open, we're good.\n      if(isCartOpen()){\n        clearInterval(t);\n        return;\n      }\n\n      if(window.RC_CART && typeof window.RC_CART.open === 'function'){\n        clearInterval(t);\n        // open() also re-renders, so this is the cleanest path\n        window.RC_CART.open();\n      }\n\n      if(tries > 80) clearInterval(t);\n    }, 120);\n  }\n\n  function patchRC(){\n    if(!window.RC_CART) return false;\n\n    // Patch open: whenever cart opens, remember it\n    if(window.RC_CART.open && !window.RC_CART.open.__rc_patched){\n      const _open = window.RC_CART.open;\n      function patchedOpen(){\n        setWasOpen(true);\n        return _open.apply(this, arguments);\n      }\n      patchedOpen.__rc_patched = true;\n      window.RC_CART.open = patchedOpen;\n    }\n\n    // Patch close: whenever user closes, forget it\n    if(window.RC_CART.close && !window.RC_CART.close.__rc_patched){\n      const _close = window.RC_CART.close;\n      function patchedClose(){\n        setWasOpen(false);\n        return _close.apply(this, arguments);\n      }\n      patchedClose.__rc_patched = true;\n      window.RC_CART.close = patchedClose;\n    }\n\n    return true;\n  }\n\n  // 1) Save state right before a refresh/navigation happens\n  window.addEventListener('beforeunload', () => {\n    // If it's open at refresh time, keep it sticky\n    setWasOpen(isCartOpen());\n  });\n\n  // 2) Also update state if something else opens/closes it without using RC_CART API\n  // (rare, but this makes it bulletproof)\n  const root = document.getElementById('rcCartDevRoot');\n  if(root && window.MutationObserver){\n    const obs = new MutationObserver(() => {\n      setWasOpen(isCartOpen());\n    });\n    obs.observe(root, { attributes:true, attributeFilter:['class'] });\n  }\n\n  // 3) Patch RC_CART when it exists (your code defines it after load)\n  (function waitForRC(){\n    let tries = 0;\n    const timer = setInterval(() => {\n      tries++;\n      if(patchRC()){\n        clearInterval(timer);\n      }\n      if(tries > 120) clearInterval(timer);\n    }, 100);\n  })();\n\n  // 4) Reopen after refresh if it was open\n  if(document.readyState === 'loading'){\n    document.addEventListener('DOMContentLoaded', reopenIfNeeded);\n  } else {\n    reopenIfNeeded();\n  }\n})();\n</script>\n\n<style>\n  \n  #rcCartDevSheet{\n    will-change: transform;\n    touch-action: none; \n  }\n  #rcCartDevSheet.rc-dragging{\n    transition: none !important;\n  }\n</style>\n\n<style>\n  @media (max-width: 749px){\n    #rcCartDevSheet{\n      height: min(80vh, 760px);\n    }\n  }\n</style>\n\n<script>\n(function () {\n  var THRESHOLD_PCT = 0.30; // 30% of viewport height\n\n  function clamp(n, min, max) {\n    if (n < min) return min;\n    if (n > max) return max;\n    return n;\n  }\n\n  function isOpen(root) {\n    return !!(root && root.classList && root.classList.contains(\"isOpen\"));\n  }\n\n  function getY(evt) {\n    if (evt && evt.touches && evt.touches.length) return evt.touches[0].clientY;\n    if (evt && evt.changedTouches && evt.changedTouches.length) return evt.changedTouches[0].clientY;\n    return evt && typeof evt.clientY === \"number\" ? evt.clientY : 0;\n  }\n\n  function setup() {\n    var root = document.getElementById(\"rcCartDevRoot\");\n    var sheet = document.getElementById(\"rcCartDevSheet\");\n    var handle = document.querySelector(\"#rcCartDevSheet .rc-handle\");\n\n    if (!root || !sheet || !handle) return false;\n\n    var dragging = false;\n    var startY = 0;\n    var currentY = 0;\n\n    function setTranslate(y) {\n      sheet.style.transform = \"translateY(\" + y + \"px)\";\n    }\n\n    function resetSheet() {\n      sheet.classList.remove(\"rc-dragging\");\n      sheet.style.transition = \"\";\n      sheet.style.transform = \"\";\n    }\n\n    function closeCart() {\n      resetSheet();\n      if (window.RC_CART && typeof window.RC_CART.close === \"function\") {\n        window.RC_CART.close();\n      } else {\n        // fallback close\n        root.classList.remove(\"isOpen\");\n        root.setAttribute(\"aria-hidden\", \"true\");\n        document.documentElement.style.overflow = \"\";\n      }\n    }\n\n    function onDown(e) {\n      if (!isOpen(root)) return;\n\n      // Only left click for mouse\n      if (e.type === \"mousedown\" && e.button !== 0) return;\n\n      dragging = true;\n      startY = getY(e);\n      currentY = 0;\n\n      sheet.classList.add(\"rc-dragging\");\n      sheet.style.transition = \"none\";\n\n      if (e.preventDefault) e.preventDefault();\n      if (e.stopPropagation) e.stopPropagation();\n    }\n\n    function onMove(e) {\n      if (!dragging) return;\n\n      var dy = getY(e) - startY;\n      if (dy < 0) dy = 0;\n\n      currentY = clamp(dy, 0, (window.innerHeight || 800));\n      setTranslate(currentY);\n\n      if (e.preventDefault) e.preventDefault();\n      if (e.stopPropagation) e.stopPropagation();\n    }\n\n    function onUp(e) {\n      if (!dragging) return;\n      dragging = false;\n\n      var h = window.innerHeight || 800;\n      var thresholdPx = h * THRESHOLD_PCT;\n\n      if (currentY >= thresholdPx) {\n        closeCart();\n        return;\n      }\n\n      // snap back\n      sheet.classList.remove(\"rc-dragging\");\n      sheet.style.transition = \"transform .18s ease\";\n      setTranslate(0);\n\n      setTimeout(function () {\n        resetSheet();\n      }, 220);\n\n      if (e && e.preventDefault) e.preventDefault();\n      if (e && e.stopPropagation) e.stopPropagation();\n    }\n\n    // Start drag only on handle\n    handle.addEventListener(\"mousedown\", onDown, false);\n    handle.addEventListener(\"touchstart\", onDown, false);\n\n    // Move + end anywhere\n    window.addEventListener(\"mousemove\", onMove, false);\n    window.addEventListener(\"touchmove\", onMove, false);\n\n    window.addEventListener(\"mouseup\", onUp, false);\n    window.addEventListener(\"touchend\", onUp, false);\n    window.addEventListener(\"touchcancel\", onUp, false);\n\n    // If cart closes another way, don’t leave it translated\n    if (window.MutationObserver) {\n      var obs = new MutationObserver(function () {\n        if (!isOpen(root)) resetSheet();\n      });\n      obs.observe(root, { attributes: true, attributeFilter: [\"class\"] });\n    }\n\n    return true;\n  }\n\n  // Retry until your cart markup exists\n  var tries = 0;\n  var timer = setInterval(function () {\n    tries++;\n    if (setup()) {\n      clearInterval(timer);\n      return;\n    }\n    if (tries > 120) clearInterval(timer);\n  }, 100);\n})();\n</script>\n\n<script>\n(function(){\n  const root = document.getElementById('rcCartDevRoot');\n  const sheet = document.getElementById('rcCartDevSheet');\n\n  if(!root || !sheet) return;\n\n  root.addEventListener('click', function(e){\n    // If click is NOT inside the cart sheet, close it\n    if(!sheet.contains(e.target)){\n      if(window.RC_CART && typeof window.RC_CART.close === 'function'){\n        window.RC_CART.close();\n      } else {\n        // Fallback close\n        root.classList.remove('isOpen');\n        root.setAttribute('aria-hidden','true');\n        document.documentElement.style.overflow = '';\n      }\n    }\n  });\n})();\n</script>",
