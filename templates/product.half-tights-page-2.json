        "code_Efr8RQ": {
          "type": "code",
          "name": "design selector",
          "settings": {
            "code": "<!-- RC: Design label synced to selected variant (auto-updating) -->\n<div class=\"rc-design-row\" data-rc-design>\n  <span class=\"rc-design-label\">Design:</span>\n  <span class=\"rc-design-value\" data-rc-design-value>—</span>\n</div>\n\n<style>\n  .rc-design-row{\n    display:flex;\n    gap:.25rem;\n    align-items: baseline;\n    margin: 0px 10px 3px;\n    font-size: 12px;\n    line-height: 1.2;\n    text-transform: uppercase !important;\n    font-style: var(--BTN-FONT-STYLE);\n    font-family: var(--BTN-FONT-STACK);\n    letter-spacing: var(--BTN-FONT-STYLE);\n\n  }\n  .rc-design-label{ opacity:1; font-weight:800; }\n  .rc-design-value{ \n    line-height: 1;\n    margin: .0em 0;\n    align-items: center;\n    font-weight: 800;\n    \n    opacity: .7 !important; }\n</style>\n\n{%- comment -%}\n  We embed the product JSON directly so it works on any theme.\n{%- endcomment -%}\n<script type=\"application/json\" data-rc-product-json>\n  {{ product | json }}\n</script>\n\n<script>\n(function () {\n  const OPTION_NAME_PRIORITY = [\"Design\",\"Color\",\"Pattern\",\"Style\"];\n\n  function getProduct() {\n    const el = document.querySelector('script[data-rc-product-json]');\n    if (!el) return null;\n    try { return JSON.parse(el.textContent); } catch(e) { return null; }\n  }\n\n  function getVariantIdFromForm() {\n    const input = document.querySelector('form[action*=\"/cart/add\"] input[name=\"id\"]');\n    if (input && input.value) return Number(input.value);\n\n    const select = document.querySelector('form[action*=\"/cart/add\"] select[name=\"id\"]');\n    if (select && select.value) return Number(select.value);\n\n    const url = new URL(window.location.href);\n    const v = url.searchParams.get(\"variant\");\n    return v ? Number(v) : null;\n  }\n\n  function findOptionIndex(product) {\n    if (!product || !Array.isArray(product.options)) return -1;\n\n    // product.options is usually an array of option names in order\n    for (const name of OPTION_NAME_PRIORITY) {\n      const idx = product.options.findIndex(o => (o || \"\").toLowerCase() === name.toLowerCase());\n      if (idx >= 0) return idx;\n    }\n    return -1;\n  }\n\n  function getDesignText(product, variant) {\n    if (!product || !variant) return null;\n\n    const optIndex = findOptionIndex(product);\n\n    if (optIndex >= 0) {\n      // Some JSON uses variant.options array, otherwise option1/2/3\n      if (Array.isArray(variant.options)) return variant.options[optIndex] || null;\n      const key = \"option\" + (optIndex + 1);\n      return variant[key] || null;\n    }\n\n    // Fallback: show variant title (may include size)\n    return variant.public_title || variant.title || null;\n  }\n\n  function render(text) {\n    const target = document.querySelector('[data-rc-design-value]');\n    if (!target) return;\n    target.textContent = text || \"—\";\n  }\n\n  function update() {\n    const product = getProduct();\n    if (!product || !Array.isArray(product.variants)) return;\n\n    const id = getVariantIdFromForm();\n    const variant = product.variants.find(v => Number(v.id) === Number(id)) || product.variants[0];\n    render(getDesignText(product, variant));\n  }\n\n  function bind() {\n    update();\n\n    // 1) Any change on option inputs/selects\n    document.addEventListener(\"change\", (e) => {\n      const t = e.target;\n      if (!t) return;\n\n      if (\n        t.closest('form[action*=\"/cart/add\"]') &&\n        (t.matches('select') || t.matches('input[type=\"radio\"]') || t.matches('input[type=\"checkbox\"]'))\n      ) {\n        // Let theme update variant id first\n        setTimeout(update, 0);\n      }\n    });\n\n    // 2) Listen to common theme variant events\n    document.addEventListener(\"variant:change\", () => setTimeout(update, 0));\n    document.addEventListener(\"product:variant-change\", () => setTimeout(update, 0));\n\n    // 3) MutationObserver: watch the hidden variant id input for changes (most reliable)\n    const idInput = document.querySelector('form[action*=\"/cart/add\"] input[name=\"id\"]');\n    if (idInput) {\n      const mo = new MutationObserver(() => update());\n      mo.observe(idInput, { attributes: true, attributeFilter: [\"value\"] });\n\n      // Also patch programmatic changes to .value (some themes don’t update the attribute)\n      const desc = Object.getOwnPropertyDescriptor(HTMLInputElement.prototype, \"value\");\n      if (desc && desc.configurable) {\n        Object.defineProperty(idInput, \"value\", {\n          get: function() { return desc.get.call(this); },\n          set: function(v) {\n            desc.set.call(this, v);\n            setTimeout(update, 0);\n          }\n        });\n      }\n    }\n  }\n\n  if (document.readyState === \"loading\") {\n    document.addEventListener(\"DOMContentLoaded\", bind);\n  } else {\n    bind();\n  }\n})();\n</script>",
