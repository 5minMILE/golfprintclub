    "section_custom_code_rdCKhc": {
      "type": "section-custom-code",
      "name": "PDP Content & Size Sheet",
      "settings": {
        "code": "<style>\n  :root{\n    --rc-line:rgba(0,0,0,.10);\n    --rc-soft:rgba(0,0,0,.06);\n    --rc-shadow: 0 18px 60px rgba(0,0,0,.25);\n    --rc-radius:18px;\n  }\n\n  \n  .rc-proof-grid{ display:grid; gap:16px; margin-top: 16px; }\n  .rc-proof img{ width:100%; display:block; aspect-ratio: 4 / 5; object-fit: cover; filter: contrast(1.02); }\n  .rc-proof .body{ padding: 14px 14px 16px; text-align:left; }\n  .rc-proof h3{ margin: 0 0 6px; font-size: 18px; font-weight: 950; letter-spacing: -.2px; display:flex; align-items:center; gap:10px; }\n  .rc-proof .rc-proof p{ margin: 0; font-size: 14px; line-height: 1.6; color:#333; }\n  .rc-proof .micro{ margin-top: 10px; font-size: 12px; color:#666; line-height: 1.45; }\n\n  .rc-box{ padding: 0px; margin-top: 0px; }\n  .rc-box p{ margin: 0; font-size: 14px; line-height: 1.65; color:#222; }\n  .rc-box ul{ margin: 10px 0 0; padding-left: 18px; font-size: 14px; line-height: 1.65; color:#222; }\n\n  .rc-fit-actions{ display:flex; flex-wrap:wrap; gap:10px; margin-top: 12px; }\n  .rc-btn{\n    display:inline-flex; align-items:center; justify-content:center; gap:8px;\n    padding: 14px 0;\n    border-radius: 0;\n    font-family: 'Montserrat', sans-serif;\n    font-size: 12px; font-weight: 800; text-decoration:none; cursor:pointer;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    line-height: 1; border: none;\n    transition: box-shadow 0.3s ease, transform 0.2s ease, background 0.2s ease;\n    will-change: transform;\n    width:100%;\n    margin: 0 auto;\n    position: relative;\n    overflow: hidden;\n  }\n  .rc-btn::before{\n    content: '';\n    position: absolute;\n    inset: 0;\n    background: radial-gradient(circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(100,180,255,0.5) 0%, rgba(0,123,255,0.15) 30%, transparent 55%);\n    opacity: 0;\n    transition: opacity 0.3s ease;\n    pointer-events: none;\n    z-index: 1;\n  }\n  .rc-btn:hover{\n    box-shadow: 0 0 12px rgba(0,123,255,0.5);\n    transform: translateY(-1px);\n  }\n  .rc-btn:hover::before{ opacity: 1; }\n  .rc-btn--primary{ background: #2E7D32; color:#fff; }\n  .rc-btn--primary:hover{ background: #0080ff; color:#fff; }\n  .rc-btn--ghost{ background:#fff; color:#111; border: 1px solid #2E7D32; }\n  .rc-btn small{ font-size: 12px; font-weight: 900; opacity:.9; }\n\n  .rc-pdp-wrap{\n    max-width: auto;\n    margin: 0 auto;\n    padding: 0px 16px 0px;\n    font-family: Arial, sans-serif;\n    color:#111;\n    text-align:center;\n  }\n  .rc-sec{ padding: 10px 0; }\n  .rc-h2{ font-size: 26px; font-weight: 950; letter-spacing: -.4px; margin: 15px 0 10px; line-height: 1.12; text-align:center; }\n  .rc-sub{ font-size: 14px; line-height: 1.7; color:#333; margin: 0 0 14px; max-width: 70ch; }\n  .rc-bullets{ margin: 16px 0 0; padding: 0; list-style: none; display: grid; gap: 10px; }\n  .rc-bullets li{ display:flex; gap:10px; align-items:flex-start; font-size: 14px; line-height: 1.45; color:#111; justify-content:center; }\n  .rc-check{ width: 18px; height: 18px; flex: 0 0 18px; border-radius: 6px; display:grid; place-items:center; font-weight: 900; font-size: 12px; background: #111; color:#fff; margin-top: 2px; }\n  .rc-hero-mini{ margin-bottom: 10px; overflow:hidden; background: #fff; }\n  .rc-hero-mini img, .rc-hero-mini video{ width:100%; display:block; aspect-ratio: 1 / 1; object-fit: cover; }\n\n  .rc-proof-grid{ display:grid; gap:16px; margin-top: 16px; }\n  .rc-proof{ border: 1px solid #ddd; border-radius: 5px; overflow:hidden; background: #fff; display:grid; }\n  .rc-proof img{ width:100%; display:block; aspect-ratio: 4 / 5; object-fit: cover; filter: contrast(1.02); }\n  .rc-proof .body{ padding: 0px 14px 16px; text-align:left; }\n  .body h3{ margin: 15px 0 5px; font-size: 30px; }\n\n  @media(min-width: 900px){\n    .rc-proof-grid{ grid-template-columns: repeat(3, 1fr); }\n  }\n\n  \n  #rcSizeSheetRoot{\n    position: fixed;\n    inset: 0;\n    z-index: 2147483000;\n    background: rgba(0,0,0,.55);\n\n    display:none;\n    opacity:0;\n    pointer-events:none;\n    transition: opacity .18s ease;\n  }\n  #rcSizeSheetRoot.isOpen{\n    display:block;\n    opacity:1;\n    pointer-events:auto;\n  }\n\n  #rcSizeSheet{\n    position: absolute;\n    left: 0; right: 0; bottom: 0;\n    margin: 0 auto;\n    width: min(980px, 100%);\n    background:#fff;\n    border-radius: 18px 18px 0 0;\n    box-shadow: var(--rc-shadow);\n    transform: translateY(110%);\n    transition: transform .22s ease;\n    overflow:hidden;\n    border-top: 1px solid var(--rc-soft);\n  }\n  #rcSizeSheetRoot.isOpen #rcSizeSheet{\n    transform: translateY(0);\n  }\n\n  #rcSizeSheetHeader{\n    display:flex;\n    align-items:center;\n    justify-content: space-between;\n    gap: 10px;\n    padding: 12px 12px;\n    background:#fbfbfb;\ntext-transform: uppercase !important;\n    font-style: var(--BTN-FONT-STYLE);\n    font-family: var(--BTN-FONT-STACK);\nfont-size:20px;\nfont-weight: 600;\n  }\n  #rcSizeSheetTitle{\n    font-weight: 700;\n    font-size: 16px;\n    color:#111;\n    letter-spacing: -.2px;\n    text-align:left;\n  }\n  #rcSizeSheetClose{\n    appearance:none;\n    border: 1px solid var(--rc-line);\n    background:#111;\n    color:#fff;\n    border-radius: 12px;\n    padding: 10px 12px;\n    font-size: 12px;\n    font-weight: 950;\n    cursor:pointer;\n    line-height: 1;\n  }\n\n  #rcSizeSheetBody{\n    height: min(74vh, 720px);\n    overflow:auto;\n    -webkit-overflow-scrolling: touch;\n    padding: 0;\n    text-align:left;\n  }\n\n  \n  #rcSizeSheetBody img{ max-width: 100%; height:auto; }\n  #rcSizeSheetBody table{ max-width: 100%; }\n  #rcSizeSheetBody a{ color:#111; font-weight: 800; text-decoration: underline; }\n\n  .rc-size-loading{\n    font-size: 13px;\n    color:#444;\n    line-height: 1.6;\n  }\n  .rc-size-loading b{ font-weight: 950; }\n\n.index-page {\n    --PT: 20px !important;\n}\n</style>\n\n<div class=\"rc-pdp-wrap\">\n\n  <!-- SECTION 1 -->\n  <section class=\"rc-sec\" id=\"rc-built-for-real-golfers\">\n    <div class=\"rc-hero-mini\">\n      <video autoplay muted loop playsinline preload=\"metadata\"\n        poster=\"https://cdn.shopify.com/s/files/1/0772/2041/3736/files/21_64c6ab67-828c-429d-8a85-f3fc13e5e5af.png?v=1771280579\">\n        <source src=\"https://cdn.shopify.com/videos/c/o/v/e93fd76a228e43e0b32bffdeb8eed5df.mp4\" type=\"video/mp4\">\n      </video>\n    </div>\n\n    <h2 class=\"rc-h2\">Built For Golfers Who Run Hard</h2>\n    <p class=\"rc-sub\">Built for track sessions, tempos, and race efforts.</p>\n\n    <ul class=\"rc-bullets\">\n      <li><span class=\"rc-check\">✓</span><span><b>Zero-chafe inner liner</b></span></li>\n      <li><span class=\"rc-check\">✓</span><span><b>Rear bounce-free phone pocket</b></span></li>\n      <li><span class=\"rc-check\">✓</span><span><b>True compression feel</b>.</span></li>\n      <li><span class=\"rc-check\">✓</span><span><b>Lightweight ribbed stretch</b></span></li>\n    </ul>\n  </section>\n\n  <!-- SECTION 2 -->\n  <section class=\"rc-sec\" id=\"rc-why-golfers-switch\">\n    <h2 class=\"rc-h2\">Why Golfers Trust Us</h2>\n    <div class=\"rc-proof-grid\">\n      <div class=\"rc-proof\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0772/2041/3736/files/hf_20260217_015438_19ddbbcc-6907-492c-9e14-de76c9bf6914.png?v=1771293745\" alt=\"No ride up\" loading=\"lazy\">\n        <div class=\"body\"><h3>No Ride Up</h3><p>Stays put through full stride. No adjusting mid-rep.</p></div>\n      </div>\n      <div class=\"rc-proof\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0772/2041/3736/files/4_c68d7779-2dcb-48e1-9e53-55cb5b039f4d.png?v=1771291015\" alt=\"No bounce pocket\" loading=\"lazy\">\n        <div class=\"body\"><h3>No Bounce Pocket</h3><p>Rear pocket holds your phone tight. It doesn’t move. Period.</p></div>\n      </div>\n      <div class=\"rc-proof\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0772/2041/3736/files/hf_20260217_014415_5b1c0901-dc73-4c13-8e12-0317781a0e3f.png?v=1771292822\" alt=\"Real compression\" loading=\"lazy\">\n        <div class=\"body\"><h3>Real Compression</h3><p>Support where it matters — without feeling restrictive or cheap.</p></div>\n      </div>\n    </div>\n  </section>\n\n  <!-- SECTION 3 -->\n  <section class=\"rc-sec\" id=\"rc-fit-confidence\">\n    <h2 class=\"rc-h2\">Get Your Size Right</h2>\n    <p class=\"rc-sub\">Compression gear only works if it fits right. Use the waist chart, or take the 10-second fit quiz.</p>\n\n    <div class=\"rc-box size\">\n      <div class=\"rc-fit-actions\">\n        <a class=\"rc-btn rc-btn--primary\" href=\"/pages/ribbed-half-tights-sizing\" data-rc-size-sheet=\"open\">View Size Chart</a>\n        <a class=\"rc-btn rc-btn--ghost\" href=\"/pages/ribbed-half-tights-sizing\" data-rc-size-sheet=\"open\">Take Fit Quiz <small>(10 sec)</small></a>\n      </div>\n\n      <p style=\"margin-top:10px;color:#444;\">\n        If you already know your waist measurement, the size chart is the most accurate.\n      </p>\n    </div>\n  </section>\n</div>\n\n<!-- =========================\n     BOTTOM SHEET POPUP\n     ========================= -->\n<div id=\"rcSizeSheetRoot\" aria-hidden=\"true\">\n  <div id=\"rcSizeSheet\" role=\"dialog\" aria-modal=\"true\" aria-label=\"Ribbed Golf Posters Sizing\">\n    <div id=\"rcSizeSheetHeader\">\n      <div id=\"rcSizeSheetTitle\">Ribbed Golf Posters Sizing</div>\n      <button id=\"rcSizeSheetClose\" type=\"button\">Close</button>\n    </div>\n    <div id=\"rcSizeSheetBody\">\n      <div class=\"rc-size-loading\"><b>Loading…</b> pulling the sizing guide.</div>\n    </div>\n  </div>\n</div>\n\n<script>\n(function(){\n  var ROOT = document.getElementById(\"rcSizeSheetRoot\");\n  var SHEET = document.getElementById(\"rcSizeSheet\");\n  var BODY = document.getElementById(\"rcSizeSheetBody\");\n  var CLOSE = document.getElementById(\"rcSizeSheetClose\");\n\n  if(!ROOT || !SHEET || !BODY || !CLOSE) return;\n\n  var cached = null;\n  var lastFocus = null;\n\n  function lockScroll(on){\n    if(on){\n      document.documentElement.style.overflow = \"hidden\";\n      document.body.style.overflow = \"hidden\";\n    }else{\n      document.documentElement.style.overflow = \"\";\n      document.body.style.overflow = \"\";\n    }\n  }\n\n  function openSheet(){\n    lastFocus = document.activeElement;\n    ROOT.classList.add(\"isOpen\");\n    ROOT.setAttribute(\"aria-hidden\",\"false\");\n    lockScroll(true);\n    CLOSE.focus({preventScroll:true});\n  }\n\n  function closeSheet(){\n    ROOT.classList.remove(\"isOpen\");\n    ROOT.setAttribute(\"aria-hidden\",\"true\");\n    lockScroll(false);\n    if(lastFocus && typeof lastFocus.focus === \"function\"){\n      lastFocus.focus({preventScroll:true});\n    }\n  }\n\n  function setLoading(){\n    BODY.innerHTML = '<div class=\"rc-size-loading\"><b>Loading…</b> pulling the sizing guide.</div>';\n  }\n  function setError(){\n    BODY.innerHTML =\n      '<div class=\"rc-size-loading\"><b>Couldn’t load.</b><br>' +\n      'Open it here: <a href=\"/pages/ribbed-half-tights-sizing\" target=\"_blank\" rel=\"noopener\">Sizing page</a>.</div>';\n  }\n\n  function extractMain(htmlText){\n    var doc = new DOMParser().parseFromString(htmlText, \"text/html\");\n    var main =\n      doc.querySelector(\"#MainContent\") ||\n      doc.querySelector(\"main\") ||\n      doc.querySelector(\".main-content\");\n\n    if(!main) return htmlText;\n\n    // If #MainContent exists, prefer its children, not the wrapper\n    return main.innerHTML;\n  }\n\n  function loadSizing(){\n    if(cached){\n      BODY.innerHTML = cached;\n      return;\n    }\n    setLoading();\n\n    // same-domain fetch; cache-buster helps during edits\n    fetch(\"/pages/ribbed-half-tights-sizing?view=content&_=\" + Date.now(), { credentials: \"same-origin\" })\n      .then(function(res){\n        if(!res.ok) throw new Error(\"Bad response\");\n        return res.text();\n      })\n      .then(function(text){\n        var inner = extractMain(text);\n        BODY.innerHTML = inner;\n        cached = BODY.innerHTML;\n      })\n      .catch(function(){\n        // Fallback without view param\n        fetch(\"/pages/ribbed-half-tights-sizing?_=\" + Date.now(), { credentials: \"same-origin\" })\n          .then(function(res){\n            if(!res.ok) throw new Error(\"Bad response\");\n            return res.text();\n          })\n          .then(function(text){\n            var inner = extractMain(text);\n            BODY.innerHTML = inner;\n            cached = BODY.innerHTML;\n          })\n          .catch(function(){ setError(); });\n      });\n  }\n\n  // Open triggers\n  document.addEventListener(\"click\", function(e){\n    var a = e.target.closest('a[data-rc-size-sheet=\"open\"]');\n    if(!a) return;\n    e.preventDefault();\n    openSheet();\n    loadSizing();\n  });\n\n  // Close actions\n  CLOSE.addEventListener(\"click\", closeSheet);\n\n  // click overlay to close\n  ROOT.addEventListener(\"click\", function(e){\n    if(e.target === ROOT) closeSheet();\n  });\n\n  // ESC close\n  document.addEventListener(\"keydown\", function(e){\n    if(e.key === \"Escape\" && ROOT.classList.contains(\"isOpen\")){\n      closeSheet();\n    }\n  });\n})();\n</script>\n<script>\n(function(){\n  document.querySelectorAll('.rc-btn').forEach(function(btn){\n    btn.addEventListener('mousemove', function(e){\n      var rect = btn.getBoundingClientRect();\n      var x = ((e.clientX - rect.left) / rect.width * 100).toFixed(1);\n      var y = ((e.clientY - rect.top) / rect.height * 100).toFixed(1);\n      btn.style.setProperty('--mouse-x', x + '%');\n      btn.style.setProperty('--mouse-y', y + '%');\n    });\n  });\n})();\n</script>",
        "width": "wrapper--full-padded",
        "bg_color": "",
        "color": "",
        "padding_top": 0,
        "padding_bottom": 0
      }
