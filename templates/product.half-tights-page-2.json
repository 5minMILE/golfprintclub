    "section_custom_code_N79wVh": {
      "type": "section-custom-code",
      "name": "Backorder Tagging",
      "settings": {
        "code": "<script>\n(function(){\n  \n\n  \n  function getRemainingMap(){\n    const wrapper = document.querySelector('.product__block.variant__countdown');\n    if(!wrapper) return null;\n\n    const jsonEl = wrapper.querySelector('[data-product-remaining-json]');\n    if(!jsonEl) return null;\n\n    try{\n      return JSON.parse((jsonEl.textContent || '').trim() || '{}');\n    }catch(e){\n      return null;\n    }\n  }\n\n  function lookupAvail(variantId){\n    const map = getRemainingMap();\n    if(!map || !variantId) return null;\n    const raw = map[String(variantId)];\n    if(raw === undefined || raw === null || raw === '') return null;\n    return String(raw);\n  }\n\n  function isBackorderAvailString(raw){\n    return String(raw || '').toLowerCase() === 'unavailable';\n  }\n\n  \n  function injectIntoFormData(fd){\n    if(!(fd instanceof FormData)) return fd;\n\n    const vid = fd.get('id');\n    if(!vid) return fd;\n\n    const avail = lookupAvail(String(vid));\n    if(!avail) return fd; // not on PDP or no map available\n\n    // Store your PDP state into line item properties\n    fd.set('properties[_rc_avail]', avail);\n    fd.set('properties[_rc_backorder]', isBackorderAvailString(avail) ? 'true' : 'false');\n\n    return fd;\n  }\n\n  function injectIntoJsonString(bodyStr){\n    try{\n      const obj = JSON.parse(bodyStr);\n      const vid = obj && (obj.id || obj.variant_id);\n      if(!vid) return bodyStr;\n\n      const avail = lookupAvail(String(vid));\n      if(!avail) return bodyStr;\n\n      obj.properties = obj.properties || {};\n      obj.properties._rc_avail = avail;\n      obj.properties._rc_backorder = isBackorderAvailString(avail) ? 'true' : 'false';\n\n      return JSON.stringify(obj);\n    }catch(e){\n      return bodyStr;\n    }\n  }\n\n  // Patch fetch\n  const _fetch = window.fetch;\n  if(typeof _fetch === 'function'){\n    window.fetch = function(resource, options){\n      try{\n        const url = typeof resource === 'string'\n          ? resource\n          : (resource && resource.url) ? resource.url : '';\n\n        const opts = options || {};\n        const method = String(opts.method || 'GET').toUpperCase();\n\n        if(url && (url.includes('/cart/add.js') || url.includes('/cart/add')) && method === 'POST' && opts.body){\n          if(typeof FormData !== 'undefined' && opts.body instanceof FormData){\n            opts.body = injectIntoFormData(opts.body);\n          } else if(typeof opts.body === 'string'){\n            opts.body = injectIntoJsonString(opts.body);\n          }\n        }\n\n        return _fetch.call(this, resource, opts);\n      }catch(e){\n        return _fetch.call(this, resource, options);\n      }\n    };\n  }\n\n  // Patch XHR\n  const XHR = window.XMLHttpRequest;\n  if(XHR){\n    const _open = XHR.prototype.open;\n    const _send = XHR.prototype.send;\n\n    XHR.prototype.open = function(method, url){\n      this.__rc_method = String(method || 'GET').toUpperCase();\n      this.__rc_url = String(url || '');\n      return _open.apply(this, arguments);\n    };\n\n    XHR.prototype.send = function(body){\n      try{\n        if(this.__rc_url && (this.__rc_url.includes('/cart/add.js') || this.__rc_url.includes('/cart/add')) && this.__rc_method === 'POST' && body){\n          if(typeof FormData !== 'undefined' && body instanceof FormData){\n            body = injectIntoFormData(body);\n          } else if(typeof body === 'string'){\n            body = injectIntoJsonString(body);\n          }\n        }\n      }catch(e){}\n      return _send.call(this, body);\n    };\n  }\n\n  \n  function removeExisting(lineEl){\n    const el = lineEl.querySelector('.rc-backorder-line');\n    if(el) el.remove();\n  }\n\n  function injectBackorderLine(lineEl){\n    removeExisting(lineEl);\n\n    const el = document.createElement('div');\n    el.className = 'rc-backorder-line';\n    el.textContent = 'This item is currently on back order and may take 4–8 weeks to arrive.';\n\n    // Style (match your system)\n    el.style.marginTop = '6px';\n    el.style.fontSize = '12px';\n    el.style.fontWeight = '950';\n    el.style.color = '#2E7D32'; // Golf Print Club blue\n    el.style.lineHeight = '1.25';\n    el.style.textTransform = 'uppercase';\n    el.style.letterSpacing = '.04em';\n\n    const variantRow = lineEl.querySelector('.rc-variant');\n    if(variantRow){\n      variantRow.insertAdjacentElement('afterend', el);\n    } else {\n      const meta = lineEl.querySelector('.rc-meta');\n      if(meta) meta.appendChild(el);\n    }\n  }\n\n  async function renderBackorderOnly(){\n    const wrap = document.getElementById('rcDevItems');\n    if(!wrap) return;\n\n    const domLines = Array.from(wrap.querySelectorAll('.rc-item'));\n    if(!domLines.length) return;\n\n    let cart;\n    try{\n      const r = await _fetch('/cart.js', { credentials:'same-origin', cache:'no-store' });\n      if(!r.ok) return;\n      cart = await r.json();\n    }catch(e){\n      return;\n    }\n\n    if(!cart?.items?.length) return;\n\n    // Clear all first\n    domLines.forEach(removeExisting);\n\n    // Match by index (your drawer renders in order)\n    cart.items.forEach((item, idx) => {\n      const lineEl = domLines[idx];\n      if(!lineEl) return;\n\n      const props = item.properties || {};\n      let raw = props._rc_avail || null;\n\n      // Fallback: if property missing, try PDP map by variant_id (works on PDP)\n      if(!raw){\n        raw = lookupAvail(String(item.variant_id)) || null;\n      }\n\n      if(isBackorderAvailString(raw)){\n        injectBackorderLine(lineEl);\n      }\n    });\n  }\n\n  \n  function patchRC(){\n    if(!window.RC_CART) return false;\n\n    if(typeof window.RC_CART.open === 'function' && !window.RC_CART.open.__rc_bo_only){\n      const _open = window.RC_CART.open;\n      window.RC_CART.open = async function(){\n        const res = await _open.apply(this, arguments);\n        setTimeout(renderBackorderOnly, 220);\n        return res;\n      };\n      window.RC_CART.open.__rc_bo_only = true;\n    }\n\n    if(typeof window.RC_CART.refresh === 'function' && !window.RC_CART.refresh.__rc_bo_only){\n      const _refresh = window.RC_CART.refresh;\n      window.RC_CART.refresh = async function(){\n        const res = await _refresh.apply(this, arguments);\n        setTimeout(renderBackorderOnly, 220);\n        return res;\n      };\n      window.RC_CART.refresh.__rc_bo_only = true;\n    }\n\n    return true;\n  }\n\n  function observeDrawer(){\n    const wrap = document.getElementById('rcDevItems');\n    if(!wrap || !window.MutationObserver) return;\n    if(wrap.__rc_bo_only_observing) return;\n    wrap.__rc_bo_only_observing = true;\n\n    const obs = new MutationObserver(() => {\n      clearTimeout(wrap.__rc_bo_only_t);\n      wrap.__rc_bo_only_t = setTimeout(renderBackorderOnly, 120);\n    });\n\n    obs.observe(wrap, { childList:true, subtree:true });\n  }\n\n  // Boot\n  let tries = 0;\n  const boot = setInterval(() => {\n    tries++;\n    observeDrawer();\n    if(patchRC()){\n      clearInterval(boot);\n      setTimeout(renderBackorderOnly, 450);\n    }\n    if(tries > 250) clearInterval(boot);\n  }, 100);\n\n})();\n</script>\n<style>\n@media only screen and (max-width: 763px) {\n    .rc-jdgm-slot-under-title .jdgm-widget {\nmargin:0 !important;}\n.jdgm-prev-badge__text{\nmargin-top:0;}}</style>",
