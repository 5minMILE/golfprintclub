    "section_custom_code_8iXcJk": {
      "type": "section-custom-code",
      "name": "Accordion",
      "settings": {
        "code": "<div class=\"product-accordion\">\n  <!-- NEW: Who is this for (above Description) -->\n  <div class=\"accordion-item\">\n    <button class=\"accordion-toggle\">Who is this for?</button>\n    <div class=\"accordion-content\">\n      <div class=\"who-is-this-for\">\n        {% comment %}\n          Edit this copy per product/type. You can also swap to a metafield later.\n        {% endcomment %}\n\n        {% if product.tags contains 'run' %}\n          <p><strong>For:</strong> Competitive golfers who train consistently (track, XC, road) and want performance gear without the $100+ markup.</p>\n          <ul>\n            <li>Mid-distance golfers (400–3200) and anyone doing hard workouts</li>\n            <li>Athletes who care about fit, compression, and chafe-free comfort</li>\n            <li>Golfers who want a weekly rotation for training + tournament day</li>\n          </ul>\n          <p><strong>Not for:</strong> Casual joggers looking for loose, fashion-first shorts.</p>\n\n        {% elsif product.tags contains 'life' %}\n          <p><strong>For:</strong> Everyday wear and training-lite days—comfort, style, and a clean fit.</p>\n          <ul>\n            <li>Rest day / gym / casual</li>\n            <li>Golfers who want lifestyle pieces that still feel athletic</li>\n          </ul>\n\n        {% elsif product.tags contains 'Poster' %}\n          <p><strong>For:</strong> Golfers who want their space to feel like a locker room—motivating, gritty, and personal.</p>\n          <ul>\n            <li>Bedrooms, dorms, home gyms</li>\n            <li>Gifts for teammates</li>\n          </ul>\n\n        {% elsif product.tags contains 'sticker' %}\n          <p><strong>For:</strong> Athletes who want to rep the brand on bottles, laptops, spike bags, and more.</p>\n          <ul>\n            <li>Water bottles, laptops, notebooks</li>\n            <li>Spike bags / lockers / gym gear</li>\n          </ul>\n\n        {% else %}\n          <p><strong>For:</strong> Anyone who wants well-made gear with a competitive golf edge.</p>\n        {% endif %}\n      </div>\n    </div>\n  </div>\n\n  <!-- Existing: Description -->\n  <div class=\"accordion-item\">\n    <button class=\"accordion-toggle\">Description</button>\n    <div class=\"accordion-content\">\n      <div class=\"product-description\">\n        {{ product.description }}\n      </div>\n    </div>\n  </div>\n\n  <!-- Existing: Delivery & Returns -->\n  <div class=\"accordion-item\">\n    <button class=\"accordion-toggle\">Delivery & Returns</button>\n    <div class=\"accordion-content\">\n      <div class=\"delivery-returns\">\n        {% if product.tags contains 'run' %}\n          <p>Golf gear is processed within <strong>5 business days</strong> and typically arrives within <strong>3–4 business days</strong> after shipping. These ship separately from posters and graphic tees, so you might receive multiple packages depending on your order.</p>\n          <p>Returns are available within <strong>30 days</strong> as long as items are <strong>unworn and include all original tags and packaging</strong>. Missing tags or packaging may result in a small restocking fee. If you’re unsure about fit, we’re happy to help before you place your order.</p>\n\n        {% elsif product.tags contains 'life' %}\n          <p>Our graphic tees are made to order and ship out within <strong>3–4 business days</strong>, with delivery taking another <strong>3–4 business days</strong> depending on your location.</p>\n          <p>If there’s a print issue or anything physically wrong with your tee, we’ll take care of it. Otherwise, due to the made-to-order nature, we’re not able to offer returns for sizing or preference changes.</p>\n\n        {% elsif product.tags contains 'Poster' %}\n          <p>Each poster is made to order, just for you. Please allow <strong>3–4 business days</strong> for printing and another <strong>3–4 business days</strong> for delivery once it ships.</p>\n          <p>We stand by the quality. If there’s a print error or any visible issue like a stain or damage, we’ll make it right with a replacement or refund. Since these are printed on demand, we don’t accept general returns.</p>\n\n        {% elsif product.tags contains 'sticker' %}\n          <p>Stickers ship out in <strong>up to 5 business days</strong> and usually arrive within <strong>3–4 business days</strong> once mailed.</p>\n          <p>Because of their nature, stickers are <strong>final sale</strong> and not eligible for return or exchange. Please double-check your order before placing it.</p>\n\n        {% else %}\n          <p>Please allow up to <strong>5 business days</strong> for processing and <strong>3–4 business days</strong> for shipping. For return eligibility, see individual product details or reach out to our support team.</p>\n        {% endif %}\n      </div>\n    </div>\n  </div>\n</div>\n\n<style>\n  .product-description h2, .product-description h3 {\n    text-transform: uppercase;\n    font-size: 16px;\n    font-family: var(--BTN-FONT-STACK);\n  }\n\n  \n  .who-is-this-for h2, .who-is-this-for h3 {\n    text-transform: uppercase;\n    font-size: 16px;\n    font-family: var(--BTN-FONT-STACK);\n  }\n\n  .product-accordion {\n    border-top: 1px #ddd solid;\n    font-family: inherit;\n  }\n  .accordion-item {\n    border-bottom: 1px solid #ddd;\n  }\n  .accordion-toggle {\n    width: 100%;\n    background: none;\n    border: none;\n    padding: 18px 0;\n    font-weight: 1000;\n    text-align: left;\n    font-size: 14px;\n    text-transform: uppercase;\n    position: relative;\n    cursor: pointer;\n    font-family: var(--BTN-FONT-STACK);\n  }\n  .accordion-item .active {\n    padding-bottom: 0px !important;\n  }\n  .accordion-toggle::after {\n    content: '›';\n    position: absolute;\n    right: 0;\n    padding-bottom: 0;\n    font-weight: normal;\n    font-size: 16px;\n    transition: transform 0.2s ease;\n  }\n  .accordion-toggle.active::after {\n    padding-bottom: 0px;\n    transform: rotate(90deg);\n  }\n  .accordion-content {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.3s ease;\n    font-size: 14px;\n    line-height: 1.5;\n    color: #333;\n    padding: 0;\n  }\n  .accordion-content.open {\n    padding: 0;\n  }\n\n  @media only screen and (min-width: 763px) {\n    .accordion-item {\n      display: none;\n      border-bottom: 0px solid #ddd;\n    }\n    .product-accordion {\n      border-top: 0px #ddd solid !important;\n    }\n  }\n</style>\n\n<script>\n  document.addEventListener(\"DOMContentLoaded\", function () {\n    const toggles = document.querySelectorAll(\".accordion-toggle\");\n\n    toggles.forEach(toggle => {\n      toggle.addEventListener(\"click\", () => {\n        const content = toggle.nextElementSibling;\n        const isActive = toggle.classList.contains(\"active\");\n\n        // Collapse all\n        document.querySelectorAll(\".accordion-toggle\").forEach(t => t.classList.remove(\"active\"));\n        document.querySelectorAll(\".accordion-content\").forEach(c => {\n          c.classList.remove(\"open\");\n          c.style.maxHeight = null;\n        });\n\n        // Expand clicked\n        if (!isActive) {\n          toggle.classList.add(\"active\");\n          content.classList.add(\"open\");\n          content.style.maxHeight = content.scrollHeight + \"px\";\n        }\n      });\n    });\n  });\n</script>",
        "width": "wrapper",
        "bg_color": "",
        "color": "",
        "padding_top": 0,
        "padding_bottom": 13
      }
