        "code_bbLAik": {
          "type": "code",
          "name": "Delivery Mobile",
          "settings": {
            "code": "<!-- DELIVERY ESTIMATOR - MOBILE -->\n<section id=\"delivery-estimator-mobile\" class=\"rc-delivery-estimator-mobile\">\n  <p id=\"deliveryMessageMobile\" class=\"rc-delivery-text-mobile\"></p>\n</section>\n\n<style>\n@media (max-width: 767px) {\n  .rc-delivery-estimator-mobile {\n    margin-top: 6px;\n    width: 90%;\nmargin:auto;\n  }\n  .rc-delivery-text-mobile {\n    margin: 0;\n    padding: 0;\n    font-family: var(--BTN-FONT-STACK, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif);\n    font-weight: 400;\n    color: #333;\n    font-size: 13px;\n    line-height: 1.4;\n    text-align: center;\n  }\n  .rc-delivery-text-mobile span {\n    font-weight: 700;\n  }\n}\n@media (min-width: 767px) {\n  .rc-delivery-estimator-mobile {\n    display:none;\n  }\n</style>\n\n<script>\ndocument.addEventListener(\"DOMContentLoaded\", function () {\n  const el = document.getElementById(\"deliveryMessageMobile\");\n  const inventoryWrapper = document.querySelector(\"[data-remaining-wrapper]\");\n  if (!el || !inventoryWrapper) return;\n\n  function addBusinessDays(date, days) {\n    const d = new Date(date);\n    let added = 0;\n    while (added < days) {\n      d.setDate(d.getDate() + 1);\n      const dow = d.getDay();\n      if (dow !== 0 && dow !== 6) added++;\n    }\n    return d;\n  }\n\n  function moveIfSunday(date) {\n    if (date.getDay() === 0) date.setDate(date.getDate() + 1);\n    return date;\n  }\n\n  function ordinal(n) {\n    if (n > 3 && n < 21) return n + \"th\";\n    switch (n % 10) {\n      case 1: return n + \"st\";\n      case 2: return n + \"nd\";\n      case 3: return n + \"rd\";\n      default: return n + \"th\";\n    }\n  }\n\n  function formatDate(date) {\n    const weekday = date.toLocaleString(\"en-US\", { weekday: \"long\" });\n    const month = date.toLocaleString(\"en-US\", { month: \"long\" });\n    const day = ordinal(date.getDate());\n    return `${weekday}, ${month} ${day}`;\n  }\n\n  function showStandardDelivery() {\n    const now = new Date();\n    const start = moveIfSunday(addBusinessDays(now, 4));\n    const end = moveIfSunday(addBusinessDays(now, 6));\n    el.innerHTML = `Estimated delivery between <span>${formatDate(start)}</span> and <span>${formatDate(end)}</span>.`;\n  }\n\n  function showBackOrderMessage() {\n    el.innerHTML =\n      `This item is currently <span>out of stock</span> and is being reordered. ` +\n      `These will come within <span>4–8 weeks</span>.`;\n  }\n\n  function updateMessage() {\n    if (inventoryWrapper.classList.contains(\"count-is-unavailable\")) {\n      showBackOrderMessage();\n    } else {\n      showStandardDelivery();\n    }\n  }\n\n  // Initial render\n  updateMessage();\n\n  // Update whenever variant state changes\n  document.addEventListener(\"change\", function (e) {\n    if (e.target.matches(\"select, input[type='radio'], input[type='checkbox']\")) {\n      setTimeout(updateMessage, 0);\n    }\n  });\n\n  // In case your variant logic updates classes without firing change\n  const observer = new MutationObserver(updateMessage);\n  observer.observe(inventoryWrapper, { attributes: true, attributeFilter: [\"class\"] });\n});\n</script>",
            "padding_bottom": 0
          }
        },
        "code_6D9zPp": {
          "type": "code",
          "name": "Discount subline",
          "settings": {
            "code": "<style>\n  \n  html, body {\n    margin: 0;\n    padding: 0;\n    overflow-x: hidden;\n    width: 100%;\n  }\n\n  @media (min-width: 1200px){\n    .form__width {\n      max-width: none;\n      margin: 0 auto;\n      padding-right: 100px;\n    }\n\n    \n    #Product--{{ section.id }}{\n      --rc-col-h: 50vh;                        \n      --rc-col-w: calc(var(--rc-col-h) * 0.8); \n      --rc-gap: 0px;                           \n      --rc-left-pad: calc(var(--rc-col-w) + var(--rc-gap));\n\n      \n      --rc-ov-left: 30vw;                      \n      --rc-ov-top: calc(80vh + 50px);          \n      --rc-ov-width: 500px;                    \n    }\n\n    \n    #Product--{{ section.id }} .product__wrapper,\n    #Product--{{ section.id }} .product__wrapper__inner,\n    #Product--{{ section.id }} .product__page{\n      max-width: 100vw !important;\n      width: 100vw !important;\n      margin: 0 !important;\n      box-sizing: border-box;\n    }\n\n    \n    #Product--{{ section.id }} .product__wrapper__inner{\n      padding-left: var(--rc-left-pad) !important;\n      padding-right: 0 !important;\n      overflow: visible !important;\n    }\n\n    \n    #Product--{{ section.id }} product-images.product-images{\n      display: none !important;\n    }\n\n    \n    #Product--{{ section.id }} .product__page{\n      display: grid !important;\n      grid-template-columns: minmax(0,1fr) 520px !important;\n      gap: 0 !important;\n      align-items: start !important;\n      position: relative !important;\n    }\n\n    \n    #Product--{{ section.id }} .rc-left{\n      position: fixed !important;\n      left: 0 !important;\n      top: 0 !important;               \n      width: var(--rc-col-w) !important;\n      height: calc(2 * var(--rc-col-h)) !important;\n      display: flex !important;\n      flex-direction: column !important;\n      gap: 0 !important;\n      margin: 0 !important;\n      padding: 0 !important;\n      z-index: 5 !important;\n      pointer-events: none !important;\n    }\n    #Product--{{ section.id }} .rc-left .rc-frame{\n      flex: 0 0 auto !important;\n      height: var(--rc-col-h) !important;\n      width: var(--rc-col-w) !important;\n      overflow: hidden !important;\n      margin: 0 !important;\n      padding: 0 !important;\n      border-right: 1px solid #000 !important;\n      background: #fff !important;\n    }\n\n    \n    #Product--{{ section.id }} .rc-right{\n      grid-column: 1 / -1 !important;\n      position: relative !important;\n      z-index: 1 !important;\n      width: calc(100vw - var(--rc-left-pad)) !important;\n      margin: 0 !important;\n      left: 0 !important;\n      height: 80vh !important;\n      display: grid !important;\n      grid-template-columns: repeat(2, 1fr) !important;\n      gap: 0 !important;\n      overflow: hidden !important;\n      box-sizing: border-box !important;\n    }\n    #Product--{{ section.id }} .rc-right .rc-frame{\n      width: 100% !important;\n      height: 80vh !important;\n      overflow: hidden !important;\n      border-bottom: 1px solid rgba(0,0,0,1) !important;\n    }\n    #Product--{{ section.id }} .rc-frame img,\n    #Product--{{ section.id }} .rc-frame video{\n      width: 100% !important;\n      height: 100% !important;\n      object-fit: cover !important;\n      display: block !important;\n    }\n\n    \n    #Product--{{ section.id }} .rc-overlay{\n      position: absolute !important;\n      left: calc(calc(100vw - var(--rc-left-pad)) - 550px) !important;\n      top: calc(80vh + 50px) !important;      \n      transform: translateY(-100%) !important;\n      width: 500px !important;\n      z-index: 10 !important;\n\n      border-radius: 22px !important;\n      padding: 24px 24px 18px !important;\n      box-shadow: 0 12px 40px rgba(0,0,0,.28) !important;\n      background:\n        radial-gradient(120% 140% at 80% 0%, rgba(66,140,255,.45) 0%, rgba(0,50,120,.55) 55%, rgba(0,20,60,.78) 100%),\n        linear-gradient(180deg, rgba(12,40,90,.62), rgba(10,18,40,.62)) !important;\n      color: #fff !important;\n      backdrop-filter: blur(10px) !important;\n      border: 1px solid rgba(255,255,255,.10) !important;\n    }\n    #Product--{{ section.id }} .rc-overlay .rc-title{\n      margin: 0 0 6px; font-weight: 800; letter-spacing:.3px;\n      font-size: clamp(22px, 2.2vw, 28px); color: #e9f2ff;\n    }\n    #Product--{{ section.id }} .rc-overlay .rc-price{\n      font-size: 22px; font-weight: 700; margin: 0 0 6px; color:#fff; opacity:.95;\n    }\n    #Product--{{ section.id }} .rc-overlay .rc-picked{\n      font-size: 12px; opacity:.9; margin: 0 0 10px;\n    }\n\n    #Product--{{ section.id }} .rc-overlay .rc-overlay-options .product__block{\n      padding: 8px 0 6px !important;\n    }\n\n    \n    #Product--{{ section.id }} .rc-overlay .radio__fieldset .radio__button,\n    #Product--{{ section.id }} .rc-overlay [data-option-buttons] .radio__button{\n      display: block; width: 100%;\n      border-radius: 12px;\n      border: 1px solid rgba(255,255,255,.22);\n      background: linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.02));\n      color: #e8f0ff; text-align: center;\n      padding: 14px 16px; margin: 10px 0;\n      font-weight: 800; letter-spacing: .5px;\n      transition: .2s ease;\n    }\n    #Product--{{ section.id }} .rc-overlay .radio__button[aria-checked=\"true\"],\n    #Product--{{ section.id }} .rc-overlay .radio__button.is-selected{\n      border-color: #91b8ff;\n      background: rgba(145,184,255,.18);\n    }\n    #Product--{{ section.id }} .rc-overlay .radio__button[disabled],\n    #Product--{{ section.id }} .rc-overlay .radio__button.is-disabled{\n      opacity: .45; filter: grayscale(1); cursor: not-allowed;\n    }\n\n    \n    #Product--{{ section.id }} .rc-overlay .product__submit .btn{\n      width: 100%;\n      border-radius: 12px;\n      padding: 14px 18px;\n      font-weight: 900; letter-spacing:.8px;\n      border: 1px solid #8ab5ff;\n      background: linear-gradient(180deg, rgba(138,181,255,.18), rgba(138,181,255,.08));\n      color:#fff; transition:.2s ease;\n    }\n    #Product--{{ section.id }} .rc-overlay .product__submit .btn:hover{\n      box-shadow: 0 0 0 3px rgba(138,181,255,.25);\n      transform: translateY(-1px);\n    }\n\n    \n    #Product--{{ section.id }} .rc-overlay .rc-discount-hint{\n      margin-top: 10px;\n      font-size: 12px;\n      line-height: 1.4;\n      text-align: center;\n      color: rgba(255,255,255,.88);\n    }\n\n    \n    #Product--{{ section.id }} .rc-below{\n      grid-column: 1 / -1 !important;\n      width: calc(100vw - var(--rc-left-pad)) !important;\n      margin-left: var(--rc-left-pad) !important;\n      margin-top: 0 !important;\n      margin-bottom: 0 !important;\n    }\n\n    \n    #Product--{{ section.id }} .rc-overlay fieldset legend{\n      position: absolute !important;\n      width: 1px !important; height: 1px !important;\n      padding: 0 !important; margin: -1px !important;\n      overflow: hidden !important; clip: rect(0,0,0,0) !important;\n      white-space: nowrap !important; border: 0 !important;\n    }\n\n    \n    #Product--template--25036446302504__main .rc-overlay {\n      background: rgba(0, 123, 255, 0.5) !important;\n      box-shadow: 0 5px 30px rgba(0, 0, 0, 0.3) !important;\n      border-radius: 10px !important;\n      backdrop-filter: blur(16px) !important;\n      -webkit-backdrop-filter: blur(16px) !important;\n    }\n    #Product--template--25036446302504__main .rc-below .product__block {\n      padding: 0 !important;\n    }\n\n    .get-the-look-grid a {\n      flex: 0 1 calc(30% - 16px);\n      aspect-ratio: 4 / 5;\n      border-radius: 6px;\n      overflow: hidden;\n      transition: transform 0.2s ease;\n    }\n\n    \n    #Product--{{ section.id }} .rc-overlay .rc-size{\n      display: block !important;            \n      margin-top: 10px !important;\n    }\n    #Product--{{ section.id }} .rc-overlay .rc-size .radio__legend{\n      display: block !important;\n      width: 100% !important;\n      margin: 0 0 10px !important;\n      font-size: 14px !important;\n      font-weight: 600 !important;\n      color: #ffffff !important;\n    }\n    #Product--{{ section.id }} .rc-overlay .rc-size .radio__legend a{\n      float: right;\n      font-size: 12px !important;\n      font-weight: 600 !important;\n      text-transform: uppercase !important;\n      color: #3a78ff !important;\n      text-decoration: none !important;\n      border-bottom: 2px solid currentColor !important;\n    }\n    #Product--{{ section.id }} .rc-overlay .rc-size .radio__buttons{\n      display: flex !important;\n      flex-direction: column !important;\n      gap: 10px !important;\n      width: 100% !important;\n    }\n    #Product--{{ section.id }} .rc-overlay .rc-size .radio__button.rc-size-btn{\n      display: block !important;\n      width: 100% !important;\n      margin: 0 !important;\n      text-align: center !important;\n      padding: 14px 16px !important;\n      border-radius: 8px !important;\n      background: #ffffff !important;\n      border: 1px solid #e5e7eb !important;\n      color: #111 !important;\n      text-transform: uppercase !important;\n      letter-spacing: .08em !important;\n      font-weight: 600 !important;\n      line-height: 1.2 !important;\n      box-shadow: none !important;\n      transition: box-shadow .15s ease, background-color .15s ease, border-color .15s ease !important;\n    }\n    #Product--{{ section.id }} .rc-overlay .rc-size .radio__button.rc-size-btn:hover:not(:disabled),\n    #Product--{{ section.id }} .rc-overlay .rc-size .radio__button.rc-size-btn:focus-visible{\n      box-shadow: 0 0 0 2px rgba(66,127,255,0.25) !important;\n      outline: none !important;\n    }\n    #Product--{{ section.id }} .rc-overlay .rc-size .radio__button.rc-size-btn[aria-checked=\"true\"]{\n      background: #eef4ff !important;\n      color: #0b2c6f !important;\n    }\n    #Product--{{ section.id }} .rc-overlay .rc-size .radio__button.rc-size-btn:disabled{\n      background: #f5f6f8 !important;\n      border-color: #e5e7eb !important;\n      color: #98a2b3 !important;\n      cursor: not-allowed !important;\n      opacity: 1 !important;\n      filter: none !important;\n    }\n\n    \n    #Product--{{ section.id }} .rc-overlay .rc-size > .rc-size-btn{ display:none !important; }\n\t.rc-price, .rc-title {\n\tdisplay:none;\n}\n\n\n\n#Product--{{ section.id }} .rc-overlay .rc-discount-hint{\n  margin-top: 15px !important;\n  font-size: 12px !important;\n  font-weight: 400 !important;\n  letter-spacing: 1px !important;\n  line-height: 1 !important;\n  text-align: center !important;\n  color: rgba(255,255,255,.95) !important;\n}\n\n\n\n\n\n\n#Product--{{ section.id }}{\n  --rc-accent: #3a78ff; \n}\n\n\n#Product--{{ section.id }} .rc-overlay .rc-size .radio__button.rc-size-btn{\n  background: transparent !important;\n  color: #ffffff !important;\n  border: 1.5px solid rgba(255,255,255,0.95) !important;\n  box-shadow: none !important;\n  text-transform: uppercase !important;\n  letter-spacing: .08em !important;\n  font-weight: 600 !important;\n  padding: 8px 16px !important;\n  border-radius: 8px !important;\n  width: 100% !important;\n  font-size: 18px;\n  transition: box-shadow .15s ease, background-color .15s ease, border-color .15s ease, color .15s ease !important;\n}\n\n\n#Product--{{ section.id }} .rc-overlay .rc-size .radio__button.rc-size-btn:hover:not(:disabled),\n#Product--{{ section.id }} .rc-overlay .rc-size .radio__button.rc-size-btn:focus-visible{\n   background: rgba(255,255,255,0.3) !important;\n\tcolor: white !important;\n}\n\n\n#Product--{{ section.id }} .rc-overlay .rc-size .radio__button.rc-size-btn[aria-checked=\"true\"]{\n  background: rgba(255,255,255,0.3) !important;\n\tcolor: white !important;\n}\n\n\n#Product--{{ section.id }} .rc-overlay .rc-size .radio__button.rc-size-btn:disabled{\n  background: transparent !important;\n  color: white !important;\n  border-color: white !important;\n  cursor: not-allowed !important;\n  box-shadow: none !important;\n}\n\n#Product--template--25036446302504__main .rc-overlay .rc-size .radio__legend {\n\tfont-size:12px !important;\n\tfont-weight:400 !important;\n\tletter-spacing: 1px !important;\n}\n\n\n\n  }\n\n  \n  @media (max-width: 1199.98px){\n    #Product--{{ section.id }} .rc-left,\n    #Product--{{ section.id }} .rc-right,\n    #Product--{{ section.id }} .rc-overlay,\n    #Product--{{ section.id }} .rc-below{ display:none !important; }\n  }\n</style>\n\n<script>\n\n(function () {\n  const section = document.querySelector('#Product--{{ section.id }}');\n  if (!section) return;\n\n  const isDesktop = () => window.innerWidth >= 1200;\n\n  \n  const page = section.querySelector('.product__page') || section;\n\n  // Left fixed column (for gallery)\n  let left = section.querySelector('.rc-left');\n  if (!left) {\n    left = document.createElement('div');\n    left.className = 'rc-left';\n    section.appendChild(left);\n  }\n\n  // Right rail (for gallery)\n  let right = section.querySelector('.rc-right');\n  if (!right) {\n    right = document.createElement('div');\n    right.className = 'rc-right';\n    page.insertBefore(right, page.querySelector('.product__content'));\n  }\n\n  // Essentials overlay (blue) — baseline had only title+price\n  let overlay = section.querySelector('.rc-overlay');\n  if (!overlay) {\n    overlay = document.createElement('aside');\n    overlay.className = 'rc-overlay';\n    overlay.innerHTML = '<div class=\"rc-title\"></div><div class=\"rc-price\"></div>';\n    page.appendChild(overlay);\n  }\n\n  const content = page.querySelector('.product__content');\n  const slides = Array.from(section.querySelectorAll('.product__slides .product__slide img'));\n\n  \n  const getKeyFromAlt = (alt) => (alt || '').toLowerCase().split('-')[0];\n  const normalize = (s) => (s || '').toLowerCase().trim();\n\n  const optionSelectors = Array.from(\n    document.querySelectorAll('input[type=\"radio\"][name^=\"options[\"], select[name^=\"options[\"]')\n  );\n  function groupByName(nodes) {\n    const groups = {};\n    nodes.forEach((el) => {\n      const name = el.name;\n      (groups[name] ||= { elements: [], values: new Set() }).elements.push(el);\n      if (el.tagName === 'SELECT') Array.from(el.options).forEach((o) => groups[name].values.add(normalize(o.value)));\n      else if (el.type === 'radio') groups[name].values.add(normalize(el.value));\n    });\n    return groups;\n  }\n  const groups = groupByName(optionSelectors);\n  function getSelectedFromGroup(name) {\n    const g = groups[name];\n    if (!g) return '';\n    const r = g.elements.find((el) => el.type === 'radio' && el.checked);\n    if (r) return r.value;\n    const s = g.elements.find((el) => el.tagName === 'SELECT');\n    return s ? s.value : '';\n  }\n\n  \n  if (isDesktop()) {\n    const media = slides\n      .map((img) => ({ img, alt: (img.getAttribute('alt') || '').trim().toLowerCase() }))\n      .filter((m) => m.alt);\n\n    const imageKeys = new Set(media.map((m) => getKeyFromAlt(m.alt)));\n    let controlling = null;\n    for (const [name, g] of Object.entries(groups)) {\n      if (Array.from(g.values).some((v) => imageKeys.has(v))) {\n        controlling = name;\n        break;\n      }\n    }\n\n    const cloneImg = (img) => {\n      const n = document.createElement('img');\n      const src = img.currentSrc || img.getAttribute('src') || img.getAttribute('data-src') || '';\n      const srcset = img.getAttribute('srcset') || img.getAttribute('data-srcset') || '';\n      const sizes = img.getAttribute('sizes') || '';\n      if (src) n.src = src;\n      if (srcset) n.srcset = srcset;\n      if (sizes) n.sizes = sizes;\n      n.alt = img.getAttribute('alt') || '';\n      n.loading = 'lazy';\n      n.decoding = 'async';\n      return n;\n    };\n\n    const setRightCols = (cols) => {\n      right.style.setProperty('grid-template-columns', cols, 'important');\n      right.style.setProperty('height', '80vh', 'important');\n    };\n\n    const renderGallery = () => {\n      if (!media.length) { left.innerHTML=''; right.innerHTML=''; return; }\n\n      const firstDefined = (arr) => arr.find(Boolean);\n      let key = controlling ? normalize(getSelectedFromGroup(controlling)) : '';\n      let matches = key ? media.filter((m) => getKeyFromAlt(m.alt) === key) : media.slice();\n      if (!matches.length) matches = media.slice();\n\n      const front = matches.find((m) => /-front(\\.|$)/.test(m.alt)) || matches[0];\n      const back  = matches.find((m) => /-back(\\.|$)/.test(m.alt))  || matches.find((m) => m !== front) || matches[0];\n\n      left.innerHTML = '';\n      [front, back].forEach((m) => {\n        const f = document.createElement('div');\n        f.className = 'rc-frame';\n        f.appendChild(cloneImg(m.img));\n        left.appendChild(f);\n      });\n\n      const rawOthers = matches\n        .filter((m) => m !== front && m !== back)\n        .sort((a, b) => {\n          const na = (a.alt.match(/-(\\d+)(\\.|$)/) || [])[1] || 9999;\n          const nb = (b.alt.match(/-(\\d+)(\\.|$)/) || [])[1] || 9999;\n          return Number(na) - Number(nb);\n        });\n\n      const totalForVariant = matches.length;\n      let rightFrames = [];\n\n      if (totalForVariant === 1) {\n        setRightCols('1fr');\n        rightFrames = [matches[0]];\n      } else if (totalForVariant === 2) {\n        setRightCols('repeat(2, 1fr)');\n        rightFrames = [matches[0], matches[1]];\n      } else {\n        if (rawOthers.length === 1) {\n          setRightCols('1fr');\n          rightFrames = [rawOthers[0]];\n        } else {\n          setRightCols('repeat(2, 1fr)');\n          rightFrames = (rawOthers.length >= 2 ? rawOthers.slice(0, 2) : matches.slice(0, 2));\n        }\n      }\n\n      right.innerHTML = '';\n      rightFrames.forEach((m) => {\n        const f = document.createElement('div');\n        f.className = 'rc-frame';\n        f.appendChild(cloneImg(m.img));\n        right.appendChild(f);\n      });\n    };\n\n    renderGallery();\n    optionSelectors.forEach((el) => el.addEventListener('change', renderGallery));\n    const idInput = section.querySelector('input[name=\"id\"]');\n    if (idInput) new MutationObserver(renderGallery).observe(idInput, { attributes: true, attributeFilter: ['value'] });\n    document.addEventListener('variant:change', renderGallery);\n  }\n\n  \n  if (isDesktop()) {\n    const titleEl = page.querySelector('.product__block .product__title, .product__title');\n    const priceEl = page.querySelector('[data-price-wrapper], .product__price');\n\n    // Ensure title/price present and synced\n    let overlayTitle = overlay.querySelector('.rc-title');\n    let overlayPrice = overlay.querySelector('.rc-price');\n    if (!overlayTitle) { overlayTitle = document.createElement('div'); overlayTitle.className = 'rc-title'; overlay.prepend(overlayTitle); }\n    if (!overlayPrice) { overlayPrice = document.createElement('div'); overlayPrice.className = 'rc-price'; overlayTitle.after(overlayPrice); }\n\n    overlayTitle.textContent = titleEl ? titleEl.textContent.trim() : '{{ product.title | strip_html }}';\n    if (priceEl) overlayPrice.textContent = (priceEl.innerText || priceEl.textContent || '').trim();\n    if (priceEl) {\n      new MutationObserver(() => {\n        overlayPrice.textContent = (priceEl.innerText || priceEl.textContent || '').trim();\n      }).observe(priceEl, { childList: true, subtree: true, characterData: true });\n    }\n\n    // ----- SIZE: hide original + build cloned buttons in overlay -----\n    const findSizeWrapper = () =>\n      section.querySelector('.selector-wrapper--size,[data-option-position=\"2\"]') ||\n      Array.from(section.querySelectorAll('fieldset')).find(f => /size/i.test((f.querySelector('legend')?.textContent)||'')) ||\n      null;\n\n    const getSizeModel = () => {\n      const wrap = findSizeWrapper();\n      if (!wrap) return null;\n\n      const radios = Array.from(wrap.querySelectorAll('input[type=\"radio\"][name^=\"options[\"]'));\n      const select = wrap.querySelector('select[name^=\"options[\"]');\n      if (radios.length) {\n        return {\n          type: 'radio',\n          wrapper: wrap,\n          items: radios.map(r => ({\n            value: r.value,\n            disabled: r.disabled || r.classList.contains('sold-out') || r.closest('.radio__button')?.classList.contains('is-disabled'),\n            checked: r.checked,\n            node: r\n          }))\n        };\n      }\n      if (select) {\n        return {\n          type: 'select',\n          wrapper: wrap,\n          select,\n          items: Array.from(select.options).map(o => ({\n            value: o.value,\n            disabled: o.disabled,\n            checked: o.selected\n          }))\n        };\n      }\n      return null;\n    };\n\n    // Create (or reuse) size block in overlay\n    let rcSize = overlay.querySelector('.rc-size');\n    if (!rcSize) {\n      rcSize = document.createElement('div');\n      rcSize.className = 'radio__fieldset rc-size';\n      rcSize.innerHTML = `\n        <legend class=\"radio__legend\">Select a size</legend>\n        <div class=\"radio__buttons\" data-rc-size-buttons></div>\n      `;\n      overlay.appendChild(rcSize);\n    }\n    const btnHolder = rcSize.querySelector('[data-rc-size-buttons]');\n\n    const hideOriginalSize = () => {\n      const wrap = findSizeWrapper();\n      if (wrap) {\n        wrap.setAttribute('data-rc-hidden-size', '');\n        wrap.style.setProperty('display', 'none', 'important');  // desktop only\n      }\n    };\n\n    const dispatch = (el, type) => el && el.dispatchEvent(new Event(type, { bubbles: true }));\n\n    const selectOriginal = (value) => {\n      const model = getSizeModel();\n      if (!model) return;\n\n      if (model.type === 'radio') {\n        const target = model.items.find(i => normalize(i.value) === normalize(value));\n        if (target && target.node) {\n          target.node.checked = true;\n          dispatch(target.node, 'input');\n          dispatch(target.node, 'change');\n        }\n      } else if (model.type === 'select') {\n        model.select.value = value;\n        dispatch(model.select, 'input');\n        dispatch(model.select, 'change');\n      }\n    };\n\n    const renderSizeButtons = () => {\n      const model = getSizeModel();\n      if (!model) { rcSize.style.display = 'none'; return; }\n      rcSize.style.display = '';\n\n      // Build/refresh buttons\n      btnHolder.innerHTML = '';\n      model.items.forEach(it => {\n        const btn = document.createElement('button');\n        btn.type = 'button';\n        btn.className = 'radio__button rc-size-btn';\n        btn.textContent = it.value;\n        btn.setAttribute('data-value', it.value);\n        btn.setAttribute('aria-checked', it.checked ? 'true' : 'false');\n        if (it.disabled) btn.disabled = true;\n\n        btn.addEventListener('click', () => {\n          if (btn.disabled) return;\n          selectOriginal(it.value);\n          // sync UI after change\n          syncFromOriginal();\n        });\n\n        btnHolder.appendChild(btn);\n      });\n\n      // finally hide the original\n      hideOriginalSize();\n    };\n\n    const syncFromOriginal = () => {\n      const model = getSizeModel();\n      if (!model) return;\n      const map = new Map(model.items.map(i => [normalize(i.value), i]));\n      btnHolder.querySelectorAll('.rc-size-btn').forEach(btn => {\n        const key = normalize(btn.getAttribute('data-value'));\n        const it = map.get(key);\n        if (!it) return;\n        btn.setAttribute('aria-checked', it.checked ? 'true' : 'false');\n        btn.disabled = !!it.disabled;\n      });\n    };\n\n    // initial render\n    renderSizeButtons();\n\n    // Observe the original size wrapper for theme-driven changes\n    const sizeWrap = findSizeWrapper();\n    if (sizeWrap) {\n      const mo = new MutationObserver(() => {\n        renderSizeButtons();\n        syncFromOriginal();\n      });\n      mo.observe(sizeWrap, { childList: true, subtree: true, attributes: true, attributeFilter: ['class', 'disabled', 'checked', 'value'] });\n    }\n\n    // Also resync when any option selector changes (e.g., Color changes which sizes are available)\n    optionSelectors.forEach(el => {\n      el.addEventListener('change', () => { renderSizeButtons(); syncFromOriginal(); });\n      el.addEventListener('input',  () => { renderSizeButtons(); syncFromOriginal(); });\n    });\n  }\n\n  \n  let last = isDesktop();\n  window.addEventListener('resize', () => {\n    const now = isDesktop();\n    if (now !== last) window.location.reload();\n    last = now;\n  });\n\n// Add a discount line inside the overlay (only once)\nlet discount = overlay.querySelector('.rc-discount-hint');\nif (!discount) {\n  discount = document.createElement('p');\n  discount.className = 'rc-discount-hint';\n  discount.textContent = 'Discounts applies automatically in the cart';\n  overlay.appendChild(discount);\n}\n})();\n\n\n\n</script>",
            "padding_bottom": 0
          }
        },
        "code_9qMBwJ": {
          "type": "code",
          "name": "ATC & Buy now",
          "settings": {
            "code": "<!-- ✅ 2 buttons IN-FLOW between Shopify installments (.shop-movement) and the features section\n     - NOT sticky (does not move on scroll)\n     - Self-contained\n     - Mobile-only (remove the media query if you want it on desktop too)\n-->\n\n<div id=\"rc-inline-cta\">\n  <button id=\"rc-inline-atc\" type=\"button\">Add to Cart</button>\n  <button id=\"rc-inline-buy\" type=\"button\">Buy Now</button>\n</div>\n\n<style>\n  \n  #rc-inline-cta { display: none; }\n\n  @media (max-width: 768px) {\n    #rc-inline-cta{\n      display: flex;\n      flex-direction: column;\n      gap: 10px;\n      margin: 12px 0 14px 0;\n      padding: 0 12px;\n      box-sizing: border-box;\n\n      text-transform: uppercase;\n      font-family: var(--BTN-FONT-STACK, inherit);\n    }\n\n    #rc-inline-atc{\n      width: 100%;\n      border: none;\n      border-radius: 10px;\n      padding: 16px 14px;\n      font-size: 18px;\n      font-weight: 800;\n      cursor: pointer;\n      background: #2E7D32;\n      color: #fff;\n    }\n\n    #rc-inline-buy{\n      width: 100%;\n      border: none;\n      border-radius: 10px;\n      padding: 16px 14px;\n      font-size: 18px;\n      font-weight: 800;\n      cursor: pointer;\n      background: #111;\n      color: #fff;\n    }\n  }\n</style>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', () => {\n  if (window.innerWidth >= 769) return; // mobile only\n\n  const cta = document.getElementById('rc-inline-cta');\n  const anchor = document.querySelector('.shop-movement');\n  const features = document.querySelector('.feature-facts-section1');\n\n  if (anchor) anchor.insertAdjacentElement('afterend', cta);\n  else if (features) features.insertAdjacentElement('beforebegin', cta);\n\n  const atcBtn = document.getElementById('rc-inline-atc');\n  const buyBtn = document.getElementById('rc-inline-buy');\n\n  const productForm = document.querySelector('form[action*=\"/cart/add\"]');\n  const variantIdInput = productForm?.querySelector('input[name=\"id\"]');\n\n  \n\n  function isSizeSelected() {\n    // Radio buttons (most themes)\n    const sizeRadios = document.querySelectorAll(\n      'input[type=\"radio\"][name*=\"Size\"], input[type=\"radio\"][data-option-name=\"Size\"]'\n    );\n    if (sizeRadios.length) {\n      return Array.from(sizeRadios).some(r => r.checked);\n    }\n\n    // Dropdown fallback\n    const sizeSelect = document.querySelector(\n      'select[name*=\"Size\"], select[data-option-name=\"Size\"]'\n    );\n    if (sizeSelect) {\n      return sizeSelect.value && sizeSelect.value !== '';\n    }\n\n    // If product has no size option, allow add\n    return true;\n  }\n\n  function getVariantId() {\n    if (!isSizeSelected()) return null;\n    const id = variantIdInput?.value?.trim();\n    return id && id !== '0' ? id : null;\n  }\n\n  function scrollToSize() {\n    const target =\n      document.querySelector('[name*=\"Size\"]') ||\n      document.querySelector('[data-option-name=\"Size\"]') ||\n      productForm;\n\n    target?.scrollIntoView({ behavior: 'smooth', block: 'center' });\n  }\n\n  function showSelectSizeFeedback(btn) {\n    const original = btn.textContent;\n    btn.disabled = true;\n    btn.textContent = 'Select a size';\n\n    setTimeout(() => {\n      btn.textContent = original;\n      btn.disabled = false;\n    }, 1500);\n  }\n\n  async function addToCart(variantId, qty = 1) {\n    const res = await fetch('/cart/add.js', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },\n      body: JSON.stringify({ id: variantId, quantity: qty })\n    });\n\n    if (!res.ok) throw new Error('Add to cart failed');\n  }\n\n  \n  atcBtn.addEventListener('click', async () => {\n    const variantId = getVariantId();\n\n    if (!variantId) {\n      scrollToSize();\n      showSelectSizeFeedback(atcBtn);\n      return;\n    }\n\n    try {\n      atcBtn.disabled = true;\n      atcBtn.textContent = 'Adding…';\n      await addToCart(variantId, 1);\n      window.location.href = '/cart';\n    } catch (e) {\n      console.warn(e);\n      atcBtn.textContent = 'Error';\n      setTimeout(() => {\n        atcBtn.textContent = 'Add to Cart';\n        atcBtn.disabled = false;\n      }, 1200);\n    }\n  });\n\n  \n  buyBtn.addEventListener('click', async () => {\n    const variantId = getVariantId();\n\n    if (!variantId) {\n      scrollToSize();\n      showSelectSizeFeedback(buyBtn);\n      return;\n    }\n\n    try {\n      buyBtn.disabled = true;\n      buyBtn.textContent = 'Loading…';\n      await addToCart(variantId, 1);\n      window.location.href = '/checkout';\n    } catch (e) {\n      console.warn(e);\n      buyBtn.textContent = 'Error';\n      setTimeout(() => {\n        buyBtn.textContent = 'Buy Now';\n        buyBtn.disabled = false;\n      }, 1200);\n    }\n  });\n});\n</script>",
            "padding_bottom": 0
          }
        },
        "code_tPgUFd": {
          "type": "code",
          "name": "Sizing Bar",
          "settings": {
            "code": "<style>\n  \n  html, body{\n    margin:0;\n    padding:0;\n    overflow-x:hidden;\n    width:100%;\n  }\n\n  @media (min-width:1200px){\n    \n    #Product--{{ section.id }}{\n      --rc-col-h: 50vh;                         \n      --rc-col-w: calc(var(--rc-col-h) * 0.8);  \n      --rc-gap: 0px;                            \n      --rc-left-pad: calc(var(--rc-col-w) + var(--rc-gap));\n\n      \n      --rc-ol-left: 55vw;   \n      --rc-ol-top:  18vh;   \n    }\n\n    \n    #Product--{{ section.id }} .product__wrapper,\n    #Product--{{ section.id }} .product__wrapper__inner,\n    #Product--{{ section.id }} .product__page{\n      max-width:100vw !important;\n      width:100vw !important;\n      margin:0 !important;\n      box-sizing:border-box;\n      overflow:visible !important;\n    }\n\n    \n    #Product--{{ section.id }} .product__wrapper__inner{\n      padding-left:var(--rc-left-pad) !important;\n      padding-right:0 !important;\n      overflow:visible !important;\n    }\n\n    \n    #Product--{{ section.id }} product-images.product-images{\n      display:none !important;\n    }\n\n    \n    #Product--{{ section.id }} .rc-left{\n      position:fixed!important;\n      left:0!important;\n      top:0!important;\n      width:var(--rc-col-w)!important;\n      height:calc(2 * var(--rc-col-h))!important;\n      display:flex!important;\n      flex-direction:column!important;\n      gap:0!important;\n      margin:0!important;\n      padding:0!important;\n      z-index:5!important;\n      pointer-events:none!important;\n    }\n    #Product--{{ section.id }} .rc-left .rc-frame{\n      flex:0 0 auto!important;\n      height:var(--rc-col-h)!important;\n      width:var(--rc-col-w)!important;\n      overflow:hidden!important;\n      margin:0!important;\n      padding:0!important;\n      border-right:1px solid #000!important;\n      background:#fff!important;\n    }\n\n    \n    #Product--{{ section.id }} .rc-right{\n      width:calc(100vw - var(--rc-left-pad))!important;\n      height:80vh!important;\n      margin:0!important;\n      left:0!important;\n      display:grid!important;\n      grid-template-columns:repeat(3, 1fr)!important;\n      gap:0!important;\n      overflow:hidden!important;\n      box-sizing:border-box!important;\n      position:relative!important;\n      z-index:1!important;\n    }\n    #Product--{{ section.id }} .rc-right .rc-frame{\n      width:100%!important;\n      height:80vh!important;\n      overflow:hidden!important;\n    }\n    #Product--{{ section.id }} .rc-frame img,\n    #Product--{{ section.id }} .rc-frame video{\n      width:100%!important;\n      height:100%!important;\n      object-fit:cover!important;\n      display:block!important;\n    }\n\n    \n    #Product--{{ section.id }} .rc-overlay{\n      position:absolute!important;    \n      left:var(--rc-ol-left)!important;\n      top:var(--rc-ol-top)!important;\n      transform:translate(-0%, -0%);  \n      z-index:10!important;\n      pointer-events:auto!important;\n\n      width:min(480px, 38vw)!important;\n      border-radius:22px!important;\n      padding:24px 24px 18px!important;\n      box-shadow:0 12px 40px rgba(0,0,0,.25)!important;\n      background:\n        radial-gradient(120% 140% at 80% 0%, rgba(66,140,255,.45) 0%, rgba(0,50,120,.55) 55%, rgba(0,20,60,.75) 100%),\n        linear-gradient(180deg, rgba(12,40,90,.6), rgba(10,18,40,.6))!important;\n      color:#fff!important;\n      backdrop-filter:blur(10px)!important;\n      border:1px solid rgba(255,255,255,.08)!important;\n    }\n\n    \n    #Product--{{ section.id }} .rc-overlay .product__title,\n    #Product--{{ section.id }} .rc-overlay .product__heading{\n      margin:0 0 6px 0!important;\n      color:#e9f2ff!important;\n      line-height:1.15!important;\n    }\n    #Product--{{ section.id }} .rc-overlay [data-price-wrapper],\n    #Product--{{ section.id }} .rc-overlay .product__price{\n      font-weight:700!important;\n      font-size:22px!important;\n      color:#fff!important;\n      margin:6px 0 12px 0!important;\n    }\n    #Product--{{ section.id }} .rc-overlay .product__block{\n      padding:10px 0!important;\n    }\n    #Product--{{ section.id }} .rc-overlay .product__submit .btn{\n      width:100%!important;\n      border-radius:12px!important;\n    }\n\n    \n    #Product--{{ section.id }} .rc-below{\n      position:relative!important;\n      z-index:2!important;\n      margin:24px 0 48px 0!important;\n      padding:0 24px 0 0!important;\n      max-width:calc(100vw - var(--rc-left-pad))!important;\n      box-sizing:border-box!important;\n    }\n    \n    #Product--{{ section.id }} .rc-below .product__block{\n      padding:16px 0!important;\n    }\n  }\n\n  \n  @media (max-width:1199.98px){\n    #Product--{{ section.id }} .rc-left,\n    #Product--{{ section.id }} .rc-right,\n    #Product--{{ section.id }} .rc-overlay{ display:none!important; }\n    \n  }\n</style>\n\n<script>\n\n(function(){\n  const section = document.querySelector('#Product--{{ section.id }}');\n  if(!section) return;\n\n  const page = section.querySelector('.product__page') || section;\n\n  // Ensure left stack + others rail exist (you already have this from your baseline script)\n  // If your baseline JS already adds .rc-left / .rc-right, we won't re-create here.\n\n  // 1) Make overlay + below containers (once)\n  let overlay = section.querySelector('.rc-overlay');\n  if(!overlay){\n    overlay = document.createElement('aside');\n    overlay.className = 'rc-overlay';\n    // Put it just after the image rail so it visually overlaps it\n    page.insertBefore(overlay, page.querySelector('.product__content'));\n  }\n\n  let below = section.querySelector('.rc-below');\n  if(!below){\n    below = document.createElement('div');\n    below.className = 'rc-below';\n    // This should sit AFTER the image rail\n    const contentAnchor = page.querySelector('.product__content');\n    if(contentAnchor){\n      contentAnchor.insertAdjacentElement('afterend', below);\n    }else{\n      page.appendChild(below);\n    }\n  }\n\n  // 2) Only restructure on desktop; return early for smaller viewports\n  function isDesktop(){ return window.innerWidth >= 1200; }\n  if(!isDesktop()) return;\n\n  // 3) Grab the source area with all your product blocks\n  const content = page.querySelector('.product__content');\n  if(!content) return;\n\n  // 4) Helper: move (NOT clone) first matching element into a target\n  function moveFirst(sel, target){\n    const el = content.querySelector(sel);\n    if(el && target){\n      target.appendChild(el);\n      return el;\n    }\n    return null;\n  }\n\n  // 5) Clear previous splits (idempotent)\n  overlay.innerHTML = '';\n  // Keep any previously moved extras by re-attaching remaining children at the end\n  // but we’ll rebuild fresh: move everything back into content first (if needed)\n  // (Safe no-op when first run)\n  Array.from(below.children).forEach(child => content.appendChild(child));\n\n  // 6) Essentials → overlay (order matters)\n  // Title\n  moveFirst('.product__title, .product__heading', overlay);\n  // Price\n  moveFirst('[data-price-wrapper], .product__price', overlay);\n  // Stock/status badges if any\n  moveFirst('.product__badge, .inventory, .product__inventory, .product__meta', overlay);\n  // Option controls (color/size/etc.)\n  // Try common containers first, then any fieldsets/selects\n  if(!moveFirst('.product__options, [data-option-buttons], .radio__fieldset', overlay)){\n    // Fallback: move any option fieldsets/selects we can find\n    const opts = content.querySelectorAll('.product__block fieldset, .product__block select');\n    if(opts.length){\n      const wrap = document.createElement('div');\n      wrap.className = 'product__block';\n      overlay.appendChild(wrap);\n      opts.forEach(el => {\n        if(el.closest('.product__content') === content) wrap.appendChild(el);\n      });\n    }\n  }\n  // Size chart link if it’s a sibling block\n  moveFirst('[data-size-chart-toggle], .size-chart, a[href*=\"size\"]', overlay);\n  // Add-to-cart area\n  moveFirst('.product__submit, [data-product-submit]', overlay);\n\n  // 7) Everything else → below\n  // Move remaining blocks that are still inside .product__content\n  const leftovers = Array.from(content.children);\n  leftovers.forEach(node => {\n    // Skip empty text nodes and invisible spacers\n    if(node.nodeType === 1){ below.appendChild(node); }\n  });\n\n  // Optional: re-run on resize (desktop <-> mobile toggles)\n  let lastState = isDesktop();\n  window.addEventListener('resize', () => {\n    const now = isDesktop();\n    if(now !== lastState){\n      // simplest: reload to recompose layout (prevents duplicate moves)\n      // If you prefer no reload, you can write a fuller two-way move.\n      window.location.reload();\n    }\n    lastState = now;\n  });\n})();\n</script>",
