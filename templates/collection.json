    "rc_sub_description": {
      "type": "section-custom-code",
      "name": "Sub-Collection Description",
      "settings": {
        "code": "<div class=\"rc-desc\" id=\"rc-collection-desc\">\n  <p id=\"rc-desc-text\">{{ collection.description }}</p>\n</div>\n\n<script>\n(function () {\n  var LIMIT = 100;\n\n  function truncWord(s, max) {\n    s = (s || '').replace(/\\s+/g, ' ').trim();\n    if (s.length <= max) return s;\n    var cut = s.slice(0, max);\n    var i = cut.lastIndexOf(' ');\n    if (i > 0) cut = cut.slice(0, i);\n    return cut;\n  }\n\n  function esc(s) {\n    var d = document.createElement('div');\n    d.textContent = s;\n    return d.innerHTML;\n  }\n\n  function init() {\n    var el = document.getElementById('rc-desc-text');\n    if (!el) return;\n    var full = el.innerHTML;\n    var text = el.textContent.replace(/\\s+/g, ' ').trim();\n    if (text.length <= LIMIT) return;\n\n    var short = esc(truncWord(text, LIMIT));\n    el.dataset.fullHtml = full;\n    el.innerHTML = short + '&hellip; <button type=\"button\" class=\"rcp-toggle\">Read more</button>';\n\n    el.querySelector('.rcp-toggle').addEventListener('click', function () {\n      el.innerHTML = el.dataset.fullHtml;\n    });\n  }\n\n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', init);\n  } else {\n    init();\n  }\n})();\n</script>\n\n<style>\n.rc-desc {\n  max-width: 90vw;\n  margin: 0 auto;\n  padding: 20px 5vw 10px;\n}\n@media (min-width: 3000px) {\n  .rc-desc { max-width: 3000px; }\n}\n.rc-desc p {\n  font-style: var(--BTN-FONT-STYLE);\n  font-family: var(--BTN-FONT-STACK);\n  font-size: 13px;\n  font-weight: 100;\n  line-height: 1.6;\n  text-transform: uppercase;\n  letter-spacing: 0.04em;\n  color: #333;\n}\n.rcp-toggle {\n  background: #2A4D1F;\n  border: 0;\n  padding: 6px 16px;\n  margin-left: 10px;\n  border-radius: 3px;\n  text-decoration: none;\n  cursor: pointer;\n  color: #fff;\n  font-style: var(--BTN-FONT-STYLE);\n  font-weight: var(--BTN-FONT-WEIGHT);\n  font-family: var(--BTN-FONT-STACK);\n  text-transform: uppercase;\n  font-size: 12px;\n}\n.rcp-toggle:hover { background: #003dbf; }\n.rcp-hidden { display: none !important; }\n\n@media (max-width: 763px) {\n  .rc-desc { padding: 16px 10px 8px; }\n}\n</style>",
