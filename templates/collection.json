p-accent);\n  }\n\n  .rcp-ql-line a:focus-visible{\n    outline:2px solid var(--rcp-accent);\n    outline-offset:2px;\n  }\n\n@media (max-width: 763px) {\n  .rcp-ql-line {\n    flex-direction: column;\n    align-items: stretch;\n    gap: 10px; /* vertical spacing between links */\n    overflow: visible; /* remove horizontal scrolling */\n  }\n\n  .rcp-ql-line a {\n    width: 100%; /* make links full-width */\n  }\n}\n\n</style>",
