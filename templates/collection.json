        "code": "<script>\n  document.addEventListener(\"DOMContentLoaded\", function () {\n    document.querySelectorAll(\".radio__fieldset--swatches\").forEach(function (fieldset) {\n      var swatches = fieldset.querySelectorAll(\"radio-swatch\");\n      if (swatches.length <= 1) {\n        fieldset.style.display = \"none\";\n      }\n    });\n  });\n</script>\n\n<style>\n/* ── Product info text ── */\n.product-information p,\n.product-information span {\n  text-transform: uppercase !important;\n  font-style: var(--BTN-FONT-STYLE);\n  font-family: var(--BTN-FONT-STACK);\n  font-size: 12px;\n  font-weight: 100;\n  line-height: 1;\n  margin: 0;\n}\n.product-information p { padding-top: 3px; }\n.product-item--centered .product-information { text-align: left; }\n.collection__products .product-item__info { padding-left: 0; }\n\n/* ── Grid gap ── */\n.grid { gap: 5px; }\n\n/* ── Layout max-width constraints ── */\n@media (min-width: 763px) and (max-width: 3000px) {\n  .wrapper--full,\n  .wrapper--full-padded,\n  .grid-outer,\n  .grid__items-holder {\n    max-width: 90vw;\n    min-width: 90vw;\n    margin: 0 auto;\n  }\n  .grid-outer { padding: 0; }\n}\n@media (min-width: 3000px) {\n  .wrapper--full,\n  .wrapper--full-padded,\n  .grid-outer {\n    max-width: 3000px !important;\n    min-width: 3000px !important;\n  }\n  .collection__products {\n    padding-left: calc((100vw - 3000px) / 2);\n  }\n}\n\n/* ── Collection products padding ── */\n.collection__products,\n.grid__items-holder {\n  padding-left: 5vw;\n  padding-right: 5vw;\n}\n.collection__products .grid-outer { padding: 10px 10px; }\n.wrapper--full-padded { padding: 0; }\n\n/* ── Mobile grid slider padding ── */\n@media only screen and (max-width: 749px) {\n  .grid--mobile-slider { padding-left: 20px; }\n  .grid--mobile-slider .grid-item { margin-right: 0; }\n}\n\n/* ── Star ratings ── */\n.custom-rating .star {\n  margin-top: -4px;\n  font-size: 14px !important;\n  margin-right: 2px !important;\n}\n\n/* ── Sub label ── */\n.sub {\n  font-size: 10px !important;\n  text-transform: uppercase;\n  color: grey;\n  padding-bottom: 3px;\n}\n</style>",
