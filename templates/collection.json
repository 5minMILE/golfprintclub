u-banner__link:hover {\n  color: #003dbf;\n}\n\n@media (max-width: 763px) {\n  .rc-edu-banner { padding: 0 10px; }\n  .rc-edu-banner__inner {\n    flex-direction: column;\n    align-items: flex-start;\n    padding: 14px 16px;\n    gap: 10px;\n  }\n  .rc-edu-banner__features {\n    flex-direction: column;\n    gap: 8px;\n  }\n  .rc-edu-banner__icon {\n    width: 16px;\n    height: 16px;\n    font-size: 8px;\n  }\n  .rc-edu-banner__label {\n    font-size: 11px;\n  }\n}\n</style>",
