    "rc_sub_education": {
      "type": "section-custom-code",
      "name": "Sub-Collection Education Banner",
      "settings": {
        "code": "<!-- RC Sub-Collection Education Banner -->\n<section class=\"rc-edu\" aria-label=\"Product features\">\n  <div class=\"rc-edu__inner\">\n    <div class=\"rc-edu__features\">\n      <div class=\"rc-edu__item\">\n        <span class=\"rc-edu__check\">&#10003;</span>\n        <span class=\"rc-edu__label\">No Ride Up</span>\n      </div>\n      <div class=\"rc-edu__item\">\n        <span class=\"rc-edu__check\">&#10003;</span>\n        <span class=\"rc-edu__label\">No Bounce Pocket</span>\n      </div>\n      <div class=\"rc-edu__item\">\n        <span class=\"rc-edu__check\">&#10003;</span>\n        <span class=\"rc-edu__label\">Real Compression</span>\n      </div>\n    </div>\n    <a href=\"/pages/about\" class=\"rc-edu__link\">Learn more &rarr;</a>\n  </div>\n</section>\n\n<style>\n.rc-edu {\n  max-width: 90vw;\n  margin: 20px auto 0;\n  padding: 0 5vw;\n}\n@media (min-width: 3000px) {\n  .rc-edu { max-width: 3000px; }\n}\n.rc-edu__inner {\n  background: #fafafa;\n  border: 1px solid #e0e0e0;\n  padding: 20px 28px;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n.rc-edu__features {\n  display: flex;\n  gap: 36px;\n  align-items: center;\n}\n.rc-edu__item {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n}\n.rc-edu__check {\n  width: 22px;\n  height: 22px;\n  border-radius: 50%;\n  background: #2A4D1F;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  color: #fff;\n  font-size: 11px;\n  flex-shrink: 0;\n  line-height: 1;\n}\n.rc-edu__label {\n  font-style: var(--BTN-FONT-STYLE);\n  font-weight: var(--BTN-FONT-WEIGHT);\n  font-family: var(--BTN-FONT-STACK);\n  font-size: 12px;\n  text-transform: uppercase;\n  letter-spacing: 0.06em;\n  color: #111;\n}\n.rc-edu__link {\n  font-style: var(--BTN-FONT-STYLE);\n  font-weight: var(--BTN-FONT-WEIGHT);\n  font-family: var(--BTN-FONT-STACK);\n  font-size: 11px;\n  color: #2A4D1F;\n  text-decoration: underline;\n  text-transform: uppercase;\n  letter-spacing: 0.04em;\n  white-space: nowrap;\n}\n.rc-edu__link:hover { color: #003dbf; }\n\n@media (max-width: 763px) {\n  .rc-edu { padding: 0 10px; }\n  .rc-edu__inner {\n    flex-direction: column;\n    align-items: flex-start;\n    padding: 16px 18px;\n    gap: 12px;\n  }\n  .rc-edu__features {\n    flex-direction: column;\n    gap: 10px;\n  }\n  .rc-edu__check {\n    width: 18px;\n    height: 18px;\n    font-size: 9px;\n  }\n  .rc-edu__label { font-size: 11px; }\n}\n</style>",
