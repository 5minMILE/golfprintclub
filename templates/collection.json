    "section_custom_code_gm9TDP": {
      "type": "section-custom-code",
      "disabled": true,
      "name": "Custom code",
      "settings": {
        "code": "<p id=\"collection-desc\" class=\"desc1\">\n{{ collection.description }}</p>\n\n<script>\n(function () {\n  const BASELINE = 100; // chars before adding \u2026 (word-safe)\n\n  // Word-safe cut\n  function truncateWordSafe(s, max) {\n    s = (s || '').replace(/\\s+/g, ' ').trim();\n    if (s.length <= max) return s;\n    let cut = s.slice(0, max);\n    const i = cut.lastIndexOf(' ');\n    if (i > 0) cut = cut.slice(0, i);\n    return cut;\n  }\n  const escapeHTML = (s) => {\n    const d = document.createElement('div'); d.textContent = s; return d.innerHTML;\n  };\n\n  // Gather the paragraphs that belong to the description block starting from the anchor.\n  function collectParagraphs(anchor) {\n    if (!anchor) return [];\n    // If anchor contains <p> children, use those.\n    let inside = anchor.querySelectorAll && anchor.querySelectorAll('p');\n    if (inside && inside.length) return Array.from(inside);\n\n    // If anchor itself is a <p>, include contiguous <p> siblings (common when HTML breaks out).\n    if (anchor.tagName === 'P') {\n      const ps = [anchor];\n      let n = anchor.nextElementSibling;\n      while (n && n.tagName === 'P') { ps.push(n); n = n.nextElementSibling; }\n      return ps;\n    }\n\n    // Fallback: if anchor is a container with text, wrap it as one \"paragraph\"\n    if (anchor.textContent && anchor.textContent.trim().length) return [anchor];\n    return [];\n  }\n\n  function applyInlineEllipsis(anchor) {\n    if (!anchor || anchor.dataset.rcpDone === '1') return;\n\n    const ps = collectParagraphs(anchor).filter(p => (p.textContent || '').trim().length);\n    if (!ps.length) return;\n\n    const first = ps[0];\n    const rest  = ps.slice(1);\n\n    // Store original HTML of first paragraph/node (works if it's a <p> or a generic container)\n    const fullFirstHTML = first.innerHTML;\n    const firstText     = first.textContent.replace(/\\s+/g, ' ').trim();\n\n    // Build short preview for first paragraph\n    let shortHTML;\n    if (rest.length >= 1) {\n      // MULTI-PARAGRAPH: always show ellipsis + button, even if first is short\n      if (firstText.length > BASELINE) {\n        const shortText = truncateWordSafe(firstText, BASELINE);\n        shortHTML = `${escapeHTML(shortText)}&hellip; `;\n      } else {\n        shortHTML = `${fullFirstHTML} &hellip; `;\n      }\n    } else {\n      // SINGLE PARAGRAPH: only show button if it exceeds baseline\n      if (firstText.length > BASELINE) {\n        const shortText = truncateWordSafe(firstText, BASELINE);\n        shortHTML = `${escapeHTML(shortText)}&hellip; `;\n      } else {\n        // Nothing to do\u2014content is short enough\n        anchor.dataset.rcpDone = '1';\n        return;\n      }\n    }\n\n    // Hide remaining paragraphs (if any)\n    rest.forEach(p => p.classList.add('rcp-hidden'));\n\n    // Insert inline Read more in the first paragraph\n    first.dataset.fullHtml = fullFirstHTML;\n    first.innerHTML = `${shortHTML}<button type=\"button\" class=\"rcp-toggle\">Read more</button>`;\n\n    const btn = first.querySelector('.rcp-toggle');\n    btn.addEventListener('click', () => {\n      // Expand only (no collapse)\n      first.innerHTML = first.dataset.fullHtml;\n      rest.forEach(p => p.classList.remove('rcp-hidden'));\n    });\n\n    anchor.dataset.rcpDone = '1';\n  }\n\n  function init() {\n    // Prefer your explicit anchor first\n    const anchor = document.getElementById('collection-desc') || document.querySelector('#collection-desc');\n    if (anchor) { applyInlineEllipsis(anchor); return; }\n\n    // Fallback: try to auto-detect a description block in main\n    const main = document.querySelector('main') || document;\n    const firstP = main.querySelector('p');\n    if (firstP) applyInlineEllipsis(firstP);\n  }\n\n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', init);\n  } else {\n    init();\n  }\n})();\n</script>\n\n<style>\n#CustomCode--template--25036444860712__section_custom_code_87HtKP {\npadding: 0 10px;}\n  .rcp-toggle {\n    background: #3D6E2E; border: 0; padding: 6px 16px;\nmargin-left: 10px;\nborder-radius:3px;\n text-decoration: none; cursor: pointer;\n\tcolor:white;\nfont-style: var(--BTN-FONT-STYLE);\n  font-weight: var(--BTN-FONT-WEIGHT);\n  font-family: var(--BTN-FONT-STACK);\ntext-transform: uppercase;\nfont-size: 14px;\n  }\n  .rcp-hidden { display: none !important; }\n</style>",
