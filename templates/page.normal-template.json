on_size":"","button_style":"btn--solid","show_social_links":false}}},"block_order":["image_Ugwzhp","newsletter_9jDTpr"],"settings":{"height":"screen-height-one-half","mobile_height":"screen-height-one-half--mobile","width":"wrapper--full-padded","bg_color":"","color":"","padding_top":0,"padding_bottom":0}},"section_rich_text_athdCn":{"type":"section-rich-text","blocks":{"heading_6jTFW3":{"type":"heading","settings":{"title":"This is Just the Beginning","text_size":8,"padding_bottom":30}},"text_QRQENm":{"type":"text","settings":{"text":"<p>Golf Print Club is more than just a brand—it’s a way of life for golfers who embrace the grind and strive for greatness every day. This movement is about building something that lasts—something that motivates the next generation and makes the sport of golf more exciting and accessible for everyone.<\/p>","text_size":4,"text_style":"font-body","padding_bottom":30}},"text_mqe64H":{"type":"text","settings":{"text":"<p>This isn’t just my story—it’s ours. Together, we can grow the sport, inspire each other, and create a brand that stands the test of time. Whether you’re golf for a new PR, just starting your journey, or grinding every day, you’re part of this community.<\/p>","text_size":4,"text_style":"font-body","padding_bottom":16}},"buttons_9mwkCM":{"type":"buttons","settings":{"button_text":"Shop now","button_url":"\/","button_type":"btn--primary","button_size":"","button_style":"btn--solid","show_arrow":false,"padding_bottom":16}}},"block_order":["heading_6jTFW3","text_QRQENm","text_mqe64H","buttons_9mwkCM"],"settings":{"width":"wrapper","align_text":"text-center","overlay_opacity":0,"overlay_color":"#000000","show_overlay_text":false,"bg_color":"","color":"","padding_top":30,"padding_bottom":30}}},"order":["section_rich_text_VG3Rmx","main","section_double_JCtaa3","section_video_AEAXk8","section_rich_text_columns_3UfeVL","section_rich_text_4FUqMw","section_rich_text_L8abcX","section_slideshow_x4LbnR","section_rich_text_L4gB9H","sec