    "section_description": {
      "type": "section-custom-code",
      "custom_css": [
        "p {font-size: 14px; line-height: 1.7; color: #555;}"
      ],
      "name": "Collection Description",
      "settings": {
        "code": "<p id=\"collection-desc\" class=\"desc1\">\n{{ collection.description }}</p>\n\n<script>\n(function () {\n  const BASELINE = 100;\n  function truncateWordSafe(s, max) {\n    s = (s || '').replace(/\\s+/g, ' ').trim();\n    if (s.length <= max) return s;\n    let cut = s.slice(0, max);\n    const i = cut.lastIndexOf(' ');\n    if (i > 0) cut = cut.slice(0, i);\n    return cut;\n  }\n  const escapeHTML = (s) => { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; };\n  function collectParagraphs(anchor) {\n    if (!anchor) return [];\n    let inside = anchor.querySelectorAll && anchor.querySelectorAll('p');\n    if (inside && inside.length) return Array.from(inside);\n    if (anchor.tagName === 'P') {\n      const ps = [anchor]; let n = anchor.nextElementSibling;\n      while (n && n.tagName === 'P') { ps.push(n); n = n.nextElementSibling; }\n      return ps;\n    }\n    if (anchor.textContent && anchor.textContent.trim().length) return [anchor];\n    return [];\n  }\n  function applyInlineEllipsis(anchor) {\n    if (!anchor || anchor.dataset.rcpDone === '1') return;\n    const ps = collectParagraphs(anchor).filter(p => (p.textContent || '').trim().length);\n    if (!ps.length) return;\n    const first = ps[0], rest = ps.slice(1);\n    const fullFirstHTML = first.innerHTML;\n    const firstText = first.textContent.replace(/\\s+/g, ' ').trim();\n    let shortHTML;\n    if (rest.length >= 1) {\n      if (firstText.length > BASELINE) {\n        shortHTML = `${escapeHTML(truncateWordSafe(firstText, BASELINE))}&hellip; `;\n      } else {\n        shortHTML = `${fullFirstHTML} &hellip; `;\n      }\n    } else {\n      if (firstText.length > BASELINE) {\n        shortHTML = `${escapeHTML(truncateWordSafe(firstText, BASELINE))}&hellip; `;\n      } else {\n        anchor.dataset.rcpDone = '1'; return;\n      }\n    }\n    rest.forEach(p => p.classList.add('rcp-hidden'));\n    first.dataset.fullHtml = fullFirstHTML;\n    first.innerHTML = `${shortHTML}<button type=\"button\" class=\"rcp-toggle\">Read more</button>`;\n    first.querySelector('.rcp-toggle').addEventListener('click', () => {\n      first.innerHTML = first.dataset.fullHtml;\n      rest.forEach(p => p.classList.remove('rcp-hidden'));\n    });\n    anchor.dataset.rcpDone = '1';\n  }\n  function init() {\n    const anchor = document.getElementById('collection-desc');\n    if (anchor) { applyInlineEllipsis(anchor); return; }\n    const main = document.querySelector('main') || document;\n    const firstP = main.querySelector('p');\n    if (firstP) applyInlineEllipsis(firstP);\n  }\n  if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', init); } else { init(); }\n})();\n</script>\n<style>\n  .rcp-toggle {\n    background: #2E7D32; border: 0; padding: 6px 16px; margin-left: 10px;\n    border-radius: 0; cursor: pointer; color: white;\n    font-family: 'Montserrat', var(--BTN-FONT-STACK); font-weight: 700;\n    text-transform: uppercase; font-size: 11px;\n    letter-spacing: 0.06em;\n    transition: background 0.2s ease;\n  }\n  .rcp-toggle:hover { background: #0056b3; }\n  .rcp-hidden { display: none !important; }\n</style>",
