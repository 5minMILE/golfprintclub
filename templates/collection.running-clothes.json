      "settings": {
        "code": "<div class=\"b2g1-box\" aria-labelledby=\"b2g1-heading\">\n  <h2 id=\"b2g1-heading\" class=\"b2g1-heading\">Buy Any 2 Shorts, Get 1 Free</h2>\n  <div class=\"b2g1-grid\">\n    <div class=\"b2g1-item\">\n      <a href=\"https://golfprintclub.net/collections/golf-posters\">\n        <video class=\"b2g1-video\" muted loop playsinline preload=\"auto\">\n          <source src=\"https://cdn.shopify.com/videos/c/o/v/28789f00563443d5ae48b95d2cfc40be.mp4\" type=\"video/mp4\">\n        </video>\n      </a>\n    </div>\n    <div class=\"b2g1-item hide-mobile\">\n      <a href=\"https://golfprintclub.net/collections/golf-posters\">\n        <video class=\"b2g1-video\" muted loop playsinline preload=\"auto\">\n          <source src=\"https://cdn.shopify.com/videos/c/o/v/95dfe6afd0674f9d9e5e26ff69151e20.mp4\" type=\"video/mp4\">\n        </video>\n      </a>\n    </div>\n    <div class=\"b2g1-item hide-mobile\">\n      <a href=\"https://golfprintclub.net/collections/golf-posters\">\n        <video class=\"b2g1-video\" muted loop playsinline preload=\"auto\">\n          <source src=\"https://cdn.shopify.com/videos/c/o/v/8d96fb84c17a475582411d22377af2e0.mp4\" type=\"video/mp4\">\n        </video>\n      </a>\n    </div>\n  </div>\n  <p class=\"b2g1-sub\">This offer is excluded from other discounts. Discount applies automatically in cart.</p>\n</div>\n<style>\n  .b2g1-box { border: 2px solid #2E7D32; padding: 24px; border-radius: 0; margin-top: 20px; background: #fff; }\n  .b2g1-heading {\n    font-weight: 800; font-size: 22px; margin: 0 0 12px;\n    letter-spacing: 0.04em; text-align: left; text-transform: uppercase;\n    font-family: 'Montserrat', var(--BTN-FONT-STACK);\n    color: #2E7D32;\n  }\n  .b2g1-sub { margin: 16px 0 0; font-size: 12px; color: #888; text-align: center; text-transform: uppercase; letter-spacing: 0.03em; font-family: 'Montserrat', var(--BTN-FONT-STACK); }\n  .b2g1-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin: auto; width: 1300px; }\n  .b2g1-item { aspect-ratio: 4/5; border-radius: 0; overflow: hidden; position: relative; }\n  .b2g1-item a { display: block; width: 100%; height: 100%; }\n  .b2g1-video { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .3s ease; pointer-events: none; }\n  .b2g1-item:hover .b2g1-video { transform: scale(1.03); }\n  @media (max-width: 768px) { .b2g1-box { margin: 10px; padding: 16px; } .b2g1-grid { grid-template-columns: repeat(2, 1fr); width: 100%; } }\n  @media (max-width: 520px) { .b2g1-grid { grid-template-columns: 1fr; width: 100%; } .hide-mobile { display: none !important; } }\n</style>\n<script>\n  document.addEventListener(\"DOMContentLoaded\", () => {\n    const videos = document.querySelectorAll(\".b2g1-video\");\n    let loaded = 0;\n    videos.forEach(video => {\n      video.addEventListener(\"canplaythrough\", () => {\n        loaded++;\n        if (loaded === videos.length) { videos.forEach(v => { v.currentTime = 0; v.play(); }); }\n      });\n    });\n  });\n</script>",
