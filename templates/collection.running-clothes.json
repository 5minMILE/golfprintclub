      "settings": {
        "code": "<style>\n/* ===== Wireframe Bold — Global CSS ===== */\n/* Typography: Montserrat, uppercase, bold */\n/* Accent: #2E7D32 */\n\n/* ===== Hero Typography ===== */\n.hero__content h1 {\n  font-size: 42px;\n  font-weight: 900;\n  font-family: 'Montserrat', var(--BTN-FONT-STACK);\n  color: #fff;\n  padding: 0;\n  text-transform: uppercase;\n  letter-spacing: 0.04em;\n}\n.hero__content p {\n  font-size: 14px;\n  font-weight: 600;\n  font-family: 'Montserrat', var(--BTN-FONT-STACK);\n  color: rgba(255, 255, 255, 0.9);\n  padding: 0;\n  text-transform: uppercase;\n  letter-spacing: 0.04em;\n  line-height: 1.6;\n}\n\n/* ===== Desktop Layout (763px–3000px) ===== */\n@media (min-width: 763px) and (max-width: 3000px) {\n  .hero__content p { width: 30vw; }\n  .wrapper--full,\n  .hero__content,\n  .wrapper--full-padded,\n  .grid-outer,\n  .grid__items-holder {\n    max-width: 90vw;\n    min-width: 90vw;\n    margin: 0 auto;\n  }\n  .index-hero .wrapper--full,\n  .hero__video {\n    max-width: 100vw !important;\n    min-width: 100vw !important;\n  }\n  .index-hero { padding-top: 0; }\n  .grid-outer { padding: 0; }\n  .frame__item { height: 90vh !important; }\n}\n\n/* ===== Ultra-wide (3000px+) ===== */\n@media (min-width: 3000px) {\n  .index-hero { padding-top: 0; }\n  .wrapper--full,\n  .hero__content,\n  .wrapper--full-padded,\n  .grid-outer,\n  .index-hero .wrapper--full,\n  .hero__video {\n    max-width: 3000px !important;\n    min-width: 3000px !important;\n  }\n  .collection__products {\n    padding-left: calc((100vw - 3000px) / 2);\n  }\n}\n\n/* ===== Collection & Grid Shared ===== */\n.collection__products,\n.grid__items-holder {\n  padding-left: 5vw;\n  padding-right: 5vw;\n}\n.wrapper--full-padded { padding: 0; }\n.collection__products .grid-outer { padding: 0; }\n.grid { gap: 16px; }\n.collection__products .product-item__info { padding-left: 0; }\n\n/* ===== Product Card Typography ===== */\n.product-item--centered .product-information { text-align: left; }\n.product-information p { padding-top: 4px; }\n.product-information p,\n.product-information span {\n  text-transform: uppercase !important;\n  font-family: 'Montserrat', var(--BTN-FONT-STACK);\n  font-size: 13px;\n  line-height: 1.4;\n  margin: 0;\n  font-weight: 600;\n  color: #333;\n  letter-spacing: 0.03em;\n}\n.product-information p a,\n.product-information p a:visited {\n  font-weight: 700;\n  color: #1a1a1a;\n  text-decoration: none;\n  text-transform: uppercase;\n}\n.sub {\n  font-size: 11px !important;\n  text-transform: uppercase !important;\n  color: #888;\n  padding-bottom: 2px;\n  letter-spacing: 0.03em;\n}\n.custom-rating .star {\n  margin-top: -3px;\n  font-size: 13px !important;\n  margin-right: 1px !important;\n  color: #2E7D32;\n}\n\n/* ===== Product Card — Clean ===== */\n.product-information {\n  border: none;\n  padding: 8px 0;\n}\n.product-item__bg {\n  border: none;\n}\n\n/* ===== Quick-Add Button — Blue ===== */\n.quick-add__button {\n  color: #fff;\n  background: #2E7D32;\n  border: none;\n  border-top: none;\n  font-size: 12px;\n  font-weight: 700;\n  letter-spacing: 0.06em;\n  text-transform: uppercase;\n  font-family: 'Montserrat', var(--BTN-FONT-STACK);\n  transition: background 0.2s ease;\n}\n.quick-add__button:hover {\n  background: #0056b3;\n}\n\n/* ===== Sold Out State — Bold ===== */\n.product-item--sold-out .product-item__bg,\n.product-item--sold-out .product-item__bg__inner img,\n.product-item--sold-out .product-item__bg img {\n  filter: grayscale(50%);\n  opacity: 0.85;\n}\n.product-item__sold-out-overlay {\n  position: absolute;\n  top: 10px;\n  left: 10px;\n  right: auto;\n  bottom: auto;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  pointer-events: none;\n  z-index: 2;\n  font-family: 'Montserrat', var(--BTN-FONT-STACK);\n  font-size: 11px;\n  font-weight: 800;\n  letter-spacing: 0.06em;\n  text-transform: uppercase;\n  background-color: #000;\n  border: none;\n  border-radius: 0;\n  padding: 6px 12px;\n  width: auto;\n  height: auto;\n  inset: auto;\n}\n.product-item__sold-out-overlay span {\n  color: #ffffff;\n  font-weight: 800;\n  font-size: 11px;\n  text-transform: uppercase;\n}\n\n/* ===== Swatch — Blue Checked ===== */\n.radio__fieldset .radio__button input:checked~label {\n  border-color: #2E7D32;\n  background: #2E7D32;\n  color: white;\n}\n.radio__fieldset .radio__button input:hover~label {\n  border-color: #2E7D32;\n  background: transparent;\n  color: inherit;\n}\n.swatch__button .swatch__label {\n  width: 18px !important;\n  height: 18px !important;\n  border-radius: 50%;\n  border: 1px solid #ddd;\n  transition: border-color 0.2s ease;\n}\n.swatch__button .swatch__label:hover {\n  border-color: #2E7D32;\n}\n\n/* ===== Quick-Add Drawer ===== */\n.product-quick-add__content {\n  position: absolute;\n  bottom: 0;\n  z-index: 2;\n  overflow-x: hidden;\n  overflow-y: auto;\n  min-width: 30vw !important;\n  width: 600px;\n  max-width: none !important;\n  max-height: 100%;\n  background-color: #fff;\n  border-left: 1px solid #e5e5e5;\n}\ndialog {\n  background: rgba(0, 0, 0, 0.4);\n  backdrop-filter: blur(8px);\n  -webkit-backdrop-filter: blur(8px);\n}\n.product-quick-add__form__inner { flex: 0 1 100%; }\n.radio__fieldset .radio__button label { padding: 10px auto; width: 100%; }\n.radio__button { padding: 0; width: calc(33% - 3px); }\n.radio__fieldset { gap: 0; }\n.radio__buttons { gap: 5px; }\n.drawer__close { --icon-size: 18px; padding: 4px; }\n.drawer__close .icon { stroke-width: 2; }\n.product-quick-add__close { background: #2E7D32; }\n.product__submit__item .btn {\n  width: 100%;\n  border: 1px solid #2E7D32;\n  color: #fff;\n  background: #2E7D32;\n  font-family: 'Montserrat', var(--BTN-FONT-STACK);\n  font-weight: 700;\n  text-transform: uppercase;\n  letter-spacing: 0.06em;\n}\n.product__submit__item .btn:hover { background: #0056b3; border-color: #0056b3; }\n.product-quick-add__form h1 {\n  font-weight: 700;\n  font-size: 18px;\n  font-family: 'Montserrat', var(--BTN-FONT-STACK);\n  text-align: center;\n  text-transform: uppercase;\n  letter-spacing: 0.04em;\n}\n.product__price__wrap {\n  font-weight: 600;\n  font-size: 16px;\n  font-family: 'Montserrat', var(--BTN-FONT-STACK);\n  text-align: center;\n  justify-content: center;\n  text-transform: uppercase;\n}\n.product__price__wrap .hidden { display: none; }\n.product__selectors .selector-wrapper {\n  display: flex !important;\n  flex-direction: column !important;\n  align-items: center !important;\n  width: 100%;\n}\n.product__selectors .radio__fieldset--swatches .radio__buttons[data-variant-buttons] {\n  display: flex !important;\n  justify-content: center !important;\n  width: 100%;\n}\n.product__selectors legend,\n.product__selectors .radio__legend { text-align: center !important; width: 100%; }\nshopify-payment-terms, .shop-pay-terms { display: none !important; }\n.selector-wrapper fieldset { width: 100%; }\n.product__selectors .radio__fieldset { padding: 0; }\n.radio__fieldset--swatches .swatch__button { padding: 0; }\n.product-quick-add__description { font-size: 13px; color: #555; }\n.product-quick-add__inner { display: grid; grid-template-rows: 73% 27%; height: 100%; }\n.product-quick-add__images .product__slide { height: 75vh; }\n.block-padding { margin-top: var(--block-padding-top, 0px); margin-bottom: var(--block-padding-bottom, 5px); }\n.radio__fieldset--swatches .radio__legend__label--text { display: none; }\n.radio__legend__label--text {\n  font-family: 'Montserrat', var(--BTN-FONT-STACK);\n  font-weight: 600;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  font-size: 12px;\n  color: #555;\n  padding-bottom: 16px;\n  text-transform: uppercase;\n  letter-spacing: 0.03em;\n}\n\n/* ===== Tab Heading — Bold Uppercase ===== */\n.tab-link h2 {\n  font-size: 13px;\n  font-weight: 700;\n  font-family: 'Montserrat', var(--BTN-FONT-STACK);\n  color: #333;\n  letter-spacing: 0.06em;\n  text-transform: uppercase;\n}\n\n/* ===== Section Headings — Uppercase Bold ===== */\n.section-rich-text h2,\n.rich-text__heading {\n  font-family: 'Montserrat', var(--BTN-FONT-STACK) !important;\n  font-weight: 800 !important;\n  text-transform: uppercase !important;\n  letter-spacing: 0.04em !important;\n}\n\n/* ===== Filters & Sort ===== */\n.collection__sidebar,\n.collection__sort {\n  border: none;\n}\n.collection__filters__toggle {\n  border: 1px solid #2E7D32;\n  font-weight: 700;\n  text-transform: uppercase;\n  font-size: 12px;\n  letter-spacing: 0.06em;\n  font-family: 'Montserrat', var(--BTN-FONT-STACK);\n  color: #2E7D32;\n}\n.collection__filters__toggle:hover {\n  background: #2E7D32;\n  color: #fff;\n}\n\n/* ===== Mobile ===== */\n@media (max-width: 763px) {\n  .grid-item { margin-right: 0 !important; max-width: none; }\n  .grid-outer { padding: 0 10px; }\n  .hero__content .btn { padding-bottom: 10px; }\n  .quick-add__holder { display: none; }\n  .hero__content h1 { font-size: 28px; padding: 0 10px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.04em; }\n  .grid--mobile-slider { padding-left: 16px; }\n  .grid--mobile-slider .grid-item { margin-right: 0; }\n  .grid { gap: 10px; }\n}\n@media (min-width: 763px) {\n  .grid-item { max-width: none; margin-right: 0; }\n}\n</style>\n\n<link href=\"https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap\" rel=\"stylesheet\">\n\n<script>\n  document.addEventListener(\"DOMContentLoaded\", function () {\n    const colorFieldset = document.querySelector(\".radio__fieldset--swatches\");\n    if (!colorFieldset) return;\n    const swatches = colorFieldset.querySelectorAll(\"radio-swatch\");\n    if (swatches.length <= 1) {\n      colorFieldset.style.display = \"none\";\n    }\n  });\n</script>",
