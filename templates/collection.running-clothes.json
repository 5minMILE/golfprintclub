      "name": "Prior Drops",
      "settings": {
        "code": "<style>\n  .rcp-drops-grid { display: grid; gap: 12px; grid-template-columns: repeat(3, 1fr); max-width: 3000px; margin: 0 auto; padding: 0; }\n  .rcp-drop-card { position: relative; display: block; border-radius: 0; overflow: hidden; aspect-ratio: 4/5; background: #f5f5f5; border: none; flex: 0 0 auto; scroll-snap-align: start; }\n  .rcp-drop-media { width: 100%; height: 100%; object-fit: cover; display: block; filter: saturate(1.01); transform: scale(1); transition: transform 6s cubic-bezier(0.215, 0.61, 0.355, 1); }\n  @media (hover: hover) { .rcp-drop-card:hover .rcp-drop-media { transform: scale(1.08); } }\n  .rcp-drop-card::after { content: \"\"; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0) 55%, rgba(0,0,0,.6) 100%); pointer-events: none; }\n  .rcp-drop-meta { position: absolute; left: 14px; right: 14px; bottom: 14px; z-index: 2; color: #fff; display: flex; flex-direction: column; gap: 4px; }\n  .rcp-drop-eyebrow { font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; opacity: .85; font-weight: 700; font-family: 'Montserrat', var(--BTN-FONT-STACK); }\n  .rcp-drop-title { font-family: 'Montserrat', var(--BTN-FONT-STACK); font-weight: 800; margin: 0; font-size: 20px; line-height: 1.2; text-transform: uppercase; letter-spacing: 0.04em; }\n  .rcp-drop-row { display: flex; gap: 8px; align-items: center; opacity: .9; font-size: 12px; line-height: 1.35; text-transform: uppercase; letter-spacing: 0.03em; font-family: 'Montserrat', var(--BTN-FONT-STACK); }\n  .rcp-dot { width: 3px; height: 3px; border-radius: 50%; background: #ffffffcc; display: inline-block; }\n  @media (max-width: 900px) {\n    .rcp-drops-grid { display: flex; overflow-x: auto; gap: 10px; padding: 0 10px 10px; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; scroll-padding: 10px; }\n    .rcp-drops-grid::-webkit-scrollbar { display: none; }\n    .rcp-drop-card { min-width: 80%; max-width: 85%; aspect-ratio: 3/4; }\n    .rcp-drop-card:first-child { margin-left: 10px; }\n    .rcp-drop-card:last-child { margin-right: 10px; }\n  }\n</style>\n<div class=\"rcp-drops-wrap\">\n  <div class=\"rcp-drops-grid\">\n    <a class=\"rcp-drop-card\" href=\"https://golfprintclub.net/collections/storm\">\n      <img class=\"rcp-drop-media\" src=\"https://cdn.shopify.com/s/files/1/0772/2041/3736/files/storm_1.png?v=1755797660\" alt=\"Storm Drop\" loading=\"lazy\">\n      <div class=\"rcp-drop-meta\">\n        <span class=\"rcp-drop-eyebrow\">Drop</span>\n        <h3 class=\"rcp-drop-title\">Storm</h3>\n        <div class=\"rcp-drop-row\"><span>Release Date</span><span class=\"rcp-dot\"></span><span>Sep 5, 2025</span></div>\n      </div>\n    </a>\n    <a class=\"rcp-drop-card\" href=\"https://golfprintclub.net/collections/2-worlds\">\n      <img class=\"rcp-drop-media\" src=\"https://cdn.shopify.com/s/files/1/0772/2041/3736/files/27_6b2888e8-8b82-48d0-a107-b78aedeb775b.png?v=1745517484\" alt=\"Two Worlds Drop\" loading=\"lazy\">\n      <div class=\"rcp-drop-meta\">\n        <span class=\"rcp-drop-eyebrow\">Drop</span>\n        <h3 class=\"rcp-drop-title\">Two Worlds</h3>\n        <div class=\"rcp-drop-row\"><span>Release Date</span><span class=\"rcp-dot\"></span><span>Apr 25, 2025</span></div>\n      </div>\n    </a>\n    <a class=\"rcp-drop-card\" href=\"https://golfprintclub.net/collections/fire-ice\">\n      <img class=\"rcp-drop-media\" src=\"https://cdn.shopify.com/s/files/1/0772/2041/3736/files/IMG_4110_1.jpg?v=1739814062\" alt=\"Fire and Ice Drop\" loading=\"lazy\">\n      <div class=\"rcp-drop-meta\">\n        <span class=\"rcp-drop-eyebrow\">Drop</span>\n        <h3 class=\"rcp-drop-title\">Fire & Ice</h3>\n        <div class=\"rcp-drop-row\"><span>Release Date</span><span class=\"rcp-dot\"></span><span>Feb 28, 2025</span></div>\n      </div>\n    </a>\n  </div>\n</div>",
