{"order":["section_custom_code_EjCPpg","section_custom_code_rtQfep","main","section_custom_code_7eYKT4","section_custom_code_YYBwJM","hero","subcollections"],"sections":{"section_custom_code_EjCPpg":{"type":"section-custom-code","name":"Hero Section","settings":{"code":"<section class=\"rc-hero hero__content--transparent\">\n  <div class=\"rc-hero__media  hero__content--transparent\">\n    <img\n      src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0772\/2041\/3736\/files\/website3.png?v=1764191021\"\n      alt=\"Golf Print Club collection hero\"\n      loading=\"eager\"\n    \/>\n    <div class=\"rc-hero__overlay\"><\/div>\n  <\/div>\n\n  <div class=\"rc-hero__content\">\n    <div class=\"rc-hero__sub\">MENS<\/div>\n    <h1 class=\"rc-hero__title\">HALF TIGHTS<\/h1>\n    <div class=\"rc-hero__count\">12 Products Available<\/div>\n\n    <p class=\"rc-hero__desc\">\n      Our ribbed golf posters are built for golfers who care about performance, not distractions.\n      Designed to feel locked-in without feeling restrictive, they move with you through workouts,\n      long runs, and race-day efforts. Lightweight, breathable, and purpose-built so you can focus\n      on the work — not your gear.\n    <\/p>\n\n    <div class=\"rc-chips\">\n      <a class=\"rc-chip\" href=\"\/collections\/half-tights\">Half tights<\/a>\n      <a class=\"rc-chip\" href=\"\/collections\/split-shorts\">Split shorts<\/a>\n      <a class=\"rc-chip\" href=\"\/collections\/golf posters\">Golf Posters<\/a>\n    <\/div>\n\n    <div class=\"rc-chips\">\n      <a class=\"rc-chip\" href=\"#details\">Details<\/a>\n      <a class=\"rc-chip\" href=\"\/pages\/size-guide\">Fit<\/a>\n      <a class=\"rc-chip\" href=\"\/pages\/materials\">Fabric<\/a>\n      <a class=\"rc-chip\" href=\"\/pages\/shipping\">Shipping<\/a>\n      <a class=\"rc-chip\" href=\"#reviews\">Reviews<\/a>\n    <\/div>\n  <\/div>\n<\/section>\n\n<style>\n\/* SECTION WRAPPER *\/\n.rc-hero{\n  position:relative;\n  max-width:3000px;\n  margin:0 auto;\n  min-height:70vh;\n  display:flex;\n  align-items:flex-end;\n  overflow:hidden;\n}\n\n\/* IMAGE *\/\n.rc-hero__media{\n  position:absolute;\n  inset:0;\n  max-width:3000px;\n  margin:0 auto;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    min-height: inherit;\n}\n\n.rc-hero__media img{\n  width:100%;\n  height:100%;\n  object-fit:cover;\n  display:block;\noverflow: hidden;\n}\n\n\/* BLACK OVERLAY *\/\n.rc-hero__overlay{\n  position:absolute;\n  inset:0;\n  background:rgba(0,0,0,.5);\n}\n\n\/* CONTENT OVERLAY *\/\n.rc-hero__content{\n  position:relative;\n  z-index:2;\n  width:100%;\n  padding:40px;\n  color:#fff;\n  text-align:left;\n}\n\n\/* DESKTOP CONTENT WIDTH *\/\n@media (min-width:1200px){\n  .rc-hero__content{\n    max-width:800px;\n  }\n}\n\n@media (max-width:1200px){\n  \t.rc-hero__content{\n\t\ttext-align:left;\n\t\tpadding:16px;\n\t}\n}\n\n\/* TYPOGRAPHY *\/\n.rc-hero__sub{\n  font-size:12px;\n  letter-spacing:.08em;\n  text-transform:uppercase;\n  opacity:.85;\n  margin-bottom:6px;\n  font-family: var(--BTN-FONT-STACK);\n}\n\n.rc-hero__title{\n  margin:0;\n  font-size:clamp(28px,4vw,40px);\n  line-height:1.05;\n  text-transform:uppercase;\n  font-family: var(--BTN-FONT-STACK);\n}\n\n.rc-hero__count{\n  margin-top:6px;\n  font-size:12px;\n  opacity:.8;\n  font-family: var(--BTN-FONT-STACK);\n}\n\n.rc-hero__desc{\n  margin-top:14px;\n  font-size:14px;\n  line-height:1.6;\n   font-family: var(--BTN-FONT-STACK);\n}\n\n\/* CHIPS *\/\n.rc-chips{\n  display:flex;\n  flex-wrap:wrap;\n  gap:10px;\n  margin-top:14px;\n}\n\n.rc-chip{\n  padding:8px 10px;\n  border-radius: 999px;\n  border:1px solid rgba(255,255,255,.35);\n  background:rgba(255,255,255,.06);\n  color:#fff;\n  text-decoration:none;\n  font-size:12px;\n  line-height:1;\n  font-family: var(--BTN-FONT-STACK);\nfont-weight:600;\n}\n\n.rc-chip:hover{\n  border-color:#fff;\n  background:#fff;\ncolor:black;\nfont-weight:600;\n}\n\n\/* MOBILE \/ <1200px *\/\n@media (max-width:1199px){\n  .rc-hero{\n    min-height:auto;\n  }\n\n  .rc-hero__media,\n  .rc-hero__overlay{\n    display:none;\n  }\n\n  .rc-hero__content{\n    color:inherit;\n    padding-top:16px;\n  }\n\n  .rc-chip{\n    background:#fff;\n    color:inherit;\n    border-color:rgba(0,0,0,.2);\n  }\n}\n@media (max-width:763px){\n\t.free-shipping-mobile {\n\t\tmargin-top:0 !important;\n\t}\n}\n<\/style>","width":"wrapper--full","bg_color":"","color":"","padding_top":0,"padding_bottom":0}},"section_custom_code_rtQfep":{"type":"section-custom-code","name":"Category","settings":{"code":"<style>\n  .rc-cat {\n    font-family: var(--BTN-FONT-STYLE);\n    max-width: 3040px;\n    margin: 0 auto;\n    padding: 10px 20px;\n    padding-bottom: 0;\n  }\n  .rc-cat.is-hidden { display: none !important; }\n\n  .rc-cat__header{ display:flex; align-items:center; justify-content:space-between; margin:0 0 10px; }\n  .rc-cat__heading{ margin:0; font-family:var(--BTN-FONT-STACK); font-size:16px; font-weight:800; text-transform:uppercase; line-height:1; }\n\n  .rc-cat__head{ display:flex; gap:10px; margin:0; }\n  .rc-cat__head.is-hidden{ display:none !important; }\n\n  .rc-cat__btn{ width:36px; height:36px; border:1px solid #000; background:#fff; cursor:pointer; display:grid; place-items:center; padding:0; transition:opacity .2s ease; }\n  .rc-cat__btn.is-disabled{ opacity:.3; pointer-events:none; }\n\n  .rc-cat__viewport{\n    overflow-x:auto; scroll-behavior:smooth; scroll-snap-type:x mandatory;\n    scrollbar-width:none; -ms-overflow-style:none;\n    scroll-padding-left:20px; scroll-padding-right:20px;\n  }\n  .rc-cat__viewport::-webkit-scrollbar{ display:none; }\n  .rc-cat__track{ display:flex; gap:5px; }\n\n  .rc-cat__card{\n    flex:0 0 auto; scroll-snap-align:start;\n    background:transparent; border:1px solid #e5e5e5;\n    text-decoration:none; color:inherit; display:block;\n  }\n  .rc-cat__card:hover{ border:1px solid #000; }\n\n  .rc-cat__img{ width:100%; aspect-ratio:4\/5; object-fit:cover; display:block; background:#eee; }\n  .rc-cat__body{ padding:10px 10px 12px; text-align:left; font-family:var(--BTN-FONT-STACK); font-weight:600; font-size:10px; }\n  .rc-cat__title{ margin:0 0 4px; font-size:16px; font-weight:800; text-transform:uppercase; font-family:var(--BTN-FONT-STACK); }\n  .rc-cat__desc{ margin:0; font-size:12px; line-height:1.35; color:#555; }\n\n  @media (max-width: 762px){\n    .rc-cat{ padding:10px; padding-bottom:0; }\n    .rc-cat__viewport{ scroll-padding-left:10px; scroll-padding-right:10px; }\n    .rc-cat__card{ width: calc((100% - 5px) \/ 1.5); }\n  }\n\n  @media (min-width: 763px){\n    .rc-cat[data-cols=\"3\"] .rc-cat__card{ width: calc((100% - (5px * 2)) \/ 3); }\n    .rc-cat[data-cols=\"4\"] .rc-cat__card{ width: calc((100% - (5px * 3)) \/ 4); }\n    .rc-cat[data-cols=\"5\"] .rc-cat__card{ width: calc((100% - (5px * 4)) \/ 5); }\n  }\n<\/style>\n\n<section class=\"rc-cat\" aria-label=\"Shop by category carousel\" data-rc-cat>\n  <div class=\"rc-cat__header\">\n    <h2 class=\"rc-cat__heading\">Shop by Category<\/h2>\n\n    <div class=\"rc-cat__head\" data-rc-head>\n      <button class=\"rc-cat__btn\" type=\"button\" data-rc-prev aria-label=\"Previous\">\n        <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" aria-hidden=\"true\">\n          <path d=\"M15 6l-6 6 6 6\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" \/>\n        <\/svg>\n      <\/button>\n      <button class=\"rc-cat__btn\" type=\"button\" data-rc-next aria-label=\"Next\">\n        <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" aria-hidden=\"true\">\n          <path d=\"M9 6l6 6-6 6\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" \/>\n        <\/svg>\n      <\/button>\n    <\/div>\n  <\/div>\n\n  <div class=\"rc-cat__viewport\" data-rc-viewport>\n    <div class=\"rc-cat__track\" data-rc-track><\/div>\n  <\/div>\n\n  {%- comment -%}\n  MULTILINE METAFIELD REQUIREMENT:\n  custom.shop_by_category must be ONE JSON array per line, like:\n  [\"img\",\"title\",\"desc\",\"\/optional-link\"]\n  [\"img\",\"title\",\"desc\"]\n  {%- endcomment -%}\n\n  <script type=\"application\/json\" id=\"rc-shop-by-category-data\">\n    {%- assign raw = collection.metafields.custom.shop_by_category.value | default: collection.metafields.custom.shop_by_category | default: '' -%}\n    {%- assign raw = raw | replace: '\\r\\n', '\\n' | replace: '\\r', '\\n' -%}\n    {%- assign lines = raw | split: '\\n' -%}\n    [\n    {%- capture out -%}{%- endcapture -%}\n    {%- assign first = true -%}\n    {%- for line in lines -%}\n      {%- assign l = line | strip -%}\n      {%- if l != '' -%}\n        {%- if first -%}\n          {%- assign first = false -%}\n          {%- capture out -%}{{ out }}{{ l }}{%- endcapture -%}\n        {%- else -%}\n          {%- capture out -%}{{ out }},{{ l }}{%- endcapture -%}\n        {%- endif -%}\n      {%- endif -%}\n    {%- endfor -%}\n    {{ out }}\n    ]\n  <\/script>\n<\/section>\n\n<script>\n(function () {\n  const root = document.querySelector(\"[data-rc-cat]\");\n  if (!root) return;\n\n  const dataEl = root.querySelector(\"#rc-shop-by-category-data\");\n  if (!dataEl) { root.classList.add(\"is-hidden\"); return; }\n\n  let arr;\n  try {\n    arr = JSON.parse((dataEl.textContent || \"\").trim());\n  } catch (e) {\n    console.warn(\"[RC CAT] JSON parse failed. Check metafield formatting. Output was:\", dataEl.textContent);\n    root.classList.add(\"is-hidden\");\n    return;\n  }\n\n  if (!Array.isArray(arr) || !arr.length) { root.classList.add(\"is-hidden\"); return; }\n\n  const cleaned = arr\n    .filter(r => Array.isArray(r) && r.length >= 3)\n    .map(r => ({\n      img: String(r[0] || \"\").trim(),\n      title: String(r[1] || \"\").trim(),\n      desc: String(r[2] || \"\").trim(),\n      href: r.length >= 4 ? String(r[3] || \"#\").trim() : \"#\"\n    }))\n    .filter(x => x.img || x.title || x.desc);\n\n  if (!cleaned.length) { root.classList.add(\"is-hidden\"); return; }\n\n  const head = root.querySelector(\"[data-rc-head]\");\n  const viewport = root.querySelector(\"[data-rc-viewport]\");\n  const track = root.querySelector(\"[data-rc-track]\");\n  const prev = root.querySelector(\"[data-rc-prev]\");\n  const next = root.querySelector(\"[data-rc-next]\");\n\n  track.innerHTML = cleaned.map((x) => {\n    const title = escHtml(x.title);\n    const desc = escHtml(x.desc);\n    const href = escAttr(x.href || \"#\");\n    const img = x.img ? encodeURI(x.img) : \"\";\n    return `\n      <a class=\"rc-cat__card\" href=\"${href}\">\n        ${img ? `<img class=\"rc-cat__img\" src=\"${img}\" alt=\"${title}\" loading=\"lazy\">` : `<div class=\"rc-cat__img\" aria-hidden=\"true\"><\/div>`}\n        <div class=\"rc-cat__body\">\n          ${x.title ? `<h3 class=\"rc-cat__title\">${title}<\/h3>` : ``}\n          ${x.desc ? `<p class=\"rc-cat__desc\">${desc}<\/p>` : ``}\n        <\/div>\n      <\/a>\n    `;\n  }).join(\"\");\n\n  function desktopMaxVisible(){ return window.innerWidth >= 1400 ? 5 : 4; }\n  function computeDesktopCols(total){\n    const maxVis = desktopMaxVisible();\n    if (total <= maxVis) return Math.max(3, total);\n    return maxVis;\n  }\n  function setColsAttr(total){\n    if (window.innerWidth <= 762) { root.removeAttribute(\"data-cols\"); return; }\n    root.setAttribute(\"data-cols\", String(computeDesktopCols(total)));\n  }\n  function shouldShowArrows(total){\n    if (window.innerWidth <= 762) return viewport.scrollWidth > viewport.clientWidth + 2;\n    return total > desktopMaxVisible();\n  }\n  function updateButtonsDisabled(){\n    if (!prev || !next) return;\n    if (head && head.classList.contains(\"is-hidden\")) return;\n    const max = viewport.scrollWidth - viewport.clientWidth;\n    const left = viewport.scrollLeft;\n    prev.classList.toggle(\"is-disabled\", left <= 1);\n    next.classList.toggle(\"is-disabled\", left >= max - 1);\n  }\n  function currentIndex(cards){\n    const x = viewport.scrollLeft;\n    let best = 0, bestDist = Infinity;\n    for (let i=0;i<cards.length;i++){\n      const dist = Math.abs(cards[i].offsetLeft - x);\n      if (dist < bestDist){ bestDist = dist; best = i; }\n    }\n    return best;\n  }\n  function scrollToIndex(i){\n    const cards = Array.from(root.querySelectorAll(\".rc-cat__card\"));\n    if (!cards.length) return;\n    i = Math.max(0, Math.min(i, cards.length - 1));\n    viewport.scrollTo({ left: cards[i].offsetLeft, behavior: \"smooth\" });\n  }\n  function updateLayout(){\n    const total = cleaned.length;\n    setColsAttr(total);\n    requestAnimationFrame(() => {\n      const show = shouldShowArrows(total);\n      if (head) head.classList.toggle(\"is-hidden\", !show);\n      if (!show) viewport.scrollLeft = 0;\n      updateButtonsDisabled();\n    });\n  }\n\n  if (prev && next){\n    prev.addEventListener(\"click\", () => {\n      const cards = Array.from(root.querySelectorAll(\".rc-cat__card\"));\n      scrollToIndex(currentIndex(cards) - 1);\n    });\n    next.addEventListener(\"click\", () => {\n      const cards = Array.from(root.querySelectorAll(\".rc-cat__card\"));\n      scrollToIndex(currentIndex(cards) + 1);\n    });\n  }\n\n  viewport.addEventListener(\"scroll\", updateButtonsDisabled, { passive:true });\n  window.addEventListener(\"resize\", updateLayout);\n\n  updateLayout();\n  window.setTimeout(updateLayout, 80);\n  window.setTimeout(updateLayout, 250);\n\n  function escHtml(str){\n    return String(str || \"\")\n      .replaceAll(\"&\",\"&amp;\")\n      .replaceAll(\"<\",\"&lt;\")\n      .replaceAll(\">\",\"&gt;\")\n      .replaceAll('\"',\"&quot;\")\n      .replaceAll(\"'\",\"&#39;\");\n  }\n  function escAttr(str){ return escHtml(str).replaceAll(\"`\",\"&#96;\"); }\n})();\n<\/script>","width":"wrapper--full","bg_color":"","color":"","padding_top":0,"padding_bottom":0}},"main":{"type":"collection","custom_css":["@media only screen and (max-width: 763px) {.collection__products {padding-left: 5px; padding-right: 5px; } .quick-add__button {display: none; }}","@media only screen and (min-width: 763px) {.collection__products .grid {width: 100%; max-width: 3000px; margin: 0; }}",".product-item__image,.product-information {border: 1px solid #ddd;}",".product-item__image {border-bottom: 0px solid transparent;}",".quick-add__button {border-top: 1px solid #ddd;}"],"settings":{"enable_sort":true,"enable_filters":true,"filter_layout":"inline-open","collection_linklist":"","grid":3,"grid_mobile":"2","products_per_page":24,"border_color":"#fbfbfb","padding_top":0,"padding_bottom":20}},"section_custom_code_7eYKT4":{"type":"section-custom-code","name":"FAQ","settings":{"code":"<div class=\"product-accordion\">\n\n  <div class=\"accordion-item\">\n    <button class=\"accordion-toggle\">Half tights vs. golf posters — which should I pick?<\/button>\n    <div class=\"accordion-content\">\n      <div class=\"delivery-returns\">\n        <p><strong>Half tights<\/strong> give light compression, zero flap, and pocket security—great for speed work and tournament day. <strong>Split shorts<\/strong> maximize airflow and freedom of movement, ideal for hot weather and long runs. If you train in heat or want the breeziest feel, go splits; if you want support and a locked-in fit, go golf posters.<\/p>\n      <\/div>\n    <\/div>\n  <\/div>\n\n  <div class=\"accordion-item\">\n    <button class=\"accordion-toggle\">How should a golf singlet fit?<\/button>\n    <div class=\"accordion-content\">\n      <div class=\"delivery-returns\">\n        <p>Skimming, not tight. Armholes shouldn’t rub; the hem should sit near the hips so it won’t bunch. For racing, choose true-to-measurement; for relaxed training, consider one size up.<\/p>\n      <\/div>\n    <\/div>\n  <\/div>\n\n  <div class=\"accordion-item\">\n    <button class=\"accordion-toggle\">What inseam should I choose for shorts?<\/button>\n    <div class=\"accordion-content\">\n      <div class=\"delivery-returns\">\n        <p><strong>2–3&quot;<\/strong> = race feel &amp; max mobility. <strong>4–5&quot;<\/strong> = everyday training balance. <strong>6–7&quot;<\/strong> = more coverage\/cooler weather. If you’re between lengths, pick the shorter for range of motion, longer for modesty\/versatility.<\/p>\n      <\/div>\n    <\/div>\n  <\/div>\n\n  <div class=\"accordion-item\">\n    <button class=\"accordion-toggle\">Best fabrics for performance shirts &amp; tights?<\/button>\n    <div class=\"accordion-content\">\n      <div class=\"delivery-returns\">\n        <p>Look for lightweight, moisture-wicking poly\/nylon blends (~90–120gsm) with mesh zones for ventilation. For tights, add elastane for 4-way stretch and recovery. Avoid heavy cotton for anything beyond easy jogs—it traps moisture and chafes.<\/p>\n      <\/div>\n    <\/div>\n  <\/div>\n\n  <div class=\"accordion-item\">\n    <button class=\"accordion-toggle\">Sizing &amp; returns for golf wall art<\/button>\n    <div class=\"accordion-content\">\n      <div class=\"delivery-returns\">\n        <p>Use waist\/hip for bottoms and chest for tops. If you’re between sizes: choose your measured size for a compressive half-tight fit; consider sizing up for relaxed shorts\/shirts. Golf gear ships within <strong>5 business days<\/strong> and typically arrives in <strong>3–4 business days<\/strong> after shipping. Returns accepted within <strong>30 days<\/strong> if items are <strong>unworn with original tags\/packaging<\/strong>.<\/p>\n      <\/div>\n    <\/div>\n  <\/div>\n\n<\/div>\n\n\n\n<style>\n\n.product-description h2, .product-description h3 {\n\ttext-transform: uppercase;\n\tfont-size: 20px;\n}\n  .product-accordion {\n    border-top: 1px solid #ddd;\n    font-family: inherit;\n  }\n  .accordion-item {\n    border-bottom: 0px solid #000;\n  }\n  .accordion-toggle {\n    width: 100%;\n    background: none;\n    border: none;\n    padding: 18px 0;\n    font-weight: 500;\n    text-align: left;\n    font-size: 14px;\n    text-transform: uppercase;\n    position: relative;\n    cursor: pointer;\nborder-bottom: 1px solid #ddd;\n  }\n  .accordion-toggle::after {\n    content: '›';\n    position: absolute;\n    right: 0;\n    font-weight: normal; \/* not bold *\/\n    font-size: 16px;\n    transition: transform 0.2s ease;\n  }\n  .accordion-toggle.active::after {\n    transform: rotate(90deg);\n  }\n  .accordion-content {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.3s ease;\n    font-size: 14px;\n    line-height: 1.5;\n    color: #333;\n    padding: 0;\n  }\n  .accordion-content.open {\n    padding: 0; \/* no extra padding *\/\n  }\n\n@media (max-width: 763px) {\n  .product-accordion {\n    padding: 0 00px;\n  }\n.product-accordion{\n\t\tmargin-top:10px;\n}\n}\n@media (min-width: 763px) {\n\t.product-accordion{\n\t\tmargin-top:20px;\n\t}\n}\n\n<\/style>\n\n<script>\n  document.addEventListener(\"DOMContentLoaded\", function () {\n    const toggles = document.querySelectorAll(\".accordion-toggle\");\n\n    toggles.forEach(toggle => {\n      toggle.addEventListener(\"click\", () => {\n        const content = toggle.nextElementSibling;\n        const isActive = toggle.classList.contains(\"active\");\n\n        \/\/ Collapse all\n        document.querySelectorAll(\".accordion-toggle\").forEach(t => t.classList.remove(\"active\"));\n        document.querySelectorAll(\".accordion-content\").forEach(c => {\n          c.classList.remove(\"open\");\n          c.style.maxHeight = null;\n        });\n\n        if (!isActive) {\n          toggle.classList.add(\"active\");\n          content.classList.add(\"open\");\n          content.style.maxHeight = content.scrollHeight + \"px\";\n        }\n      });\n    });\n  });\n<\/script>","width":"wrapper--full-padded","bg_color":"","color":"","padding_top":0,"padding_bottom":0}},"section_custom_code_YYBwJM":{"type":"section-custom-code","name":"quick links","settings":{"code":"<!-- GOLF PRINT CLUB – Bottom Quick Links (single-line pills, 3000px max width, .2s fade) -->\n<section class=\"rcp-quicklinks\" aria-label=\"Quick links\">\n  <nav class=\"rcp-ql-nav\">\n    <ul class=\"rcp-ql-line\">\n      <li><a href=\"\/collections\/golf-half-tights\">Golf Posters<\/a><\/li>\n      <li><a href=\"\/collections\/golf-split-shorts\">Golf Posters<\/a><\/li>\n      <li><a href=\"\/collections\/golf-golf posters\">Golf Posters<\/a><\/li>\n      <li><a href=\"\/collections\/golf-shirts\">Golf Shirts<\/a><\/li>\n      <li><a href=\"\/collections\/lifestyle-clothing\">Graphic Shirts<\/a><\/li>\n      <li><a href=\"\/collections\/lifestyle-clothing\">Hoodies<\/a><\/li>\n      <li><a href=\"\/collections\/golf-posters\">Posters<\/a><\/li>\n      <li><a href=\"\/collections\/golf-stickers\">Stickers<\/a><\/li>\n    <\/ul>\n  <\/nav>\n<\/section>\n\n<style>\n  :root{ --rcp-accent:#2E7D32; }\n\n  .rcp-quicklinks{\n    background:#fbfbfb;\n    border-top:0px solid #e9e9e9;\n    padding:10px 0;\n  }\n  .rcp-ql-nav{\n    max-width:3000px;\n    margin:0 auto;\n    padding:0 10px;\n  }\n\n  .rcp-ql-line{\n    list-style:none;\n    margin:0;\n    padding:0;\n    display:flex;\n    flex-wrap:nowrap;\n    gap:8px;\n    justify-content:center;\n    align-items:center;\n    overflow:auto;\n    scrollbar-width:none;\n  }\n  .rcp-ql-line::-webkit-scrollbar{ display:none; }\n\n  .rcp-ql-line a{\n    display:inline-block;\n    min-width:150px;\n    padding:8px 20px;\n    border:1px solid #ddd;\n    border-radius:3px;\n    text-decoration:none;\n    text-align:center;\n    font-weight:500;\n    font-size:12px;\n    letter-spacing:.08em;\n    text-transform:uppercase;\n    color:#111;\n    background:#fbfbfb;\n    \/* .2s fade on bg\/text\/border *\/\n    transition: background-color .2s ease-in-out, color .2s ease-in-out, border-color .2s ease-in-out;\n  }\n\n  .rcp-ql-line a:hover,\n  .rcp-ql-line a:active{\n    border-color: black;\n  }\n\n  .rcp-ql-line a:focus-visible{\n    outline:2px solid var(--rcp-accent);\n    outline-offset:2px;\n  }\n\n@media (max-width: 76