                <script>
                  
document.addEventListener("DOMContentLoaded", function () {
  const hiddenBadges = document.querySelectorAll('.jdgm-prev-badge');

  hiddenBadges.forEach(badge => {
    const avgRaw = badge.getAttribute('data-average-rating');

    // Only display if there's an actual rating above 0
    if (avgRaw && parseFloat(avgRaw) > 0 && !badge.nextElementSibling?.classList?.contains('custom-rating-display')) {
      let avg = parseFloat(avgRaw);
      // Remove trailing .0 if whole number
      avg = (avg % 1 === 0) ? avg.toFixed(0) : avg.toFixed(1);

      const ratingDiv = document.createElement('div');
      ratingDiv.className = 'custom-rating-display';
      ratingDiv.textContent = `★ ${avg}`;

      badge.insertAdjacentElement('afterend', ratingDiv);
    }
  });
});





</script>

