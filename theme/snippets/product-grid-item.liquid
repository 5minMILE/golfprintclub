 {%- liquid
  assign sold_out_front = false

  # URL stored in product.metafields.custom.master_reference
  assign master_ref_raw = product.metafields.custom.master_reference

  if master_ref_raw != blank
    # Get handle from URL: ".../products/md-half-tights?variant=123" -> "md-half-tights"
    assign after_products = master_ref_raw | split: '/products/' | last
    assign handle = after_products | split: '?' | first

    # Get variant ID: "...variant=50617530122536&..." -> "50617530122536"
    assign variant_part = master_ref_raw | split: 'variant=' | last
    assign variant_id_str = variant_part | split: '&' | first
    assign master_variant_id = variant_id_str | plus: 0

    assign real_product = all_products[handle]

    if real_product and master_variant_id > 0
      # 1) Find the referenced variant
      assign style_value = nil

      for v in real_product.variants
        if v.id == master_variant_id
          # Assuming option1 is the color / style (Storm, Statue of Liberty, etc.)
          assign style_value = v.option1
          break
        endif
      endfor

      # 2) Check all variants with that same color/style
      if style_value
        assign any_available = false

        for v in real_product.variants
          if v.option1 == style_value and v.available
            assign any_available = true
            break
          endif
        endfor

        unless any_available
          assign sold_out_front = true
        endunless
      endif
    endif
  endif
-%}







