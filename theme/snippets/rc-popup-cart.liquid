    height: 44px !important;
    min-height: 44px !important;
  }
</style>

<script>
(function(){
  // Rebuild the input + rebind handlers if theme removes/hides it
  function ensureDiscountUI(){
    const body = document.getElementById('rcDiscountBody');
    const btn  = document.getElementById('rcDiscountApplyBtn');
    const hint = document.getElementById('rcDiscountHint');

    if(!body || !btn) return;

    let input = document.getElementById('rcDiscountInput');

    // If removed, recreate it (insert before apply button)
    if(!input){
      input = document.createElement('input');
      input.className = 'rc-discountInput';
      input.id = 'rcDiscountInput';
      input.type = 'text';
      input.placeholder = 'Enter code';
      input.autocomplete = 'off';
      body.insertBefore(input, btn);
    }

    // Smash any inline styles that might hide it
    input.style.display = 'block';
    input.style.opacity = '1';
    input.style.visibility = 'visible';
    input.style.pointerEvents = 'auto';
    input.style.height = '44px';
    input.style.minHeight = '44px';

    // Prevent double-binding
    if(input.dataset.rcBound === '1') return;
    input.dataset.rcBound = '1';

    // We reuse your existing apply logic if present
    // (your main script defines window.RC_CART + uses /discount/ redirect)
    function apply(){
      const code = (input.value || '').trim();
      if(!code){
        if(hint) hint.textContent = 'Enter a code first.';
        return;
      }

      // If your main script exposes apply behavior, use it.
      // Otherwise fallback to Shopify's /discount/ redirect.
      if(typeof window.RC_APPLY_DISCOUNT === 'function'){
        window.RC_APPLY_DISCOUNT(code);
        return;
      }

      const returnUrl = window.location.pathname + window.location.search + window.location.hash;
      sessionStorage.setItem('rc_cart_should_open', '1');
      sessionStorage.setItem('rc_cart_return_url', returnUrl);
      sessionStorage.setItem('rc_cart_last_discount_code', code.toUpperCase());

      window.location.href = '/discount/' + encodeURIComponent(code) + '?redirect=' + encodeURIComponent(returnUrl);
    }

    btn.addEventListener('click', apply, true);
    input.addEventListener('keydown', (e) => {
      if(e.key === 'Enter'){
        e.preventDefault();
        apply();
      }
    }, true);
  }

  // Run immediately + after a short delay (some themes run after initial render)
  ensureDiscountUI();
  setTimeout(ensureDiscountUI, 200);
  setTimeout(ensureDiscountUI, 800);

  // Observe for theme scripts removing/changing the discount block
  const root = document.getElementById('rcCartDevSheet') || document.body;
  const obs = new MutationObserver(() => ensureDiscountUI());
  obs.observe(root, { childList: true, subtree: true });

  // Also re-ensure whenever cart is opened via your API
  const _open = window.RC_CART && window.RC_CART.open;
  if(window.RC_CART && typeof _open === 'function'){
    window.RC_CART.open = async function(){
      const r = await _open.apply(this, arguments);
      ensureDiscountUI();
      return r;
    };
  }
})();
</script>

<script>
(function(){
  // Keys you already use (match your existing names)
  const SS_OPEN_KEY  = 'rc_cart_should_open';
  const SS_CODE_KEY  = 'rc_cart_last_discount_code';

  function norm(s){ return (s || '').toString().trim().toUpperCase(); }

  function getStatusEl(){
    return document.getElementById('rcStatus');
  }

  function setPromoStatus(code){
    const el = getStatusEl();
    if(!el) return;
    const c = norm(code);
    if(!c) { el.textContent = ''; return; }
    el.textContent = `Promo code: ${c}`;
  }

  // HARD open fallback (in case window.RC_CART.open isn't available)
  function openCartFallback(){
    const root  = document.getElementById('rcCartDevRoot');
    if(root){
      root.style.display = 'block';
      root.style.opacity = '1';
      root.style.pointerEvents = 'auto';
      root.setAttribute('aria-hidden','false');
      document.documentElement.style.overflow = 'hidden';
    }
  }

  function openCart(){
    // Prefer your exposed API if you have it
    if(window.RC_CART && typeof window.RC_CART.open === 'function'){
      window.RC_CART.open();
      return;
    }
    openCartFallback();
  }

  // 1) Monkey-patch your discount apply so it sets the "reopen" flag
  // If your brute-force discount box patch is using window.RC_APPLY_DISCOUNT, we attach it.
  // If not, we still intercept clicks/Enter on your discount UI.
  function applyDiscountAndReturn(rawCode){
    const code = (rawCode || '').toString().trim();
    if(!code) return;

    // Store intent to reopen + show code after reload
    sessionStorage.setItem(SS_OPEN_KEY, '1');
    sessionStorage.setItem(SS_CODE_KEY, norm(code));

    const returnUrl = window.location.pathname + window.location.search + window.location.hash;
    window.location.href =
      '/discount/' + encodeURIComponent(code) +
      '?redirect=' + encodeURIComponent(returnUrl);
  }

  // Expose for other scripts (optional, but makes everything consistent)
  window.RC_APPLY_DISCOUNT = applyDiscountAndReturn;

  // 2) After redirect back, reopen cart and show promo code under checkout
  function restoreAfterDiscountRedirect(){
    const shouldOpen = sessionStorage.getItem(SS_OPEN_KEY) === '1';
    const code = sessionStorage.getItem(SS_CODE_KEY) || '';

    if(shouldOpen){
      sessionStorage.removeItem(SS_OPEN_KEY);

      // open cart again after the new page loads + DOM exists
      // slight delay helps if theme scripts render late
      setTimeout(() => {
        openCart();
        setPromoStatus(code);
      }, 120);
    } else {
      // If they refresh later and you still want it visible, keep this:
      // setPromoStatus(code);
      // If you ONLY want it right after apply, leave it off.
    }
  }

  // Run on load
  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', restoreAfterDiscountRedirect);
  } else {
    restoreAfterDiscountRedirect();
  }

  // 3) Ensure your discount input/button uses this apply logic (even if theme re-renders)
  function wireDiscountUI(){
    const input = document.getElementById('rcDiscountInput');
    const btn   = document.getElementById('rcDiscountApplyBtn');
    if(!input || !btn) return;

    if(btn.dataset.rcApplyBound !== '1'){
      btn.dataset.rcApplyBound = '1';
      btn.addEventListener('click', () => applyDiscountAndReturn(input.value), true);
    }

    if(input.dataset.rcApplyBound !== '1'){
      input.dataset.rcApplyBound = '1';
      input.addEventListener('keydown', (e) => {
        if(e.key === 'Enter'){
          e.preventDefault();
          applyDiscountAndReturn(input.value);
        }
      }, true);
    }
  }

  wireDiscountUI();

  // Re-wire if the theme nukes/rebuilds the discount UI
  const sheet = document.getElementById('rcCartDevSheet') || document.body;
  const obs = new MutationObserver(() => wireDiscountUI());
  obs.observe(sheet, { childList:true, subtree:true });

})();
</script>

<script>
(function () {
  // ====== STORAGE KEYS ======
  const SS_OPEN_KEY = "rc_cart_should_open";
  const SS_CODE_KEY = "rc_cart_last_discount_code";

  const norm = (s) => (s || "").toString().trim().toUpperCase();

  // ====== OPEN CART (works even if you don't have a global open()) ======
  function openCartNow() {
    // If you already exposed an API, use it
    if (window.RC_CART && typeof window.RC_CART.open === "function") {
      window.RC_CART.open();
      return true;
    }

    // Otherwise brute-force open the root
    const root = document.getElementById("rcCartDevRoot");
    if (!root) return false;

    root.style.display = "block";
    root.style.opacity = "1";
    root.style.pointerEvents = "auto";
    root.setAttribute("aria-hidden", "false");

    document.documentElement.style.overflow = "hidden";
    return true;
  }

  // ====== SHOW APPLIED DISCOUNTS (REAL from cart.js) ======
  async function showAppliedDiscounts() {
    const statusEl = document.getElementById("rcStatus");
    if (!statusEl) return;

    try {
      const r = await fetch("/cart.js", { credentials: "same-origin", cache: "no-store" });
      if (!r.ok) throw new Error("cart.js failed");
      const cart = await r.json();

      const codes = [];
      if (Array.isArray(cart.discount_codes)) {
        cart.discount_codes.forEach(d => {
          const c = d && d.code ? String(d.code) : "";
          if (c) codes.push(norm(c));
        });
      }

      // Some discounts show up as cart_level_discount_applications instead
      if (!codes.length && Array.isArray(cart.cart_level_discount_applications)) {
        cart.cart_level_discount_applications.forEach(d => {
          const t = d && d.title ? String(d.title) : "";
          if (t) codes.push(t);
        });
      }

      if (codes.length) {
        statusEl.textContent = `Promo code applied: ${codes.join(", ")}`;
      } else {
        statusEl.textContent = "No promo code applied.";
      }
    } catch (e) {
      console.log("[RC DISCOUNT] Could not read applied discounts:", e);
    }
  }

  // ====== APPLY DISCOUNT (Shopify standard) ======
  function applyDiscount(codeRaw) {
    const code = (codeRaw || "").toString().trim();
    const hint = document.getElementById("rcDiscountHint");

    if (!code) {
      if (hint) hint.textContent = "Enter a code first.";
      return;
    }

    sessionStorage.setItem(SS_OPEN_KEY, "1");
    sessionStorage.setItem(SS_CODE_KEY, norm(code));

    const returnUrl = window.location.pathname + window.location.search + window.location.hash;
    window.location.href =
      "/discount/" + encodeURIComponent(code) +
      "?redirect=" + encodeURIComponent(returnUrl);
  }

  // ====== INTERCEPT YOUR DISCOUNT UI (capture phase = beats existing handlers) ======
  function wireDiscountUI() {
    const input = document.getElementById("rcDiscountInput");
    const btn = document.getElementById("rcDiscountApplyBtn");
    if (!input || !btn) return false;

    if (!btn.dataset.rcPatched) {
      btn.dataset.rcPatched = "1";
      btn.addEventListener("click", function (e) {
        e.preventDefault();
        e.stopPropagation();
        e.stopImmediatePropagation();
        applyDiscount(input.value);
      }, true);
    }

    if (!input.dataset.rcPatched) {
      input.dataset.rcPatched = "1";
      input.addEventListener("keydown", function (e) {
        if (e.key === "Enter") {
          e.preventDefault();
          e.stopPropagation();
          e.stopImmediatePropagation();
          applyDiscount(input.value);
        }
      }, true);
    }

    return true;
  }

  // keep trying in case your drawer UI renders late or gets re-rendered
  (function retryWire() {
    let tries = 0;
    const t = setInterval(() => {
      tries++;
      wireDiscountUI();
      if (tries > 80) clearInterval(t);
    }, 150);
  })();

  // ====== AFTER REDIRECT: REOPEN CART + SHOW APPLIED DISCOUNTS ======
  function restoreOpenAfterDiscount() {
    const shouldOpen = sessionStorage.getItem(SS_OPEN_KEY) === "1";
    if (!shouldOpen) return;

    sessionStorage.removeItem(SS_OPEN_KEY);

    // Poll until your popup cart exists, then open it
    let tries = 0;
    const timer = setInterval(async () => {
      tries++;

      const opened = openCartNow();
      if (opened) {
        clearInterval(timer);

        // Give your cart render() a beat, then read discounts
        setTimeout(() => { showAppliedDiscounts(); }, 250);
      }

      if (tries > 80) clearInterval(timer);
    }, 150);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", restoreOpenAfterDiscount);
  } else {
    restoreOpenAfterDiscount();
  }
})();
</script>

<script>
(function(){
  // New key dedicated to "cart was open" persistence
  const SS_WAS_OPEN_KEY = 'rc_cart_was_open';

  function isCartOpen(){
    const root = document.getElementById('rcCartDevRoot');
    return !!(root && root.classList.contains('isOpen'));
  }

  function setWasOpen(on){
    try{
      if(on) sessionStorage.setItem(SS_WAS_OPEN_KEY, '1');
      else sessionStorage.removeItem(SS_WAS_OPEN_KEY);
    }catch(e){}
  }

  function reopenIfNeeded(){
    let shouldReopen = false;
    try{
      shouldReopen = sessionStorage.getItem(SS_WAS_OPEN_KEY) === '1';
    }catch(e){}

    if(!shouldReopen) return;

    // Wait for your main script to define RC_CART, then open.
    let tries = 0;
    const t = setInterval(() => {
      tries++;

      // If user already has it open, we're good.
      if(isCartOpen()){
        clearInterval(t);
        return;
      }

      if(window.RC_CART && typeof window.RC_CART.open === 'function'){
        clearInterval(t);
        // open() also re-renders, so this is the cleanest path
        window.RC_CART.open();
      }

      if(tries > 80) clearInterval(t);
    }, 120);
  }

  function patchRC(){
    if(!window.RC_CART) return false;

    // Patch open: whenever cart opens, remember it
    if(window.RC_CART.open && !window.RC_CART.open.__rc_patched){
      const _open = window.RC_CART.open;
      function patchedOpen(){
        setWasOpen(true);
        return _open.apply(this, arguments);
      }
      patchedOpen.__rc_patched = true;
      window.RC_CART.open = patchedOpen;
    }

    // Patch close: whenever user closes, forget it
    if(window.RC_CART.close && !window.RC_CART.close.__rc_patched){
      const _close = window.RC_CART.close;
      function patchedClose(){
        setWasOpen(false);
        return _close.apply(this, arguments);
      }
      patchedClose.__rc_patched = true;
      window.RC_CART.close = patchedClose;
    }

    return true;
  }

  // 1) Save state right before a refresh/navigation happens
  window.addEventListener('beforeunload', () => {
    // If it's open at refresh time, keep it sticky
    setWasOpen(isCartOpen());
  });

  // 2) Also update state if something else opens/closes it without using RC_CART API
  // (rare, but this makes it bulletproof)
  const root = document.getElementById('rcCartDevRoot');
  if(root && window.MutationObserver){
    const obs = new MutationObserver(() => {
      setWasOpen(isCartOpen());
    });
    obs.observe(root, { attributes:true, attributeFilter:['class'] });
  }

  // 3) Patch RC_CART when it exists (your code defines it after load)
  (function waitForRC(){
    let tries = 0;
    const timer = setInterval(() => {
      tries++;
      if(patchRC()){
        clearInterval(timer);
      }
      if(tries > 120) clearInterval(timer);
    }, 100);
  })();

  // 4) Reopen after refresh if it was open
  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', reopenIfNeeded);
  } else {
    reopenIfNeeded();
  }
})();
</script>

