<script>
(function () {
  var THRESHOLD_PCT = 0.30; // 30% of viewport height

  function clamp(n, min, max) {
    if (n < min) return min;
    if (n > max) return max;
    return n;
  }

  function isOpen(root) {
    return !!(root && root.classList && root.classList.contains("isOpen"));
  }

  function getY(evt) {
    if (evt && evt.touches && evt.touches.length) return evt.touches[0].clientY;
    if (evt && evt.changedTouches && evt.changedTouches.length) return evt.changedTouches[0].clientY;
    return evt && typeof evt.clientY === "number" ? evt.clientY : 0;
  }

  function setup() {
    var root = document.getElementById("rcCartDevRoot");
    var sheet = document.getElementById("rcCartDevSheet");
    var handle = document.querySelector("#rcCartDevSheet .rc-handle");

    if (!root || !sheet || !handle) return false;

    var dragging = false;
    var startY = 0;
    var currentY = 0;

    function setTranslate(y) {
      sheet.style.transform = "translateY(" + y + "px)";
    }

    function resetSheet() {
      sheet.classList.remove("rc-dragging");
      sheet.style.transition = "";
      sheet.style.transform = "";
    }

    function closeCart() {
      resetSheet();
      if (window.RC_CART && typeof window.RC_CART.close === "function") {
        window.RC_CART.close();
      } else {
        // fallback close
        root.classList.remove("isOpen");
        root.setAttribute("aria-hidden", "true");
        document.documentElement.style.overflow = "";
      }
    }

    function onDown(e) {
      if (!isOpen(root)) return;

      // Only left click for mouse
      if (e.type === "mousedown" && e.button !== 0) return;

      dragging = true;
      startY = getY(e);
      currentY = 0;

      sheet.classList.add("rc-dragging");
      sheet.style.transition = "none";

      if (e.preventDefault) e.preventDefault();
      if (e.stopPropagation) e.stopPropagation();
    }

    function onMove(e) {
      if (!dragging) return;

      var dy = getY(e) - startY;
      if (dy < 0) dy = 0;

      currentY = clamp(dy, 0, (window.innerHeight || 800));
      setTranslate(currentY);

      if (e.preventDefault) e.preventDefault();
      if (e.stopPropagation) e.stopPropagation();
    }

    function onUp(e) {
      if (!dragging) return;
      dragging = false;

      var h = window.innerHeight || 800;
      var thresholdPx = h * THRESHOLD_PCT;

      if (currentY >= thresholdPx) {
        closeCart();
        return;
      }

      // snap back
      sheet.classList.remove("rc-dragging");
      sheet.style.transition = "transform .18s ease";
      setTranslate(0);

      setTimeout(function () {
        resetSheet();
      }, 220);

      if (e && e.preventDefault) e.preventDefault();
      if (e && e.stopPropagation) e.stopPropagation();
    }

    // Start drag only on handle
    handle.addEventListener("mousedown", onDown, false);
    handle.addEventListener("touchstart", onDown, false);

    // Move + end anywhere
    window.addEventListener("mousemove", onMove, false);
    window.addEventListener("touchmove", onMove, false);

    window.addEventListener("mouseup", onUp, false);
    window.addEventListener("touchend", onUp, false);
    window.addEventListener("touchcancel", onUp, false);

    // If cart closes another way, don’t leave it translated
    if (window.MutationObserver) {
      var obs = new MutationObserver(function () {
        if (!isOpen(root)) resetSheet();
      });
      obs.observe(root, { attributes: true, attributeFilter: ["class"] });
    }

    return true;
  }

  // Retry until your cart markup exists
  var tries = 0;
  var timer = setInterval(function () {
    tries++;
    if (setup()) {
      clearInterval(timer);
      return;
    }
    if (tries > 120) clearInterval(timer);
  }, 100);
})();
</script>

<script>
(function(){
  const root = document.getElementById('rcCartDevRoot');
  const sheet = document.getElementById('rcCartDevSheet');

  if(!root || !sheet) return;

  root.addEventListener('click', function(e){
    // If click is NOT inside the cart sheet, close it
    if(!sheet.contains(e.target)){
      if(window.RC_CART && typeof window.RC_CART.close === 'function'){
        window.RC_CART.close();
      } else {
        // Fallback close
        root.classList.remove('isOpen');
        root.setAttribute('aria-hidden','true');
        document.documentElement.style.overflow = '';
      }
    }
  });
})();
</script>