<!-- /sections/footer.liquid -->

{%- style -%}
  .site-footer-wrapper { --PT: {{ section.settings.padding_top }}px; --PB: {{ section.settings.padding_bottom }}px; }
{%- endstyle -%}

<style>
  /* Footer sits on the brand-blue background, so content is WHITE and hovers are white/underline (never blue, which would vanish into the bg). */
  .site-footer-wrapper { font-family: 'Montserrat', sans-serif; }

  /* Container: constrain max width and center on desktop so columns don't sprawl edge-to-edge on wide screens */
  .site-footer-wrapper .site-footer { max-width: 3000px; margin: 0 auto; padding-inline: clamp(20px, 4vw, 48px); }

  /* Desktop layout: brand block left, 3 link columns right */
  .site-footer-wrapper .rc-foot-grid {
    display: grid;
    grid-template-columns: minmax(220px, 1.2fr) repeat(3, minmax(0, 1fr));
    gap: 40px 56px;
    align-items: start;
  }

  /* Brand block (left) */
  .site-footer-wrapper .rc-foot-brand { display: flex; flex-direction: column; gap: 18px; max-width: 320px; }
  .site-footer-wrapper .rc-foot-brand__name {
    font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 18px;
    letter-spacing: 0.12em; text-transform: uppercase; color: #fff;
  }
  .site-footer-wrapper .rc-foot-brand__tag {
    color: rgba(255,255,255,0.82); font-size: 13px; line-height: 1.6; margin: 0;
  }
  .site-footer-wrapper .rc-foot-brand__social { display: flex; gap: 16px; margin-top: 4px; }
  .site-footer-wrapper .rc-foot-brand__social a {
    color: rgba(255,255,255,0.82); display: inline-flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; border: 1px solid rgba(255,255,255,0.28); border-radius: 50%;
    transition: color .15s ease, border-color .15s ease, background .15s ease;
  }
  .site-footer-wrapper .rc-foot-brand__social a:hover { color: #fff; border-color: #fff; background: rgba(255,255,255,0.08); }
  .site-footer-wrapper .rc-foot-brand__social svg { width: 16px; height: 16px; fill: currentColor; }

  /* Link columns (right) */
  .site-footer-wrapper .rc-foot-col { min-width: 0; }
  .site-footer-wrapper summary { list-style: none; }
  .site-footer-wrapper summary::-webkit-details-marker { display: none; }
  .site-footer-wrapper .footer__block__title {
    color: #fff !important; background: none !important; border: none !important; padding: 0 !important;
    margin: 0 0 16px !important; font-family: 'Montserrat', sans-serif !important;
    font-size: 13px !important; font-weight: 800 !important; letter-spacing: 0.09em; text-transform: uppercase; width: auto !important;
  }
  .site-footer-wrapper .footer__quicklinks { list-style: none; margin: 0; padding: 0; }
  .site-footer-wrapper .footer__quicklinks li { margin: 0 0 11px; }
  .site-footer-wrapper .footer__quicklinks a {
    color: rgba(255,255,255,0.82); font-size: 13px; font-weight: 500; text-decoration: none; text-transform: none;
    transition: color .15s ease;
  }
  .site-footer-wrapper .footer__quicklinks a:hover { color: #fff; text-decoration: underline; }

  /* Tablet: drop the brand block to one row, keep the 3 link columns underneath */
  @media (max-width: 1023px) and (min-width: 769px) {
    .site-footer-wrapper .rc-foot-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 32px 40px;
    }
    .site-footer-wrapper .rc-foot-brand { grid-column: 1 / -1; max-width: 100%; }
    .site-footer-wrapper .rc-foot-brand__social { margin-top: 0; }
  }

  @media (min-width: 769px) {
    /* Desktop: static column headers, not clickable toggles */
    .site-footer-wrapper summary.footer__block__title { pointer-events: none; }
  }
  @media (max-width: 768px) {
    /* Mobile: stack everything; brand block on top, link sections collapse to accordions */
    .site-footer-wrapper .rc-foot-grid { display: block; }
    .site-footer-wrapper .rc-foot-brand { margin-bottom: 28px; max-width: 100%; }
    .site-footer-wrapper .rc-foot-col { border-top: 1px solid rgba(255,255,255,0.28); }
    .site-footer-wrapper .footer__block__title {
      display: flex; align-items: center; justify-content: space-between;
      margin: 0 !important; padding: 18px 2px !important; cursor: pointer;
    }
    .site-footer-wrapper details.rc-foot-col .footer__block__title::after {
      content: ''; width: 9px; height: 9px;
      border-right: 2px solid #fff; border-bottom: 2px solid #fff;
      transform: rotate(45deg); transition: transform .2s ease; flex-shrink: 0; margin: -4px 4px 0 12px;
    }
    .site-footer-wrapper details.rc-foot-col[open] .footer__block__title::after { transform: rotate(-135deg); margin-top: 2px; }
    .site-footer-wrapper .footer__quicklinks { padding: 0 2px 16px; }
  }
</style>

<footer class="site-footer-wrapper section-padding" data-section-id="{{ section.id }}" data-section-type="footer">
  <div class="site-footer">
    <div class="footer__blocks rc-foot-grid">

      <div class="rc-foot-brand">
        <div class="rc-foot-brand__name">Golf Print Club</div>
        <p class="rc-foot-brand__tag">Golf posters, wall art, and apparel for golfers who actually train. Hand-illustrated prints, made to order.</p>
      </div>

      <details class="footer__block rc-foot-col" open>
        <summary class="footer__block__title">Shop</summary>
        <ul class="footer__quicklinks">
          <li><a href="/collections/golf-posters">All Posters</a></li>
          <li><a href="/collections/best-selling-posters">Best Sellers</a></li>
          <li><a href="/collections/motivational-golf-posters">Motivational Posters</a></li>
          <li><a href="/collections/new-arrivals">New Arrivals</a></li>
          <li><a href="/collections/golf-gear">Golf Wall Art</a></li>
          <li><a href="/collections/gifts-for-golfers">Gifts for Golfers</a></li>
        </ul>
      </details>

      <details class="footer__block rc-foot-col" open>
        <summary class="footer__block__title">Help</summary>
        <ul class="footer__quicklinks">
          <li><a href="/pages/shipping-protection">Shipping</a></li>
          <li><a href="/pages/return-exchange">Returns &amp; Exchanges</a></li>
          <li><a href="/pages/size-chart">Size Chart</a></li>
          <li><a href="/pages/frequently-asked-questions">FAQs</a></li>
          <li><a href="/pages/contact-us">Contact Us</a></li>
        </ul>
      </details>

      <details class="footer__block rc-foot-col" open>
        <summary class="footer__block__title">Company</summary>
        <ul class="footer__quicklinks">
          <li><a href="/pages/about">About Us</a></li>
          <li><a href="/pages/why-run">Why Run</a></li>
          <li><a href="/pages/reviews">Reviews</a></li>
          <li><a href="/pages/blogs">Blog</a></li>
        </ul>
      </details>

    </div>
  </div>
</footer>

<script>
  /* Footer dropdowns: collapsed accordions on mobile, open columns on desktop (native <details>). */
  (function () {
    var mq = window.matchMedia('(max-width: 768px)');
    function sync() {
      var dets = document.querySelectorAll('.site-footer-wrapper details.rc-foot-col');
      // (selector unchanged; rc-foot-col still applied to each details element)
      for (var i = 0; i < dets.length; i++) { dets[i].open = !mq.matches; }
    }
    sync();
    if (mq.addEventListener) { mq.addEventListener('change', sync); }
    else if (mq.addListener) { mq.addListener(sync); }
  })();
</script>

{% schema %}
{
  "name": "Footer",
  "max_blocks": 6,
  "settings": [
    {
      "type": "paragraph",
      "content": "Footer navigation columns are set in the section code (Shop / Help / Company)."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding top",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding bottom",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "linklist",
      "name": "Link list",
      "settings": [
        { "type": "link_list", "id": "linklist", "label": "Link list" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "range", "id": "column_width", "label": "Column width", "unit": "%", "min": 1, "max": 100, "step": 1, "default": 25 },
        { "type": "checkbox", "id": "enable_accordion", "label": "Enable accordion (mobile)", "default": true }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        { "type": "text", "id": "title", "label": "Heading", "default": "Text" },
        { "type": "richtext", "id": "text", "label": "Text" },
        { "type": "range", "id": "column_width", "label": "Column width", "unit": "%", "min": 1, "max": 100, "step": 1, "default": 25 },
        { "type": "checkbox", "id": "enable_accordion", "label": "Enable accordion (mobile)", "default": true }
      ]
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  }
}
{% endschema %}
