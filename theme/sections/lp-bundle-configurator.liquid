    },
    {
      "type": "text",
      "id": "fine_print",
      "label": "Fine print",
      "default": "Easy Exchanges · Secure Checkout · 4,000+ golfers"
    }
  ],
  "blocks": [
    {
      "type": "pair",
      "name": "Pair Selector",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Pair label",
