    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Choose your 3 designs and size. Mix any way you want."
    },
    {
      "type": "text",
      "id": "summary_line1_label",
      "label": "Summary line 1 label",
      "default": "Pair 1 + Pair 2"
    },
    {
      "type": "text",
      "id": "summary_line1_value",
      "label": "Summary line 1 value",
      "default": "$120"
    },
    {
      "type": "text",
      "id": "summary_line2_label",
      "label": "Summary line 2 label",
      "default": "Pair 3 (Free)"
    },
    {
      "type": "text",
      "id": "summary_line2_value",
      "label": "Summary line 2 value",
      "default": "-$60"
    },
    {
      "type": "text",
      "id": "total_price",
      "label": "Total price",
      "default": "$120"
    },
    {
      "type": "text",
      "id": "savings_text",
      "label": "Savings text",
      "default": "You save $60 · Free shipping"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Add Bundle to Cart"
    },
    {
      "type": "url",
      "id": "button_url",
