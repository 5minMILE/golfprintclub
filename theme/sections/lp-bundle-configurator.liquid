          "default": "S, M, L"
        },
        {
          "type": "color",
          "id": "color_1",
          "label": "Swatch 1 color",
          "default": "#1a1a1a"
        },
        {
          "type": "image_picker",
          "id": "swatch_1",
          "label": "Swatch 1 image (optional)"
        },
        {
          "type": "color",
          "id": "color_2",
          "label": "Swatch 2 color",
          "default": "#2255bb"
        },
        {
          "type": "image_picker",
          "id": "swatch_2",
          "label": "Swatch 2 image (optional)"
        },
        {
          "type": "color",
          "id": "color_3",
          "label": "Swatch 3 color",
          "default": "#cc4499"
        },
        {
          "type": "image_picker",
          "id": "swatch_3",
          "label": "Swatch 3 image (optional)"
        },
        {
          "type": "color",
          "id": "color_4",
          "label": "Swatch 4 color",
          "default": "#333333"
        },
        {
          "type": "image_picker",
          "id": "swatch_4",
          "label": "Swatch 4 image (optional)"
        },
        {
          "type": "color",
          "id": "color_5",
          "label": "Swatch 5 color",
          "default": "#8B7355"
        },
        {
          "type": "image_picker",
          "id": "swatch_5",
          "label": "Swatch 5 image (optional)"
        },
        {
          "type": "color",
          "id": "color_6",
          "label": "Swatch 6 color",
          "default": "#4a7a4a"
        },
        {
          "type": "image_picker",
          "id": "swatch_6",
          "label": "Swatch 6 image (optional)"
        },
        {
          "type": "color",
          "id": "color_7",
          "label": "Swatch 7 color",
          "default": "#cc3300"
        },
        {
          "type": "image_picker",
          "id": "swatch_7",
          "label": "Swatch 7 image (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP Bundle — Configurator",
      "blocks": [
        { "type": "pair", "settings": { "label": "Pair 1", "price": "$60" } },
        { "type": "pair", "settings": { "label": "Pair 2", "price": "$60" } },
