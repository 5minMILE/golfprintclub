<!-- /sections/section-wf-poster-styles.liquid -->
<style>
  .ps-{{ section.id }} {
    padding: 64px 0;
    background: #3D6E2E;
    color: #fff;
  }
  .ps-{{ section.id }} .ps-wrap {
    max-width: 3000px;
    margin: 0 auto;
    padding: 0 32px;
    display: grid;
    grid-template-columns: 1fr 1.25fr;
    gap: 56px;
    align-items: center;
  }
  .ps-{{ section.id }} .ps-text {
    text-align: left;
  }
  .ps-{{ section.id }} .ps-eyebrow {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 800;
    color: #fff;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 0 0 14px;
    display: block;
    opacity: 0.85;
  }
  .ps-{{ section.id }} .ps-heading {
    font-family: 'Montserrat', sans-serif;
    font-size: 48px;
    font-weight: 1000;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0;
    line-height: 1.02;
    margin: 0 0 18px;
  }
  .ps-{{ section.id }} .ps-sub {
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: rgba(255,255,255,0.92);
    line-height: 1.6;
    margin: 0 0 26px;
    max-width: 40ch;
  }
  .ps-{{ section.id }} .ps-cta {
    display: inline-block;
    background: #fff;
    color: #3D6E2E;
    padding: 14px 26px;
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    font-weight: 1000;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }
  .ps-{{ section.id }} .ps-cta:hover {
    background: #0A0A0A;
    color: #fff;
    transform: translateY(-2px);
  }
  .ps-{{ section.id }} .ps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }
  .ps-{{ section.id }} .ps-card {
    position: relative;
    display: block;
    aspect-ratio: 2 / 3;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    background: transparent;
    border: 2px solid #fff;
    transition: transform 0.3s ease;
  }
  .ps-{{ section.id }} .ps-card:hover {
    transform: translateY(-3px);
  }
  .ps-{{ section.id }} .ps-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .ps-{{ section.id }} .ps-card:hover .ps-card__img {
    transform: scale(1.06);
  }
  .ps-{{ section.id }} .ps-card__tag {
    position: absolute;
    bottom: 10px;
    left: 10px;
    background: rgba(0,0,0,0.85);
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 5px 9px;
    line-height: 1;
    border-radius: 2px;
  }
  @media (max-width: 749px) {
    .ps-{{ section.id }} {
      padding: 40px 0;
    }
    .ps-{{ section.id }} .ps-wrap {
      grid-template-columns: 1fr;
      gap: 28px;
      padding: 0 18px;
    }
    .ps-{{ section.id }} .ps-text {
      text-align: center;
    }
    .ps-{{ section.id }} .ps-heading {
      font-size: 30px;
    }
    .ps-{{ section.id }} .ps-sub {
      font-size: 13px;
      margin-left: auto;
      margin-right: auto;
    }
    .ps-{{ section.id }} .ps-cta {
      font-size: 11px;
      padding: 12px 22px;
    }
    .ps-{{ section.id }} .ps-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
    .ps-{{ section.id }} .ps-card__tag {
      font-size: 9px;
      padding: 4px 7px;
      bottom: 8px;
      left: 8px;
    }
  }
</style>

<section class="ps-{{ section.id }}" data-section-id="{{ section.id }}" data-section-type="poster-styles">
  {%- comment -%}
    Pick a fallback image so the cards aren't empty grey boxes until the
    user uploads their own. Prefer the first product in the golf-posters
    collection so the placeholder is actually a poster image.
  {%- endcomment -%}
  {%- assign fallback_image_url = '' -%}
  {%- assign poster_col = collections['golf-posters'] -%}
  {%- if poster_col != blank and poster_col.products.first.featured_image != blank -%}
    {%- assign fallback_image_url = poster_col.products.first.featured_image | image_url: width: 800 -%}
  {%- endif -%}

  <div class="ps-wrap">
    <div class="ps-text">
      {%- if section.settings.eyebrow != blank -%}
        <span class="ps-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="ps-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="ps-sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_link | default: '/collections/golf-posters' }}" class="ps-cta">{{ section.settings.cta_text }}</a>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="ps-grid">
        {%- for block in section.blocks -%}
          <a href="{{ block.settings.link | default: '#' }}" class="ps-card" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img class="ps-card__img" src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.label | escape }}" loading="lazy">
            {%- elsif fallback_image_url != '' -%}
              <img class="ps-card__img" src="{{ fallback_image_url }}" alt="{{ block.settings.label | escape }}" loading="lazy">
            {%- endif -%}
            <span class="ps-card__tag">{{ block.settings.label }}</span>
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Poster Styles",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Wall art that runs"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The #1 Destination for Golf Posters"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Vintage racing prints, motivational typography, modern aesthetics. Pick the style that fits your training space."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "Shop All Posters"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    }
  ],
  "blocks": [
    {
      "type": "style_card",
      "name": "Style card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "label", "label": "Style name", "default": "Style" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Poster Styles",
      "category": "Collection",
      "blocks": [
        { "type": "style_card", "settings": { "label": "Vintage" } },
        { "type": "style_card", "settings": { "label": "Motivational" } },
        { "type": "style_card", "settings": { "label": "Aesthetic" } },
        { "type": "style_card", "settings": { "label": "Track" } }
      ]
    }
  ]
}
{% endschema %}
