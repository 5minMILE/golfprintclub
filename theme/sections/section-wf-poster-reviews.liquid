<!-- /sections/section-wf-poster-reviews.liquid -->
{%- comment -%}
  Poster review section. Shows the poster product-group's reviews (strictly posters),
  pulled live from Judge.me's reviews_for_widget endpoint (the same call its native
  widget makes — no token needed). If that fetch ever fails, it falls back to the
  reviews already server-rendered in product.metafields.judgeme.widget so it's never
  empty. "Load more" reveals 3 more at a time.
{%- endcomment -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;900&display=swap" rel="stylesheet">

{%- liquid
  assign badge = product.metafields.judgeme.badge.value | default: ''
  assign p_count = badge | split: "data-number-of-reviews='" | last | split: "'" | first
  assign p_rating = badge | split: "data-average-rating='" | last | split: "'" | first
-%}

<style>
  #WfPosterReviews--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    font-family: 'Montserrat', sans-serif;
  }
  #WfPosterReviews--{{ section.id }} .wfpr__inner { max-width: 3000px; margin: 0 60px; text-align: center; position: relative; }
  @media (min-width: 3001px) { #WfPosterReviews--{{ section.id }} .wfpr__inner { margin: 0 auto; } }
  #WfPosterReviews--{{ section.id }} .wfpr__heading { font-size: 28px; font-weight: 1000; text-transform: uppercase; letter-spacing: 0.06em; line-height: 1.2; margin: 0; }
  #WfPosterReviews--{{ section.id }} .wfpr__stars { font-size: 20px; font-weight: 600; color: #3D6E2E; margin-top: 5px; }

  #WfPosterReviews--{{ section.id }} .wfpr__grid {
    display: flex; gap: 16px; margin-top: 28px;
    overflow-x: auto; scroll-behavior: smooth;
    scrollbar-width: none; -ms-overflow-style: none;
    align-items: stretch;
  }
  #WfPosterReviews--{{ section.id }} .wfpr__grid::-webkit-scrollbar { display: none; }
  #WfPosterReviews--{{ section.id }} .wfpr__card {
    flex: 0 0 calc(33.333% - 11px); min-width: 300px;
    min-height: 400px;
    border: 1px solid #3D6E2E; border-radius: 6px; background: #fff; text-align: left;
    display: flex; flex-direction: column; overflow: hidden;
  }
  #WfPosterReviews--{{ section.id }} .wfpr__white { padding: 28px 28px 22px; flex: 1; display: flex; flex-direction: column; }
  #WfPosterReviews--{{ section.id }} .wfpr__meta-row { margin-top: auto; padding-top: 14px; display: flex; align-items: flex-end; justify-content: space-between; gap: 12px; }
  #WfPosterReviews--{{ section.id }} .wfpr__meta { min-width: 0; }
  #WfPosterReviews--{{ section.id }} .wfpr__thumbs { flex-shrink: 0; display: flex; flex-direction: row; gap: 6px; align-items: flex-end; }
  #WfPosterReviews--{{ section.id }} .wfpr__thumbs a { display: block; }
  #WfPosterReviews--{{ section.id }} .wfpr__thumbs img { width: 46px; height: 69px; object-fit: cover; border-radius: 4px; display: block; background: #f0f0f0; }
  #WfPosterReviews--{{ section.id }} .wfpr__blue { background: #3D6E2E; color: #fff; padding: 14px 18px; }
  #WfPosterReviews--{{ section.id }} .wfpr__blue-text { font-size: 12px; font-weight: 600; line-height: 1.45; text-align: left; }
  #WfPosterReviews--{{ section.id }} .wfpr__blue-text a { color: #fff; font-weight: 800; text-decoration: underline; }
  #WfPosterReviews--{{ section.id }} .wfpr__text { font-size: 18px; font-weight: 500; color: #333; line-height: 1.5; margin: 0 0 18px; }
  #WfPosterReviews--{{ section.id }} .wfpr__rating { font-size: 13px; font-weight: 600; color: #3D6E2E; margin-top: auto; }
  #WfPosterReviews--{{ section.id }} .wfpr__name { font-size: 12px; font-weight: 1000; letter-spacing: 0.04em; text-transform: uppercase; margin-top: 4px; }
  #WfPosterReviews--{{ section.id }} .wfpr__date { font-size: 11px; font-weight: 600; letter-spacing: 0.02em; color: #9a9a9a; margin-top: 4px; }

  /* Desktop slider arrows — same component as "Pairs well with" */
  #WfPosterReviews--{{ section.id }} .wfpr__arrow {
    display: none; position: absolute; top: 50%; transform: translateY(-50%); z-index: 2;
    width: 40px; height: 40px; border-radius: 50%; background: #3D6E2E; border: none;
    box-shadow: 0 2px 6px rgba(0,0,0,0.15); cursor: pointer; font-size: 18px; line-height: 1; color: #fff;
    align-items: center; justify-content: center;
    transition: box-shadow 0.3s ease, transform 0.2s ease, background 0.2s ease;
  }
  #WfPosterReviews--{{ section.id }} .wfpr__arrow:hover { background: #0080ff; box-shadow: 0 0 12px rgba(0,123,255,0.5); transform: translateY(-50%) scale(1.1); }
  #WfPosterReviews--{{ section.id }} .wfpr__arrow--prev { left: -16px; }
  #WfPosterReviews--{{ section.id }} .wfpr__arrow--next { right: -16px; }
  #WfPosterReviews--{{ section.id }} .wfpr__arrow.is-visible { display: flex; }
  /* Load-more button — mobile only (desktop uses the carousel arrows) */
  #WfPosterReviews--{{ section.id }} .wfpr__card.is-hidden { display: none; }
  #WfPosterReviews--{{ section.id }} .wfpr__more {
    display: none; margin-top: 20px; border: none; background: #3D6E2E;
    padding: 14px 0; width: 100%; font-family: 'Montserrat', sans-serif; font-size: 15px; font-weight: 700;
    letter-spacing: 0.05em; text-transform: uppercase; color: #fff; cursor: pointer; border-radius: 6px;
  }
  #WfPosterReviews--{{ section.id }} .wfpr__more[hidden] { display: none; }
  #WfPosterReviews--{{ section.id }} .wfpr__empty { color: #888; font-size: 14px; margin-top: 24px; }

  @media (max-width: 990px) { #WfPosterReviews--{{ section.id }} .wfpr__card { flex: 0 0 calc(50% - 8px); min-width: 280px; } }
  @media (max-width: 749px) {
    #WfPosterReviews--{{ section.id }} .wfpr__inner { margin: 0 16px; }
    #WfPosterReviews--{{ section.id }} .wfpr__heading { font-size: 20px; }
    /* Mobile reverts to a vertical list + load-more (no carousel, no 400px min-height) */
    #WfPosterReviews--{{ section.id }} .wfpr__grid { display: block; overflow: visible; margin-top: 20px; }
    #WfPosterReviews--{{ section.id }} .wfpr__card { flex: none; width: 100%; min-width: 0; min-height: auto; margin-bottom: 12px; }
    #WfPosterReviews--{{ section.id }} .wfpr__white { padding: 22px; }
    #WfPosterReviews--{{ section.id }} .wfpr__blue { padding: 12px 16px; }
    #WfPosterReviews--{{ section.id }} .wfpr__arrow { display: none !important; }
    #WfPosterReviews--{{ section.id }} .wfpr__more { display: block; }
  }
</style>

<section id="WfPosterReviews--{{ section.id }}"
  data-section-type="wf-poster-reviews"
  data-product-id="{{ product.id }}"
  data-shop="{{ shop.permanent_domain }}"
  data-initial="{{ section.settings.initial_count | default: 9 }}"
  data-batch="{{ section.settings.batch_count | default: 3 }}">
  <div class="wfpr__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="wfpr__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="wfpr__stars">&#9733;&#9733;&#9733;&#9733;&#9733; {{ p_rating | default: '4.8' }} ({{ p_count | default: '60' }})</div>

    <button class="wfpr__arrow wfpr__arrow--prev" data-wfpr-prev aria-label="Previous reviews">&#8249;</button>
    <button class="wfpr__arrow wfpr__arrow--next" data-wfpr-next aria-label="Next reviews">&#8250;</button>
    <div class="wfpr__grid" data-wfpr-grid></div>
    <button class="wfpr__more" data-wfpr-more hidden>{{ section.settings.more_text | default: 'Load more reviews' }}</button>
  </div>

  {%- comment -%} Fallback reviews, server-rendered (inert template — parsed only if the live fetch fails) {%- endcomment -%}
  <script type="text/template" data-wfpr-fallback>{{ product.metafields.judgeme.widget }}</script>

  {%- comment -%} handle -> product image map, so each review's "ordered" tag can show a thumbnail {%- endcomment -%}
  <script type="application/json" data-wfpr-products>{"_":""
    {%- assign wfpr_seen = '' -%}
    {%- assign wfpr_cols = 'golf-posters,gifts-for-golfers,graphic,hoodies,everyday-shirts,lifestyle-clothing,new-arrivals,golf-stickers,shorts-shirts' | split: ',' -%}
    {%- for ch in wfpr_cols -%}{%- for p in collections[ch].products -%}{%- unless wfpr_seen contains p.handle -%}{%- assign wfpr_seen = wfpr_seen | append: p.handle | append: '|' -%},{{ p.handle | json }}:{{ p.featured_image | image_url: width: 120 | json }}{%- endunless -%}{%- endfor -%}{%- endfor -%}
  }</script>

  {%- comment -%} review-id -> [posters ordered] map, cross-referenced from Shopify orders (snapshot; refresh via script) {%- endcomment -%}
  {% render 'wfpr-bundles' %}
</section>

<script>
  (function () {
    var section = document.getElementById('WfPosterReviews--{{ section.id }}');
    if (!section) return;
    var grid = section.querySelector('[data-wfpr-grid]');
    var prevBtn = section.querySelector('[data-wfpr-prev]');
    var nextBtn = section.querySelector('[data-wfpr-next]');
    var moreBtn = section.querySelector('[data-wfpr-more]');
    var isMobile = window.matchMedia('(max-width: 749px)');
    var MOB_INITIAL = 3, MOB_BATCH = 3, shownM = MOB_INITIAL;
    var fallback = section.querySelector('[data-wfpr-fallback]');
    var productId = section.getAttribute('data-product-id');
    var shop = section.getAttribute('data-shop');
    var INITIAL = parseInt(section.getAttribute('data-initial'), 10) || 9;
    var BATCH = parseInt(section.getAttribute('data-batch'), 10) || 3;
    var PER_PAGE = 100;

    function esc(t) { var d = document.createElement('div'); d.textContent = t == null ? '' : t; return d.innerHTML; }
    function stars(n) { n = parseInt(n, 10) || 5; var s = ''; for (var i = 1; i <= 5; i++) s += (i <= n) ? '★' : '☆'; return s; }
    function fmtDate(d) { if (!d) return ''; var dt = new Date(d); if (isNaN(dt.getTime())) return ''; return dt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }); }

    function parseReviews(root) {
      var out = [];
      var nodes = root.querySelectorAll('.jdgm-rev');
      for (var i = 0; i < nodes.length; i++) {
        var el = nodes[i];
        var ratingEl = el.querySelector('.jdgm-rev__rating');
        var tsEl = el.querySelector('.jdgm-rev__timestamp');
        var authEl = el.querySelector('.jdgm-rev__author');
        var bodyEl = el.querySelector('.jdgm-rev__body');
        var picEl = el.querySelector('.jdgm-rev__pic-img, .jdgm-rev__pics img, .jdgm-rev__pic img');
        var varEl = el.querySelector('.jdgm-rev__prod-variant-wrapper');
        var variant = varEl ? varEl.textContent.replace(/\s+/g, ' ').trim() : '';
        if (variant.indexOf('/') > -1) {
          var vparts = variant.split('/'); var vpick = '';
          for (var vi = 0; vi < vparts.length; vi++) { if (/[″"×]/.test(vparts[vi])) { vpick = vparts[vi].trim(); break; } }
          if (!vpick) { for (var vj = 0; vj < vparts.length; vj++) { if (/^\s*(XS|S|M|L|XL|XXL|2XL|3XL|4XL)\s*$/i.test(vparts[vj])) { vpick = vparts[vj].trim(); break; } } }
          if (!vpick) { vpick = vparts[vparts.length - 1].trim(); }
          variant = vpick;
        }
        var body = bodyEl ? bodyEl.textContent.replace(/\s+/g, ' ').replace(/Read more$/, '').trim() : '';
        if (!body || body.length < 12) continue;
        out.push({
          rating: ratingEl ? ratingEl.getAttribute('data-score') : 5,
          date: tsEl ? (tsEl.getAttribute('data-content') || tsEl.textContent) : '',
          name: authEl ? authEl.textContent.trim() : '',
          body: body,
          uuid: el.getAttribute('data-review-id') || '',
          purl: el.getAttribute('data-product-url') || '',
          ptitle: el.getAttribute('data-product-title') || '',
          variant: variant
        });
      }
      return out;
    }

    var reviews = [], shown = 0;
    var pmap = {};
    try { var pmTag = section.querySelector('[data-wfpr-products]'); if (pmTag) pmap = JSON.parse(pmTag.textContent); } catch (e) {}
    var bundles = {};
    try { var bt = document.querySelector('[data-wfpr-bundles]'); if (bt) bundles = JSON.parse(bt.textContent); } catch (e) {}
    function firstName(n) { var w = (n || '').trim().split(/\s+/)[0] || 'A golfer'; return w.charAt(0).toUpperCase() + w.slice(1).toLowerCase(); }
    function joinAnd(a) { if (a.length <= 1) return a[0] || ''; if (a.length === 2) return a[0] + ' and ' + a[1]; return a.slice(0, -1).join(', ') + ', and ' + a[a.length - 1]; }
    function plink(p) { return p.h ? '<a href="/products/' + esc(p.h) + '">' + esc(p.t) + '</a>' : esc(p.t); }
    function sizePhrase(s) {
      s = (s || '').trim(); if (!s) return '';
      var map = { XS: 'X-Small', S: 'Small', M: 'Medium', L: 'Large', XL: 'X-Large', XXL: '2X-Large', '2XL': '2X-Large', '3XL': '3X-Large', '4XL': '4X-Large' };
      var k = s.toUpperCase();
      return map[k] ? 'size ' + map[k] : s; /* posters keep their dimension, e.g. 12x18 */
    }
    function orderedPhrase(ps) {
      if (ps.length === 1) { return plink(ps[0]) + (ps[0].s ? ' in ' + esc(sizePhrase(ps[0].s)) : ''); }
      var sizes = ps.map(function (p) { return p.s; });
      var allSame = sizes[0] && sizes.every(function (s) { return s === sizes[0]; });
      if (allSame) return joinAnd(ps.map(plink)) + ' in ' + esc(sizePhrase(sizes[0]));
      return joinAnd(ps.map(function (p) { return plink(p) + (p.s ? ' (' + esc(sizePhrase(p.s)) + ')' : ''); }));
    }

    function updateArrows() {
      if (!prevBtn || !nextBtn) return;
      if (isMobile.matches) { prevBtn.classList.remove('is-visible'); nextBtn.classList.remove('is-visible'); return; }
      var canScroll = grid.scrollWidth > grid.offsetWidth + 5;
      prevBtn.classList.toggle('is-visible', canScroll && grid.scrollLeft > 5);
      nextBtn.classList.toggle('is-visible', canScroll && grid.scrollLeft < grid.scrollWidth - grid.offsetWidth - 5);
    }
    function wfprScrollAmt() { var c = grid.querySelector('.wfpr__card'); return c ? (c.offsetWidth + 16) : grid.offsetWidth * 0.8; }
    if (prevBtn) prevBtn.addEventListener('click', function () { grid.scrollBy({ left: -wfprScrollAmt(), behavior: 'smooth' }); });
    if (nextBtn) nextBtn.addEventListener('click', function () { grid.scrollBy({ left: wfprScrollAmt(), behavior: 'smooth' }); });
    grid.addEventListener('scroll', function () { if (!isMobile.matches) updateArrows(); });

    // Desktop = horizontal carousel (arrows, all cards). Mobile = vertical list, 3 at a time + load-more.
    function applyMode() {
      var cards = grid.querySelectorAll('.wfpr__card');
      if (isMobile.matches) {
        if (prevBtn) prevBtn.classList.remove('is-visible');
        if (nextBtn) nextBtn.classList.remove('is-visible');
        for (var i = 0; i < cards.length; i++) { cards[i].classList.toggle('is-hidden', i >= shownM); }
        if (moreBtn) { if (shownM >= cards.length) moreBtn.setAttribute('hidden', ''); else moreBtn.removeAttribute('hidden'); }
      } else {
        for (var j = 0; j < cards.length; j++) { cards[j].classList.remove('is-hidden'); }
        if (moreBtn) moreBtn.setAttribute('hidden', '');
        updateArrows();
      }
    }
    if (moreBtn) moreBtn.addEventListener('click', function () { shownM = Math.min(shownM + MOB_BATCH, grid.querySelectorAll('.wfpr__card').length); applyMode(); });
    if (isMobile.addEventListener) isMobile.addEventListener('change', applyMode);
    window.addEventListener('resize', applyMode);
    window.addEventListener('load', applyMode);

    function build(list) {
      var seen = {};
      reviews = list.filter(function (r) {
        var k = (r.name || '') + '|' + r.body.slice(0, 40).toLowerCase();
        if (seen[k]) return false; seen[k] = 1; return true;
      });
      if (!reviews.length) { grid.innerHTML = ''; return; }
      grid.innerHTML = reviews.map(function (r) {
        var dt = fmtDate(r.date);
        var nm = esc(r.name || 'A golfer');
        /* posters this reviewer ordered: the cross-referenced order bundle, else just the one they reviewed */
        var posters = (r.uuid && bundles[r.uuid]) ? bundles[r.uuid] : null;
        if (!posters) {
          var h = (r.purl || '').replace(/^.*\/products\//, '').split('?')[0];
          if (h) posters = [{ h: h, t: r.ptitle || 'this poster', s: r.variant || '' }];
          else if (r.ptitle) posters = [{ h: '', t: r.ptitle, s: r.variant || '' }]; /* product since removed: title only, no link/image */
          else posters = [];
        }
        var thumbs = posters.map(function (p) {
          var img = p.h ? (pmap[p.h] || '') : '';
          return img ? '<a href="/products/' + esc(p.h) + '" title="' + esc(p.t) + '"><img src="' + esc(img) + '" alt="' + esc(p.t) + '"></a>' : '';
        }).join('');
        var thumbsHtml = thumbs ? '<div class="wfpr__thumbs">' + thumbs + '</div>' : '';
        var blueHtml = posters.length ? '<div class="wfpr__blue"><div class="wfpr__blue-text">' + esc(firstName(r.name)) + ' ordered ' + orderedPhrase(posters) + '</div></div>' : '';
        return '<div class="wfpr__card">'
          + '<div class="wfpr__white">'
          +   '<div class="wfpr__text">' + esc(r.body) + '</div>'
          +   '<div class="wfpr__meta-row">'
          +     '<div class="wfpr__meta">'
          +       '<div class="wfpr__rating">' + stars(r.rating) + '</div>'
          +       '<div class="wfpr__name">' + nm + '</div>'
          +       (dt ? '<div class="wfpr__date">' + dt + '</div>' : '')
          +     '</div>'
          +     thumbsHtml
          +   '</div>'
          + '</div>'
          + blueHtml
          + '</div>';
      }).join('');
      applyMode();
      // Re-measure after layout settles — the strip's scrollWidth isn't final the instant
      // innerHTML is set, so an immediate measure can wrongly read "not scrollable" and hide the arrow.
      requestAnimationFrame(applyMode);
      setTimeout(applyMode, 350);
    }

    function useFallback() {
      var doc = new DOMParser().parseFromString(fallback.textContent || '', 'text/html');
      build(parseReviews(doc));
    }

    var done = false;
    var timer = setTimeout(function () { if (!done) { done = true; useFallback(); } }, 8000);
    var url = 'https://api.judge.me/reviews/reviews_for_widget?url=' + encodeURIComponent(shop)
      + '&shop_domain=' + encodeURIComponent(shop) + '&platform=shopify&page=1&per_page=' + PER_PAGE
      + '&product_id=' + encodeURIComponent(productId);
    fetch(url)
      .then(function (r) { return r.text(); })
      .then(function (t) {
        if (done) return; done = true; clearTimeout(timer);
        var html = t;
        try { var j = JSON.parse(t); if (j && j.html) html = j.html; } catch (e) {}
        var doc = new DOMParser().parseFromString(html, 'text/html');
        var list = parseReviews(doc);
        if (list.length) build(list); else useFallback();
      })
      .catch(function () { if (done) return; done = true; clearTimeout(timer); useFallback(); });
  })();
</script>

{% schema %}
{
  "name": "WF Poster Reviews",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Golfers Say" },
    { "type": "text", "id": "more_text", "label": "Load-more button text", "default": "Load more reviews" },
    { "type": "range", "id": "initial_count", "min": 3, "max": 24, "step": 3, "label": "Reviews shown initially", "default": 9 },
    { "type": "range", "id": "batch_count", "min": 1, "max": 9, "step": 1, "label": "Reviews added per 'Load more'", "default": 3 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 40 }
  ],
  "presets": [ { "name": "WF Poster Reviews" } ]
}
{% endschema %}
