-items: center;\n      gap: 20px;\n    }\n\n    .three-images-wrapper img {\n      width: 80vw;\n    }\n\n    .scroll-button {\n      font-size: 20px; \/* slightly smaller on mobile *\/\n      padding: 16px 40px;\n    }\n  }\n\n  \/* Smooth scrolling globally *\/\n  html {\n    scroll-behavior: smooth;\n  }\n<\/style>\n\n<!-- Three Images Section -->\n<div class=\"three-images-section\">\n  <div class=\"three-images-wrapper\">\n    <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0772\/2041\/3736\/files\/37_8be9f776-17e5-4468-a914-dcb8bfbdd756.png?v=1755817040\" alt=\"Image 1\">\n    <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0772\/2041\/3736\/files\/17_648fe799-a955-4377-a2b5-6acd3dfc3120.png?v=1755817748\" alt=\"Image 2\">\n    <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0772\/2041\/3736\/files\/15_8cac9c13-e10d-4557-b6af-40d01be26706.png?v=1755817748\" alt=\"Image 3\">\n  <\/div>\n\n  <!-- Scroll-to-top button -->\n  <button class=\"scroll-button\" onclick=\"window.scrollTo({top: 0, behavior: 'smooth'});\">\n    Sign Up for Early Access\n  <\/button>\n<\/div>","width":"wrapper","bg_color":"","color":"","padding_top":0,"padding_bottom":0}}},"order":["main","section_custom_code_ejFE8D","section_video_fayN3B","section_custom_code_CUBxm8","section_rich_text_ng3h3b","section_custom_code_K9hJEm"]}