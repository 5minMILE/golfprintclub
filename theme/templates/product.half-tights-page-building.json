n/* Hide meta */\nvar metaEl=pw.querySelector(\".product__price__meta\");\nif(metaEl)metaEl.style.display=\"none\";\n/* Move deal line inside price card */\nvar dealLine=document.querySelector(\".v1-deal-line\");\nif(dealLine){pw.appendChild(dealLine);}\n/* Hide shop pay terms */\nvar terms=pw.querySelectorAll(\"shopify-payment-terms,.shopify-payment-terms,[class*='shop-pay']\");\nterms.forEach(function(t){t.style.display=\"none\";});\n}\n/* === ABBREVIATE SIZE LABELS === */\nvar sizeLabels=document.querySelectorAll(\".radio__fieldset:not(.radio__fieldset--swatches) .radio__button label\");\nvar abbrevMap={\"Small\":\"S\",\"Medium\":\"M\",\"Large\":\"L\",\"X-Small\":\"XS\",\"X-Large\":\"XL\",\"XX-Large\":\"XXL\"};\nsizeLabels.forEach(function(lbl){\nvar txt=lbl.textContent.trim();\nif(abbrevMap[txt])lbl.textContent=abbrevMap[txt];\n});\n/* === VARIANT IMAGE FILTERING === */\nvar allSlides=document.querySelectorAll(\".product__slides .product__slide\");\nvar dotsContainer=document.querySelector(\".v1-img-dots\");\nvar slidesContainer=document.querySelector(\".product__slides\");\nfunction filterImagesByColor(color){\nif(!color||!allSlides.length)return;\nvar colorKey=color.toLowerCase().replace(/\\s+/g,\"-\");\nvar visibleSlides=[];\nallSlides.forEach(function(slide){\nvar img=slide.querySelector(\"img\");\nif(!img)return;\nvar alt=(img.alt||\"\").toLowerCase().replace(/\\s+/g,\"-\");\nif(alt.indexOf(colorKey)===0||alt===colorKey){\nslide.style.display=\"\";\nslide.style.width=\"100%\";\nslide.style.flex=\"0 0 100%\";\nvisibleSlides.push(slide);\n}else{\nslide.style.display=\"none\";\n}\n});\nif(visibleSlides.length===0){\nallSlides.forEach(function(s){s.style.display=\"\";s.style.width=\"100%\";s.style.flex=\"0 0 100%\";});\nvisibleSlides=Array.prototype.slice.call(allSlides);\n}\n/* Rebuild dots */\nif(dotsContainer){\ndotsContainer.innerHTML=\"\";\nfor(var i=0;i<visibleSlides.length;i++){\nvar d=document.createElement(\"button\");\nd.className=\"v1-img-dot\"+(i===0?\" v1-img-dot--active\":\"\");\nd.setAttribute(\"data-idx\",i);\n(function(idx,vs){\nd.addEventListener(\"click\",function(){\nvs[idx].scrollIntoView({behavior:\"smooth\",block:\"nearest\",inline:\"center\"});\n});\n})(i,visibleSlides);\ndotsContainer.appendChild(d);\n}\n/* Re-observe for dot updates */\nif(slidesContainer){\nvar obs=new IntersectionObserver(function(entries){\nentries.forEach(function(entry){\nif(entry.isIntersecting){\nvar idx=visibleSlides.indexOf(entry.target);\nif(idx<0)return;\nvar dots=dotsContainer.querySelectorAll(\".v1-img-dot\");\nfor(var j=0;j<dots.length;j++){\ndots[j].className=\"v1-img-dot\"+(j===idx?\" v1-img-dot--active\":\"\");\n}\n}\n});\n},{root:slidesContainer,threshold:0.6});\nvisibleSlides.forEach(function(s){obs.observe(s);});\n}\n}\n/* Scroll to first visible slide */\nif(visibleSlides[0])visibleSlides[0].scrollIntoView({behavior:\"auto\",block:\"nearest\",inline:\"start\"});\n}\n/* Listen for swatch clicks */\ndocument.querySelectorAll(\".radio__fieldset--swatches input[type='radio']\").forEach(function(inp){\ninp.addEventListener(\"change\",function(){\nvar lbl=this.nextElementSibling||this.parentElement.querySelector(\"label\");\nvar colorName=this.value||this.getAttribute(\"data-value\")||(lbl?lbl.getAttribute(\"data-value\"):\"\")||\"\";\nfilterImagesByColor(colorName);\n});\n});\n/* Also listen for variant:change event */\ndocument.addEventListener(\"variant:change\",function(){\nvar pj=document.querySelector(\"[data-product-json]\");\nif(!pj)return;\nvar p=JSON.parse(pj.textContent);\nvar vid=document.querySelector('input[name=\"id\"]');\nif(!vid)return;\nfor(var i=0;i<p.variants.length;i++){\nif(p.variants[i].id==vid.value){\nvar dOpt=null;\nfor(var j=0;j<p.options.length;j++){\nvar n=p.options[j].toLowerCase();\nif(n===\"color\"||n===\"design\"||n===\"style\"||n===\"pattern\"){dOpt=j;break;}\n}\nif(dOpt!==null)filterImagesByColor(p.variants[i].options[dOpt]);\nbreak;\n}\n}\n});\n/* Initial filter based on selected